{
  "standard_version": "mn.blueprint.config.v1",
  "identity": {
    "blueprint_id": "vc_assistant",
    "name": "VC Assistant"
  },
  "mode": "document_automation_review",
  "metadata": {
    "category": "Finance",
    "description": "A VC analysis co-worker for early startup screening reports. Put pitch decks, memos, financial snippets, company folders, or other startup documents in the input folder; it groups documents by company, performs privacy-safe public research, applies seven VC heuristic scoring methods, audits the math and evidence, and writes score-only per-company reports and batch indexes to the output folder."
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default demo inputs use bundled synthetic startup packets with one first-level folder per company.",
    "payload": {
      "document_folder": "vc_assistant/examples/sample_inputs",
      "output_folder": "~/Downloads/vc_assistant",
      "field_profile": [
        "company_name",
        "founder_team",
        "market",
        "product",
        "traction",
        "strategic_relationships",
        "risks",
        "comparables",
        "cost_to_duplicate"
      ],
      "grouping": {
        "mode": "folder_first",
        "infer_loose_files": true
      },
      "monitoring": {
        "enabled": true,
        "poll_interval_seconds": 60,
        "max_cycles": 1
      },
      "public_dataset": {
        "name": "Synthetic startup packet samples",
        "provider": "OtterDesk blueprint fixtures",
        "license": "Synthetic demo data",
        "availability_note": "Bundled sample startup documents are synthetic and intended only for local blueprint validation.",
        "expected_files": [
          "*.pdf",
          "*.txt",
          "*.md",
          "*.json",
          "*.csv"
        ]
      },
      "input_folder": "vc_assistant/examples/sample_inputs"
    }
  },
  "document_sources": {
    "folder_path": "vc_assistant/examples/sample_inputs",
    "expected_files": [
      "*.pdf",
      "*.txt",
      "*.md",
      "*.json",
      "*.csv"
    ],
    "grouping": "first_level_folder_then_infer_company_name"
  },
  "local_inputs": {
    "folders": [
      {
        "config_path": "document_sources.folder_path",
        "default_config_value": "vc_assistant/examples/sample_inputs",
        "source_path": "examples/sample_inputs",
        "payload_path": "document_workflow/mn_local_inputs/vc_documents",
        "runtime_path": "mn_local_inputs/vc_documents",
        "allowed_extensions": [
          ".pdf",
          ".txt",
          ".md",
          ".json",
          ".csv"
        ],
        "linked_config_paths": [
          "inputs.payload.document_folder",
          "inputs.payload.input_folder",
          "state.document_folder",
          "state.input_folder"
        ]
      }
    ]
  },
  "dataset_input": {
    "name": "Synthetic startup packet samples",
    "provider": "OtterDesk blueprint fixtures",
    "license": "Synthetic demo data",
    "availability_note": "Bundled sample startup documents are synthetic and intended only for local blueprint validation.",
    "expected_files": [
      "*.pdf",
      "*.txt",
      "*.md",
      "*.json",
      "*.csv"
    ]
  },
  "document_automation": {
    "fields": [
      "company_name",
      "founder_team",
      "market",
      "product",
      "traction",
      "strategic_relationships",
      "risks",
      "comparables",
      "cost_to_duplicate"
    ],
    "output_type": "vc_early_heuristic_analysis_reports",
    "review_required": true,
    "recommended_action": "review_scores_sources_and_assumptions_before_making_any_investment_decision"
  },
  "llm": {
    "enabled": true,
    "mode": "live",
    "mock_mode": "fake",
    "model": "small",
    "fallback_model": "small",
    "default_config": "primary",
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "model": "small",
        "runtime_model": "small",
        "fallback_model": "small",
        "backend": "llama.cpp",
        "api_base": "auto",
        "timeout_seconds": 60,
        "max_tokens": 1800,
        "num_retries": 2,
        "retry_backoff_seconds": 1.0,
        "mock_mode": "fake",
        "mode": "live"
      }
    },
    "agents": {
      "startup_folder_watcher": {
        "llm_config": "primary",
        "role": "Startup Folder Watcher",
        "responsibilities": [
          "Detect changed files.",
          "Build company fingerprints.",
          "Identify unchanged company packets."
        ]
      },
      "company_packet_grouper": {
        "llm_config": "primary",
        "role": "Company Packet Grouper",
        "responsibilities": [
          "Group files by company.",
          "Resolve stable company ids.",
          "Preserve source refs."
        ]
      },
      "document_evidence_extractor": {
        "llm_config": "primary",
        "role": "Document Evidence Extractor",
        "responsibilities": [
          "Extract local evidence.",
          "Capture structured claims.",
          "Mark unreadable files."
        ]
      },
      "claim_normalizer": {
        "llm_config": "primary",
        "role": "Claim Normalizer",
        "responsibilities": [
          "Build fact tables.",
          "Normalize numeric evidence.",
          "Separate local and public facts."
        ]
      },
      "research_planner": {
        "llm_config": "primary",
        "role": "Research Planner",
        "responsibilities": [
          "Create safe queries.",
          "Avoid confidential excerpts.",
          "Plan profile and market lookups."
        ]
      },
      "company_identity_researcher": {
        "llm_config": "primary",
        "role": "Company Identity Researcher",
        "responsibilities": [
          "Research company identity.",
          "Check Crunchbase/profile targets.",
          "Record blocked outcomes."
        ]
      },
      "funding_researcher": {
        "llm_config": "primary",
        "role": "Funding Researcher",
        "responsibilities": [
          "Research funding mentions.",
          "Check investor and accelerator signals.",
          "Record source quality."
        ]
      },
      "market_comp_researcher": {
        "llm_config": "primary",
        "role": "Market And Comparable Researcher",
        "responsibilities": [
          "Research market context.",
          "Find comparable candidates.",
          "Capture source references."
        ]
      },
      "traction_verifier": {
        "llm_config": "primary",
        "role": "Traction Verifier",
        "responsibilities": [
          "Verify customer and launch claims.",
          "Check public traction signals.",
          "Flag missing evidence."
        ]
      },
      "rendered_page_researcher": {
        "llm_config": "primary",
        "role": "Rendered Page Researcher",
        "responsibilities": [
          "Use rendered browser when enabled.",
          "Respect robots and blocked pages.",
          "Record JS-heavy page status."
        ]
      },
      "research_reconciler": {
        "llm_config": "primary",
        "role": "Research Reconciler",
        "responsibilities": [
          "Merge local and public evidence.",
          "Flag confirmations.",
          "Flag conflicts and missing evidence."
        ]
      },
      "berkus_scorer": {
        "llm_config": "primary",
        "role": "Berkus Scorer",
        "responsibilities": [
          "Score five Berkus buckets.",
          "Use deterministic formulas.",
          "Record assumptions."
        ]
      },
      "scorecard_bill_payne_scorer": {
        "llm_config": "primary",
        "role": "Scorecard Bill Payne Scorer",
        "responsibilities": [
          "Apply weighted factors.",
          "Record inputs used.",
          "Keep scores report-only."
        ]
      },
      "risk_factor_summation_scorer": {
        "llm_config": "primary",
        "role": "Risk Factor Summation Scorer",
        "responsibilities": [
          "Run 12-risk checklist.",
          "Record adjustments.",
          "Mark missing risk evidence."
        ]
      },
      "venture_capital_method_scorer": {
        "llm_config": "primary",
        "role": "Venture Capital Method Scorer",
        "responsibilities": [
          "Run exit-back math.",
          "Record assumptions.",
          "Avoid valuation recommendations."
        ]
      },
      "first_chicago_scorer": {
        "llm_config": "primary",
        "role": "First Chicago Scorer",
        "responsibilities": [
          "Build bear/base/bull cases.",
          "Apply probabilities.",
          "Record scenario warnings."
        ]
      },
      "comparables_market_multiple_scorer": {
        "llm_config": "primary",
        "role": "Comparables Market Multiple Scorer",
        "responsibilities": [
          "Use comparable evidence.",
          "Record market multiple assumptions.",
          "Mark insufficient evidence."
        ]
      },
      "cost_to_duplicate_scorer": {
        "llm_config": "primary",
        "role": "Cost To Duplicate Scorer",
        "responsibilities": [
          "Estimate rebuild-cost floor.",
          "Use asset evidence.",
          "Flag missing asset details."
        ]
      },
      "score_consistency_auditor": {
        "llm_config": "primary",
        "role": "Score Consistency Auditor",
        "responsibilities": [
          "Check score math.",
          "Check missing-evidence handling.",
          "Flag unsupported assumptions."
        ]
      },
      "company_report_writer": {
        "llm_config": "primary",
        "role": "Company Report Writer",
        "responsibilities": [
          "Write per-company folders.",
          "Preserve method sections.",
          "Write warnings and evidence files."
        ]
      },
      "batch_index_writer": {
        "llm_config": "primary",
        "role": "Batch Index Writer",
        "responsibilities": [
          "Write batch indexes.",
          "Write coverage summaries.",
          "Keep output report-only."
        ]
      }
    },
    "responsibilities": [
      "Keep VC outputs report-only and source-grounded.",
      "Use specialist agents for research, scoring, audit, and report writing.",
      "Avoid automated investment decisions or confidential-data web disclosure."
    ],
    "require_live": false,
    "provider": "docker_model_runner",
    "runtime_model": "small",
    "backend": "llama.cpp",
    "small_model_profile": {
      "provider": "docker_model_runner",
      "model": "small",
      "runtime_model": "small",
      "fallback_model": "small",
      "backend": "llama.cpp",
      "api_base": "auto",
      "timeout_seconds": 60,
      "max_tokens": 1800,
      "num_retries": 2,
      "retry_backoff_seconds": 1.0,
      "strict_json": false,
      "require_live": false
    },
    "live_model_profile": {
      "provider": "docker_model_runner",
      "model": "small",
      "runtime_model": "small",
      "fallback_model": "small",
      "backend": "llama.cpp",
      "api_base": "auto",
      "timeout_seconds": 60,
      "max_tokens": 1800,
      "num_retries": 2,
      "retry_backoff_seconds": 1.0,
      "strict_json": false,
      "require_live": false
    },
    "preferred_model": "medium",
    "large_model_profile": {
      "provider": "docker_model_runner",
      "model": "medium",
      "runtime_model": "medium",
      "backend": "llama.cpp",
      "timeout_seconds": 60,
      "max_tokens": 1800,
      "num_retries": 1,
      "retry_backoff_seconds": 1.0,
      "strict_json": true,
      "require_live": true,
      "context_size": 8192,
      "quantization": "MOSTLY_Q4_K_M",
      "parameter_count_b": 31.58,
      "hardware": {
        "gpu": {
          "min_count": 1,
          "min_memory_mb": 49152,
          "memory_operator": ">="
        }
      }
    }
  },
  "outputs": {
    "folder_path": "~/Downloads/vc_assistant",
    "write_run_store": true,
    "write_markdown_report": true,
    "per_company_subfolders": true
  },
  "logging": {
    "level": "info",
    "events_jsonl": true,
    "logs_jsonl": true,
    "resources_jsonl": true,
    "stderr_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key",
      "customer_name",
      "email",
      "phone"
    ],
    "events": [
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed",
      "tool_call_started",
      "tool_call_completed",
      "tool_call_failed",
      "startup_folder_watcher_completed",
      "company_packet_grouper_completed",
      "document_evidence_extractor_completed",
      "claim_normalizer_completed",
      "research_planner_completed",
      "company_identity_researcher_completed",
      "funding_researcher_completed",
      "market_comp_researcher_completed",
      "traction_verifier_completed",
      "rendered_page_researcher_completed",
      "research_reconciler_completed",
      "berkus_scorer_completed",
      "scorecard_bill_payne_scorer_completed",
      "risk_factor_summation_scorer_completed",
      "venture_capital_method_scorer_completed",
      "first_chicago_scorer_completed",
      "comparables_market_multiple_scorer_completed",
      "cost_to_duplicate_scorer_completed",
      "score_consistency_auditor_completed",
      "company_report_writer_completed",
      "batch_index_writer_completed",
      "watch_cycle_started",
      "watch_cycle_completed"
    ]
  },
  "resources": {
    "cpu": {
      "min_cores": 1
    },
    "memory": {
      "min_gb": 2
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    }
  },
  "human_control": {
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "make_investment_decision",
      "send_investment_recommendation",
      "share_confidential_documents",
      "submit_term_sheet",
      "contact_founder_without_review",
      "mark_scores_as_final_valuation"
    ],
    "decision_event": "human_decision_applied",
    "default_action": "reject",
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "approval_required",
    "reason": "Human approval is required before any external sharing, investment action, founder contact, valuation use, or downstream decision.",
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "timeout_seconds": 3600
  },
  "privacy": {
    "default_classification": "confidential",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": true
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "vc_assistant_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "state": {
    "document_folder": "vc_assistant/examples/sample_inputs",
    "output_folder": "~/Downloads/vc_assistant",
    "monitor_state": {},
    "final_report": {},
    "input_folder": "vc_assistant/examples/sample_inputs"
  },
  "triggers": {
    "type": "folder_watch",
    "sources": [
      "vc_startup_document_folder"
    ],
    "schedule": null
  },
  "real_adapters": {
    "filesystem": {
      "enabled": true,
      "read": true,
      "write": true
    }
  },
  "streams": {
    "enabled": false
  },
  "simulation": {
    "enabled": false
  },
  "monitoring": {
    "enabled": true,
    "poll_interval_seconds": 60,
    "max_cycles": 1,
    "processed_state_file": "watch_state.json"
  },
  "cache_policy": {
    "enabled": true,
    "force_reprocess": false,
    "freshness_fields": [
      "fingerprint",
      "previous_fingerprint",
      "previous_run_id",
      "cache_source",
      "freshness",
      "decision"
    ],
    "force_reprocess_inputs": [
      "force_reprocess",
      "cache_policy.force_reprocess",
      "VC_ASSISTANT_FORCE_REPROCESS",
      "MN_BLUEPRINT_FORCE_REPROCESS"
    ]
  },
  "execution": {
    "max_company_workers": 1,
    "deterministic_output_order": "company_slug",
    "quick_test": false
  },
  "research_budget": {
    "default_actions": 160,
    "chargeable_actions": [
      "llm_call",
      "browser_search",
      "browser_page",
      "rendered_browser_page",
      "financial_tool"
    ],
    "exhaustion_mode": "finish_with_budget_exhausted_warnings"
  },
  "internet_research": {
    "enabled": true,
    "browser_skill": "w3m_browser_skill",
    "rendered_browser_skill": "web_browser_skill",
    "privacy": "derive queries from company names, public categories, domains, and public claims only",
    "research_targets": [
      "company_website",
      "crunchbase_profile",
      "founder_public_profiles",
      "funding_and_investor_mentions",
      "news_and_press",
      "market_size_sources",
      "competitors_and_comparables",
      "SEC_or_public_company_context_when_relevant"
    ],
    "verification_fields": [
      "company_profile",
      "founders",
      "funding",
      "category",
      "competitors",
      "traction_claims",
      "source_conflicts"
    ],
    "verification_domains": [
      "crunchbase.com",
      "linkedin.com/company",
      "sec.gov",
      "company_website",
      "news_and_press"
    ],
    "source_url_templates": [
      "https://www.crunchbase.com/organization/{company_slug}",
      "https://www.linkedin.com/company/{company_slug}",
      "https://www.sec.gov/edgar/search/"
    ],
    "default_source_urls": [
      "https://www.sba.gov/business-guide/plan-your-business/market-research-competitive-analysis",
      "https://www.sec.gov/education/smallbusiness",
      "https://www.bls.gov/"
    ],
    "blocked_inputs": [
      "raw_document_text",
      "confidential_pitch_deck_excerpts",
      "customer_names",
      "private_financials",
      "founder_contact_details"
    ],
    "max_queries": 10,
    "max_sources_per_company": 10,
    "max_target_urls_per_company": 6,
    "max_stage_workers": 1,
    "timeout_seconds": 20,
    "max_chars": 12000,
    "use_model_compression": true,
    "python_http_fallback": {
      "enabled": true,
      "purpose": "Bounded stdlib HTTP fallback for public search/result pages when the optional w3m binary is unavailable in the worker image.",
      "timeout_seconds": 5,
      "max_chars": 6000,
      "max_search_results": 2,
      "user_agent": "MirrorNeuron-VC-Assistant/1.0 (+public research fallback)"
    },
    "rendered_browser": {
      "enabled": true,
      "purpose": "Optional Playwright fallback for JavaScript-rendered public pages such as Crunchbase profiles when w3m cannot extract useful text.",
      "respect_robots": true,
      "stop_on_blocked": true,
      "no_proxy_rotation": true,
      "no_captcha_solving": true,
      "timeout_seconds": 30,
      "max_chars": 12000,
      "max_pages_per_company": 3,
      "per_host_delay_seconds": 1
    }
  },
  "agentic_research": {
    "enabled": true,
    "agent_ids": [
      "research_planner",
      "company_identity_researcher",
      "funding_researcher",
      "market_comp_researcher",
      "traction_verifier",
      "rendered_page_researcher"
    ],
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "allowed_tools": [
      "browser_search",
      "browser_page",
      "rendered_browser_page",
      "finish"
    ],
    "quick_test_behavior": "disabled_for_default_smoke_run",
    "default_mode": "bounded_llm_guided_public_tool_research",
    "note": "Default batch research uses bounded LLM tool-decision loops for public-safe evidence collection; browser failures remain warnings and are recorded."
  },
  "financial_tools": {
    "enabled": true,
    "adapters": [
      "local_public_comparable_and_exit_math"
    ],
    "paid_provider_connectors": false,
    "missing_provider_data_policy": "record_missing_evidence"
  },
  "scoring": {
    "max_workers": 7,
    "deterministic_method_order": true
  },
  "input_skills": {
    "llm_ocr": {
      "skill": "llm_ocr_skill",
      "package": "mirrorneuron-llm-ocr-skill",
      "connector": "docker_model_runner",
      "purpose": "shared local LightOnOCR-2-1B OCR for scanned or low-text PDF startup packets",
      "enabled": true,
      "required": true,
      "backend": "auto",
      "endpoint": "http://host.docker.internal:12434",
      "model": null,
      "quantization": null,
      "min_text_chars": 40,
      "max_pages": null,
      "preload": false,
      "install_policy": "on_first_required_document",
      "remove_policy": "manual",
      "require_hardware_acceleration": true,
      "timeout_seconds": 180
    },
    "w3m_browser": {
      "skill": "w3m_browser_skill",
      "package": "mirrorneuron-w3m-browser-skill",
      "import": "mn_w3m_browser_skill",
      "runner": "w3m",
      "purpose": "primary lightweight text-browser research for startup verification, Crunchbase search snippets, competitors, and public market context",
      "enabled": true,
      "required": false,
      "install_policy": "docker_worker_image",
      "runtime": {
        "driver": "docker_worker",
        "install_scope": "shared_job_container",
        "docker_worker_image": "document_workflow/docker_worker",
        "image": "mirror-neuron/vc-assistant:local",
        "network": "mirror-neuron-runtime",
        "node_scope": "vc_python_executor_nodes"
      },
      "timeout_seconds": 20,
      "max_chars": 12000,
      "max_queries": 8,
      "max_sources_per_company": 8,
      "use_model_compression": true,
      "docker_worker_requirements": "document_workflow/requirements.txt"
    },
    "web_browser": {
      "skill": "web_browser_skill",
      "package": "mirrorneuron-web-browser-skill",
      "import": "mn_web_browser_skill",
      "runner": "playwright",
      "purpose": "optional rendered-page fallback for JavaScript-heavy public sources such as Crunchbase pages; records blocked/login/robots states instead of bypassing them",
      "enabled": true,
      "required": false,
      "install_policy": "python_environment_pip",
      "activation": "set internet_research.rendered_browser.enabled=true for rendered public-page verification",
      "respect_robots": true,
      "stop_on_blocked": true,
      "no_proxy_rotation": true,
      "no_captcha_solving": true,
      "timeout_seconds": 30,
      "max_chars": 12000,
      "max_pages_per_company": 2,
      "per_host_delay_seconds": 1,
      "python_environment": "document_workflow/requirements.txt"
    }
  },
