  "error_handling": {
    "default": "fail_closed",
    "missing_evidence": "mark_insufficient_evidence",
    "external_research_failure": "continue_with_warning"
  },
  "backpressure": {
    "max_documents_per_cycle": 100,
    "max_companies_per_cycle": 25,
    "llm": {
      "max_concurrent_calls": 1,
      "min_interval_seconds": 1.0,
      "rationale": "Protect local Docker Model Runner from concurrent VC agent calls."
    }
  },
