{
  "standard_version": "mn.blueprint.config.v1",
  "mode": "document_automation_review",
  "metadata": {
    "category": "Finance",
    "description": "A VC analysis co-worker for early startup screening reports. Put pitch decks, memos, financial snippets, company folders, or other startup documents in the input folder; it groups documents by company, performs privacy-safe public research, applies seven VC heuristic scoring methods, audits the math and evidence, and writes score-only per-company reports and batch indexes to the output folder."
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default demo inputs use bundled synthetic startup packets with one first-level folder per company.",
    "payload": {
      "document_folder": "@/examples/sample_inputs",
      "output_folder": "~/Downloads/vc_assistant",
      "field_profile": [
        "company_name",
        "founder_team",
        "market",
        "product",
        "traction",
        "strategic_relationships",
        "risks",
        "comparables",
        "cost_to_duplicate"
      ],
      "grouping": {
        "mode": "folder_first",
        "infer_loose_files": true
      },
      "public_dataset": {
        "name": "Synthetic startup packet samples",
        "provider": "OtterDesk blueprint fixtures",
        "license": "Synthetic demo data",
        "availability_note": "Bundled sample startup documents are synthetic and intended only for local blueprint validation.",
        "expected_files": [
          "*.pdf",
          "*.txt",
          "*.md",
          "*.json",
          "*.csv"
        ]
      },
      "input_folder": "@/examples/sample_inputs"
    }
  },
  "document_sources": {
    "folder_path": "@/examples/sample_inputs",
    "expected_files": [
      "*.pdf",
      "*.txt",
      "*.md",
      "*.json",
      "*.csv"
    ],
    "grouping": "first_level_folder_then_infer_company_name"
  },
  "local_inputs": {
    "folders": [
      {
        "config_path": "document_sources.folder_path",
        "payload_path": "runtime/mn_local_inputs/vc_documents",
        "runtime_path": "mn_local_inputs/vc_documents",
        "allowed_extensions": [
          ".pdf",
          ".txt",
          ".md",
          ".json",
          ".csv"
        ],
        "linked_config_paths": [
          "inputs.payload.document_folder",
          "inputs.payload.input_folder",
          "state.document_folder",
          "state.input_folder"
        ]
      }
    ]
  },
  "dataset_input": {
    "name": "Synthetic startup packet samples",
    "provider": "OtterDesk blueprint fixtures",
    "license": "Synthetic demo data",
    "availability_note": "Bundled sample startup documents are synthetic and intended only for local blueprint validation.",
    "expected_files": [
      "*.pdf",
      "*.txt",
      "*.md",
      "*.json",
      "*.csv"
    ]
  },
  "document_automation": {
    "fields": [
      "company_name",
      "founder_team",
      "market",
      "product",
      "traction",
      "strategic_relationships",
      "risks",
      "comparables",
      "cost_to_duplicate"
    ],
    "output_type": "vc_early_heuristic_analysis_reports",
    "review_required": true,
    "recommended_action": "review_scores_sources_and_assumptions_before_making_any_investment_decision"
  },
  "llm": {
    "strict_json": false,
    "configs": {
      "primary": {
        "max_tokens": 1800,
        "num_retries": 2,
        "retry_backoff_seconds": 1.0
      }
    },
    "require_live": false
  },
  "outputs": {
    "folder_path": "~/Downloads/vc_assistant",
    "write_run_store": true,
    "write_markdown_report": true,
    "per_company_subfolders": true
  },
  "logging": {
    "level": "info",
    "events_jsonl": true,
    "logs_jsonl": true,
    "resources_jsonl": true,
    "stderr_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key",
      "customer_name",
      "email",
      "phone"
    ],
    "events": [
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed",
      "tool_call_started",
      "tool_call_completed",
      "tool_call_failed",
      "startup_folder_watcher_completed",
      "company_packet_grouper_completed",
      "document_evidence_extractor_completed",
      "claim_normalizer_completed",
      "research_planner_completed",
      "company_identity_researcher_completed",
      "funding_researcher_completed",
      "market_comp_researcher_completed",
      "traction_verifier_completed",
      "rendered_page_researcher_completed",
      "research_reconciler_completed",
      "berkus_scorer_completed",
      "scorecard_bill_payne_scorer_completed",
      "risk_factor_summation_scorer_completed",
      "venture_capital_method_scorer_completed",
      "first_chicago_scorer_completed",
      "comparables_market_multiple_scorer_completed",
      "cost_to_duplicate_scorer_completed",
      "score_consistency_auditor_completed",
      "company_report_writer_completed",
      "batch_index_writer_completed",
      "watch_cycle_started",
      "watch_cycle_completed"
    ]
  },
  "privacy": {
    "default_classification": "confidential",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": true
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "vc_assistant_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "state": {
    "document_folder": "@/examples/sample_inputs",
    "output_folder": "~/Downloads/vc_assistant",
    "monitor_state": {},
    "final_report": {},
    "input_folder": "@/examples/sample_inputs"
  },
  "triggers": {
    "type": "folder_watch",
    "sources": [
      "vc_startup_document_folder"
    ],
    "schedule": null
  },
  "real_adapters": {
    "filesystem": {
      "enabled": true,
      "read": true,
      "write": true
    }
  },
  "streams": {
    "enabled": false
  },
  "simulation": {
    "enabled": false
  },
  "monitoring": {
    "enabled": true,
    "poll_interval_seconds": 60,
    "max_cycles": 1,
    "processed_state_file": "watch_state.json"
  },
  "cache_policy": {
    "enabled": true,
    "force_reprocess": false,
    "freshness_fields": [
      "fingerprint",
      "previous_fingerprint",
      "previous_run_id",
      "cache_source",
      "freshness",
      "decision"
    ],
    "force_reprocess_inputs": [
      "force_reprocess",
      "cache_policy.force_reprocess",
      "VC_ASSISTANT_FORCE_REPROCESS",
      "MN_BLUEPRINT_FORCE_REPROCESS"
    ]
  },
  "execution": {
    "max_company_workers": 1,
    "deterministic_output_order": "company_slug",
    "quick_test": false
  },
  "research_budget": {
    "default_actions": 160,
    "chargeable_actions": [
      "llm_call",
      "browser_search",
      "browser_page",
      "rendered_browser_page",
      "financial_tool"
    ],
    "exhaustion_mode": "finish_with_budget_exhausted_warnings"
  },
  "internet_research": {
    "enabled": true,
    "browser_skill": "web_browser_skill",
    "privacy": "derive queries from company names, public categories, domains, and public claims only",
    "research_targets": [
      "company_website",
      "crunchbase_profile",
      "founder_public_profiles",
      "funding_and_investor_mentions",
      "news_and_press",
      "market_size_sources",
      "competitors_and_comparables",
      "SEC_or_public_company_context_when_relevant"
    ],
    "verification_fields": [
      "company_profile",
      "founders",
      "funding",
      "category",
      "competitors",
      "traction_claims",
      "source_conflicts"
    ],
    "verification_domains": [
      "crunchbase.com",
      "linkedin.com/company",
      "sec.gov",
      "company_website",
      "news_and_press"
    ],
    "source_url_templates": [
      "https://www.crunchbase.com/organization/{company_slug}",
      "https://www.linkedin.com/company/{company_slug}",
      "https://www.sec.gov/edgar/search/"
    ],
    "default_source_urls": [
      "https://www.sba.gov/business-guide/plan-your-business/market-research-competitive-analysis",
      "https://www.sec.gov/education/smallbusiness",
      "https://www.bls.gov/"
    ],
    "blocked_inputs": [
      "raw_document_text",
      "confidential_pitch_deck_excerpts",
      "customer_names",
      "private_financials",
      "founder_contact_details"
    ],
    "max_queries": 10,
    "max_sources_per_company": 10,
    "max_target_urls_per_company": 6,
    "max_parallel_research_agents": 1,
    "timeout_seconds": 20,
    "total_timeout_seconds": 60,
    "max_chars": 12000,
    "use_model_compression": true,
    "rendered_browser": {
      "enabled": true,
      "purpose": "Explicit deep mode for JavaScript-rendered public pages through the policy-governed agent-browser actuator; normal engine fallback is handled inside web_browser_skill standard mode.",
      "respect_robots": true,
      "stop_on_blocked": true,
      "no_proxy_rotation": true,
      "no_captcha_solving": true,
      "timeout_seconds": 30,
      "max_chars": 12000,
      "max_pages_per_company": 3,
      "per_host_delay_seconds": 1
    }
  },
  "financial_tools": {
    "enabled": true,
    "adapters": [
      "local_public_comparable_and_exit_math"
    ],
    "paid_provider_connectors": false,
    "missing_provider_data_policy": "record_missing_evidence"
  },
  "scoring": {
    "max_workers": 7,
    "deterministic_method_order": true
  },
  "input_skills": {
    "llm_ocr": {
      "skill": "llm_ocr_skill",
      "package": "mirrorneuron-llm-ocr-skill",
      "purpose": "shared local OCR for scanned or low-text PDF startup packets",
      "enabled": true,
      "required": true,
      "min_text_chars": 40,
      "max_pages": null,
      "timeout_seconds": 180
    },
    "web_browser": {
      "skill": "web_browser_skill",
      "package": "mirrorneuron-web-browser-skill",
      "import": "mn_web_browser_skill",
      "runner": "policy_governed_agent_browser",
      "purpose": "unified public research with lightweight w3m routing and a deterministic agent-browser rendered actuator, plain-text extraction, bounded retries, audits, and structured blocked outcomes",
      "enabled": true,
      "required": false,
      "install_policy": "docker_worker_image",
      "runtime": {
        "driver": "docker_worker",
        "install_scope": "shared_job_container",
        "docker_worker_image": "docker_worker",
        "image": "mirror-neuron/vc-assistant:local",
        "network": "mirror-neuron-runtime",
        "node_scope": "vc_python_executor_nodes"
      },
      "respect_robots": true,
      "stop_on_blocked": true,
      "no_proxy_rotation": true,
      "no_captcha_solving": true,
      "timeout_seconds": 20,
      "total_timeout_seconds": 60,
      "max_chars": 12000,
      "max_queries": 8,
      "max_sources_per_company": 8,
      "max_pages_per_company": 3,
      "per_host_delay_seconds": 1,
      "use_model_compression": true,
      "docker_worker_requirements": "requirements.txt"
    }
  },
  "output_skills": {},
  "error_handling": {
    "default": "fail_closed",
    "missing_evidence": "mark_insufficient_evidence",
    "external_research_failure": "continue_with_warning"
  },
  "backpressure": {
    "max_documents_per_cycle": 100,
    "max_companies_per_cycle": 25,
    "llm": {
      "max_concurrent_calls": 1,
      "min_interval_seconds": 1.0,
      "rationale": "Protect local Docker Model Runner from concurrent VC agent calls."
    }
  },
  "determinism": {
    "seed": 7,
    "stable_company_slug": true
  },
  "capabilities": [
    "folder_monitoring",
    "document_evidence_extraction",
    "llm.ocr",
    "pdf.render",
    "privacy_safe_public_research",
    "vc_heuristic_scoring",
    "per_company_report_generation",
    "company_work_queue",
    "fact_table_normalization",
    "parallel_web_research",
    "parallel_numerical_scoring",
    "score_consistency_audit",
    "batch_report_factory",
    "action_budgeted_deep_research",
    "deterministic_financial_tools",
    "evidence_backed_method_results"
  ],
  "budgets": {
    "max_runtime_seconds": 900,
    "max_public_queries": 1000,
    "default_action_budget": 80
  },
  "agent_handoffs": {},
  "web_ui": {
    "enabled": true,
    "input": {
      "adapter": "none",
      "fields": [],
      "host": "127.0.0.1",
      "port": null,
      "share": false,
      "title": null,
      "instructions": null,
      "custom_url": null
    },
    "output": {
      "adapter": "gradio",
      "auto_generate": true,
      "refresh_seconds": 2,
      "title": "VC Assistant",
      "custom_url": null
    },
    "dashboard": {
      "data_source": "local_run_store",
      "reads": [
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json",
        "web_ui.json"
      ],
      "panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ],
      "standard_panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ]
    }
  },
  "schemas": {
    "artifact_record": "mn.artifact.record.v1",
    "config": "mn.blueprint.config.v1",
    "events": "mn.blueprint.events.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "human_control": "mn.blueprint.human_control.v1",
    "input_skills": "mn.blueprint.input_skills.v1",
    "inputs": "mn.blueprint.inputs.v1",
    "logs": "mn.blueprint.logs.v1",
    "output_skills": "mn.blueprint.output_skills.v1",
    "resources": "mn.blueprint.resources.v1",
    "status_contract": "mn.blueprint.status_contract.v1",
    "web_ui": "mn.blueprint.web_ui.v1"
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "description": "Stable run-store files plus per-company startup analysis outputs.",
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json",
          "action_ledger.json",
          "artifact_quality.json",
          "run_health.json"
        ],
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl",
          "llm_rag_trace.jsonl",
          "debug_trace.jsonl",
          "browser_audit.jsonl",
          "browser_artifacts/*",
          "human.jsonl",
          "resources.jsonl",
          "company_index.md",
          "*/analysis.md",
          "*/research_plan.json",
          "*/agent_tool_trace.json"
        ]
      },
      "events": {
        "artifact": "events.jsonl",
        "description": "Append-only workflow events."
      },
      "human": {
        "artifact": "human.jsonl",
        "description": "Human notices, approval requests, responses, timeouts, and applied decisions."
      },
      "input_skills": {
        "description": "Local filesystem startup packet intake, required shared llm_ocr_skill PDF OCR, and optional public browser research."
      },
      "inputs": {
        "artifact": "inputs.json",
        "description": "Resolved startup document folder, monitoring settings, and field profile."
      },
      "logs": {
        "artifact": "logs.jsonl",
        "description": "Runtime stdout/stderr and redacted startup-analysis logs.",
        "stream": "stdout/stderr"
      },
      "outputs": {
        "artifacts": [
          "result.json",
          "final_artifact.json",
          "action_ledger.json",
          "artifact_quality.json",
          "run_health.json",
          "company_index.json",
          "company_index.md",
          "*/analysis.json",
          "*/analysis.md",
          "*/research_plan.json",
          "*/agent_tool_trace.json"
        ],
        "description": "Score-only VC heuristic reports and structured company index."
      },
      "resources": {
        "artifact": "resources.jsonl",
        "description": "Resource samples such as token, runtime, connector, and disk usage."
      },
      "web_ui": {
        "artifacts": [
          "web_ui.json",
          "ui.json",
          "web/index.html"
        ],
        "description": "Optional review dashboard for artifact inspection."
      },
      "observability": {
        "artifact": "llm_rag_trace.jsonl",
        "description": "Metadata-only LLM, RAG, OCR, tool, and artifact timing trace for diagnosing slow VC runs."
      }
    },
    "config": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "resources",
      "human_control",
      "real_adapters",
      "streams",
      "python_dependencies",
      "skill_runtime",
      "input_skills",
      "output_skills",
      "error_handling",
      "state",
