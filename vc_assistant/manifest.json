{
  "agentic_research": {
    "agent_ids": [
      "research_planner",
      "company_identity_researcher",
      "funding_researcher",
      "market_comp_researcher",
      "traction_verifier",
      "rendered_page_researcher"
    ],
    "allowed_tools": [
      "browser_search",
      "browser_page",
      "rendered_browser_page",
      "finish"
    ],
    "default_mode": "bounded_llm_guided_public_tool_research",
    "enabled": true,
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "note": "Default batch research uses bounded LLM tool-decision loops for public-safe evidence collection; browser failures remain warnings and are recorded.",
    "quick_test_behavior": "disabled_for_default_smoke_run"
  },
  "agents": {
    "registry": {
      "startup_folder_watcher": {
        "handler": "agents.startup_folder_watcher",
        "role": "Startup Folder Watcher"
      },
      "company_packet_grouper": {
        "handler": "agents.company_packet_grouper",
        "role": "Company Packet Grouper"
      },
      "document_evidence_extractor": {
        "handler": "agents.document_evidence_extractor",
        "role": "Document Evidence Extractor"
      },
      "claim_normalizer": {
        "handler": "agents.claim_normalizer",
        "role": "Claim Normalizer"
      },
      "research_planner": {
        "handler": "agents.research_planner",
        "role": "Research Planner"
      },
      "company_identity_researcher": {
        "handler": "agents.public_researcher",
        "role": "Company Identity Researcher"
      },
      "funding_researcher": {
        "handler": "agents.public_researcher",
        "role": "Funding Researcher"
      },
      "market_comp_researcher": {
        "handler": "agents.public_researcher",
        "role": "Market And Comparable Researcher"
      },
      "traction_verifier": {
        "handler": "agents.public_researcher",
        "role": "Traction Verifier"
      },
      "rendered_page_researcher": {
        "handler": "agents.public_researcher",
        "role": "Rendered Page Researcher"
      },
      "research_reconciler": {
        "handler": "agents.research_reconciler",
        "role": "Research Reconciler"
      },
      "berkus_scorer": {
        "handler": "agents.berkus_scorer",
        "role": "Berkus Scorer",
        "with": {
          "method": "berkus_method"
        }
      },
      "scorecard_bill_payne_scorer": {
        "handler": "agents.scorecard_bill_payne_scorer",
        "role": "Scorecard Bill Payne Scorer",
        "with": {
          "method": "scorecard_bill_payne_method"
        }
      },
      "risk_factor_summation_scorer": {
        "handler": "agents.risk_factor_summation_scorer",
        "role": "Risk Factor Summation Scorer",
        "with": {
          "method": "risk_factor_summation_method"
        }
      },
      "venture_capital_method_scorer": {
        "handler": "agents.venture_capital_method_scorer",
        "role": "Venture Capital Method Scorer",
        "with": {
          "method": "venture_capital_method"
        }
      },
      "first_chicago_scorer": {
        "handler": "agents.first_chicago_scorer",
        "role": "First Chicago Scorer",
        "with": {
          "method": "first_chicago_method"
        }
      },
      "comparables_market_multiple_scorer": {
        "handler": "agents.comparables_market_multiple_scorer",
        "role": "Comparables Market Multiple Scorer",
        "with": {
          "method": "comparables_market_multiple_method"
        }
      },
      "cost_to_duplicate_scorer": {
        "handler": "agents.cost_to_duplicate_scorer",
        "role": "Cost To Duplicate Scorer",
        "with": {
          "method": "cost_to_duplicate_method"
        }
      },
      "score_consistency_auditor": {
        "handler": "agents.score_consistency_auditor",
        "role": "Score Consistency Auditor"
      },
      "company_report_writer": {
        "handler": "agents.company_report_writer",
        "role": "Company Report Writer"
      },
      "batch_index_writer": {
        "handler": "agents.batch_index_writer",
        "lifecycle": {
          "rag_stage": "batch_indexing",
          "review_after_run": false
        },
        "role": "Batch Index Writer"
      }
    }
  },
  "apiVersion": "mn.workflow.source/v2",
  "config": {
    "default": "config/default.json",
    "embed": true,
    "manifest_defaults": [
      "agentic_research",
      "knowledge_rag",
      "llm",
      {
        "from": "requirements",
        "to": "resources"
      },
      {
        "from": "workflow.policy.human",
        "to": "human_control"
      },
      {
        "from": "contracts.input_adapters.supported",
        "to": "interfaces.input_adapters"
      },
      {
        "from": "contracts.inputs.monitoring.example",
        "to": "inputs.payload.monitoring"
      },
      {
        "from": "identity.id",
        "to": "identity.blueprint_id"
      },
      {
        "from": "identity.name",
        "to": "identity.name"
      }
    ]
  },
  "contracts": {
    "events": {
      "human_stream": "human.jsonl",
      "stream": "events.jsonl",
      "types": [
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "artifact_written",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
        "output_skill_started",
        "output_skill_completed",
        "output_skill_failed",
        "tool_call_started",
        "tool_call_completed",
        "tool_call_failed",
        "detect_packet_changes_completed",
        "assemble_company_packets_completed",
        "prepare_company_evidence_completed",
        "plan_public_research_completed",
        "collect_public_research_completed",
        "reconcile_research_evidence_completed",
        "calculate_valuation_scores_completed",
        "audit_valuation_analysis_completed",
        "write_company_reports_completed",
        "publish_batch_summary_completed",
        "watch_cycle_started",
        "watch_cycle_completed"
      ]
    },
    "input_adapters": {
      "default": "mock",
      "resolved_artifact": "inputs.json",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ]
    },
    "inputs": {
      "document_folder": {
        "description": "Local folder monitored for startup documents; first-level folders are treated as companies.",
        "example": "@/examples/sample_inputs",
        "path_kind": "directory",
        "privacy": "confidential",
        "required": true,
        "type": "local_path"
      },
      "field_profile": {
        "description": "Startup evidence fields captured by the analyzer.",
        "example": [
          "company_name",
          "founder_team",
          "market",
          "product",
          "traction",
          "strategic_relationships",
          "risks"
        ],
        "privacy": "internal",
        "required": false,
        "type": "domain_value"
      },
      "force_reprocess": {
        "description": "Reprocess unchanged company packets instead of reusing durable cached reports.",
        "example": false,
        "privacy": "internal",
        "required": false,
        "type": "boolean"
      },
      "input_folder": {
        "description": "Default local input folder for sample files or user-provided files.",
        "example": "@/examples/sample_inputs",
        "path_kind": "directory",
        "privacy": "confidential",
        "required": false,
        "type": "local_path"
      },
      "monitoring": {
        "description": "Folder monitoring configuration for one-shot or continuous polling runs.",
        "example": {
          "enabled": true,
          "max_cycles": 1,
          "poll_interval_seconds": 60
        },
        "privacy": "internal",
        "required": false,
        "type": "domain_value"
      },
      "output_folder": {
        "description": "Local folder where per-company reports and the company index should be written.",
        "example": "~/Downloads/vc_assistant",
        "path_kind": "directory",
        "privacy": "confidential",
        "required": true,
        "type": "local_path"
      }
    },
    "outputs": {
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "action_ledger",
          "mime_type": "application/json",
          "path": "action_ledger.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.action_ledger.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "action_ledger"
        },
        {
          "artifact_id": "artifact_quality",
          "mime_type": "application/json",
          "path": "artifact_quality.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.artifact_quality.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "artifact_quality"
        },
        {
          "artifact_id": "run_health",
          "mime_type": "application/json",
          "path": "run_health.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.run_health.v1",
          "source_refs": [
            "final_artifact.json",
            "action_ledger.json",
            "artifact_quality.json"
          ],
          "type": "run_health"
        },
        {
          "artifact_id": "logs",
          "mime_type": "application/x-jsonlines",
          "path": "logs.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.logs.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "logs"
        },
        {
          "artifact_id": "resources",
          "mime_type": "application/x-jsonlines",
          "path": "resources.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.resources.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "resource_samples"
        },
        {
          "artifact_id": "web_ui",
          "mime_type": "application/json",
          "path": "web_ui.json",
          "producer": "web_ui",
          "schema_version": "mn.blueprint.web_ui.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "web_ui"
        },
        {
          "artifact_id": "human_events",
          "mime_type": "application/x-jsonlines",
          "path": "human.jsonl",
          "producer": "human_control",
          "schema_version": "mn.blueprint.human_events.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "human_events"
        },
        {
          "artifact_id": "company_index",
          "mime_type": "application/json",
          "path": "<outputs.folder_path>/company_index.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.generated_report.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "generated_report"
        }
      ],
      "primary": {
        "id": "final_artifact",
        "path": "final_artifact.json",
        "required_fields": [
          "type",
          "executive_summary",
          "recommended_action",
          "confidence",
          "evidence",
          "next_steps",
          "source_refs",
          "research_summary",
          "research_sources",
          "research_warnings"
        ],
        "schema_version": "mn.blueprint.final_artifact_contract.v1",
        "type": "final_artifact"
      },
      "profile": "standard_run_store"
    },
    "status": {
      "heartbeat": true
    }
  },
  "defaults": {
    "worker": {
      "with": {
        "image": "mirror-neuron/vc-assistant:local",
        "upload_paths": [
          {
            "source": "domain",
            "target": "domain"
          }
        ]
      }
    }
  },
  "identity": {
    "category": "finance",
    "id": "vc_assistant",
    "job_name": "vc-assistant",
    "manifest_version": "1.0",
    "name": "VC Assistant",
    "version": 1
  },
  "intent": {
    "description": "A VC analysis co-worker for early startup screening reports. Put pitch decks, memos, financial snippets, company folders, or other startup documents in the input folder; it groups documents by company, performs privacy-safe public research, applies seven VC heuristic scoring methods, audits the math and evidence, and writes score-only per-company reports and batch indexes to the output folder.",
    "problem": "Early startup packets are noisy and inconsistent; analysts need quick heuristic reports with evidence, assumptions, and missing-information flags while retaining the final decision.",
    "safety": {
      "allowed_decisions": [
        "approve",
        "revise",
        "reject"
      ],
      "blocked_actions": [
        "make_investment_decision",
        "send_investment_recommendation",
        "share_confidential_documents",
        "submit_term_sheet",
        "contact_founder_without_review",
        "mark_scores_as_final_valuation"
      ],
      "decision_event": "human_decision_applied",
      "default_action": "reject",
      "enabled": true,
      "events": [
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied"
      ],
      "mode": "approval_required",
      "reason": "Human approval is required before any external sharing, investment action, founder contact, valuation use, or downstream decision.",
      "request_event": "human_input_requested",
      "response_event": "human_input_received",
      "timeout_event": "human_input_timeout",
      "timeout_seconds": 3600
    },
    "target_users": "VC analysts, angel investors, accelerator reviewers, startup scouts, and founder-led investment teams."
  },
  "kind": "WorkflowSource",
  "knowledge_rag": {
    "chunk_overlap": 80,
    "chunk_size": 800,
    "embedding_api_base": "auto",
    "embedding_document_prefix": "Document: ",
    "embedding_healthcheck_enabled": true,
    "embedding_model": "rag-embedding",
    "embedding_provider": "docker_model_runner",
    "embedding_query_prefix": "Query: ",
    "embedding_start_command": "",
    "enabled": true,
    "index_on_startup": true,
    "knowledge_dir": "@/payloads/knowledge",
    "max_context_chars": 6000,
    "namespace": "",
    "required": true,
    "top_k": 5,
    "vector_dim": 1024
  },
  "llm": {
    "agents": {
      "batch_index_writer": {
        "llm_config": "primary",
        "responsibilities": [
          "Write batch indexes.",
          "Write coverage summaries.",
          "Keep output report-only."
        ]
