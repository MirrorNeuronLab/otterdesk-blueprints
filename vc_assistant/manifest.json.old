\"gradio\",\"custom\"]},\"internet_research\":{\"blocked_inputs\":[\"raw_document_text\",\"confidential_pitch_deck_excerpts\",\"customer_names\",\"private_financials\",\"founder_contact_details\"],\"browser_skill\":\"w3m_browser_skill\",\"default_source_urls\":[\"https://www.sba.gov/business-guide/plan-your-business/market-research-competitive-analysis\",\"https://www.sec.gov/education/smallbusiness\",\"https://www.bls.gov/\"],\"enabled\":true,\"max_chars\":12000,\"max_queries\":10,\"max_sources_per_company\":10,\"max_stage_workers\":1,\"max_target_urls_per_company\":6,\"privacy\":\"derive queries from company names, public categories, domains, and public claims only\",\"python_http_fallback\":{\"enabled\":true,\"max_chars\":6000,\"max_search_results\":2,\"purpose\":\"Bounded stdlib HTTP fallback for public search/result pages when the optional w3m binary is unavailable in the worker image.\",\"timeout_seconds\":5,\"user_agent\":\"MirrorNeuron-VC-Assistant/1.0 (+public research fallback)\"},\"rendered_browser\":{\"enabled\":true,\"max_chars\":12000,\"max_pages_per_company\":3,\"no_captcha_solving\":true,\"no_proxy_rotation\":true,\"per_host_delay_seconds\":1,\"purpose\":\"Optional Playwright fallback for JavaScript-rendered public pages such as Crunchbase profiles when w3m cannot extract useful text.\",\"respect_robots\":true,\"stop_on_blocked\":true,\"timeout_seconds\":30},\"rendered_browser_skill\":\"web_browser_skill\",\"research_targets\":[\"company_website\",\"crunchbase_profile\",\"founder_public_profiles\",\"funding_and_investor_mentions\",\"news_and_press\",\"market_size_sources\",\"competitors_and_comparables\",\"SEC_or_public_company_context_when_relevant\"],\"source_url_templates\":[\"https://www.crunchbase.com/organization/{company_slug}\",\"https://www.linkedin.com/company/{company_slug}\",\"https://www.sec.gov/edgar/search/\"],\"timeout_seconds\":20,\"use_model_compression\":true,\"verification_domains\":[\"crunchbase.com\",\"linkedin.com/company\",\"sec.gov\",\"company_website\",\"news_and_press\"],\"verification_fields\":[\"company_profile\",\"founders\",\"funding\",\"category\",\"competitors\",\"traction_claims\",\"source_conflicts\"]},\"knowledge_rag\":{\"chunk_overlap\":80,\"chunk_size\":800,\"embedding_api_base\":\"http://host.docker.internal:12434/engines/v1\",\"embedding_document_prefix\":\"Document: \",\"embedding_healthcheck_enabled\":true,\"embedding_model\":\"rag-embedding\",\"embedding_provider\":\"docker_model_runner\",\"embedding_query_prefix\":\"Query: \",\"embedding_start_command\":\"\",\"enabled\":true,\"index_on_startup\":true,\"max_context_chars\":6000,\"namespace\":\"\",\"redis_url\":\"\",\"required\":true,\"top_k\":5,\"vector_dim\":1024},\"llm\":{\"agents\":{\"batch_index_writer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Write batch indexes.\",\"Write coverage summaries.\",\"Keep output report-only.\"],\"role\":\"Batch Index Writer\"},\"berkus_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Score five Berkus buckets.\",\"Use deterministic formulas.\",\"Record assumptions.\"],\"role\":\"Berkus Scorer\"},\"claim_normalizer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Build fact tables.\",\"Normalize numeric evidence.\",\"Separate local and public facts.\"],\"role\":\"Claim Normalizer\"},\"company_identity_researcher\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Research company identity.\",\"Check Crunchbase/profile targets.\",\"Record blocked outcomes.\"],\"role\":\"Company Identity Researcher\"},\"company_packet_grouper\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Group files by company.\",\"Resolve stable company ids.\",\"Preserve source refs.\"],\"role\":\"Company Packet Grouper\"},\"company_report_writer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Write per-company folders.\",\"Preserve method sections.\",\"Write warnings and evidence files.\"],\"role\":\"Company Report Writer\"},\"comparables_market_multiple_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Use comparable evidence.\",\"Record market multiple assumptions.\",\"Mark insufficient evidence.\"],\"role\":\"Comparables Market Multiple Scorer\"},\"cost_to_duplicate_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Estimate rebuild-cost floor.\",\"Use asset evidence.\",\"Flag missing asset details.\"],\"role\":\"Cost To Duplicate Scorer\"},\"document_evidence_extractor\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Extract local evidence.\",\"Capture structured claims.\",\"Mark unreadable files.\"],\"role\":\"Document Evidence Extractor\"},\"first_chicago_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Build bear/base/bull cases.\",\"Apply probabilities.\",\"Record scenario warnings.\"],\"role\":\"First Chicago Scorer\"},\"funding_researcher\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Research funding mentions.\",\"Check investor and accelerator signals.\",\"Record source quality.\"],\"role\":\"Funding Researcher\"},\"market_comp_researcher\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Research market context.\",\"Find comparable candidates.\",\"Capture source references.\"],\"role\":\"Market And Comparable Researcher\"},\"rendered_page_researcher\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Use rendered browser when enabled.\",\"Respect robots and blocked pages.\",\"Record JS-heavy page status.\"],\"role\":\"Rendered Page Researcher\"},\"research_planner\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Create safe queries.\",\"Avoid confidential excerpts.\",\"Plan profile and market lookups.\"],\"role\":\"Research Planner\"},\"research_reconciler\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Merge local and public evidence.\",\"Flag confirmations.\",\"Flag conflicts and missing evidence.\"],\"role\":\"Research Reconciler\"},\"risk_factor_summation_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Run 12-risk checklist.\",\"Record adjustments.\",\"Mark missing risk evidence.\"],\"role\":\"Risk Factor Summation Scorer\"},\"score_consistency_auditor\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Check score math.\",\"Check missing-evidence handling.\",\"Flag unsupported assumptions.\"],\"role\":\"Score Consistency Auditor\"},\"scorecard_bill_payne_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Apply weighted factors.\",\"Record inputs used.\",\"Keep scores report-only.\"],\"role\":\"Scorecard Bill Payne Scorer\"},\"startup_folder_watcher\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Detect changed files.\",\"Build company fingerprints.\",\"Identify unchanged company packets.\"],\"role\":\"Startup Folder Watcher\"},\"traction_verifier\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Verify customer and launch claims.\",\"Check public traction signals.\",\"Flag missing evidence.\"],\"role\":\"Traction Verifier\"},\"venture_capital_method_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Run exit-back math.\",\"Record assumptions.\",\"Avoid valuation recommendations.\"],\"role\":\"Venture Capital Method Scorer\"}},\"backend\":\"llama.cpp\",\"configs\":{\"primary\":{\"api_base\":\"auto\",\"backend\":\"llama.cpp\",\"context_size\":8192,\"fallback_model\":\"small\",\"max_tokens\":1200,\"mock_mode\":\"fake\",\"mode\":\"live\",\"model\":\"medium\",\"num_retries\":1,\"parameter_count_b\":31.58,\"provider\":\"docker_model_runner\",\"quantization\":\"MOSTLY_Q4_K_M\",\"runtime_model\":\"medium\",\"timeout_seconds\":60}},\"context_size\":8192,\"default_config\":\"primary\",\"enabled\":true,\"fallback_model\":\"small\",\"live_model_profile\":{\"backend\":\"llama.cpp\",\"context_size\":8192,\"fallback_model\":\"small\",\"hardware\":{\"gpu\":{\"memory_operator\":\">=\",\"min_count\":1,\"min_memory_mb\":49152}},\"model\":\"medium\",\"parameter_count_b\":31.58,\"provider\":\"docker_model_runner\",\"quantization\":\"MOSTLY_Q4_K_M\",\"runtime_model\":\"medium\"},\"mock_mode\":\"fake\",\"mode\":\"live\",\"model\":\"medium\",\"parameter_count_b\":31.58,\"prefer_shared_skill\":true,\"provider\":\"docker_model_runner\",\"quantization\":\"MOSTLY_Q4_K_M\",\"quick_test_uses_fake\":true,\"require_live\":true,\"responsibilities\":[\"Keep VC outputs report-only and source-grounded.\",\"Use specialist agents for research, scoring, audit, and report writing.\",\"Avoid automated investment decisions or confidential-data web disclosure.\"],\"runtime_model\":\"medium\",\"strict_json\":true},\"local_inputs\":{\"folders\":[{\"allowed_extensions\":[\".pdf\",\".txt\",\".md\",\".json\",\".csv\"],\"config_path\":\"document_sources.folder_path\",\"default_config_value\":\"vc_assistant/examples/sample_inputs\",\"linked_config_paths\":[\"inputs.payload.document_folder\",\"inputs.payload.input_folder\",\"state.document_folder\",\"state.input_folder\"],\"payload_path\":\"document_workflow/mn_local_inputs/vc_documents\",\"runtime_path\":\"mn_local_inputs/vc_documents\",\"source_path\":\"examples/sample_inputs\"}]},\"logging\":{\"events\":[\"blueprint_status\",\"blueprint_phase_started\",\"blueprint_phase_completed\",\"blueprint_phase_failed\",\"artifact_written\",\"human_notice\",\"human_input_requested\",\"human_input_received\",\"human_input_timeout\",\"human_decision_applied\",\"output_skill_started\",\"output_skill_completed\",\"output_skill_failed\",\"tool_call_started\",\"tool_call_completed\",\"tool_call_failed\",\"startup_folder_watcher_completed\",\"company_packet_grouper_completed\",\"document_evidence_extractor_completed\",\"claim_normalizer_completed\",\"research_planner_completed\",\"company_identity_researcher_completed\",\"funding_researcher_completed\",\"market_comp_researcher_completed\",\"traction_verifier_completed\",\"rendered_page_researcher_completed\",\"research_reconciler_completed\",\"berkus_scorer_completed\",\"scorecard_bill_payne_scorer_completed\",\"risk_factor_summation_scorer_completed\",\"venture_capital_method_scorer_completed\",\"fir