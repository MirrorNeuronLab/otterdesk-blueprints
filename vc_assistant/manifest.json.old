        "internet_research": {
            "blocked_inputs": [
                "raw_document_text",
                "confidential_pitch_deck_excerpts",
                "customer_names",
                "private_financials",
                "founder_contact_details"
            ],
            "browser_skill": "w3m_browser_skill",
            "default_source_urls": [
                "https://www.sba.gov/business-guide/plan-your-business/market-research-competitive-analysis",
                "https://www.sec.gov/education/smallbusiness",
                "https://www.bls.gov/"
            ],
            "enabled": true,
            "max_chars": 12000,
            "max_queries": 8,
            "max_sources_per_company": 8,
            "max_stage_workers": 1,
            "max_target_urls_per_company": 4,
            "privacy": "derive queries from company names, public categories, domains, and public claims only",
            "rendered_browser": {
                "enabled": true,
                "max_chars": 12000,
                "max_pages_per_company": 2,
                "no_captcha_solving": true,
                "no_proxy_rotation": true,
                "per_host_delay_seconds": 1,
                "purpose": "Optional Playwright fallback for JavaScript-rendered public pages such as Crunchbase profiles when w3m cannot extract useful text.",
                "respect_robots": true,
                "stop_on_blocked": true,
                "timeout_seconds": 30
            },
            "rendered_browser_skill": "web_browser_skill",
            "research_targets": [
                "company_website",
                "crunchbase_profile",
                "founder_public_profiles",
                "funding_and_investor_mentions",
                "news_and_press",
                "market_size_sources",
                "competitors_and_comparables",
                "SEC_or_public_company_context_when_relevant"
            ],
            "source_url_templates": [
                "https://www.crunchbase.com/organization/{company_slug}",
                "https://www.linkedin.com/company/{company_slug}",
                "https://www.sec.gov/edgar/search/"
            ],
            "timeout_seconds": 20,
            "use_model_compression": true,
            "verification_domains": [
                "crunchbase.com",
                "linkedin.com/company",
                "sec.gov",
                "company_website",
                "news_and_press"
            ],
            "verification_fields": [
                "company_profile",
                "founders",
                "funding",
                "category",
                "competitors",
                "traction_claims",
                "source_conflicts"
            ]
        },
        "knowledge_rag": {
            "chunk_overlap": 80,
            "chunk_size": 800,
            "embedding_api_base": "http://host.docker.internal:12434/engines/v1",
            "embedding_document_prefix": "Document: ",
            "embedding_healthcheck_enabled": true,
            "embedding_model": "rag-embedding",
            "embedding_provider": "docker_model_runner",
            "embedding_query_prefix": "Query: ",
            "embedding_start_command": "",
            "enabled": true,
            "index_on_startup": true,
            "knowledge_dir": "payloads/knowledge",
            "max_context_chars": 6000,
            "namespace": "",
            "redis_url": "",
            "required": true,
            "top_k": 5,
            "vector_dim": 1024
        },
        "llm": {
            "agents": {
                "batch_index_writer": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Write batch indexes.",
                        "Write coverage summaries.",
                        "Keep output report-only."
                    ],
                    "role": "Batch Index Writer"
                },
                "berkus_scorer": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Score five Berkus buckets.",
                        "Use deterministic formulas.",
                        "Record assumptions."
                    ],
                    "role": "Berkus Scorer"
                },
                "claim_normalizer": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Build fact tables.",
                        "Normalize numeric evidence.",
                        "Separate local and public facts."
                    ],
                    "role": "Claim Normalizer"
                },
                "company_identity_researcher": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Research company identity.",
                        "Check Crunchbase/profile targets.",
                        "Record blocked outcomes."
                    ],
                    "role": "Company Identity Researcher"
                },
                "company_packet_grouper": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Group files by company.",
                        "Resolve stable company ids.",
                        "Preserve source refs."
                    ],
                    "role": "Company Packet Grouper"
                },
                "company_report_writer": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Write per-company folders.",
                        "Preserve method sections.",
                        "Write warnings and evidence files."
                    ],
                    "role": "Company Report Writer"
                },
                "comparables_market_multiple_scorer": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Use comparable evidence.",
                        "Record market multiple assumptions.",
                        "Mark insufficient evidence."
                    ],
                    "role": "Comparables Market Multiple Scorer"
                },
                "cost_to_duplicate_scorer": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Estimate rebuild-cost floor.",
                        "Use asset evidence.",
                        "Flag missing asset details."
                    ],
                    "role": "Cost To Duplicate Scorer"
                },
                "document_evidence_extractor": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Extract local evidence.",
                        "Capture structured claims.",
                        "Mark unreadable files."
                    ],
                    "role": "Document Evidence Extractor"
                },
                "first_chicago_scorer": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Build bear/base/bull cases.",
                        "Apply probabilities.",
                        "Record scenario warnings."
                    ],
                    "role": "First Chicago Scorer"
                },
                "funding_researcher": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Research funding mentions.",
                        "Check investor and accelerator signals.",
                        "Record source quality."
                    ],
                    "role": "Funding Researcher"
                },
                "market_comp_researcher": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Research market context.",
                        "Find comparable candidates.",
                        "Capture source references."
                    ],
                    "role": "Market And Comparable Researcher"
                },
                "rendered_page_researcher": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Use rendered browser when enabled.",
                        "Respect robots and blocked pages.",
                        "Record JS-heavy page status."
                    ],
                    "role": "Rendered Page Researcher"
                },
                "research_planner": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Create safe queries.",
                        "Avoid confidential excerpts.",
                        "Plan profile and market lookups."
                    ],
                    "role": "Research Planner"
                },
                "research_reconciler": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Merge local and public evidence.",
                        "Flag confirmations.",
                        "Flag conflicts and missing evidence."
                    ],
                    "role": "Research Reconciler"
                },
                "risk_factor_summation_scorer": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Run 12-risk checklist.",
                        "Record adjustments.",
                        "Mark missing risk evidence."
                    ],
                    "role": "Risk Factor Summation Scorer"
                },
                "score_consistency_auditor": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Check score math.",
                        "Check missing-evidence handling.",
                        "Flag unsupported assumptions."
                    ],
                    "role": "Score Consistency Auditor"
                },
                "scorecard_bill_payne_scorer": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Apply weighted factors.",
                        "Record inputs used.",
                        "Keep scores report-only."
                    ],
                    "role": "Scorecard Bill Payne Scorer"
                },
                "startup_folder_watcher": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Detect changed files.",
                        "Build company fingerprints.",
                        "Identify unchanged company packets."
                    ],
                    "role": "Startup Folder Watcher"
                },
                "traction_verifier": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Verify customer and launch claims.",
                        "Check public traction signals.",
                        "Flag missing evidence."
                    ],
                    "role": "Traction Verifier"
                },
                "venture_capital_method_scorer": {
                    "llm_config": "primary",
                    "responsibilities": [
                        "Run exit-back math.",
                        "Record assumptions.",
                        "Avoid valuation recommendations."
                    ],
                    "role": "Venture Capital Method Scorer"
                }
            },
            "backend": "llama.cpp",
            "configs": {
                "primary": {
                    "provider": "docker_model_runner",
                    "model": "small",
                    "runtime_model": "small",
                    "fallback_model": "small",
                    "backend": "llama.cpp",
                    "api_base": "auto",
                    "timeout_seconds": 60,
                    "max_tokens": 1800,
                    "num_retries": 2,
                    "retry_backoff_seconds": 1.0,
                    "mock_mode": "fake",
                    "mode": "live"
                }
            },
            "default_config": "primary",
            "enabled": true,
            "small_model_profile": {
                "provider": "docker_model_runner",
                "model": "small",
                "runtime_model": "small",
                "fallback_model": "small",
                "backend": "llama.cpp",
                "api_base": "auto",
                "timeout_seconds": 60,
                "max_tokens": 1800,
                "num_retries": 2,
                "retry_backoff_seconds": 1.0,
                "strict_json": false,
                "require_live": false
            },
            "live_model_profile": {
                "provider": "docker_model_runner",
                "model": "small",
                "runtime_model": "small",
                "fallback_model": "small",
                "backend": "llama.cpp",
                "api_base": "auto",
                "timeout_seconds": 60,
                "max_tokens": 1800,
                "num_retries": 2,
                "retry_backoff_seconds": 1.0,
                "strict_json": false,
                "require_live": false
            },
            "mock_mode": "fake",
            "mode": "live",
            "model": "small",
            "fallback_model": "small",
            "prefer_shared_skill": true,
            "provider": "docker_model_runner",
            "quick_test_uses_fake": false,
            "require_live": false,
            "responsibilities": [
                "Keep VC outputs report-only and source-grounded.",
                "Use specialist agents for research, scoring, audit, and report writing.",
                "Avoid automated investment decisions or confidential-data web disclosure."
            ],
            "runtime_model": "small",
            "strict_json": false,
            "preferred_model": "medium",
            "large_model_profile": {
                "provider": "docker_model_runner",
                "model": "medium",
                "runtime_model": "medium",
                "backend": "llama.cpp",
                "timeout_seconds": 60,
                "max_tokens": 1800,
                "num_retries": 1,
                "retry_backoff_seconds": 1.0,
                "strict_json": true,
                "require_live": true,
                "context_size": 8192,
                "quantization": "MOSTLY_Q4_K_M",
                "parameter_count_b": 31.58,
                "hardware": {
                    "gpu": {
                        "min_count": 1,
                        "min_memory_mb": 49152,
                        "memory_operator": ">="
                    }
                }
            }
        },
        "local_on_prem_rationale": "Startup packets can contain confidential deal flow; local intake and review-only outputs preserve user control.",
        "memory_layer": {
            "collection": "mn_memory",
            "containers": "optional_sidecar",
            "context_addr_env": "MN_CONTEXT_ADDR",
            "conversation": {
                "agent_role": "otterdesk_chat",
                "include_human_events": true,
                "include_runtime_events": true,
                "include_runtime_logs": true,
                "target_tokens": 2400,
                "token_budget": 6000,
                "use_model_compression": true
            },
            "conversation_enabled": true,
            "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
            "default_context_addr": "localhost:50052",
            "enabled": true,
            "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
            "namespace": "vc_assistant_context",
            "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
            "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
            "sdk_distribution": "mirrorneuron-membrane-python-sdk",
            "sdk_import_package": "mn_context_engine_sdk"
        },
        "mn_skill_runtime": {
            "build_context": "document_workflow/docker_worker",
            "generated": false,
            "patched_nodes": [
                "startup_folder_watcher",
                "company_packet_grouper",
                "document_evidence_extractor",
                "claim_normalizer",
                "research_planner",
                "company_identity_researcher",
                "funding_researcher",
                "market_comp_researcher",
                "traction_verifier",
                "rendered_page_researcher",
                "research_reconciler",
                "berkus_scorer",
                "scorecard_bill_payne_scorer",
                "risk_factor_summation_scorer",
                "venture_capital_method_scorer",
                "first_chicago_scorer",
                "comparables_market_multiple_scorer",
                "cost_to_duplicate_scorer",
                "score_consistency_auditor",
                "company_report_writer",
                "batch_index_writer"
            ]
        },
        "name": "VC Assistant",
        "observability_dashboard": {
            "panels": [
                "current_status",
                "recent_events",
                "pending_human_requests",
                "output_artifacts",
                "resource_usage",
                "errors",
                "llm_calls",
                "token_budget",
                "llm_retries"
            ],
            "reads": [
                "events.jsonl",
                "human.jsonl",
                "logs.jsonl",
                "resources.jsonl",
                "result.json",
                "final_artifact.json",
                "web_ui.json"
            ],
            "schema_version": "mn.blueprint.observability_dashboard.v1",
            "source": "local_run_store"
        },
        "output_contract": {
            "artifacts": [
                {
                    "artifact_id": "run_metadata",
                    "mime_type": "application/json",
                    "path": "run.json",
                    "producer": "local_run_store",
                    "schema_version": "mn.artifact.run_summary.v1",
                    "source_refs": [],
                    "type": "run_summary"
                },
                {
                    "artifact_id": "resolved_config",
                    "mime_type": "application/json",
                    "path": "config.json",
                    "producer": "local_run_store",
                    "schema_version": "mn.blueprint.config.v1",
                    "source_refs": [],
                    "type": "config"
                },
                {
                    "artifact_id": "resolved_inputs",
                    "mime_type": "application/json",
                    "path": "inputs.json",
                    "producer": "local_run_store",
                    "schema_version": "mn.blueprint.inputs.v1",
                    "source_refs": [],
                    "type": "inputs"
                },
                {
                    "artifact_id": "event_stream",
                    "mime_type": "application/x-jsonlines",
                    "path": "events.jsonl",
                    "producer": "local_run_store",
                    "schema_version": "mn.blueprint.events.v1",
                    "source_refs": [],
                    "type": "events"
                },
                {
                    "artifact_id": "result",
                    "mime_type": "application/json",
                    "path": "result.json",
                    "producer": "local_run_store",
                    "schema_version": "mn.blueprint.response.v1",
                    "source_refs": [
                        "inputs.json",
                        "events.jsonl"
                    ],
                    "type": "result"
                },
                {
                    "artifact_id": "final_artifact",
                    "mime_type": "application/json",
                    "path": "final_artifact.json",
                    "producer": "workflow",
                    "schema_version": "mn.blueprint.final_artifact.v1",
                    "source_refs": [
                        "inputs.json",
                        "events.jsonl",
                        "result.json"
                    ],
                    "type": "final_artifact"
                },
                {
                    "artifact_id": "action_ledger",
                    "mime_type": "application/json",
                    "path": "action_ledger.json",
                    "producer": "workflow",
                    "schema_version": "mn.blueprint.action_ledger.v1",
                    "source_refs": [
                        "final_artifact.json"
                    ],
                    "type": "action_ledger"
                },
                {
                    "artifact_id": "artifact_quality",
                    "mime_type": "application/json",
                    "path": "artifact_quality.json",
                    "producer": "workflow",
                    "schema_version": "mn.blueprint.artifact_quality.v1",
                    "source_refs": [
                        "final_artifact.json"
                    ],
                    "type": "artifact_quality"
                },
                {
                    "artifact_id": "run_health",
                    "mime_type": "application/json",
                    "path": "run_health.json",
                    "producer": "workflow",
                    "schema_version": "mn.blueprint.run_health.v1",
                    "source_refs": [
                        "final_artifact.json",
                        "action_ledger.json",
                        "artifact_quality.json"
                    ],
                    "type": "run_health"
                },
                {
                    "artifact_id": "logs",
                    "mime_type": "application/x-jsonlines",
                    "path": "logs.jsonl",
                    "producer": "local_run_store",
                    "schema_version": "mn.blueprint.logs.v1",
                    "source_refs": [
                        "events.jsonl"
                    ],
                    "type": "logs"
                },
                {
                    "artifact_id": "resources",
                    "mime_type": "application/x-jsonlines",
                    "path": "resources.jsonl",
                    "producer": "local_run_store",
                    "schema_version": "mn.blueprint.resources.v1",
                    "source_refs": [
                        "run.json"
                    ],
                    "type": "resource_samples"
                },
                {
                    "artifact_id": "web_ui",
                    "mime_type": "application/json",
                    "path": "web_ui.json",
                    "producer": "web_ui",
                    "schema_version": "mn.blueprint.web_ui.v1",
                    "source_refs": [
                        "run.json"
                    ],
                    "type": "web_ui"
                },
                {
                    "artifact_id": "human_events",
                    "mime_type": "application/x-jsonlines",
                    "path": "human.jsonl",
                    "producer": "human_control",
                    "schema_version": "mn.blueprint.human_events.v1",
                    "source_refs": [
                        "events.jsonl"
                    ],
                    "type": "human_events"
                },
                {
                    "artifact_id": "company_index",
                    "mime_type": "application/json",
                    "path": "<outputs.folder_path>/company_index.json",
                    "producer": "workflow",
                    "schema_version": "mn.blueprint.generated_report.v1",
                    "source_refs": [
                        "final_artifact.json"
                    ],
                    "type": "generated_report"
                }
            ],
            "events_jsonl": "events.jsonl",
            "final_artifact": {
                "description": "Score-only VC heuristic report packet with company reports, evidence, public sources, confidence, and next steps.",
                "required_fields": [
                    "type",
                    "executive_summary",
                    "recommended_action",
                    "confidence",
                    "evidence",
                    "next_steps",
                    "source_refs"
                ],
                "schema_version": "mn.blueprint.final_artifact_contract.v1",
                "type": "vc_early_heuristic_analysis_reports"
            },
            "final_artifact_json": "final_artifact.json",
            "result_json": "result.json",
            "stdout": "JSON object with result, final_artifact, artifact paths, and run metadata when the runner is executed directly."
        },
        "problem": "Early startup packets are noisy and inconsistent; analysts need quick heuristic reports with evidence, assumptions, and missing-information flags while retaining the final decision.",
        "python_dependencies": {
            "extra_index_url": "https://pypi.org/simple",
            "index_url": "https://us-central1-python.pkg.dev/mirrorneuron-public-packages/agent-skills/simple/",
            "installer": "pip",
            "packages": [
                "mirrorneuron-blueprint-support-skill",
                "mirrorneuron-membrane-python-sdk",
                "mirrorneuron-llm-ocr-skill",
                "mirrorneuron-rag-skill",
                "mirrorneuron-w3m-browser-skill",
                "mirrorneuron-web-browser-skill"
            ],
            "requirements": "document_workflow/requirements.txt"
        },
        "research_budget": {
            "chargeable_actions": [
                "llm_call",
                "browser_search",
                "browser_page",
                "rendered_browser_page",
                "financial_tool"
            ],
            "default_actions": 80,
            "exhaustion_mode": "finish_with_budget_exhausted_warnings"
        },
        "runtime_features": [
            "daily scheduled folder scan",
            "folder-first startup company grouping",
            "privacy-safe public web research",
            "w3m_browser_skill lightweight source research",
            "web_browser_skill optional rendered-page verification",
            "Crunchbase and public profile verification planning",
            "Berkus Method scoring",
            "Scorecard Bill Payne Method scoring",
            "Risk Factor Summation Method scoring",
            "Venture Capital Method scoring",
            "First Chicago Method scoring",
            "Comparables Market Multiple Method scoring",
            "Cost-to-Duplicate Method scoring",
            "per-company Markdown and JSON reports",
            "human approval policy",
            "artifact records",
            "run-store observability dashboard",
            "Membrane context memory optimization",
            "company work queue generation",
            "deterministic fact table normalization",
            "parallel specialist web research",
            "parallel numerical method scoring",
            "score consistency auditing",
            "research coverage reports",
            "method coverage reports",
            "1000-action budgeted deep research",
            "deterministic public financial-tool heuristics",
            "method-level evidence and missing-evidence contract",
            "pip-installed runtime skill packages from Google Artifact Registry",
            "selected research agents use bounded LLM tool calls"
        ],
        "standard": {
            "workflow_model": "contract -> workflow -> agents/runtime"
        },
        "status_contract": {
            "attempt_event": "workflow_step_attempt_started",
            "beacon_event": "agent_beacon",
            "beacon_interval_ms": 15000,
            "beacon_missed_action": "fail_attempt",
            "beacon_timeout_ms": 45000,
            "blocked_event": "workflow_step_blocked",
            "events": [],
            "heartbeat_event": "agent_beacon",
            "heartbeat_required": true,
            "phases": [
                {
                    "completion_event": "blueprint_phase_completed",
                    "failure_event": "blueprint_phase_failed",
                    "phase": "loading_inputs",
                    "progress_event": "blueprint_status",
                    "required": true,
                    "start_event": "blueprint_phase_started"
                },
                {
                    "completion_event": "blueprint_phase_completed",
                    "failure_event": "blueprint_phase_failed",
                    "phase": "running_worker",
                    "progress_event": "blueprint_status",
                    "required": true,
                    "start_event": "blueprint_phase_started"
                },
                {
                    "completion_event": "blueprint_phase_completed",
                    "failure_event": "blueprint_phase_failed",
                    "phase": "waiting_for_human",
                    "progress_event": "blueprint_status",
                    "required": true,
                    "start_event": "blueprint_phase_started"
                },
                {
                    "completion_event": "blueprint_phase_completed",
                    "failure_event": "blueprint_phase_failed",
                    "phase": "writing_artifacts",
                    "progress_event": "blueprint_status",
                    "required": true,
                    "start_event": "blueprint_phase_started"
                },
                {
                    "completion_event": "blueprint_phase_completed",
                    "failure_event": "blueprint_phase_failed",
                    "phase": "completed",
                    "progress_event": "blueprint_status",
                    "required": true,
                    "start_event": "blueprint_phase_started"
                }
            ],
            "retry_event": "workflow_step_attempt_retry_scheduled",
            "runtime_state_source": "workflow_state",
            "schema_version": "mn.blueprint.status_contract.v1",
            "source": "run_store",
            "status_event": "blueprint_status",
            "terminal_step_events": [
                "workflow_step_completed",
                "workflow_step_partial",
                "workflow_step_skipped",
                "workflow_step_failed"
            ]
        },
        "target_users": "VC analysts, angel investors, accelerator reviewers, startup scouts, and founder-led investment teams.",
        "web_ui": {
            "dashboard": {
                "data_source": "local_run_store",
                "panels": [
                    "current_status",
                    "recent_events",
                    "pending_human_requests",
                    "output_artifacts",
                    "resource_usage",
