                                "target": "vc_assistant/examples/sample_inputs"
                            },
                            {
                                "source": "knowledge",
                                "target": "knowledge"
                            }
                        ],
                        "workdir": "/mn/job/document_workflow"
                    }
                },
                {
                    "node_id": "claim_normalizer",
                    "uses": "mn-agents.data_python_executor@1",
                    "with": {
                        "cleanup_remote_dir": true,
                        "command": [
                            "python3",
                            "scripts/run_blueprint.py"
                        ],
                        "docker_worker_image": "document_workflow/docker_worker",
                        "environment": {
                            "MN_BLUEPRINT_CONFIG_JSON": "{\"actor_review\":{\"context_target_tokens\":1800,\"context_token_budget\":5000,\"llm_actor_ids\":[\"research_planner\",\"company_identity_researcher\",\"funding_researcher\",\"market_comp_researcher\",\"traction_verifier\",\"research_reconciler\",\"berkus_scorer\",\"venture_capital_method_scorer\",\"comparables_market_multiple_scorer\",\"score_consistency_auditor\",\"company_report_writer\",\"batch_index_writer\"],\"max_context_chars\":9000,\"use_context_engine\":true,\"working_memory_persist_to_redis\":false},\"agent_handoffs\":[\"startup_folder_watcher_to_company_packet_grouper\",\"company_packet_grouper_to_document_evidence_extractor\",\"document_evidence_extractor_to_claim_normalizer\",\"claim_normalizer_to_research_planner\",\"research_planner_to_company_identity_researcher\",\"company_identity_researcher_to_funding_researcher\",\"funding_researcher_to_market_comp_researcher\",\"market_comp_researcher_to_traction_verifier\",\"traction_verifier_to_rendered_page_researcher\",\"rendered_page_researcher_to_research_reconciler\",\"research_reconciler_to_berkus_scorer\",\"berkus_scorer_to_scorecard_bill_payne_scorer\",\"scorecard_bill_payne_scorer_to_risk_factor_summation_scorer\",\"risk_factor_summation_scorer_to_venture_capital_method_scorer\",\"venture_capital_method_scorer_to_first_chicago_scorer\",\"first_chicago_scorer_to_comparables_market_multiple_scorer\",\"comparables_market_multiple_scorer_to_cost_to_duplicate_scorer\",\"cost_to_duplicate_scorer_to_score_consistency_auditor\",\"score_consistency_auditor_to_company_report_writer\",\"company_report_writer_to_batch_index_writer\"],\"agentic_research\":{\"agent_ids\":[\"research_planner\",\"company_identity_researcher\",\"funding_researcher\",\"market_comp_researcher\",\"traction_verifier\",\"rendered_page_researcher\"],\"allowed_tools\":[\"browser_search\",\"browser_page\",\"rendered_browser_page\",\"finish\"],\"default_mode\":\"bounded_llm_guided_public_tool_research\",\"enabled\":true,\"max_iterations_per_agent\":1,\"max_tool_calls_per_agent\":2,\"note\":\"Default batch research uses bounded LLM tool-decision loops for public-safe evidence collection; browser failures remain warnings and are recorded.\",\"quick_test_behavior\":\"disabled_for_default_smoke_run\"},\"backpressure\":{\"llm\":{\"max_concurrent_calls\":1,\"min_interval_seconds\":1.0,\"rationale\":\"Protect local Docker Model Runner from concurrent VC agent calls.\"},\"max_companies_per_cycle\":25,\"max_documents_per_cycle\":100},\"budgets\":{\"default_action_budget\":80,\"max_public_queries\":1000,\"max_runtime_seconds\":900},\"cache_policy\":{\"enabled\":true,\"force_reprocess\":false,\"force_reprocess_inputs\":[\"force_reprocess\",\"cache_policy.force_reprocess\",\"VC_ASSISTANT_FORCE_REPROCESS\",\"MN_BLUEPRINT_FORCE_REPROCESS\"],\"freshness_fields\":[\"fingerprint\",\"previous_fingerprint\",\"previous_run_id\",\"cache_source\",\"freshness\",\"decision\"]},\"capabilities\":[\"folder_monitoring\",\"document_evidence_extraction\",\"llm.ocr\",\"pdf.render\",\"privacy_safe_public_research\",\"vc_heuristic_scoring\",\"per_company_report_generation\",\"company_work_queue\",\"fact_table_normalization\",\"parallel_web_research\",\"parallel_numerical_scoring\",\"score_consistency_audit\",\"batch_report_factory\",\"action_budgeted_deep_research\",\"deterministic_financial_tools\",\"evidence_backed_method_results\"],\"dataset_input\":{\"availability_note\":\"Bundled sample startup documents are synthetic and intended only for local blueprint validation.\",\"expected_files\":[\"*.pdf\",\"*.txt\",\"*.md\",\"*.json\",\"*.csv\"],\"license\":\"Synthetic demo data\",\"name\":\"Synthetic startup packet samples\",\"provider\":\"OtterDesk blueprint fixtures\"},\"determinism\":{\"seed\":7,\"stable_company_slug\":true},\"document_automation\":{\"fields\":[\"company_name\",\"founder_team\",\"market\",\"product\",\"traction\",\"strategic_relationships\",\"risks\",\"comparables\",\"cost_to_duplicate\"],\"output_type\":\"vc_early_heuristic_analysis_reports\",\"recommended_action\":\"review_scores_sources_and_assumptions_before_making_any_investment_decision\",\"review_required\":true},\"document_sources\":{\"expected_files\":[\"*.pdf\",\"*.txt\",\"*.md\",\"*.json\",\"*.csv\"],\"folder_path\":\"vc_assistant/examples/sample_inputs\",\"grouping\":\"first_level_folder_then_infer_company_name\"},\"error_handling\":{\"default\":\"fail_closed\",\"external_research_failure\":\"continue_with_warning\",\"missing_evidence\":\"mark_insufficient_evidence\"},\"execution\":{\"deterministic_output_order\":\"company_slug\",\"max_company_workers\":1,\"quick_test\":false},\"execution_model\":{\"entrypoint\":\"startup_folder_watcher\",\"runtime_note\":\"Each workflow node executes a bounded step handler and exchanges JSON workflow-state artifacts through the shared run directory; report_sink completes the finite run.\",\"step_count\":21,\"terminal_sink\":\"report_sink\",\"type\":\"static_dag_step_handlers\",\"worker_sink\":\"batch_index_writer\"},\"financial_tools\":{\"adapters\":[\"local_public_comparable_and_exit_math\"],\"enabled\":true,\"missing_provider_data_policy\":\"record_missing_evidence\",\"paid_provider_connectors\":false},\"human_control\":{\"allowed_decisions\":[\"approve\",\"revise\",\"reject\"],\"blocked_actions\":[\"make_investment_decision\",\"send_investment_recommendation\",\"share_confidential_documents\",\"submit_term_sheet\",\"contact_founder_without_review\",\"mark_scores_as_final_valuation\"],\"decision_event\":\"human_decision_applied\",\"default_action\":\"reject\",\"enabled\":true,\"events\":[\"human_notice\",\"human_input_requested\",\"human_input_received\",\"human_input_timeout\",\"human_decision_applied\"],\"mode\":\"approval_required\",\"reason\":\"Human approval is required before any external sharing, investment action, founder contact, valuation use, or downstream decision.\",\"request_event\":\"human_input_requested\",\"response_event\":\"human_input_received\",\"timeout_event\":\"human_input_timeout\",\"timeout_seconds\":3600},\"identity\":{\"blueprint_id\":\"vc_assistant\",\"name\":\"VC Assistant\"},\"input_skills\":{\"llm_ocr\":{\"backend\":\"auto\",\"connector\":\"docker_model_runner\",\"enabled\":true,\"endpoint\":\"http://host.docker.internal:12434\",\"install_policy\":\"on_first_required_document\",\"max_pages\":null,\"min_text_chars\":40,\"model\":null,\"package\":\"mirrorneuron-llm-ocr-skill\",\"preload\":false,\"purpose\":\"shared local LightOnOCR-2-1B OCR for scanned or low-text PDF startup packets\",\"quantization\":null,\"remove_policy\":\"manual\",\"require_hardware_acceleration\":true,\"required\":true,\"skill\":\"llm_ocr_skill\",\"timeout_seconds\":180},\"w3m_browser\":{\"docker_worker_requirements\":\"document_workflow/requirements.txt\",\"enabled\":true,\"import\":\"mn_w3m_browser_skill\",\"install_policy\":\"docker_worker_image\",\"max_chars\":12000,\"max_queries\":8,\"max_sources_per_company\":8,\"package\":\"mirrorneuron-w3m-browser-skill\",\"purpose\":\"primary lightweight text-browser research for startup verification, Crunchbase search snippets, competitors, and public market context\",\"required\":false,\"runner\":\"w3m\",\"runtime\":{\"docker_worker_image\":\"document_workflow/docker_worker\",\"driver\":\"docker_worker\",\"image\":\"mirror-neuron/vc-assistant:local\",\"install_scope\":\"shared_job_container\",\"network\":\"mirror-neuron-runtime\",\"node_scope\":\"vc_python_executor_nodes\"},\"skill\":\"w3m_browser_skill\",\"timeout_seconds\":20,\"use_model_compression\":true},\"web_browser\":{\"activation\":\"set internet_research.rendered_browser.enabled=true for rendered public-page verification\",\"enabled\":true,\"import\":\"mn_web_browser_skill\",\"install_policy\":\"python_environment_pip\",\"max_chars\":12000,\"max_pages_per_company\":2,\"no_captcha_solving\":true,\"no_proxy_rotation\":true,\"package\":\"mirrorneuron-web-browser-skill\",\"per_host_delay_seconds\":1,\"purpose\":\"optional rendered-page fallback for JavaScript-heavy public sources such as Crunchbase pages; records blocked/login/robots states instead of bypassing them\",\"python_environment\":\"document_workflow/requirements.txt\",\"required\":false,\"respect_robots\":true,\"runner\":\"playwright\",\"skill\":\"web_browser_skill\",\"stop_on_blocked\":true,\"timeout_seconds\":30}},\"inputs\":{\"adapter\":\"mock\",\"description\":\"Default demo inputs use bundled synthetic startup packets with one first-level folder per company.\",\"payload\":{\"document_folder\":\"vc_assistant/examples/sample_inputs\",\"field_profile\":[\"company_name\",\"founder_team\",\"market\",\"product\",\"traction\",\"strategic_relationships\",\"risks\",\"comparables\",\"cost_to_duplicate\"],\"grouping\":{\"infer_loose_files\":true,\"mode\":\"folder_first\"},\"input_folder\":\"vc_assistant/examples/sample_inputs\",\"monitoring\":{\"enabled\":true,\"max_cycles\":1,\"poll_interval_seconds\":60},\"output_folder\":\"~/Downloads/vc_assistant\",\"public_dataset\":{\"availability_note\":\"Bundled sample startup documents are synthetic and intended only for local blueprint validation.\",\"expected_files\":[\"*.pdf\",\"*.txt\",\"*.md\",\"*.json\",\"*.csv\"],\"license\":\"Synthetic demo data\",\"name\":\"Synthetic startup packet samples\",\"provider\":\"OtterDesk blueprint fixtures\"}}},\"interfaces\":{\"channels\":{\"artifacts\":{\"artifacts\":[\"run.json\",\"config.json\",\"inputs.json\",\"events.jsonl\",\"result.json\",\"final_artifact.json\",\"action_ledger.json\",\"artifact_quality.json\",\"run_health.json\"],\"description\":\"Stable run-store files plus per-company startup analysis outputs.\",\"optional_artifacts\":[\"job.json\",\"web_ui.json\",\"ui.json\",\"web/index.html\",\"logs.jsonl\",\"llm_rag_trace.jsonl\",\"human.jsonl\",\"resources.jsonl\",\"company_index.md\",\"*/analysis.md\",\"*/research_plan.json\",\"*/agent_tool_trace.json\"]},\"events\":{\"artifact\":\"events.jsonl\",\"description\":\"Append-only workflow events.\"},\"human\":{\"artifact\":\"human.jsonl\",\"description\":\"Human notices, approval requests, responses, timeouts, and applied decisions.\"},\"input_skills\":{\"description\":\"Local filesystem startup packet intake, required shared llm_ocr_skill PDF OCR, and optional public browser research.\"},\"inputs\":{\"artifact\":\"inputs.json\",\"description\":\"Resolved startup document folder, monitoring settings, and field profile.\"},\"logs\":{\"artifact\":\"logs.jsonl\",\"description\":\"Runtime stdout/stderr and redacted startup-analysis logs.\",\"stream\":\"stdout/stderr\"},\"observability\":{\"artifact\":\"llm_rag_trace.jsonl\",\"description\":\"Metadata-only LLM, RAG, OCR, tool, and artifact timing trace for diagnosing slow VC runs.\"},\"outputs\":{\"artifacts\":[\"result.json\",\"final_artifact.json\",\"action_ledger.json\",\"artifact_quality.json\",\"run_health.json\",\"company_index.json\",\"company_index.md\",\"*/analysis.json\",\"*/analysis.md\",\"*/research_plan.json\",\"*/agent_tool_trace.json\"],\"description\":\"Score-only VC heuristic reports and structured company index.\"},\"resources\":{\"artifact\":\"resources.jsonl\",\"description\":\"Resource samples such as token, runtime, connector, and disk usage.\"},\"web_ui\":{\"artifacts\":[\"web_ui.json\",\"ui.json\",\"web/index.html\"],\"description\":\"Optional review dashboard for artifact inspection.\"}},\"config\":[\"standard_version\",\"identity\",\"mode\",\"metadata\",\"inputs\",\"simulation\",\"llm\",\"outputs\",\"logging\",\"resources\",\"human_control\",\"real_adapters\",\"streams\",\"python_dependencies\",\"skill_runtime\",\"input_skills\",\"output_skills\",\"error_handling\",\"state\",\"capabilities\",\"privacy\",\"triggers\",\"cache_policy\",\"execution\",\"research_budget\",\"financial_tools\",\"backpressure\",\"scoring\",\"determinism\",\"schemas\",\"budgets\",\"agent_handoffs\",\"web_ui\",\"interfaces\",\"execution_model\",\"memory_layer\",\"dataset_input\",\"document_automation\",\"agentic_research\",\"actor_review\",\"knowledge_rag\",\"suggested_schedule\"],\"config_sections\":[\"standard_version\",\"identity\",\"mode\",\"metadata\",\"inputs\",\"simulation\",\"llm\",\"outputs\",\"logging\",\"resources\",\"human_control\",\"real_adapters\",\"streams\",\"python_dependencies\",\"skill_runtime\",\"input_skills\",\"output_skills\",\"error_handling\",\"state\",\"capabilities\",\"privacy\",\"triggers\",\"cache_policy\",\"execution\",\"research_budget\",\"financial_tools\",\"backpressure\",\"scoring\",\"determinism\",\"schemas\",\"budgets\",\"agent_handoffs\",\"web_ui\",\"interfaces\",\"execution_model\",\"memory_layer\",\"dataset_input\",\"document_automation\",\"agentic_research\",\"actor_review\",\"knowledge_rag\",\"suggested_schedule\"],\"identity\":[\"blueprint_id\",\"name\",\"run_id\"],\"identity_fields\":[\"blueprint_id\",\"name\",\"run_id\"],\"input_adapters\":[\"mock\",\"json\",\"file\",\"env_json\"],\"optional_outputs\":[\"job.json\",\"web_ui.json\",\"ui.json\",\"web/index.html\",\"logs.jsonl\",\"llm_rag_trace.jsonl\",\"human.jsonl\",\"resources.jsonl\",\"company_index.md\",\"*/analysis.md\",\"*/research_plan.json\",\"*/agent_tool_trace.json\"],\"optional_run_artifacts\":[\"job.json\",\"web_ui.json\",\"ui.json\",\"web/index.html\",\"logs.jsonl\",\"llm_rag_trace.jsonl\",\"human.jsonl\",\"resources.jsonl\",\"company_index.md\",\"*/analysis.md\",\"*/research_plan.json\",\"*/agent_tool_trace.json\"],\"output_adapters\":[\"local_run_store\"],\"outputs\":[\"run.json\",\"config.json\",\"inputs.json\",\"events.jsonl\",\"result.json\",\"final_artifact.json\",\"action_ledger.json\",\"artifact_quality.json\",\"run_health.json\"],\"response_schema\":\"mn.blueprint.response.v1\",\"run_artifacts\":[\"run.json\",\"config.json\",\"inputs.json\",\"events.jsonl\",\"result.json\",\"final_artifact.json\",\"action_ledger.json\",\"artifact_quality.json\",\"run_health.json\"],\"web_ui_adapters\":[\"none\",\"static_html\",\"gradio\",\"custom\"]},\"internet_research\":{\"blocked_inputs\":[\"raw_document_text\",\"confidential_pitch_deck_excerpts\",\"customer_names\",\"private_financials\",\"founder_contact_details\"],\"browser_skill\":\"w3m_browser_skill\",\"default_source_urls\":[\"https://www.sba.gov/business-guide/plan-your-business/market-research-competitive-analysis\",\"https://www.sec.gov/education/smallbusiness\",\"https://www.bls.gov/\"],\"enabled\":true,\"max_chars\":12000,\"max_queries\":10,\"max_sources_per_company\":10,\"max_stage_workers\":1,\"max_target_urls_per_company\":6,\"privacy\":\"derive queries from company names, public categories, domains, and public claims only\",\"python_http_fallback\":{\"enabled\":true,\"max_chars\":6000,\"max_search_results\":2,\"purpose\":\"Bounded stdlib HTTP fallback for public search/result pages when the optional w3m binary is unavailable in the worker image.\",\"timeout_seconds\":5,\"user_agent\":\"MirrorNeuron-VC-Assistant/1.0 (+public research fallback)\"},\"rendered_browser\":{\"enabled\":true,\"max_chars\":12000,\"max_pages_per_company\":3,\"no_captcha_solving\":true,\"no_proxy_rotation\":true,\"per_host_delay_seconds\":1,\"purpose\":\"Optional Playwright fallback for JavaScript-rendered public pages such as Crunchbase profiles when w3m cannot extract useful text.\",\"respect_robots\":true,\"stop_on_blocked\":true,\"timeout_seconds\":30},\"rendered_browser_skill\":\"web_browser_skill\",\"research_targets\":[\"company_website\",\"crunchbase_profile\",\"founder_public_profiles\",\"funding_and_investor_mentions\",\"news_and_press\",\"market_size_sources\",\"competitors_and_comparables\",\"SEC_or_public_company_context_when_relevant\"],\"source_url_templates\":[\"https://www.crunchbase.com/organization/{company_slug}\",\"https://www.linkedin.com/company/{company_slug}\",\"https://www.sec.gov/edgar/search/\"],\"timeout_seconds\":20,\"use_model_compression\":true,\"verification_domains\":[\"crunchbase.com\",\"linkedin.com/company\",\"sec.gov\",\"company_website\",\"news_and_press\"],\"verification_fields\":[\"company_profile\",\"founders\",\"funding\",\"category\",\"competitors\",\"traction_claims\",\"source_conflicts\"]},\"knowledge_rag\":{\"chunk_overlap\":80,\"chunk_size\":800,\"embedding_api_base\":\"http://host.docker.internal:12434/engines/v1\",\"embedding_document_prefix\":\"Document: \",\"embedding_healthcheck_enabled\":true,\"embedding_model\":\"rag-embedding\",\"embedding_provider\":\"docker_model_runner\",\"embedding_query_prefix\":\"Query: \",\"embedding_start_command\":\"\",\"enabled\":true,\"index_on_startup\":true,\"max_context_chars\":6000,\"namespace\":\"\",\"redis_url\":\"\",\"required\":true,\"top_k\":5,\"vector_dim\":1024},\"llm\":{\"agents\":{\"batch_index_writer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Write batch indexes.\",\"Write coverage summaries.\",\"Keep output report-only.\"],\"role\":\"Batch Index Writer\"},\"berkus_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Score five Berkus buckets.\",\"Use deterministic formulas.\",\"Record assumptions.\"],\"role\":\"Berkus Scorer\"},\"claim_normalizer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Build fact tables.\",\"Normalize numeric evidence.\",\"Separate local and public facts.\"],\"role\":\"Claim Normalizer\"},\"company_identity_researcher\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Research company identity.\",\"Check Crunchbase/profile targets.\",\"Record blocked outcomes.\"],\"role\":\"Company Identity Researcher\"},\"company_packet_grouper\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Group files by company.\",\"Resolve stable company ids.\",\"Preserve source refs.\"],\"role\":\"Company Packet Grouper\"},\"company_report_writer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Write per-company folders.\",\"Preserve method sections.\",\"Write warnings and evidence files.\"],\"role\":\"Company Report Writer\"},\"comparables_market_multiple_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Use comparable evidence.\",\"Record market multiple assumptions.\",\"Mark insufficient evidence.\"],\"role\":\"Comparables Market Multiple Scorer\"},\"cost_to_duplicate_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Estimate rebuild-cost floor.\",\"Use asset evidence.\",\"Flag missing asset details.\"],\"role\":\"Cost To Duplicate Scorer\"},\"document_evidence_extractor\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Extract local evidence.\",\"Capture structured claims.\",\"Mark unreadable files.\"],\"role\":\"Document Evidence Extractor\"},\"first_chicago_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Build bear/base/bull cases.\",\"Apply probabilities.\",\"Record scenario warnings.\"],\"role\":\"First Chicago Scorer\"},\"funding_researcher\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Research funding mentions.\",\"Check investor and accelerator signals.\",\"Record source quality.\"],\"role\":\"Funding Researcher\"},\"market_comp_researcher\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Research market context.\",\"Find comparable candidates.\",\"Capture source references.\"],\"role\":\"Market And Comparable Researcher\"},\"rendered_page_researcher\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Use rendered browser when enabled.\",\"Respect robots and blocked pages.\",\"Record JS-heavy page status.\"],\"role\":\"Rendered Page Researcher\"},\"research_planner\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Create safe queries.\",\"Avoid confidential excerpts.\",\"Plan profile and market lookups.\"],\"role\":\"Research Planner\"},\"research_reconciler\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Merge local and public evidence.\",\"Flag confirmations.\",\"Flag conflicts and missing evidence.\"],\"role\":\"Research Reconciler\"},\"risk_factor_summation_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Run 12-risk checklist.\",\"Record adjustments.\",\"Mark missing risk evidence.\"],\"role\":\"Risk Factor Summation Scorer\"},\"score_consistency_auditor\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Check score math.\",\"Check missing-evidence handling.\",\"Flag unsupported assumptions.\"],\"role\":\"Score Consistency Auditor\"},\"scorecard_bill_payne_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Apply weighted factors.\",\"Record inputs used.\",\"Keep scores report-only.\"],\"role\":\"Scorecard Bill Payne Scorer\"},\"startup_folder_watcher\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Detect changed files.\",\"Build company fingerprints.\",\"Identify unchanged company packets.\"],\"role\":\"Startup Folder Watcher\"},\"traction_verifier\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Verify customer and launch claims.\",\"Check public traction signals.\",\"Flag missing evidence.\"],\"role\":\"Traction Verifier\"},\"venture_capital_method_scorer\":{\"llm_config\":\"primary\",\"responsibilities\":[\"Run exit-back math.\",\"Record assumptions.\",\"Avoid valuation recommendations.\"],\"role\":\"Venture Capital Method Scorer\"}},\"backend\":\"llama.cpp\",\"configs\":{\"primary\":{\"api_base\":\"auto\",\"backend\":\"llama.cpp\",\"context_size\":8192,\"fallback_model\":\"small\",\"max_tokens\":1200,\"mock_mode\":\"fake\",\"mode\":\"live\",\"model\":\"medium\",\"num_retries\":1,\"parameter_count_b\":31.58,\"provider\":\"docker_model_runner\",\"quantization\":\"MOSTLY_Q4_K_M\",\"runtime_model\":\"medium\",\"timeout_seconds\":60}},\"context_size\":8192,\"default_config\":\"primary\",\"enabled\":true,\"fallback_model\":\"small\",\"live_model_profile\":{\"backend\":\"llama.cpp\",\"context_size\":8192,\"fallback_model\":\"small\",\"hardware\":{\"gpu\":{\"memory_operator\":\">=\",\"min_count\":1,\"min_memory_mb\":49152}},\"model\":\"medium\",\"parameter_count_b\":31.58,\"provider\":\"docker_model_runner\",\"quantization\":\"MOSTLY_Q4_K_M\",\"runtime_model\":\"medium\"},\"mock_mode\":\"fake\",\"mode\":\"live\",\"model\":\"medium\",\"parameter_count_b\":31.58,\"prefer_shared_skill\":true,\"provider\":\"docker_model_runner\",\"quantization\":\"MOSTLY_Q4_K_M\",\"quick_test_uses_fake\":true,\"require_live\":true,\"responsibilities\":[\"Keep VC outputs report-only and source-grounded.\",\"Use specialist agents for research, scoring, audit, and report writing.\",\"Avoid automated investment decisions or confidential-data web disclosure.\"],\"runtime_model\":\"medium\",\"strict_json\":true},\"local_inputs\":{\"folders\":[{\"allowed_extensions\":[\".pdf\",\".txt\",\".md\",\".json\",\".csv\"],\"config_path\":\"document_sources.folder_path\",\"default_config_value\":\"vc_assistant/examples/sample_inputs\",\"linked_config_paths\":[\"inputs.payload.document_folder\",\"inputs.payload.input_folder\",\"state.document_folder\",\"state.input_folder\"],\"payload_path\":\"document_workflow/mn_local_inputs/vc_documents\",\"runtime_path\":\"mn_local_inputs/vc_documents\",\"source_path\":\"examples/sample_inputs\"}]},\"logging\":{\"events\":[\"blueprint_status\",\"blueprint_phase_started\",\"blueprint_phase_completed\",\"blueprint_phase_failed\",\"artifact_written\",\"human_notice\",\"human_input_requested\",\"human_input_received\",\"human_input_timeout\",\"human_decision_applied\",\"output_skill_started\",\"output_skill_completed\",\"output_skill_failed\",\"tool_call_started\",\"tool_call_completed\",\"tool_call_failed\",\"startup_folder_watcher_completed\",\"company_packet_grouper_completed\",\"document_evidence_extractor_completed\",\"claim_normalizer_completed\",\"research_planner_completed\",\"company_identity_researcher_completed\",\"funding_researcher_completed\",\"market_comp_researcher_completed\",\"traction_verifier_completed\",\"rendered_page_researcher_completed\",\"research_reconciler_completed\",\"berkus_scorer_completed\",\"scorecard_bill_payne_scorer_completed\",\"risk_factor_summation_scorer_completed\",\"venture_capital_method_scorer_completed\",\"first_chicago_scorer_completed\",\"comparables_market_multiple_scorer_completed\",\"cost_to_duplicate_scorer_completed\",\"score_consistency_auditor_completed\",\"company_report_writer_completed\",\"batch_index_writer_completed\",\"watch_cycle_started\",\"watch_cycle_completed\"],\"events_jsonl\":true,\"level\":\"info\",\"logs_jsonl\":true,\"redact_env_secrets\":true,\"redact_fields\":[\"api_key\",\"token\",\"authorization\",\"cookie\",\"password\",\"private_key\",\"customer_name\",\"email\",\"phone\"],\"resources_jsonl\":true,\"stderr_jsonl\":true},\"memory_layer\":{\"collection\":\"mn_memory\",\"containers\":\"optional_sidecar\",\"context_addr_env\":\"MN_CONTEXT_ADDR\",\"conversation\":{\"agent_role\":\"otterdesk_chat\",\"include_human_events\":true,\"include_runtime_events\":true,\"include_runtime_logs\":true,\"target_tokens\":2400,\"token_budget\":6000,\"use_model_compression\":true},\"conversation_enabled\":true,\"conversation_enabled_env\":\"OTTERDESK_CONTEXT_MEMORY_ENABLED\",\"default_context_addr\":\"localhost:50052\",\"enabled\":true,\"enabled_env\":\"MN_CONTEXT_MEMORY_ENABLED\",\"namespace\":\"vc_assistant_context\",\"project_path\":\"${MN_MEMBRANE_PROJECT_PATH}\",\"python_sdk_path\":\"${MN_MEMBRANE_SDK_PATH}\",\"sdk_distribution\":\"mirrorneuron-membrane-python-sdk\",\"sdk_import_package\":\"mn_context_engine_sdk\"},\"metadata\":{\"category\":\"Finance\",\"description\":\"A VC analysis co-worker for early startup screening reports. Put pitch decks, memos, financial snippets, company folders, or other startup documents in the input folder; it groups documents by company, performs privacy-safe public research, applies seven VC heuristic scoring methods, audits the math and evidence, and writes score-only per-company reports and batch indexes to the output folder.\"},\"mode\":\"document_automation_review\",\"monitoring\":{\"enabled\":true,\"max_cycles\":1,\"poll_interval_seconds\":60,\"processed_state_file\":\"watch_state.json\"},\"output_skills\":{},\"outputs\":{\"folder_path\":\"~/Downloads/vc_assistant\",\"per_company_subfolders\":true,\"write_markdown_report\":true,\"write_run_store\":true},\"privacy\":{\"default_classification\":\"confidential\",\"rules\":{\"confidential\":{\"log\":\"redacted\",\"send_to_llm\":\"allowed_configs_only\",\"send_to_output_skills\":\"approved_destinations_only\"},\"internal\":{\"log\":\"metadata_only\",\"send_to_llm\":true,\"send_to_output_skills\":true},\"public\":{\"log\":true,\"send_to_llm\":true,\"send_to_output_skills\":true},\"regulated\":{\"log\":\"redacted\",\"send_to_llm\":\"allowed_configs_only\",\"send_to_output_skills\":\"approved_destinations_only\"}}},\"python_dependencies\":{\"extra_index_url\":\"https://pypi.org/simple\",\"index_url\":\"https://us-central1-python.pkg.dev/mirrorneuron-public-packages/agent-skills/simple/\",\"installer\":\"pip\",\"packages\":[\"mirrorneuron-blueprint-support-skill\",\"mirrorneuron-membrane-python-sdk\",\"mirrorneuron-llm-ocr-skill\",\"mirrorneuron-rag-skill\",\"mirrorneuron-w3m-browser-skill\",\"mirrorneuron-web-browser-skill\"],\"requirements\":\"document_workflow/requirements.txt\"},\"real_adapters\":{\"filesystem\":{\"enabled\":true,\"read\":true,\"write\":true}},\"research_budget\":{\"chargeable_actions\":[\"llm_call\",\"browser_search\",\"browser_page\",\"rendered_browser_page\",\"financial_tool\"],\"default_actions\":160,\"exhaustion_mode\":\"finish_with_budget_exhausted_warnings\"},\"resources\":{\"cpu\":{\"min_cores\":1},\"disk\":{\"min_gb\":1},\"gpu\":{\"enforcement\":\"hard\",\"memory_operator\":\">=\",\"min_count\":1,\"min_memory_mb\":49152},\"memory\":{\"min_gb\":2}},\"schemas\":{\"artifact_record\":\"mn.artifact.record.v1\",\"config\":\"mn.blueprint.config.v1\",\"events\":\"mn.blueprint.events.v1\",\"final_artifact\":\"mn.blueprint.final_artifact.v1\",\"human_control\":\"mn.blueprint.human_control.v1\",\"input_skills\":\"mn.blueprint.input_skills.v1\",\"inputs\":\"mn.blueprint.inputs.v1\",\"logs\":\"mn.blueprint.logs.v1\",\"output_skills\":\"mn.blueprint.output_skills.v1\",\"resources\":\"mn.blueprint.resources.v1\",\"status_contract\":\"mn.blueprint.status_contract.v1\",\"web_ui\":\"mn.blueprint.web_ui.v1\"},\"scoring\":{\"deterministic_method_order\":true,\"max_workers\":7},\"simulation\":{\"enabled\":false},\"skill_runtime\":{\"auto_patch\":false,\"docker_worker_image\":\"document_workflow/docker_worker\",\"driver\":\"docker_worker\",\"enabled\":true,\"image\":\"mirror-neuron/vc-assistant:local\",\"install_scope\":\"shared_job_container\",\"network\":\"mirror-neuron-runtime\",\"node_scope\":\"vc_python_executor_nodes\"},\"standard_version\":\"mn.blueprint.config.v1\",\"state\":{\"document_folder\":\"vc_assistant/examples/sample_inputs\",\"final_report\":{},\"input_folder\":\"vc_assistant/examples/sample_inputs\",\"monitor_state\":{},\"output_folder\":\"~/Downloads/vc_assistant\"},\"streams\":{\"enabled\":false},\"suggested_schedule\":{\"advisory_only\":true,\"cadence\":\"daily\",\"cron\":\"0 7 * * *\",\"note\":\"Suggested cadence only; runtime decides the actual schedule.\"},\"triggers\":{\"schedule\":null,\"sources\":[\"vc_startup_document_folder\"],\"type\":\"folder_watch\"},\"web_ui\":{\"dashboard\":{\"data_source\":\"local_run_store\",\"panels\":[\"current_status\",\"recent_events\",\"pending_human_requests\",\"output_artifacts\",\"resource_usage\",\"errors\",\"llm_calls\",\"token_budget\",\"llm_retries\"],\"reads\":[\"events.jsonl\",\"human.jsonl\",\"logs.jsonl\",\"resources.jsonl\",\"result.json\",\"final_artifact.json\",\"web_ui.json\"],\"standard_panels\":[\"current_status\",\"recent_events\",\"pending_human_requests\",\"output_artifacts\",\"resource_usage\",\"errors\",\"llm_calls\",\"token_budget\",\"llm_retries\"]},\"enabled\":true,\"input\":{\"adapter\":\"none\",\"custom_url\":null,\"fields\":[],\"host\":\"127.0.0.1\",\"instructions\":null,\"port\":null,\"share\":false,\"title\":null},\"output\":{\"adapter\":\"gradio\",\"auto_generate\":true,\"custom_url\":null,\"refresh_seco