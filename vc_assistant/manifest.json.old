        "memory": {
            "collection": "mn_memory",
            "containers": "optional_sidecar",
            "context_addr_env": "MN_CONTEXT_ADDR",
            "conversation": {
                "agent_role": "otterdesk_chat",
                "include_human_events": true,
                "include_runtime_events": true,
                "include_runtime_logs": true,
                "target_tokens": 2400,
                "token_budget": 6000,
                "use_model_compression": true
            },
            "conversation_enabled": true,
            "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
            "default_context_addr": "localhost:50052",
            "enabled": true,
            "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
            "namespace": "vc_assistant_context",
            "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
            "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
            "sdk_distribution": "mirrorneuron-membrane-python-sdk",
            "sdk_import_package": "mn_context_engine_sdk"
        },
        "models": {
            "primary": {
                "provider": "docker_model_runner",
                "model": "small",
                "runtime_model": "small",
                "fallback_model": "small",
                "required": true,
                "type": "llm",
                "backend": "llama.cpp",
                "api_base": "auto"
            },
            "large": {
                "provider": "docker_model_runner",
                "model": "medium",
                "runtime_model": "medium",
                "backend": "llama.cpp",
                "context_size": 8192,
                "quantization": "MOSTLY_Q4_K_M",
                "parameter_count_b": 31.58,
                "hardware": {
                    "gpu": {
                        "min_count": 1,
                        "min_memory_mb": 49152,
                        "memory_operator": ">="
                    }
                },
                "required": false,
                "type": "llm"
            }
        },
        "observability": {
            "panels": [
                "current_status",
                "recent_events",
                "pending_human_requests",
                "output_artifacts",
                "resource_usage",
                "errors",
                "llm_calls",
                "token_budget",
                "llm_retries"
            ],
            "reads": [
                "events.jsonl",
                "human.jsonl",
                "logs.jsonl",
                "resources.jsonl",
                "result.json",
                "final_artifact.json",
                "web_ui.json"
            ],
            "schema_version": "mn.blueprint.observability_dashboard.v1",
            "source": "local_run_store"
        },
        "resources": {
            "cpu": {
                "min_cores": 1
            },
            "memory": {
                "min_gb": 2
            },
            "disk": {
                "min_gb": 1
            },
            "gpu": {
                "min_count": 0
            }
        },
        "store": {
            "artifacts": [
                "run.json",
                "config.json",
                "inputs.json",
                "events.jsonl",
                "human.jsonl",
                "logs.jsonl",
                "resources.jsonl",
                "result.json",
                "final_artifact.json"
            ],
            "path": "./runs/${run_id}",
            "type": "local_run_store"
        },
        "worker_defaults": {
            "model": "small",
            "pool": "default",
            "pool_slots": 1,
            "runner": "MirrorNeuron.Runner.HostLocal",
            "uses": "mn-agents.data_python_executor@1",
            "workdir": "/sandbox/job/document_workflow"
        },
        "workflow_control": {
            "attempts": {
                "dispatch_metadata": [
                    "workflow_run_id",
                    "step_id",
                    "attempt_id",
                    "attempt",
                    "deadline_at",
                    "heartbeat_deadline_at",
                    "idempotency_key"
                ],
                "retry_policy_source": "workflow.steps[].control.retry",
                "stale_attempt_outputs": "ignore",
                "timeout_source": "workflow.steps[].control.timeout_seconds"
            },
            "enabled": true,
            "events": [
                "workflow_step_attempt_started",
                "workflow_step_beacon",
                "workflow_step_attempt_completed",
                "workflow_step_attempt_timed_out",
                "workflow_step_attempt_retry_scheduled",
                "workflow_step_blocked",
                "workflow_step_completed",
                "workflow_step_failed",
                "workflow_message_dead_lettered"
            ],
            "liveness": {
                "event": "agent_beacon",
                "interval_ms": 15000,
                "missed_action": "fail_attempt",
                "required": true,
                "timeout_ms": 45000
            },
            "pause_cancel": {
                "cancel_mode": "terminate_active_attempts",
                "pause_mode": "stop_active_attempts",
                "resume_mode": "reconcile_from_workflow_state"
            },
            "reconciliation": {
                "interval_ms": 2000,
                "on_missed_beacon": "fail_attempt_then_retry",
                "on_retry_exhausted": "apply_step_failure_policy",
                "on_timeout": "fail_attempt_then_retry"
            },
            "schema_version": "mn.workflow.runtime_control.v1",
            "source_of_truth": "workflow.steps",
            "state_ledger": {
                "delivery_semantics": "at_least_once_with_idempotency",
                "enabled": true,
                "message_ledger": true,
                "persisted_field": "workflow_state",
                "step_statuses": [
                    "pending",
                    "ready",
                    "queued",
                    "running",
                    "retry_wait",
                    "blocked",
                    "completed",
                    "partial",
                    "skipped",
                    "failed"
                ]
            }
        }
    },
