    "name": "VC Assistant",
    "requirements": {
        "cpu": {
            "min_cores": 1
        },
        "memory": {
            "min_gb": 2
        },
        "disk": {
            "min_gb": 1
        },
        "gpu": {
            "min_count": 0
        }
    },
    "runtime": {
        "bindings": {
            "batch_index_writer": {
                "risk": "medium",
                "side_effect": "internal_write",
                "strategy": "single",
                "type": "worker",
                "workers": [
                    {
                        "alias": "batch_index_writer",
                        "id": "batch_index_writer",
                        "kind": "worker",
                        "model": "small",
                        "required": true,
                        "role": "Batch Index Writer",
                        "tools": 4
                    }
                ]
            },
            "berkus_scorer": {
                "risk": "low",
                "side_effect": "read",
                "strategy": "single",
                "type": "worker",
                "workers": [
                    {
                        "alias": "berkus_scorer",
                        "id": "berkus_scorer",
                        "kind": "worker",
