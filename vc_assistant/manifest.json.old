,\"description\":\"Append-only workflow events.\"},\"human\":{\"artifact\":\"human.jsonl\",\"description\":\"Human notices, approval requests, responses, timeouts, and applied decisions.\"},\"input_skills\":{\"description\":\"Local filesystem startup packet intake, required shared llm_ocr_skill PDF OCR, and optional public browser research.\"},\"inputs\":{\"artifact\":\"inputs.json\",\"description\":\"Resolved startup document folder, monitoring settings, and field profile.\"},\"logs\":{\"artifact\":\"logs.jsonl\",\"description\":\"Runtime stdout/stderr and redacted startup-analysis logs.\",\"stream\":\"stdout/stderr\"},\"observability\":{\"artifact\":\"llm_rag_trace.jsonl\",\"description\":\"Metadata-only LLM, RAG, OCR, tool, and artifact timing trace for diagnosing slow VC runs.\"},\"outputs\":{\"artifacts\":[\"result.json\",\"final_artifact.json\",\"action_ledger.json\",\"artifact_quality.json\",\"run_health.json\",\"company_index.json\",\"company_index.md\",\"*/analysis.json\",\"*/analysis.md\",\"*/research_plan.json\",\"*/agent_tool_trace.json\"],\"description\":\"Score-only VC heuristic reports and structured company index.\"},\"resources\":{\"artifact\":\"resources.jsonl\",\"description\":\"Resource samples such as token, runtime, connector, and disk usage.\"},\"web_ui\":{\"artifacts\":[\"web_ui.json\",\"ui.json\",\"web/index.html\"],\"description\":\"Optional review dashboard for artifact inspection.\"}},\"config\":[\"standard_version\",\"identity\",\"mode\",\"metadata\",\"inputs\",\"simulation\",\"llm\",\"outputs\",\"logging\",\"resources\",\"human_control\",\"real_adapters\",\"streams\",\"python_dependencies\",\"skill_runtime\",\"input_skills\",\"output_skills\",\"error_handling\",\"state\",\"capabilities\",\"privacy\",\"triggers\",\"cache_policy\",\"execution\",\"research_budget\",\"financial_tools\",\"backpressure\",\"scoring\",\"determinism\",\"schemas\",\"budgets\",\"agent_handoffs\",\"web_ui\",\"interfaces\",\"execution_model\",\"memory_layer\",\"data