{
  "daemon": false,
  "description": "Rank property acquisition opportunities with working memory over noisy ZIP-code history, broker flow, financing constraints, and prior decision outcomes.",
  "edges": [
    {
      "edge_id": "simulation_to_report",
      "from_node": "simulation_loop",
      "message_type": "blueprint_report",
      "to_node": "report_sink"
    }
  ],
  "entrypoints": [
    "simulation_loop"
  ],
  "graph_id": "finance_zip_code_property_alpha_engine_with_memory_v1",
  "initial_inputs": {
    "simulation_loop": [
      {
        "all_context_attention_limit": 36,
        "all_context_token_budget": 8000,
        "history_months": 24,
        "max_price": 950000,
        "memory_limit": 36,
        "memory_mode": "compare",
        "noise_events_per_month": 10,
        "seed": 77,
        "steps": 6,
        "target_zip": "02139"
      }
    ]
  },
  "job_name": "finance-zip-code-property-alpha-engine-with-memory",
  "manifest_version": "1.0",
  "metadata": {
    "blueprint_id": "finance_zip_code_property_alpha_engine_with_memory",
    "category": "finance",
    "customizable_for": "Rental acquisitions, flipping pipelines, multifamily sourcing, market expansion, diligence memory, and capital-allocation committees.",
    "description": "Rank property acquisition opportunities with working memory over noisy ZIP-code history, broker flow, financing constraints, and prior decision outcomes.",
    "interfaces": {
      "config": [
        "metadata",
        "identity",
        "inputs",
        "simulation",
        "memory",
        "benchmark",
        "llm",
        "outputs",
        "logging",
        "real_adapters"
      ],
      "identity": [
        "blueprint_id",
        "name",
        "run_id"
      ],
      "input_adapters": [
        "mock",
        "json",
        "file",
        "env_json"
      ],
      "output_adapters": [
        "local_run_store"
      ],
      "outputs": [
        "run.json",
        "config.json",
        "inputs.json",
        "events.jsonl",
        "result.json",
        "final_artifact.json"
      ]
    },
    "llm": {
      "default_api_base": "http://192.168.4.173:11434",
      "default_model": "ollama/nemotron3:33b",
      "mock_mode": "run payloads/simulation_loop/scripts/run_blueprint.py --mock-llm"
    },
    "llm_agent_role": "Real estate investment analyst with working memory.",
    "name": "Zip Code Property Alpha Engine With Memory",
    "output": "Ranked opportunities, source-grounded bid/watchlist recommendation, and full-context versus optimized-memory benchmark.",
    "output_contract": {
      "events": "blueprint_report",
      "stdout": "JSON object with timeline, all-context summaries, memory packets, state_changes, benchmark, final_artifact, and llm metadata"
    },
    "problem_solved": "Property acquisition decisions often depend on older broker, lender, rent, insurance, and diligence facts that disappear inside large noisy deal flow.",
    "quick_test": {
      "command": "python3 payloads/simulation_loop/scripts/run_blueprint.py --mock-llm --steps 2",
      "enabled": true
    },
    "runtime_features": [
      "large synthetic finance context",
      "working memory retrieval",
      "source_refs",
      "decision quality benchmark",
      "full-context baseline",
      "optimized memory comparison",
      "LLM investment reasoning"
    ],
    "simulation": {
      "actions": [
        "submit_bid",
        "negotiate_discount",
        "watchlist_only"
      ],
      "agent_role": "Real estate investment analyst with working memory",
      "dynamic_metrics": [
        "median_price_index",
        "demand_index",
        "cap_rate_pct",
        "risk_score",
        "liquidity_score",
        "rent_growth_signal"
      ]
    },
    "simulation_type": "ZIP-code property market simulation with large historical memory.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load metadata -> resolve config -> load inputs -> seed large context -> compile full-history baseline -> retrieve optimized memory -> simulate/decide loop -> benchmark memory lift -> emit events -> write final artifact",
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "file",
        "json",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0"
    },
    "target_user": "Real-estate investors, acquisition analysts, property-tech teams, and diligence operators."
  },
  "name": "Zip Code Property Alpha Engine With Memory",
  "nodes": [
    {
      "agent_type": "executor",
      "config": {
        "command": [
          "python3",
          "scripts/run_blueprint.py"
        ],
        "environment": {
          "LITELLM_API_BASE": "http://192.168.4.173:11434",
          "LITELLM_MAX_TOKENS": "700",
          "LITELLM_MODEL": "ollama/nemotron3:33b",
          "LITELLM_NUM_RETRIES": "1",
          "LITELLM_TIMEOUT_SECONDS": "60",
          "MN_BLUEPRINT_ID": "finance_zip_code_property_alpha_engine_with_memory",
          "MN_LLM_API_BASE": "http://192.168.4.173:11434",
          "MN_LLM_MAX_TOKENS": "700",
          "MN_LLM_MODEL": "ollama/nemotron3:33b",
          "MN_LLM_NUM_RETRIES": "1",
          "MN_LLM_TIMEOUT_SECONDS": "60"
        },
        "from": "base",
        "name_prefix": "finance_real_estate_memory_opportunity_",
        "no_auto_providers": true,
        "no_keep": true,
        "output_message_type": "blueprint_report",
        "pool": "default",
