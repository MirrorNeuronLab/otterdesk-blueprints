{
  "agent_handoffs": {},
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 30,
      "max_concurrent_calls": 2
    },
    "max_concurrency": 4,
    "max_events_per_second": 10,
    "queue_size": 1000
  },
  "benchmark": {
    "baseline": "all_context",
    "enabled": true,
    "quality_metrics": [
      "action_accuracy",
      "property_match",
      "critical_fact_recall",
      "risk_awareness",
      "quality_score_delta",
      "estimated_token_reduction_ratio",
      "budget_violation_rate"
    ],
    "schema_version": "mn.finance.property_alpha.memory_benchmark.v2"
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 20,
    "max_disk_mb": 250,
    "max_llm_calls": 20,
    "max_llm_tokens": 20000,
    "max_runtime_seconds": 600,
    "max_stream_duration_seconds": 3600
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "network.egress",
      "stream.subscribe"
    ],
    "required": [
      "filesystem.write"
    ]
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "evaluate_workflow_state",
    "route_by_context",
    "request_human_input",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact",
    "fan_out_output_skills"
  ],
