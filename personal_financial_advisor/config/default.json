    "identity": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "outputs": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
