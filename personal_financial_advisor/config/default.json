{
  "standard_version": "mn.blueprint.config.v1",
  "identity": {
    "blueprint_id": "personal_financial_advisor",
    "name": "Personal Financial Advisor"
  },
  "mode": "service",
  "metadata": {
    "category": "Finance",
    "description": "Continuously monitors a local personal finance folder, OCRs statements, income documents, receipts, bills, and related records, then writes review-only household finance status, advice, risk reminders, and source-grounded reports."
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default demo inputs start the continuous folder-monitoring service; set monitoring.max_cycles for bounded smoke tests.",
    "payload": {
      "document_folder": "",
      "output_folder": "/Users/homer/Download/personal_financial_advisor",
      "field_profile": [
        "document_kind",
        "institution_or_merchant",
        "account_or_source",
        "document_date",
        "income_amounts",
        "expense_amounts",
        "recurring_items",
        "balances",
        "debt_or_credit_obligations",
        "fees",
        "risk_flags",
        "recommended_actions"
      ],
      "monitoring": {
        "enabled": true,
        "poll_interval_seconds": 60,
        "max_cycles": null
      },
      "public_dataset": {
        "name": "AgamiAI Indian Bank Statement Synthetic Dataset",
        "provider": "AgamiAI on Hugging Face",
        "url": "https://huggingface.co/datasets/AgamiAI/Indian-Bank-Statements",
        "license": "Apache 2.0",
        "availability_note": "Public synthetic bank statement sample used only as one finance-document demo source; real runs can include statements, income docs, receipts, bills, images, text, JSON, and CSV files.",
        "expected_files": [
          "*.pdf",
          "*.png",
          "*.jpg",
          "*.jpeg",
          "*.tif",
          "*.tiff",
          "*.webp",
          "*.txt",
          "*.json",
          "*.csv"
        ],
        "download_hint": "Use the bundled sample files or fetch a small public sample before trying a larger local folder."
      }
    }
  },
  "document_sources": {
    "folder_path": "",
    "expected_files": [
      "*.pdf",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.tif",
      "*.tiff",
      "*.webp",
      "*.txt",
      "*.json",
      "*.csv"
    ],
    "public_dataset_url": "https://huggingface.co/datasets/AgamiAI/Indian-Bank-Statements"
  },
  "dataset_input": {
    "name": "AgamiAI Indian Bank Statement Synthetic Dataset",
    "provider": "AgamiAI on Hugging Face",
    "url": "https://huggingface.co/datasets/AgamiAI/Indian-Bank-Statements",
    "license": "Apache 2.0",
    "availability_note": "Public synthetic bank statement sample used only as one finance-document demo source; real runs can include statements, income docs, receipts, bills, images, text, JSON, and CSV files.",
    "expected_files": [
      "*.pdf",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.tif",
      "*.tiff",
      "*.webp",
      "*.txt",
      "*.json",
      "*.csv"
    ],
    "download_hint": "Use the bundled sample files or fetch a small public sample before trying a larger local folder."
  },
  "document_automation": {
    "fields": [
      "document_kind",
      "institution_or_merchant",
      "account_or_source",
      "document_date",
      "income_amounts",
      "expense_amounts",
      "recurring_items",
      "balances",
      "debt_or_credit_obligations",
      "fees",
      "risk_flags",
      "recommended_actions"
    ],
    "output_type": "personal_financial_advisor_report",
    "review_required": true,
    "recommended_action": "review_household_finance_report_before_any_financial_action"
  },
  "llm": {
    "enabled": true,
    "mode": "live",
    "mock_mode": "fake",
    "model": "default",
    "agent_role": "Actor-style household finance coworker using the default LLM for source-grounded review work.",
    "default_config": "primary",
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "model": "default",
        "api_base": "http://localhost:12434/engines/v1",
        "timeout_seconds": 60,
        "max_tokens": 1200,
        "num_retries": 1
      }
    },
    "agents": {
      "financial_folder_watcher": {
        "llm_config": "primary",
        "model": "default",
        "role": "Financial folder watcher",
        "responsibilities": [
          "review the monitored folder status",
          "identify missing or newly changed document types",
          "explain intake readiness without opening private web channels"
        ]
      },
      "financial_document_reader": {
        "llm_config": "primary",
        "model": "default",
        "role": "Financial document reader",
        "responsibilities": [
          "summarize redacted finance document snippets",
          "separate income, statement, receipt, bill, debt, and tax-document evidence",
          "flag OCR or source-quality review needs"
        ]
      },
      "financial_activity_classifier": {
        "llm_config": "primary",
        "model": "default",
        "role": "Financial activity classifier",
        "responsibilities": [
          "classify source-grounded income, expenses, balances, fees, and obligations",
          "stay within allowed finance-document categories",
          "explain classification uncertainty for human review"
        ]
      },
      "financial_health_assessor": {
        "llm_config": "primary",
        "model": "default",
        "role": "Financial health assessor",
        "responsibilities": [
          "review cash-flow status from structured totals",
          "explain blocker risks and reminders",
          "prepare review questions without making consequential financial decisions"
        ]
      },
      "financial_market_researcher": {
        "llm_config": "primary",
        "model": "default",
        "role": "Financial market researcher",
        "responsibilities": [
          "plan privacy-safe public web searches from generic risk categories",
          "choose public sources from DuckDuckGo search results",
          "summarize source-grounded public guidance without exposing private document text"
        ]
      },
      "financial_advice_reporter": {
        "llm_config": "primary",
        "model": "default",
        "role": "Financial advice reporter",
        "responsibilities": [
          "write the final review-only household finance report",
          "combine document analysis, health assessment, and research findings",
          "preserve source refs and human-approval boundaries"
        ]
      }
    },
    "responsibilities": [
      "keep private document text out of public web searches",
      "ground every recommendation in local evidence or cited public sources",
      "keep outputs review-only and require human approval before action"
    ]
  },
  "outputs": {
    "folder_path": "/Users/homer/Download/personal_financial_advisor",
    "write_run_store": true,
    "write_markdown_report": true
  },
  "logging": {
    "level": "info",
    "events_jsonl": true,
    "logs_jsonl": true,
    "resources_jsonl": true,
    "stderr_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key",
      "ssn",
      "taxpayer_id",
      "account_number",
      "medical_record_number"
    ],
    "events": [
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed",
      "financial_folder_watcher_completed",
      "financial_document_reader_completed",
      "financial_activity_classifier_completed",
      "financial_health_assessor_completed",
      "financial_advice_reporter_completed",
      "watch_cycle_started",
      "watch_cycle_completed",
      "financial_market_researcher_completed"
    ]
  },
  "resources": {
    "cpu": {
      "min_cores": 1
    },
    "memory": {
      "min_gb": 2
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    }
  },
  "human_control": {
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "move_money",
      "pay_bill",
      "place_trade",
      "file_tax_return",
      "sync_to_accounting_system",
      "sync_to_bank_or_brokerage",
      "send_report_without_review",
      "mark_advice_final_without_review"
    ],
    "decision_event": "human_decision_applied",
    "default_action": "reject",
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "approval_required",
    "reason": "Human approval is required before any financial action, external sharing, filing, payment, investment, or system-sync action.",
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "timeout_seconds": 3600
  },
  "input_skills": {
    "llm_ocr": {
      "skill": "llm_ocr_skill",
      "package": "mirrorneuron-llm-ocr-skill",
      "connector": "docker_model_runner",
      "purpose": "shared local LightOnOCR-2-1B OCR for scanned PDFs, images, forms, statements, and bills",
      "enabled": true,
      "required": false,
      "backend": "auto",
      "endpoint": "http://localhost:12434",
      "model": null,
      "quantization": null,
      "min_text_chars": 40,
      "max_pages": null,
      "preload": false,
      "install_policy": "on_first_required_document",
      "remove_policy": "manual",
      "require_hardware_acceleration": true,
      "timeout_seconds": 180
    },
    "w3m_browser": {
      "skill": "w3m_browser_skill",
      "package": "mirrorneuron-w3m-browser-skill",
      "runner": "w3m",
      "purpose": "privacy-safe public web research for source-grounded personal finance advice",
      "enabled": true,
      "required": false,
      "install_policy": "docker_worker_image",
      "timeout_seconds": 12,
      "max_chars": 6000,
      "max_queries": 3,
      "max_sources_per_query": 2,
      "source_urls": [
        "https://consumer.gov/managing-your-money",
        "https://www.consumerfinance.gov/consumer-tools/bank-accounts/",
        "https://www.consumerfinance.gov/consumer-tools/credit-cards/",
        "https://www.consumerfinance.gov/consumer-tools/debt-collection/"
      ],
      "use_model_compression": true
    }
  },
  "output_skills": {},
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "missing_folder": {
        "mode": "use_public_dataset_note"
      },
      "ocr_required": {
        "mode": "continue_with_review_warning"
      },
      "llm_call": {
        "mode": "retry",
        "max_attempts": 3,
        "backoff_seconds": 2
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "privacy": {
    "default_classification": "regulated",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "schemas": {
    "artifact_record": "mn.artifact.record.v1",
    "config": "mn.blueprint.config.v1",
    "events": "mn.blueprint.events.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "human_control": "mn.blueprint.human_control.v1",
    "input_skills": "mn.blueprint.input_skills.v1",
    "inputs": "mn.blueprint.inputs.v1",
    "logs": "mn.blueprint.logs.v1",
    "output_skills": "mn.blueprint.output_skills.v1",
    "resources": "mn.blueprint.resources.v1",
    "status_contract": "mn.blueprint.status_contract.v1",
    "web_ui": "mn.blueprint.web_ui.v1"
  },
  "budgets": {
    "max_runtime_seconds": 900,
    "max_llm_calls": 30,
    "max_llm_tokens": 60000,
    "max_disk_mb": 500,
    "max_connector_reads": 200,
    "max_connector_writes": 0
  },
  "capabilities": {
    "required": [
      "filesystem.read",
      "filesystem.write",
      "pdf.extract"
    ],
    "optional": [
      "document.ocr",
      "llm.ocr",
      "llm.call",
      "pdf.render",
      "image.ocr",
      "csv.read"
    ]
  },
  "determinism": {
    "enabled": true,
    "seed_field": "seed",
    "replay": {
      "from_inputs": "inputs.json",
      "from_events": "events.jsonl",
      "llm_mode": "fake"
    },
    "frozen_clock": null
  },
  "backpressure": {
    "max_concurrency": 4,
    "queue_size": 1000,
    "max_events_per_second": 10,
    "llm": {
      "max_concurrent_calls": 2,
      "max_calls_per_minute": 30
    },
    "drop_policy": "skip_with_error"
  },
  "web_ui": {
    "enabled": true,
    "input": {
      "adapter": "none",
      "fields": [],
      "host": "127.0.0.1",
      "port": null,
      "share": false,
      "title": null,
      "instructions": null,
      "custom_url": null
    },
    "output": {
      "adapter": "gradio",
      "auto_generate": true,
      "refresh_seconds": 2,
      "title": "Personal Financial Advisor",
      "custom_url": null
    },
    "dashboard": {
      "data_source": "local_run_store",
      "reads": [
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json",
        "web_ui.json"
      ],
      "panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ],
      "standard_panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ]
    }
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "description": "Stable run-store files and domain-specific document automation outputs.",
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl",
          "human.jsonl",
          "resources.jsonl",
          "*-review.md"
        ]
      },
      "events": {
        "artifact": "events.jsonl",
        "description": "Append-only workflow events."
      },
      "human": {
        "artifact": "human.jsonl",
        "description": "Human notices, approval requests, responses, timeouts, and applied decisions."
      },
      "input_skills": {
        "description": "Local filesystem intake plus shared llm_ocr_skill OCR through Docker Model Runner."
      },
      "inputs": {
        "artifact": "inputs.json",
        "description": "Resolved finance document folder, continuous monitoring settings, public sample reference, and field review profile."
      },
      "logs": {
        "artifact": "logs.jsonl",
        "description": "Runtime stdout/stderr and redacted document automation logs.",
        "stream": "stdout/stderr"
      },
      "outputs": {
        "artifacts": [
          "result.json",
          "final_artifact.json",
          "*-report.md"
        ],
        "description": "Primary review packet, advisor report, and structured personal finance review results."
      },
      "resources": {
        "artifact": "resources.jsonl",
        "description": "Resource samples such as token, runtime, connector, and disk usage."
      },
      "web_ui": {
        "artifacts": [
          "web_ui.json",
          "ui.json",
          "web/index.html"
        ],
        "description": "Optional review dashboard for artifact inspection."
      }
    },
    "config": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "resources",
      "human_control",
      "real_adapters",
      "streams",
      "input_skills",
      "output_skills",
      "error_handling",
      "state",
      "capabilities",
      "privacy",
      "triggers",
      "backpressure",
      "determinism",
      "schemas",
      "budgets",
      "agent_handoffs",
      "web_ui",
      "interfaces",
      "execution_model",
      "memory_layer",
      "dataset_input",
      "document_automation"
    ],
    "config_sections": [
      "standard_version",
      "identity",
      "mode",
