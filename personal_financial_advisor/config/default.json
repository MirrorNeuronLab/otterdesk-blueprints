    ],
    "optional_outputs": [
      "job.json",
      "web_ui.json",
      "ui.json",
      "web/index.html",
      "logs.jsonl",
      "human.jsonl",
      "resources.jsonl",
      "*-review.md"
    ],
    "optional_run_artifacts": [
      "job.json",
      "web_ui.json",
      "ui.json",
      "web/index.html",
      "logs.jsonl",
      "human.jsonl",
      "resources.jsonl",
      "*-review.md"
    ],
    "response_schema": "mn.blueprint.response.v1",
    "web_ui_adapters": [
      "none",
      "static_html",
      "gradio",
      "custom"
    ]
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "start_folder_monitoring_service",
    "financial_folder_watcher",
    "extract_embedded_text_or_ocr",
    "redact_sensitive_values",
    "financial_activity_classifier",
    "financial_health_assessor",
    "financial_market_researcher",
    "request_human_review",
    "write_final_artifact_each_cycle",
    "write_markdown_report_each_cycle",
    "write_artifact_records",
    "call_actor_llm",
    "write_actor_findings",
    "llm_guided_public_research"
  ],
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": true
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "personal_financial_advisor_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "state": {
    "document_folder": "",
    "output_folder": "/Users/homer/Download/personal_financial_advisor",
    "watch_state": {},
    "final_report": {}
  },
  "triggers": {
    "type": "folder_watch",
    "sources": [
      "personal_financial_advisor_folder"
    ],
    "schedule": null
  },
  "real_adapters": {
    "filesystem": {
      "enabled": true,
      "read": true,
      "write": true
    }
  },
  "streams": {
    "enabled": false
  },
  "simulation": {
    "enabled": false
  },
  "monitoring": {
    "enabled": true,
    "poll_interval_seconds": 60,
    "max_cycles": null,
    "processed_state_file": "watch_state.json"
  },
  "internet_research": {
    "enabled": true,
    "browser_skill": "w3m_browser_skill",
    "privacy": "derive queries from generic risk categories and document types only",
    "default_source_urls": [
      "https://consumer.gov/managing-your-money",
      "https://www.consumerfinance.gov/consumer-tools/bank-accounts/",
      "https://www.consumerfinance.gov/consumer-tools/credit-cards/",
      "https://www.consumerfinance.gov/consumer-tools/debt-collection/"
    ],
    "blocked_inputs": [
      "raw_document_text",
      "account_numbers",
      "customer_names",
      "transaction_descriptions",
      "taxpayer_ids"
    ],
    "max_queries": 3,
    "max_sources_per_query": 2,
    "timeout_seconds": 12,
    "use_model_compression": true
  }
}
