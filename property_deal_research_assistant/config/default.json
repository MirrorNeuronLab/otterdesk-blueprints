{
  "agent_handoffs": {},
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 30,
      "max_concurrent_calls": 2
    },
    "max_concurrency": 4,
    "max_events_per_second": 10,
    "queue_size": 1000
  },
  "benchmark": {
    "baseline": "all_context",
    "enabled": true,
    "quality_metrics": [
      "action_accuracy",
      "property_match",
      "critical_fact_recall",
      "risk_awareness",
      "quality_score_delta",
      "estimated_token_reduction_ratio",
      "budget_violation_rate"
    ],
    "schema_version": "mn.finance.property_alpha.memory_benchmark.v2"
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 20,
    "max_disk_mb": 250,
    "max_llm_calls": 20,
    "max_llm_tokens": 20000,
    "max_runtime_seconds": 600,
    "max_stream_duration_seconds": 3600
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "network.egress",
      "stream.subscribe"
    ],
    "required": [
      "filesystem.write"
    ]
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "evaluate_workflow_state",
    "route_by_context",
    "request_human_input",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact",
    "fan_out_output_skills",
    "emit_status_events",
    "handle_human_control",
    "write_artifact_records"
  ],
  "human_control": {
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "submit_bid",
      "send_loi",
      "negotiate_discount",
      "notify_broker_without_review"
    ],
    "decision_event": "human_decision_applied",
    "default_action": "reject",
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "approval_required",
    "reason": "Human approval is required before high-impact downstream actions such as submit_bid, send_loi, negotiate_discount.",
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "timeout_seconds": 3600
  },
  "identity": {
    "blueprint_id": "property_deal_research_assistant",
    "name": "Property Deal Research Assistant"
  },
  "input_skills": {},
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic large-context inputs bundled with the blueprint.",
    "payload": {
      "all_context_attention_limit": 36,
      "all_context_token_budget": 8000,
      "history_months": 24,
      "max_price": 950000,
      "memory_limit": 36,
      "memory_mode": "compare",
      "noise_events_per_month": 10,
      "seed": 77,
      "steps": 6,
      "target_zip": "02139"
    }
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
        "description": "Stable run-store files and domain-specific outputs.",
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl"
        ]
      },
      "events": {
        "artifact": "events.jsonl",
        "description": "Append-only workflow events."
      },
      "human": {
        "artifact": "human.jsonl",
        "description": "Human notices, approval requests, responses, timeouts, and applied decisions.",
        "mirrored_to": "events.jsonl"
      },
      "input_skills": {
        "description": "Connector-backed or reusable skill-backed input sources."
      },
      "inputs": {
        "artifact": "inputs.json",
        "description": "Resolved runtime inputs and adapter provenance."
      },
      "logs": {
        "artifact": "logs.jsonl",
        "description": "Runtime stdout/stderr and explicit log artifacts.",
        "index": "logs.index.json",
        "stream": "stdout/stderr"
      },
      "output_skills": {
        "description": "Optional fan-out destinations after local run-store writes."
      },
      "outputs": {
        "artifacts": [
          "result.json",
          "final_artifact.json"
        ],
        "description": "Primary result and final user-facing artifact."
      },
      "resources": {
        "artifact": "resources.jsonl",
        "description": "Resource samples such as token, runtime, connector, and disk usage."
      },
      "streams": {
        "default": [
          "events"
        ],
        "description": "Named data or event streams exposed by the blueprint.",
        "kinds": [
          "audio",
          "video",
          "data",
          "multimodal"
        ],
        "transports": [
          "file",
          "http",
          "https",
          "rtsp",
          "rtmp",
          "webrtc",
          "websocket",
          "socketio",
          "tcp",
          "udp",
          "sse",
          "kafka",
          "mqtt",
          "custom"
        ]
      },
      "web_ui": {
        "artifacts": [
          "web_ui.json",
          "ui.json",
          "web/index.html"
        ],
        "description": "Optional web input/output handles."
      }
    },
    "config_sections": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "resources",
      "human_control",
      "real_adapters",
      "streams",
      "input_skills",
      "output_skills",
      "error_handling",
      "state",
      "capabilities",
      "privacy",
      "triggers",
      "backpressure",
      "determinism",
      "schemas",
      "budgets",
      "agent_handoffs",
      "web_ui",
      "interfaces",
      "execution_model"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "optional_run_artifacts": [
      "job.json",
      "web_ui.json",
      "ui.json",
      "web/index.html",
      "logs.jsonl",
      "logs.index.json",
      "human.jsonl",
      "resources.jsonl"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "response_schema": "mn.blueprint.response.v1",
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ],
    "stream_kinds": [
      "audio",
      "video",
      "data",
      "multimodal"
    ],
    "stream_transports": [
      "file",
      "http",
      "https",
      "rtsp",
      "rtmp",
      "webrtc",
      "websocket",
      "socketio",
      "tcp",
      "udp",
      "sse",
      "kafka",
      "mqtt",
      "custom"
    ],
    "web_ui_adapters": [
      "none",
      "static_html",
      "gradio",
      "custom"
    ]
  },
  "llm": {
    "enabled": true,
    "agent_role": "AI assistant for researching property deals and drafting opportunity rankings.",
    "agents": {
      "property:zip_market": {
        "llm_config": "primary",
        "model": "default",
        "role": "ZIP-market researcher",
        "responsibilities": [
          "Review target ZIP demand and pricing signals.",
          "Separate target and distractor market evidence.",
          "Flag stale or noisy market facts."
        ]
      },
      "property:broker_notes": {
        "llm_config": "primary",
        "model": "default",
        "role": "Broker-note analyst",
        "responsibilities": [
          "Extract broker motivation and diligence signals.",
          "Tie broker claims to source references.",
          "Flag unsupported seller claims."
        ]
      },
      "property:financing": {
        "llm_config": "primary",
        "model": "default",
        "role": "Property financing reviewer",
        "responsibilities": [
          "Review lender notes and DSCR constraints.",
          "Flag financing exceptions and liquidity blockers.",
          "Keep underwriting assumptions review-only."
        ]
      },
      "property:memory_retriever": {
        "llm_config": "primary",
        "model": "default",
        "role": "Property memory curator",
        "responsibilities": [
          "Retrieve important historical facts from working memory.",
          "Drop noisy or irrelevant facts under budget.",
          "Preserve critical source references."
        ]
      },
      "property:signal_comparer": {
        "llm_config": "primary",
        "model": "default",
        "role": "Property signal comparer",
        "responsibilities": [
          "Connect rent, risk, financing, and seller signals.",
          "Compare optimized memory with full context.",
          "Flag decision quality gaps."
        ]
      },
      "property:ranker": {
        "llm_config": "primary",
        "model": "default",
        "role": "Acquisition opportunity ranker",
        "responsibilities": [
          "Rank candidate properties from source-grounded signals.",
          "Explain bid, discount, or watchlist logic.",
          "Avoid final investment advice."
        ]
      },
      "property:risk_reviewer": {
        "llm_config": "primary",
        "model": "default",
        "role": "Property risk reviewer",
        "responsibilities": [
          "Review flood, roof, insurance, and inspection risks.",
          "Flag blockers needing diligence.",
          "Keep risk calls tied to evidence."
        ]
      },
      "property:memo_writer": {
        "llm_config": "primary",
        "model": "default",
        "role": "Property deal memo writer",
        "responsibilities": [
          "Prepare the review-only acquisition memo.",
          "Summarize ranking, evidence, and open questions.",
          "Require human approval before action."
        ]
      }
    },
    "responsibilities": [
      "Keep working-memory retrieval and scoring outputs as the source of truth.",
      "Use actors to connect property, lender, broker, rent, and diligence signals.",
      "Keep acquisition decisions review-only and source-referenced."
    ],
    "mock_mode": "fake",
    "model": "default",
    "mode": "live",
    "default_config": "primary",
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "model": "default",
        "api_base": "http://localhost:12434/engines/v1",
        "timeout_seconds": 60,
        "max_tokens": 900,
        "num_retries": 1,
        "mock_mode": "fake",
        "mode": "live"
      }
    }
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "large_context_seeded",
      "simulation_step_started",
      "memory_context_compiled",
      "llm_decision",
      "benchmark_step_scored",
      "simulation_state_updated",
      "run_completed",
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "resources_jsonl": true,
    "rotation": {
      "check_interval_records": 100,
      "compress": "background",
      "enabled": true,
      "max_bytes_mb": 100,
      "max_segments": 7,
      "span_seconds": 86400
    },
    "stderr_jsonl": true,
    "writer": {
      "batch_size": 100,
      "flush_interval_seconds": 0.5,
      "mode": "async",
      "overflow_policy": "drop_low_priority",
      "queue_size": 10000,
      "shutdown_flush_timeout_seconds": 2
    }
  },
  "memory": {
    "compression_goal": "replace full-history agent handoffs with a compact source-grounded decision packet while preserving older critical facts",
    "enabled": true,
    "mode": "compare",
    "retrieval_tags": [
      "critical",
      "demand_tailwind",
      "rent_growth",
      "risk_flag",
      "financing"
    ],
    "selection_limit": 36
  },
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "property_deal_research_assistant_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "metadata": {
    "agent_role": "AI assistant for researching property deals and drafting opportunity rankings.",
    "blueprint_id": "property_deal_research_assistant",
    "blueprint_revision": "v1",
    "category": "finance",
    "customizable_for": "Rental acquisitions, flipping pipelines, multifamily sourcing, market expansion, diligence review, and capital-allocation meetings.",
    "description": "Reviews ZIP-code history, broker notes, financing constraints, and deal memory to rank property opportunities and explain which ones deserve attention.",
    "llm_agent_role": "AI assistant for researching property deals and drafting opportunity rankings.",
    "name": "Property Deal Research Assistant",
    "problem_solved": "Property deal review depends on older broker, lender, rent, insurance, and diligence details that are easy to lose in noisy pipelines.",
    "simulation_type": "Property opportunity research with deal-memory retrieval.",
    "standard_version": "1.0",
    "target_user": "Real-estate investors, acquisition analysts, property-tech teams, and diligence operators.",
    "target_users": "Real-estate investors, acquisition analysts, property-tech teams, and diligence operators."
  },
  "mode": "mock",
  "output_skills": {},
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Ranked property opportunities, source-grounded notes, and watchlist or bid recommendations for review.",
    "run_root": "~/.mn/runs",
    "skills": {},
    "tcp": {
      "enabled": false,
      "ports": []
    },
    "write_run_store": true
  },
  "privacy": {
    "default_classification": "confidential",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "resources": {
    "enabled": true,
    "gpu_enabled": "auto",
    "gpu_sample_interval_seconds": 60,
    "history_window_hours": 24,
    "raw_retention_hours": 48,
    "rollup_bucket_seconds": 3600,
    "sample_interval_seconds": 10
  },
  "schemas": {
    "artifact_record": "mn.artifact.record.v1",
    "config": "mn.blueprint.config.v1",
    "events": "mn.blueprint.events.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "human_control": "mn.blueprint.human_control.v1",
    "input_skills": "mn.blueprint.input_skills.v1",
    "inputs": "mn.blueprint.inputs.v1",
    "logs": "mn.blueprint.logs.v1",
    "output_skills": "mn.blueprint.output_skills.v1",
    "resources": "mn.blueprint.resources.v1",
    "status_contract": "mn.blueprint.status_contract.v1",
    "web_ui": "mn.blueprint.web_ui.v1"
  },
  "simulation": {
    "actions": [
      "submit_bid",
      "negotiate_discount",
      "watchlist_only"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "median_price_index",
      "demand_index",
      "cap_rate_pct",
      "risk_score",
