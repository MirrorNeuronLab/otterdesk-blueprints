  "llm": {
    "agent_role": "Customer-service voice co-worker that answers from the customer knowledge base, asks clarifying questions when needed, and recommends escalation when it is unsure or outside scope.",
    "base_url": "http://127.0.0.1:8000/v1",
    "model": "nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-BF16",
    "provider": "openai-compatible",
    "system_prompt": "prompts/chat-system.md",
    "temperature": 0.2
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed",
      "human_notice",
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed",
      "customer_service_voice_start_requested",
      "customer_service_voice_prepared",
      "customer_service_voice_stack_ready",
      "customer_service_voice_started",
      "customer_service_voice_ready",
      "customer_service_voice_health_checked",
      "customer_service_knowledge_loaded",
      "customer_service_knowledge_updated",
      "customer_service_rag_context_selected",
      "customer_service_turn_started",
      "customer_service_turn_completed",
      "customer_service_escalation_recommended",
      "customer_service_voice_error"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "resources_jsonl": true,
    "rotation": {
      "check_interval_records": 100,
      "compress": "background",
      "enabled": true,
      "max_bytes_mb": 100,
      "max_segments": 7,
      "span_seconds": 86400
    },
    "stderr_jsonl": true,
    "writer": {
      "batch_size": 100,
      "flush_interval_seconds": 0.5,
      "mode": "async",
      "overflow_policy": "drop_low_priority",
      "queue_size": 10000,
      "shutdown_flush_timeout_seconds": 2
    }
  },
  "manifest_config_bindings": [
    {
      "config_path": "identity.run_id",
      "manifest_path": "runtime.bindings.run_workflow.workers.visual_detector.with.environment.MN_RUN_ID",
      "stringify": true
    },
    {
      "config_path": "outputs.run_root",
      "manifest_path": "runtime.bindings.run_workflow.workers.visual_detector.with.environment.MN_RUNS_ROOT",
      "stringify": true
    }
  ],
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "generic_customer_service_voice_coworker_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
