{
  "agent_handoffs": {},
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 30,
      "max_concurrent_calls": 2
    },
    "max_concurrency": 4,
    "max_events_per_second": 25,
    "queue_size": 1000
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 20,
    "max_disk_mb": 250,
    "max_llm_calls": 20,
    "max_llm_tokens": 20000,
    "max_runtime_seconds": 600,
    "max_stream_duration_seconds": 3600
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "network.egress",
      "stream.publish",
      "stream.subscribe"
    ],
    "required": [
      "filesystem.write",
      "stream.subscribe"
    ]
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": {
    "execution_profile": "customer-service-voice-nvidia",
    "placement": {
      "node_constraint": "mn2@192.168.4.173",
      "spark_host": "homer@spark",
      "spark_ip": "192.168.4.173"
    },
    "required_gpu": {
      "gpu_count": 1
    },
    "runner": "MirrorNeuron.Runner.HostLocal",
    "target_node": "mn2@192.168.4.173"
  },
  "human_control": {
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "notice_only",
    "notice_event": "human_notice",
    "reason": "The co-worker can converse with customers and recommend escalation, but it does not approve refunds, account changes, or other business actions by itself.",
    "requires_ack": false
  },
  "identity": {
    "blueprint_id": "generic_customer_service_voice_coworker",
    "name": "Generic Customer Service Voice AI Co-worker"
  },
  "input_skills": {},
