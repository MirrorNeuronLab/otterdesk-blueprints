    "adapter": "mock",
    "description": "Default generic customer-service voice co-worker inputs.",
    "payload": {
      "business_name": "Acme Customer Care",
      "escalation_policy": "Escalate billing disputes, emergencies, account security issues, angry or distressed callers, requests for refunds or account changes, and any answer not grounded in the knowledge base.",
