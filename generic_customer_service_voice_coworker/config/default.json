      "opening_message": "Thanks for calling Acme Customer Care. How can I help today?",
      "service_scope": "Answer common customer-service questions from the editable knowledge base, ask clarifying questions, and recommend escalation when needed.",
      "spark_host": "homer@spark",
      "spark_ip": "192.168.4.173",
      "spark_node": "mn2@192.168.4.173",
      "voice": "aria",
      "voice_https_port": 7863,
      "voice_public_url": "https://192.168.4.173:7863/customer-service"
