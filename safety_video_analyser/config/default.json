{
  "identity": {
    "blueprint_id": "safety_video_analyser",
    "name": "Safety Video Analyser"
  },
  "video_inputs": {
    "folder_path": "safety_video_analyser/examples/sample_inputs"
  },
  "inputs": {
    "payload": {
      "video_folder": "safety_video_analyser/examples/sample_inputs",
      "input_folder": "safety_video_analyser/examples/sample_inputs",
      "output_folder": "~/Download/safety_video_analyser"
    }
  },
  "node_allocation": {
    "write_safety_report_preferred_node": "mirror_neuron@192.168.4.173"
  },
  "llm": {
    "enabled": true,
    "provider": "docker_model_runner",
    "model": "gemma4:e2b",
    "backend": "llama.cpp",
    "context_size": 4096,
    "max_tokens": 800,
    "timeout_seconds": 120,
    "mode": "live",
    "mock_mode": "fake",
    "default_config": "primary",
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "responsibilities": [
      "Keep video metadata and model outputs tied to staged media evidence.",
      "Use actors to summarize observed safety review signals and reporting caveats.",
      "Avoid treating the report as a substitute for human safety review."
    ],
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "model": "gemma4:e2b",
        "api_base": "http://localhost:12434/engines/v1",
        "timeout_seconds": 60,
        "max_tokens": 900,
        "num_retries": 1,
        "mock_mode": "fake",
        "mode": "live"
      }
    },
    "agents": {
      "video_understanding_agent": {
        "llm_config": "primary",
        "model": "gemma4:e2b",
        "role": "Safety video understanding actor",
        "responsibilities": [
          "Inspect staged video metadata and model outputs.",
          "Summarize visible safety-review context.",
          "Flag missing videos, model, or media-quality blockers."
        ]
      },
      "write_safety_report": {
        "llm_config": "primary",
        "model": "gemma4:e2b",
        "role": "Safety report generator actor",
        "responsibilities": [
          "Write a concise safety review report.",
          "Preserve video evidence and routing context.",
          "Keep findings review-only for human safety review."
        ]
      }
    }
  },
  "vl_model": {
    "provider": "docker_model_runner",
    "model": "otterdesk-video-watch:default",
    "runtime_model": "hf.co/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-BF16",
    "install_mode": "cluster_provided",
    "timeout_seconds": 300
  },
  "local_inputs": {
    "folders": [
      {
        "config_path": "video_inputs.folder_path",
        "payload_path": "safety_video_analyser/mn_local_inputs/videos",
        "runtime_path": "mn_local_inputs/videos",
        "allowed_extensions": [
          ".mp4",
          ".mov",
          ".mkv",
          ".avi",
          ".webm"
        ],
        "linked_config_paths": [
          "inputs.payload.video_folder"
        ]
      }
    ]
  },
  "manifest_config_bindings": [
    {
      "config_path": "node_allocation.write_safety_report_preferred_node",
      "manifest_path": "agents.nodes.write_safety_report.policies.scheduler.preferred_node"
    }
  ],
  "outputs": {
    "folder_path": "~/Download/safety_video_analyser"
  },
  "state": {
    "input_folder": "safety_video_analyser/examples/sample_inputs",
    "output_folder": "~/Download/safety_video_analyser"
  },
  "metadata": {
    "description": "A safety-video analysis co-worker for reviewing local workplace footage. Put video files in the input folder; it stages them for the visual analysis node, identifies safety-relevant observations, and writes a structured safety report and supporting artifacts to the output folder."
  },
  "suggested_schedule": {
    "cron": "0 2 * * *",
    "cadence": "daily",
    "advisory_only": true,
    "note": "Suggested cadence only; runtime decides the actual schedule."
  },
  "knowledge_rag": {
    "enabled": true,
    "backend": "redis_vector_rag",
    "required": false,
    "knowledge_dir": "knowledge",
    "purpose": "Retrieve safety-video review policy for staged media evidence, visual-model uncertainty, and human safety-review boundaries.",
    "retrieval_targets": [
      "video evidence grounding",
      "model uncertainty",
      "safety review blockers",
      "report-only language"
    ],
    "grounding_policy": "Use retrieved local blueprint knowledge to improve actor review prompts; do not invent facts when retrieval is unavailable.",
    "redis_url": "",
    "namespace": "",
    "embedding_provider": "docker_model_runner",
    "embedding_model": "hf.co/jinaai/jina-embeddings-v5-text-small-retrieval:Q4_K_M",
    "embedding_api_base": "http://localhost:12434/engines/v1",
    "embedding_query_prefix": "Query: ",
    "embedding_document_prefix": "Document: ",
    "embedding_start_command": "",
    "embedding_healthcheck_enabled": true,
    "vector_dim": 1024,
    "index_on_startup": false,
    "top_k": 4,
    "max_context_chars": 4000,
    "chunk_size": 700,
    "chunk_overlap": 70,
    "privacy": "index local blueprint knowledge only; do not index private run documents unless a future runtime explicitly opts in"
  },
  "agentic_research": {
    "enabled": true,
    "agent_ids": [
      "video_understanding_agent",
      "write_safety_report"
    ],
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "allowed_tools": [
      "blobref_stage_video",
      "visual_model_infer",
      "knowledge_retrieve",
      "report_write",
      "finish"
    ],
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run",
    "default_mode": "bounded_llm_guided_safety_video_review",
    "note": "Safety video actors ground reports in staged media and model outputs, leaving safety decisions to humans."
  },
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "safety_video_analyser_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "interfaces": {
    "config": [
      "identity",
      "metadata",
      "inputs",
      "llm",
      "outputs",
      "state",
      "interfaces",
      "agentic_research",
      "knowledge_rag",
      "memory_layer",
      "suggested_schedule"
    ],
    "config_sections": [
      "identity",
      "metadata",
      "inputs",
      "llm",
      "outputs",
      "state",
      "interfaces",
      "agentic_research",
      "knowledge_rag",
      "memory_layer",
      "suggested_schedule"
    ],
    "channels": {
      "input_skills": {
        "description": "Connector-backed or reusable skill-backed input sources."
      },
      "knowledge_rag": {
        "description": "Optional local blueprint knowledge retrieval used to ground actor prompts and tool planning.",
        "config": "knowledge_rag",
        "artifact": "knowledge/",
        "privacy": "blueprint knowledge only by default"
      },
      "agentic_research": {
        "description": "Bounded LLM-selected or actor-guided tool contract for domain work.",
        "config": "agentic_research"
      }
    }
  }
}
