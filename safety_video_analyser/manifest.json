{
  "manifest_version": "1.0",
  "workflow_id": "safety_video_analyser_v1",
  "job_name": "safety-video-analyser",
  "type": "batch",
  "policies": {
    "recovery_mode": "local_restart",
    "job_type": "batch",
    "scheduler": {
      "strategy": "binpack"
    }
  },
  "requirements": {
    "gpu": {
      "min_count": 1,
      "vendor": "nvidia",
      "driver": "cuda",
      "min_api_version": "12.0",
      "api_version_operator": ">",
      "min_memory_mb": 49152,
      "memory_operator": ">",
      "enforcement": "hard"
    }
  },
  "metadata": {
    "blueprint_id": "safety_video_analyser",
    "name": "Safety Video Analyser",
    "category": "Security",
    "description": "A safety-video analysis co-worker for reviewing local workplace footage. Put video files in the input folder; it stages them for the visual analysis node, identifies safety-relevant observations, and writes a structured safety report and supporting artifacts to the output folder.",
    "init_config_review": {
      "required": true,
      "instruction": "Review the local video folder and optional report-generator node preference before launch.",
      "fields": [
        {
          "label": "Video folder",
          "path": "video_inputs.folder_path",
          "default": "safety_video_analyser/examples/sample_inputs",
          "description": "Host-local folder containing sample safety videos. Files are staged through BlobRef sharing.",
          "type": "local_path",
          "path_kind": "directory"
        },
        {
          "label": "Report node",
          "path": "node_allocation.report_generator_preferred_node",
          "default": "mirror_neuron@192.168.4.173",
          "description": "Suggestive node preference for the report generator. Scheduler falls back automatically if unavailable."
        },
        {
          "path": "outputs.folder_path",
          "label": "Output folder",
          "default": "~/Download/safety_video_analyser",
          "description": "Default local output folder for generated artifacts and reports.",
          "type": "local_path",
          "path_kind": "directory"
        }
      ]
    },
    "input_contract": {
      "required_inputs": [],
      "optional_inputs": [
        {
          "name": "input_folder",
          "type": "local_path",
          "path_kind": "directory",
          "description": "Default local input folder for sample files or user-provided files.",
          "example": "safety_video_analyser/examples/sample_inputs",
          "privacy": "internal",
          "required": false
        },
        {
          "name": "output_folder",
          "type": "local_path",
          "path_kind": "directory",
          "description": "Default local output folder for generated artifacts and reports.",
          "example": "~/Download/safety_video_analyser",
          "privacy": "internal",
          "required": false
        }
      ]
    }
  },
  "agents": {
    "schema": "mn.agents.communication_graph/v1",
    "entrypoints": [
      "video_understanding_agent"
    ],
    "nodes": [
      {
        "node_id": "video_understanding_agent",
        "type": "generic",
        "agent_type": "executor",
        "role": "root",
        "config": {
          "runner_module": "MirrorNeuron.Runner.HostLocal",
          "upload_path": "safety_video_analyser",
          "upload_as": "safety_video_analyser",
          "workdir": "/sandbox/job/safety_video_analyser",
          "command": [
            "python3.11",
            "scripts/run_video_understanding.py"
          ],
          "from": "base",
          "no_auto_providers": true,
          "no_keep": true,
          "pool": "default",
          "pool_slots": 1,
          "tty": false,
          "model": "otterdesk-video-watch:default",
          "output_message_type": "safety_video_understood",
          "environment": {
            "MN_WORKFLOW_STEP_ID": "video_understanding_agent",
            "MN_VLM_PROVIDER": "docker_model_runner",
            "MN_VLM_MODEL": "hf.co/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-BF16",
            "MN_LLM_MODEL": "hf.co/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-BF16",
            "MN_LLM_RUNTIME_MODEL": "hf.co/nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-BF16"
          },
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_timeout_ms": 45000,
          "beacon_missed_action": "fail_attempt",
          "agent_beacon_required": true,
          "timeout_seconds": 600,
          "max_attempts": 1
        },
        "constraints": [
          {
            "attribute": "capabilities",
            "operator": "contains_all",
            "value": [
              "nvidia",
              "cuda"
            ]
          }
        ],
        "resources": {
          "cpu_cores": 4,
          "memory_mb": 8192,
          "gpu_count": 1,
          "devices": [
            {
              "kind": "gpu",
              "type": "nvidia/gpu",
              "vendor": "nvidia",
              "driver": "cuda",
              "count": 1,
              "min_api_version": "12.0",
              "api_version_operator": ">",
              "min_memory_mb": 49152,
              "memory_operator": ">"
            }
          ]
        }
      },
      {
        "node_id": "report_generator",
        "type": "generic",
        "agent_type": "executor",
        "config": {
          "runner_module": "MirrorNeuron.Runner.HostLocal",
          "upload_path": "safety_video_analyser",
          "upload_as": "safety_video_analyser",
          "workdir": "/sandbox/job/safety_video_analyser",
          "command": [
            "python3.11",
            "scripts/run_report_generator.py"
          ],
          "from": "base",
          "no_auto_providers": true,
          "no_keep": true,
          "pool": "default",
          "pool_slots": 1,
          "tty": false,
          "output_message_type": "safety_report_ready",
          "terminal_sink": true,
          "complete_run": true,
          "environment": {
            "MN_WORKFLOW_STEP_ID": "report_generator"
          },
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_timeout_ms": 45000,
          "beacon_missed_action": "fail_attempt",
          "agent_beacon_required": true,
          "timeout_seconds": 300,
          "max_attempts": 1
        },
        "policies": {
          "scheduler": {
            "preferred_node": "mirror_neuron@192.168.4.173"
          }
        },
        "resources": {
          "cpu_cores": 1,
          "memory_mb": 1024
        }
      }
    ],
    "edges": [
      {
        "edge_id": "video_to_report",
        "from_node": "video_understanding_agent",
        "message_type": "safety_video_understood",
        "to_node": "report_generator"
      }
    ]
  },
  "runtime": {
    "models": {
      "default": {
        "type": "llm",
        "provider": "docker_model_runner",
        "model": "gemma4:e2b",
        "runtime_model": "gemma4:e2b",
        "backend": "llama.cpp",
        "required": true
      },
      "video_understanding": {
        "type": "vlm",
        "provider": "docker_model_runner",
        "model": "otterdesk-video-watch:default",
        "runtime_model": "otterdesk-video-watch:default",
        "backend": "llama.cpp",
        "install_mode": "cluster_provided",
        "required": true
      }
    },
    "resources": {
      "gpu": {
        "min_count": 1,
        "vendor": "nvidia",
        "driver": "cuda",
        "min_api_version": "12.0",
        "api_version_operator": ">",
        "min_memory_mb": 49152,
        "memory_operator": ">",
        "enforcement": "hard"
      }
    }
  },
  "initial_inputs": {
    "video_understanding_agent": [
      {
        "task": "analyse_safety_videos",
        "source": "local_video_folder"
      }
    ]
  },
  "contract": {
    "inputs": {
      "input_folder": {
        "type": "local_path",
        "path_kind": "directory",
        "description": "Default local input folder for sample files or user-provided files.",
        "privacy": "internal",
        "required": false,
        "example": "safety_video_analyser/examples/sample_inputs"
      },
      "output_folder": {
        "type": "local_path",
        "path_kind": "directory",
        "description": "Default local output folder for generated artifacts and reports.",
        "privacy": "internal",
        "required": false,
        "example": "~/Download/safety_video_analyser"
      }
    }
  },
  "description": "A safety-video analysis co-worker for reviewing local workplace footage. Put video files in the input folder; it stages them for the visual analysis node, identifies safety-relevant observations, and writes a structured safety report and supporting artifacts to the output folder."
}
