{
  "apiVersion": "mn.workflow/v1",
  "kind": "Workflow",
  "id": "safety_video_analyser",
  "name": "Safety Video Analyser",
  "version": 1,
  "manifest_version": "1.0",
  "skill_dependencies": [],
  "job_name": "safety-video-analyser",
  "type": "batch",
  "policies": {
    "recovery_mode": "local_restart",
    "job_type": "batch",
    "scheduler": {
      "strategy": "binpack"
    }
  },
  "requirements": {
    "gpu": {
      "min_count": 1,
      "vendor": "nvidia",
      "driver": "cuda",
      "min_api_version": "12.0",
      "api_version_operator": ">=",
      "min_memory_mb": 49152,
      "memory_operator": ">=",
      "enforcement": "hard"
    }
  },
  "metadata": {
    "blueprint_id": "safety_video_analyser",
    "name": "Safety Video Analyser",
    "category": "Security",
    "description": "A safety-video analysis co-worker for reviewing local workplace footage. Put video files in the input folder; it stages them for the visual analysis node, identifies safety-relevant observations, and writes a structured safety report and supporting artifacts to the output folder.",
    "standard": {
      "workflow_model": "contract -> workflow -> agents/runtime"
    },
    "memory_layer": {
      "collection": "mn_memory",
      "containers": "optional_sidecar",
      "context_addr_env": "MN_CONTEXT_ADDR",
      "conversation": {
        "agent_role": "otterdesk_chat",
        "include_human_events": true,
        "include_runtime_events": true,
        "include_runtime_logs": true,
        "target_tokens": 2400,
        "token_budget": 6000,
        "use_model_compression": false
      },
      "conversation_enabled": true,
      "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
      "default_context_addr": "localhost:50052",
      "enabled": true,
      "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
      "namespace": "safety_video_analyser_context",
      "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
      "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
      "sdk_distribution": "mirrorneuron-membrane-python-sdk",
      "sdk_import_package": "mn_context_engine_sdk"
    },
    "status_contract": {
      "runtime_state_source": "workflow_state",
      "attempt_event": "workflow_step_attempt_started",
      "retry_event": "workflow_step_attempt_retry_scheduled",
      "blocked_event": "workflow_step_blocked",
      "terminal_step_events": [
        "workflow_step_completed",
        "workflow_step_partial",
        "workflow_step_skipped",
        "workflow_step_failed"
      ]
    },
    "init_config_review": {
      "required": true,
      "instruction": "Review the local video folder and optional report-generator node preference before launch.",
      "fields": [
        {
          "label": "Video folder",
          "path": "video_inputs.folder_path",
          "default": "safety_video_analyser/examples/sample_inputs",
          "description": "Host-local folder containing sample safety videos. Files are staged through BlobRef sharing.",
          "type": "local_path",
          "path_kind": "directory"
        },
        {
          "label": "Report node",
          "path": "node_allocation.write_safety_report_preferred_node",
          "default": "mirror_neuron@192.168.4.173",
          "description": "Suggestive node preference for the report generator. Scheduler falls back automatically if unavailable."
        },
        {
          "path": "outputs.folder_path",
          "label": "Output folder",
          "default": "~/Download/safety_video_analyser",
          "description": "Default local output folder for generated artifacts and reports.",
          "type": "local_path",
          "path_kind": "directory"
        }
      ]
    },
    "input_contract": {
      "required_inputs": [],
      "optional_inputs": [
        {
          "name": "input_folder",
          "type": "local_path",
          "path_kind": "directory",
          "description": "Default local input folder for sample files or user-provided files.",
          "example": "safety_video_analyser/examples/sample_inputs",
          "privacy": "internal",
          "required": false
        },
        {
          "name": "output_folder",
          "type": "local_path",
          "path_kind": "directory",
          "description": "Default local output folder for generated artifacts and reports.",
          "example": "~/Download/safety_video_analyser",
          "privacy": "internal",
          "required": false
        }
      ]
    },
    "knowledge_rag": {
      "enabled": true,
      "backend": "redis_vector_rag",
      "required": false,
      "knowledge_dir": "knowledge",
      "purpose": "Retrieve safety-video review policy for staged media evidence, visual-model uncertainty, and human safety-review boundaries.",
      "retrieval_targets": [
        "video evidence grounding",
        "model uncertainty",
        "safety review blockers",
        "report-only language"
      ],
      "grounding_policy": "Use retrieved local blueprint knowledge to improve actor review prompts; do not invent facts when retrieval is unavailable.",
      "redis_url": "",
      "namespace": "",
      "embedding_provider": "docker_model_runner",
      "embedding_model": "rag-embedding",
      "embedding_api_base": "http://localhost:12434/engines/v1",
      "embedding_query_prefix": "Query: ",
      "embedding_document_prefix": "Document: ",
      "embedding_start_command": "",
      "embedding_healthcheck_enabled": true,
      "vector_dim": 1024,
      "index_on_startup": false,
      "top_k": 4,
      "max_context_chars": 4000,
      "chunk_size": 700,
      "chunk_overlap": 70,
      "privacy": "index local blueprint knowledge only; do not index private run documents unless a future runtime explicitly opts in"
    },
    "agentic_research": {
      "enabled": true,
      "agent_ids": [
        "video_understanding_agent",
        "write_safety_report"
      ],
      "max_iterations_per_agent": 1,
      "max_tool_calls_per_agent": 2,
      "allowed_tools": [
        "blobref_stage_video",
        "visual_model_infer",
        "knowledge_retrieve",
        "report_write",
        "finish"
      ],
      "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run",
      "default_mode": "bounded_llm_guided_safety_video_review",
      "note": "Safety video actors ground reports in staged media and model outputs, leaving safety decisions to humans."
    },
    "features": [
      "optional local knowledge RAG grounding",
      "bounded LLM tool-plan contract"
    ],
    "runtime_features": [
      "optional knowledge_rag guidance",
      "actor-style LLM specialists use retrieved policy context when available",
      "Membrane context memory optimization"
    ],
    "configuration_contract": {
      "optional_files": [
        "knowledge/"
      ]
    },
    "interfaces": {
      "config": [
        "identity",
        "metadata",
        "inputs",
        "llm",
        "outputs",
        "state",
        "interfaces",
        "agentic_research",
        "knowledge_rag",
        "suggested_schedule"
      ],
      "config_sections": [
        "identity",
        "metadata",
        "inputs",
        "llm",
        "outputs",
        "state",
        "interfaces",
        "agentic_research",
        "knowledge_rag",
        "suggested_schedule"
      ],
      "channels": {
        "knowledge_rag": {
          "description": "Optional local blueprint knowledge retrieval used to ground actor prompts and tool planning.",
          "config": "knowledge_rag",
          "artifact": "knowledge/",
          "privacy": "blueprint knowledge only by default"
        },
        "agentic_research": {
          "description": "Bounded LLM-selected or actor-guided tool contract for domain work.",
          "config": "agentic_research"
        }
      }
    }
  },
  "workflow": {
    "schema": "mn.workflow.problem_graph/v1",
    "workflow_id": "safety_video_analyser_v1",
    "mode": "static_dag",
    "entrypoint": "analyse_safety_videos",
    "source": "analyse_safety_videos",
    "sink": "write_safety_report",
    "execution": {
      "strategy": "serial"
    },
    "dynamic": {
      "enabled": false,
      "apply_at": "between_steps",
      "patch_events": []
    },
    "state": {
      "input_folder": {
        "from": "$inputs.input_folder"
      },
      "output_folder": {
        "from": "$inputs.output_folder"
      },
      "workflow": {},
      "final_report": {}
    },
    "steps": [
      {
        "id": "analyse_safety_videos",
        "kind": "source",
        "label": "Analyse Safety Videos",
        "goal": "Stage local safety-video inputs and produce visual safety observations.",
        "action": "analyse_safety_videos",
        "run": "analyse_safety_videos",
        "emits": "safety_video_understood",
        "on": {
          "safety_video_understood": "write_safety_report"
        },
        "control": {
          "required": true,
          "retry": {
            "max_attempts": 1,
            "backoff_seconds": 1,
            "backoff_multiplier": 2,
            "jitter": 0
          },
          "failure_policy": "fail_workflow",
          "timeout_seconds": 600,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "in": {
          "input_folder": "$state.input_folder"
        },
        "out": {
          "safety_video_understanding": "$state.workflow.safety_video_understanding"
        },
        "provides": [
          "safety_video_analyser.analyse_safety_videos.ready"
        ],
        "requires": []
      },
      {
        "id": "write_safety_report",
        "kind": "sink",
        "label": "Write Safety Report",
        "goal": "Write a structured safety report from the visual observations.",
        "action": "write_safety_report",
        "run": "write_safety_report",
        "emits": "safety_report_ready",
        "on": {
          "safety_report_ready": "completed"
        },
        "control": {
          "required": true,
          "retry": {
            "max_attempts": 1,
            "backoff_seconds": 1,
            "backoff_multiplier": 2,
            "jitter": 0
          },
          "failure_policy": "fail_workflow",
          "timeout_seconds": 300,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "in": {
          "previous": "$state.workflow",
          "output_folder": "$state.output_folder"
        },
        "out": {
          "final_report": "$state.final_report"
        },
        "provides": [
          "safety_video_analyser.write_safety_report.ready"
        ],
        "requires": [
          "safety_video_analyser.analyse_safety_videos.ready"
        ]
      }
    ],
    "edges": [
      {
        "id": "analyse_safety_videos_to_write_safety_report",
        "from": "analyse_safety_videos",
        "to": "write_safety_report",
        "event": "safety_video_understood",
        "required": true,
        "accepts": [
          "done"
        ]
      }
    ]
  },
  "agents": {
    "schema": "mn.agents.communication_graph/v1",
    "entrypoints": [
      "video_understanding_agent"
    ],
    "nodes": [
      {
        "node_id": "video_understanding_agent",
        "type": "generic",
        "agent_type": "executor",
        "role": "root",
        "config": {
          "runner_module": "MirrorNeuron.Runner.HostLocal",
          "upload_path": "safety_video_analyser",
          "upload_as": "safety_video_analyser",
          "workdir": "/sandbox/job/safety_video_analyser",
          "command": [
            "python3.11",
            "scripts/run_video_understanding.py"
          ],
          "from": "base",
          "no_auto_providers": true,
          "no_keep": true,
          "pool": "default",
          "pool_slots": 1,
          "tty": false,
          "model": "medium",
          "output_message_type": "safety_video_understood",
          "environment": {
            "MN_WORKFLOW_STEP_ID": "video_understanding_agent",
            "MN_VLM_PROVIDER": "docker_model_runner",
            "MN_VLM_MODEL": "medium",
            "MN_LLM_MODEL": "medium",
            "MN_LLM_RUNTIME_MODEL": "medium"
          },
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_timeout_ms": 45000,
          "beacon_missed_action": "fail_attempt",
          "agent_beacon_required": true,
          "timeout_seconds": 600,
          "max_attempts": 1
        },
        "constraints": [
          {
            "attribute": "capabilities",
            "operator": "contains_all",
            "value": [
              "nvidia",
              "cuda"
            ]
          }
        ],
        "resources": {
          "cpu_cores": 4,
          "memory_mb": 8192,
          "gpu_count": 1,
          "devices": [
            {
              "kind": "gpu",
              "type": "nvidia/gpu",
              "vendor": "nvidia",
              "driver": "cuda",
              "count": 1,
              "min_api_version": "12.0",
              "api_version_operator": ">=",
              "min_memory_mb": 49152,
              "memory_operator": ">="
            }
          ]
        }
      },
      {
        "node_id": "write_safety_report",
        "type": "generic",
        "agent_type": "executor",
        "config": {
          "runner_module": "MirrorNeuron.Runner.HostLocal",
          "upload_path": "safety_video_analyser",
          "upload_as": "safety_video_analyser",
          "workdir": "/sandbox/job/safety_video_analyser",
          "command": [
            "python3.11",
            "scripts/run_report_generator.py"
          ],
          "from": "base",
          "no_auto_providers": true,
          "no_keep": true,
          "pool": "default",
          "pool_slots": 1,
          "tty": false,
          "output_message_type": "safety_report_ready",
          "environment": {
            "MN_WORKFLOW_STEP_ID": "write_safety_report"
          },
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_timeout_ms": 45000,
          "beacon_missed_action": "fail_attempt",
          "agent_beacon_required": true,
          "timeout_seconds": 300,
          "max_attempts": 1
        },
        "policies": {
          "scheduler": {
            "preferred_node": "mirror_neuron@192.168.4.173"
          }
        },
        "resources": {
          "cpu_cores": 1,
          "memory_mb": 1024
        }
      },
      {
        "node_id": "report_sink",
        "type": "reduce",
        "agent_type": "aggregator",
        "config": {
          "complete_on_message": true,
          "terminal_sink": true,
          "complete_run": true
        },
        "role": "result_sink"
      }
    ],
    "edges": [
      {
        "edge_id": "video_to_report",
        "from_node": "video_understanding_agent",
        "message_type": "safety_video_understood",
        "to_node": "write_safety_report"
      },
      {
        "edge_id": "report_to_sink",
        "from_node": "write_safety_report",
        "message_type": "safety_report_ready",
        "to_node": "report_sink"
      }
    ]
  },
  "runtime": {
    "bindings": {
      "analyse_safety_videos": {
        "type": "worker",
        "strategy": "single",
        "side_effect": "read",
        "risk": "medium",
        "workers": [
          {
            "id": "video_understanding_agent",
            "alias": "video_understanding_agent",
            "kind": "worker",
            "role": "Safety video understanding analyst",
            "model": "medium",
            "tokens": 14000,
            "tools": 4,
            "required": true
          }
        ]
      },
      "write_safety_report": {
        "type": "worker",
        "strategy": "single",
        "side_effect": "write",
        "risk": "low",
        "workers": [
          {
            "id": "write_safety_report",
            "alias": "write_safety_report",
            "kind": "worker",
            "role": "Safety report generator",
            "model": "small",
            "tokens": 8000,
            "tools": 3,
            "required": true
          }
        ]
      }
    },
    "workflow_control": {
      "schema_version": "mn.workflow.runtime_control.v1",
      "enabled": true,
      "source_of_truth": "workflow.steps",
      "state_ledger": {
        "enabled": true,
        "persisted_field": "workflow_state",
        "step_statuses": [
          "pending",
          "ready",
          "queued",
          "running",
          "retry_wait",
          "blocked",
          "completed",
          "partial",
          "skipped",
          "failed"
        ],
        "message_ledger": true,
        "delivery_semantics": "at_least_once_with_idempotency"
      },
      "attempts": {
        "dispatch_metadata": [
          "workflow_run_id",
          "step_id",
          "attempt_id",
          "attempt",
          "deadline_at",
          "heartbeat_deadline_at",
          "idempotency_key"
        ],
        "stale_attempt_outputs": "ignore",
        "retry_policy_source": "workflow.steps[].control.retry",
        "timeout_source": "workflow.steps[].control.timeout_seconds"
      },
      "liveness": {
        "event": "agent_beacon",
        "interval_ms": 15000,
        "timeout_ms": 45000,
        "required": true,
        "missed_action": "fail_attempt"
      },
      "reconciliation": {
        "interval_ms": 2000,
        "on_timeout": "fail_attempt_then_retry",
        "on_missed_beacon": "fail_attempt_then_retry",
        "on_retry_exhausted": "apply_step_failure_policy"
      },
      "pause_cancel": {
        "pause_mode": "stop_active_attempts",
        "resume_mode": "reconcile_from_workflow_state",
        "cancel_mode": "terminate_active_attempts"
      },
      "events": [
        "workflow_step_attempt_started",
        "workflow_step_beacon",
        "workflow_step_attempt_completed",
        "workflow_step_attempt_timed_out",
        "workflow_step_attempt_retry_scheduled",
        "workflow_step_blocked",
        "workflow_step_completed",
        "workflow_step_failed",
        "workflow_message_dead_lettered"
      ]
    },
    "models": {
      "default": {
        "type": "llm",
        "provider": "docker_model_runner",
        "model": "small",
        "runtime_model": "small",
        "backend": "llama.cpp",
        "required": true
      },
      "video_understanding": {
        "type": "vlm",
        "provider": "docker_model_runner",
        "model": "medium",
        "runtime_model": "medium",
        "backend": "llama.cpp",
        "install_mode": "cluster_provided",
        "required": true
      }
    },
    "resources": {
      "gpu": {
        "min_count": 1,
        "vendor": "nvidia",
        "driver": "cuda",
        "min_api_version": "12.0",
        "api_version_operator": ">=",
        "min_memory_mb": 49152,
        "memory_operator": ">=",
        "enforcement": "hard"
      }
    }
  },
  "initial_inputs": {
    "video_understanding_agent": [
      {
        "task": "analyse_safety_videos",
        "source": "local_video_folder"
      }
    ]
  },
  "contract": {
    "inputs": {
      "input_folder": {
        "type": "local_path",
        "path_kind": "directory",
        "description": "Default local input folder for sample files or user-provided files.",
        "privacy": "internal",
        "required": false,
        "example": "safety_video_analyser/examples/sample_inputs"
      },
      "output_folder": {
        "type": "local_path",
        "path_kind": "directory",
        "description": "Default local output folder for generated artifacts and reports.",
        "privacy": "internal",
        "required": false,
        "example": "~/Download/safety_video_analyser"
      }
    },
    "outputs": {
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json",
            "safety_video_report.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "logs",
          "mime_type": "application/x-jsonlines",
          "path": "logs.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.logs.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "logs"
        },
        {
          "artifact_id": "resources",
          "mime_type": "application/x-jsonlines",
          "path": "resources.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.resources.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "resource_samples"
        },
        {
          "artifact_id": "web_ui",
          "mime_type": "application/json",
          "path": "web_ui.json",
          "producer": "web_ui",
          "schema_version": "mn.blueprint.web_ui.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "web_ui"
        },
        {
          "artifact_id": "human_events",
          "mime_type": "application/x-jsonlines",
          "path": "human.jsonl",
          "producer": "human_control",
          "schema_version": "mn.blueprint.human_events.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "human_events"
        },
        {
          "artifact_id": "safety_video_analysis",
          "mime_type": "application/json",
          "path": "video_analysis.json",
          "producer": "video_understanding_agent",
          "schema_version": "otterdesk.safety_video_analysis.v1",
          "source_refs": [
            "inputs.json"
          ],
          "type": "safety_video_analysis"
        },
        {
          "artifact_id": "safety_video_report_json",
          "mime_type": "application/json",
          "path": "safety_video_report.json",
          "producer": "write_safety_report",
          "schema_version": "otterdesk.safety_video_report.v1",
          "source_refs": [
            "video_analysis.json",
            "events.jsonl"
          ],
          "type": "safety_video_report"
        },
        {
          "artifact_id": "safety_video_report_markdown",
          "mime_type": "text/markdown",
          "path": "safety_video_report.md",
          "producer": "write_safety_report",
