{
  "agentic_research": {
    "agent_ids": [
      "research_goal_framer",
      "research_evidence_curator",
      "autonomous_researcher",
      "research_packet_auditor",
      "research_report_writer"
    ],
    "allow_generated_code": true,
    "allow_goal_refinement": true,
    "allow_prompt_creation": true,
    "allowed_tools": [
      "document_extract",
      "browser_search",
      "browser_page",
      "knowledge_retrieve",
      "hypothesis_rank",
      "generated_python",
      "finish"
    ],
    "default_mode": "isolated_autonomous_research",
    "enabled": true,
    "generated_code": {
      "language": "python",
      "max_memory_mb": 256,
      "max_output_chars": 20000,
      "timeout_seconds": 15,
      "workspace": "generated_research"
    },
    "isolation": {
      "autonomous_node": "autonomous_researcher",
      "reuse_shared_sandbox": true,
      "runner": "openshell",
      "single_job_instance": true
    },
    "max_iterations_per_agent": 3,
    "max_tool_calls_per_agent": 4,
    "max_total_tool_calls": 12,
    "note": "One job-scoped OpenShell worker owns every autonomous subphase. It may refine goals, create prompts, request allowlisted mn-skills tools, and execute bounded generated Python; deterministic stages prepare evidence and verify all outputs.",
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run"
  },
  "agents": {
    "registry": {
      "research_goal_framer": {
        "handler": "agents.research_goal_framer",
        "role": "Research Goal Framer"
      },
      "research_evidence_curator": {
        "handler": "agents.research_evidence_curator",
        "role": "Research Evidence Curator"
      },
      "autonomous_researcher": {
        "handler": "agents.autonomous_researcher",
        "role": "Autonomous Researcher"
      },
      "research_packet_auditor": {
        "handler": "agents.research_packet_auditor",
        "role": "Research Packet Auditor"
      },
      "research_report_writer": {
        "handler": "agents.research_report_writer",
        "role": "Research Report Writer"
      }
    }
  },
  "apiVersion": "mn.workflow.source/v2",
  "config": {
    "default": "config/default.json",
    "embed": true,
    "manifest_defaults": [
      "llm",
      "knowledge_rag",
      "agentic_research",
      {
        "from": "requirements",
        "to": "resources"
      },
      {
        "from": "workflow.policy.human",
        "to": "human_control"
      },
      {
        "from": "contracts.input_adapters.supported",
        "to": "interfaces.input_adapters"
      },
      {
        "from": "identity.id",
        "to": "identity.blueprint_id"
      },
      {
        "from": "identity.name",
        "to": "identity.name"
      }
    ]
  },
  "contracts": {
    "events": {
      "human_stream": "human.jsonl",
      "stream": "events.jsonl",
      "types": [
        "run_started",
        "inputs_loaded",
        "large_context_seeded",
        "simulation_step_started",
        "memory_context_compiled",
        "llm_decision",
        "benchmark_step_scored",
        "simulation_state_updated",
        "run_completed",
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "artifact_written",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
        "output_skill_started",
        "output_skill_completed",
        "output_skill_failed",
        "autonomous_research_started",
        "autonomous_research_completed",
        "autonomous_prompt_created",
        "autonomous_tool_called",
        "generated_code_executed",
        "deterministic_verification_completed"
      ]
    },
    "input_adapters": {
      "default": "mock",
      "resolved_artifact": "inputs.json",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ]
    },
    "inputs": {
      "constraints": {
        "description": "Safety, ethics, budget, data, or policy constraints.",
        "example": {
          "no_live_system_changes": true
        },
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "input_folder": {
        "description": "Local papers, notes, datasets, and evidence approved for this run.",
        "example": "examples/sample_inputs",
        "path_kind": "directory",
        "privacy": "confidential",
        "required": false,
        "type": "local_path"
      },
      "output_folder": {
        "description": "Folder for the research packet and supporting ledgers.",
        "example": "~/Downloads/research_coscientist",
        "path_kind": "directory",
        "privacy": "confidential",
        "required": false,
        "type": "local_path"
      },
      "research_domain": {
        "description": "Optional domain used to frame terminology and methods.",
        "example": "engineering",
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "research_goal": {
        "description": "The outcome, mechanism, or problem to investigate.",
        "example": "Reduce energy use in a small data-center cooling loop without compromising thermal safety.",
        "privacy": "confidential",
        "required": true,
        "type": "domain_value"
      },
      "research_question": {
        "description": "Optional answerable question or decision boundary.",
        "example": "Which controllable interventions should be tested first?",
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "scope": {
        "description": "Optional exclusions, time horizon, and permitted research activities.",
        "example": "Desk research and experiment planning only.",
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "seed_hypotheses": {
        "description": "Optional human-provided ideas to challenge and refine.",
        "example": [
          "Variable-speed pumping may reduce energy use at low thermal load."
        ],
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "success_criteria": {
        "description": "Optional criteria for a useful research packet.",
        "example": [
          "testable hypotheses",
          "traceable evidence"
        ],
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      }
    },
    "outputs": {
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "logs",
          "mime_type": "application/x-jsonlines",
          "path": "logs.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.logs.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "logs"
        },
        {
          "artifact_id": "resources",
          "mime_type": "application/x-jsonlines",
          "path": "resources.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.resources.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "resource_samples"
        },
        {
          "artifact_id": "web_ui",
          "mime_type": "application/json",
          "path": "web_ui.json",
          "producer": "web_ui",
          "schema_version": "mn.blueprint.web_ui.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "web_ui"
        },
        {
          "artifact_id": "human_events",
          "mime_type": "application/x-jsonlines",
          "path": "human.jsonl",
          "producer": "human_control",
          "schema_version": "mn.blueprint.human_events.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "human_events"
        },
        {
          "artifact_id": "research_packet",
          "mime_type": "application/json",
          "path": "research_packet.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.research_coscientist.v2",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "research_packet"
        },
        {
          "artifact_id": "research_brief",
          "mime_type": "text/markdown",
          "path": "research_brief.md",
          "producer": "workflow",
          "schema_version": "mn.blueprint.research_coscientist_brief.v2",
          "source_refs": [
            "research_packet.json"
          ],
          "type": "research_brief"
        },
        {
          "artifact_id": "evidence_ledger",
          "mime_type": "application/json",
          "path": "evidence_ledger.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.evidence_ledger.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "evidence_ledger"
        },
        {
          "artifact_id": "hypothesis_ledger",
          "mime_type": "application/json",
          "path": "hypothesis_ledger.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.hypothesis_ledger.v1",
          "source_refs": [
            "research_packet.json"
          ],
          "type": "hypothesis_ledger"
        },
        {
          "artifact_id": "review_ledger",
          "mime_type": "application/json",
          "path": "review_ledger.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.review_ledger.v1",
          "source_refs": [
            "research_packet.json"
          ],
          "type": "review_ledger"
        },
        {
          "artifact_id": "artifact_quality",
          "mime_type": "application/json",
          "path": "artifact_quality.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.artifact_quality.v1",
          "source_refs": [
            "research_packet.json"
          ],
          "type": "artifact_quality"
        },
        {
          "artifact_id": "run_health",
          "mime_type": "application/json",
          "path": "run_health.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.run_health.v1",
          "source_refs": [
            "research_packet.json"
          ],
          "type": "run_health"
        }
      ],
      "primary": {
        "id": "final_artifact",
        "path": "final_artifact.json",
        "required_fields": [
          "type",
          "status",
          "executive_summary",
          "recommended_action",
          "confidence",
          "evidence",
          "next_steps",
          "source_refs",
          "provenance_refs"
        ],
        "schema_version": "mn.blueprint.final_artifact_contract.v1",
        "type": "final_artifact"
      },
      "profile": "standard_run_store"
    },
    "privacy": {
      "default_classification": "confidential",
      "rules": {
        "confidential": {
          "log": "redacted",
          "send_to_llm": "allowed_configs_only",
          "send_to_output_skills": "approved_destinations_only"
        },
        "internal": {
          "log": "metadata_only",
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "public": {
          "log": true,
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "regulated": {
          "log": "redacted",
          "send_to_llm": false,
          "send_to_output_skills": "approved_destinations_only"
        }
      }
    },
    "status": {
      "event": "blueprint_status",
      "heartbeat": true,
      "phases": [
        "loading_inputs",
        "running_worker",
        "waiting_for_human",
        "writing_artifacts",
        "completed"
      ]
    },
    "summary": "Find, evaluate, critique, and draft research directions with an explicit evidence ledger and human review boundary.",
    "users": [
      "Researchers, scientists, engineers, analysts, and research leads."
    ]
  },
  "defaults": {
    "worker": {
      "with": {
        "stereotype": "internal_write_worker",
        "image": "mirror-neuron/research-coscientist:local"
      }
    }
  },
  "identity": {
    "category": "Science",
    "id": "research_coscientist",
    "job_name": "research-coscientist",
    "manifest_version": "1.0",
    "name": "Research Co-Scientist",
    "version": 1
  },
  "intent": {
    "description": "A research co-scientist combining deterministic evidence and verification stages with one isolated OpenShell worker for autonomous, tool-driven exploration and bounded generated-code experiments.",
    "problem": "Research teams need to explore many possible explanations while preserving evidence, exposing counterarguments, and keeping experiments and claims under human control.",
    "safety": {
      "allowed_decisions": [
        "approve",
        "revise",
        "reject"
      ],
      "blocked_actions": [
        "execute_unapproved_experiment",
        "claim_validated_result",
        "publish_or_submit_manuscript",
        "contact_external_research_participant",
        "make_clinical_or_safety_decision"
      ],
      "decision_event": "human_decision_applied",
      "default_action": "reject",
      "enabled": true,
      "events": [
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied"
      ],
      "mode": "approval_required",
      "reason": "Human approval is required before experiments, public claims, manuscripts, participant contact, or consequential scientific and safety decisions.",
      "request_event": "human_input_requested",
      "response_event": "human_input_received",
      "timeout_event": "human_input_timeout",
      "timeout_seconds": 3600
    },
    "target_users": "Researchers, scientists, engineers, analysts, and research leads."
  },
  "kind": "WorkflowSource",
  "knowledge_rag": {
    "backend": "milvus_lite",
    "chunk_overlap": 70,
    "chunk_size": 700,
    "embedding_api_base": "auto",
    "embedding_document_prefix": "Document: ",
    "embedding_healthcheck_enabled": true,
    "embedding_model": "rag-embedding",
    "embedding_provider": "docker_model_runner",
    "embedding_query_prefix": "Query: ",
    "embedding_start_command": "",
    "enabled": true,
    "grounding_policy": "Use retrieved material to locate and evaluate evidence; label hypotheses, inferences, and unknowns rather than treating them as facts.",
    "index_on_startup": true,
    "knowledge_dir": "knowledge",
    "max_context_chars": 4000,
    "namespace": "",
    "privacy": "Index checked-in guidance and approved local input files in an isolated per-run namespace; never send private records, credentials, or participant data to public research.",
    "purpose": "Retrieve research-method guidance, evidence-quality checks, and approved local documents for topic framing, hypothesis critique, experiment design, and drafting.",
    "required": false,
    "retrieval_targets": [
      "research question and scope framing",
      "literature and source-quality evaluation",
      "hypothesis and counter-hypothesis criteria",
      "experiment, benchmark, and analysis planning",
      "evidence gaps, ethics, safety, and human-review checks"
    ],
    "top_k": 4,
    "vector_dim": 1024
  },
  "manifest": {
    "input_validation": {
      "required": [
        "research_goal"
      ],
      "rules": []
    },
    "license": "LICENSE.md",
    "policies": {
      "recovery_mode": "local_restart"
    },
    "requiredContextEngine": false,
    "term": "TERM.md"
  },
  "metadata": {
    "blueprint_id": "research_coscientist",
    "job_data": {
      "resources": [
        {
          "name": "knowledge",
          "path": "knowledge",
          "access": "read_write",
          "seed": "@/payloads/knowledge"
        },
        {
          "name": "rag",
          "path": "databases/rag",
          "access": "read_write"
        },
        {
          "name": "state",
          "path": "state",
          "access": "read_write"
        }
      ]
    }
  },
  "requirements": {
    "cpu": {
      "min_cores": 1
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    },
    "memory": {
      "min_gb": 2
    }
  },
  "skill_dependencies": [
    {
      "name": "mirrorneuron-blueprint-support-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-llm-ocr-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-rag-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-w3m-browser-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-web-browser-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-autonomous-research-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    }
  ],
  "agent_dependencies": [
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-stateful-step-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-bounded-tool-loop-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-actor-review-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-artifact-finalizer-agent",
      "version": "1.2.29"
    }
  ],
  "standard": {
    "migration_policy": "sdk_managed",
    "profile": "blueprint",
    "source_schema": "mn.workflow.source/v2",
    "target_schema": "mn.workflow/v1"
  },
  "workflow": {
    "workflow_id": "research_coscientist_v1",
    "execution": {
      "strategy": "parallel"
    },
    "policy": {
      "failure": {
        "default": "fail_closed"
      },
      "human": {
        "allowed_decisions": [
          "approve",
          "revise",
          "reject"
        ],
        "blocked_actions": [
          "execute_unapproved_experiment",
          "claim_validated_result",
          "publish_or_submit_manuscript",
          "contact_external_research_participant",
          "make_clinical_or_safety_decision"
        ],
        "decision_event": "human_decision_applied",
        "default_action": "reject",
        "enabled": true,
        "events": [
          "human_notice",
          "human_input_requested",
          "human_input_received",
          "human_input_timeout",
          "human_decision_applied"
        ],
        "mode": "approval_required",
        "reason": "Human approval is required before experiments, public claims, manuscripts, participant contact, or consequential scientific and safety decisions.",
        "request_event": "human_input_requested",
        "response_event": "human_input_received",
        "timeout_event": "human_input_timeout",
        "timeout_seconds": 3600
      }
    },
    "state": {
      "input_folder": {
        "from": "$inputs.input_folder"
      },
      "output_folder": {
        "from": "$inputs.output_folder"
      },
      "workflow": {},
      "final_report": {}
    },
    "steps": [
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 900,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Turn the request into answerable questions, definitions, success criteria, assumptions, and stop conditions.",
        "id": "frame_research_problem",
        "kind": "source",
        "label": "Frame Research Problem",
        "needs": [],
        "run": {
          "definition": "steps.frame_research_problem"
        }
      },
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 1800,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Extract approved local evidence, retrieve method guidance, and record bounded public-source observations.",
        "id": "build_research_evidence",
        "kind": "stage",
        "label": "Build Research Evidence",
        "needs": [
          "frame_research_problem"
        ],
        "run": {
          "definition": "steps.build_research_evidence"
        }
      },
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 2400,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Use one isolated OpenShell worker to generate, critique, rank, and test bounded hypothesis analyses.",
        "id": "develop_and_challenge_hypotheses",
        "kind": "stage",
        "label": "Develop And Challenge Hypotheses",
        "needs": [
          "build_research_evidence"
        ],
        "run": {
          "definition": "steps.develop_and_challenge_hypotheses"
        }
      },
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 1800,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Deterministically audit traceability, falsifiability, controls, safety gates, and publish the review packet.",
        "id": "verify_and_publish_research_packet",
        "kind": "sink",
        "label": "Verify And Publish Research Packet",
        "needs": [
          "develop_and_challenge_hypotheses"
        ],
        "run": {
