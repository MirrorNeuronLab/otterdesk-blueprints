  "llm": {
    "enabled": true,
    "agent_role": "Multi-agent research team that finds, evaluates, critiques, and drafts evidence-grounded research directions.",
    "agents": {
      "research:topic_finder": {
        "llm_config": "primary",
        "role": "Research goal framer",
        "responsibilities": [
          "Turn the goal into answerable questions and definitions.",
          "Separate supplied facts, assumptions, and unknowns.",
          "Define scope and success criteria without inventing evidence."
        ]
      },
      "research:literature_reviewer": {
        "llm_config": "primary",
        "role": "Literature reviewer",
        "responsibilities": [
          "Find relevant evidence in approved local and public sources.",
          "Record source references, dates, and access limits.",
          "Distinguish primary evidence from commentary and unsupported claims."
        ]
      },
      "research:idea_generator": {
        "llm_config": "primary",
        "role": "Hypothesis generator",
        "responsibilities": [
          "Propose distinct, falsifiable hypotheses grounded in the evidence ledger.",
          "State mechanisms, predictions, and disconfirming observations.",
          "Avoid claiming hypotheses are validated."
        ]
      },
      "research:skeptic": {
        "llm_config": "primary",
        "role": "Skeptic and reflection reviewer",
        "responsibilities": [
          "Challenge causal leaps, confounders, novelty claims, and missing controls.",
          "Identify plausible competing explanations.",
          "Return actionable critique with source or method gaps."
        ]
      },
      "research:proximity_reviewer": {
        "llm_config": "primary",
        "role": "Proximity and novelty reviewer",
        "responsibilities": [
          "Compare candidates for conceptual overlap with retrieved evidence.",
          "Flag duplicate, incremental, or already-supported ideas.",
          "Explain novelty as a bounded assessment, not a guarantee."
        ]
      },
      "research:experiment_designer": {
        "llm_config": "primary",
        "role": "Experiment designer",
        "responsibilities": [
          "Translate high-value hypotheses into falsifiable study plans.",
          "Specify controls, measurements, decision rules, and failure modes.",
          "Mark ethics, safety, approval, or feasibility dependencies."
        ]
      },
      "research:code_implementer": {
        "llm_config": "primary",
        "role": "Code implementation planner",
        "responsibilities": [
          "Outline reproducible analysis or simulation work needed for a test.",
          "Identify datasets, dependencies, and validation checks.",
          "Do not run unapproved code against external systems."
        ]
      },
      "research:benchmark_runner": {
        "llm_config": "primary",
        "role": "Benchmark planning reviewer",
        "responsibilities": [
          "Define baseline comparisons and evaluation metrics.",
          "Check whether proposed benchmarks answer the question.",
          "Expose data leakage, overfitting, and reproducibility risks."
        ]
      },
      "research:result_analyst": {
        "llm_config": "primary",
        "role": "Result analysis planner",
        "responsibilities": [
          "Specify how results would be interpreted under uncertainty.",
          "List alternative explanations and sensitivity checks.",
          "Prohibit causal or clinical conclusions beyond the evidence."
        ]
      },
      "research:paper_writer": {
        "llm_config": "primary",
        "role": "Research brief writer",
        "responsibilities": [
          "Draft an evidence-grounded research brief.",
          "Carry uncertainty, counterarguments, and citations into the draft.",
          "Keep language proportional to evidence strength."
        ]
      },
      "research:meta_reviewer": {
        "llm_config": "primary",
        "role": "Meta-reviewer and ranking auditor",
        "responsibilities": [
          "Rank candidates using traceable criteria.",
          "Audit evidence coverage and review boundaries.",
          "Recommend revision or human review rather than self-approval."
        ]
      },
      "research:evidence_ranker": {
        "llm_config": "primary",
        "role": "Evidence ranking reviewer",
        "responsibilities": [
          "Rate source traceability, relevance, and methodological strength.",
          "Identify conflicts, stale evidence, and unverified claims.",
          "Keep ranking criteria explicit and non-authoritative."
        ]
      }
    },
    "responsibilities": [
      "Keep source evidence, uncertainty, and counterarguments visible.",
      "Use specialized roles to generate and challenge research hypotheses.",
      "Keep experiments, conclusions, and external actions review-only until a person approves them."
    ],
    "provider": "docker_model_runner",
    "model": "default",
    "backend": "llama.cpp",
    "mode": "live",
    "mock_mode": "fake",
    "default_config": "primary",
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "backend": "llama.cpp",
        "api_base": "auto",
        "timeout_seconds": 60,
        "max_tokens": 900,
        "num_retries": 1,
        "mock_mode": "fake",
        "mode": "live"
      }
    }
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "large_context_seeded",
      "simulation_step_started",
      "memory_context_compiled",
      "llm_decision",
      "benchmark_step_scored",
      "simulation_state_updated",
      "run_completed",
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed",
      "autonomous_research_started",
      "autonomous_research_completed",
      "autonomous_prompt_created",
      "autonomous_tool_called",
      "generated_code_executed",
      "deterministic_verification_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "resources_jsonl": true,
    "rotation": {
      "check_interval_records": 100,
      "compress": "background",
      "enabled": true,
      "max_bytes_mb": 100,
      "max_segments": 7,
      "span_seconds": 86400
    },
    "stderr_jsonl": true,
    "writer": {
      "batch_size": 100,
      "flush_interval_seconds": 0.5,
      "mode": "async",
      "overflow_policy": "drop_low_priority",
      "queue_size": 10000,
      "shutdown_flush_timeout_seconds": 2
    }
  },
  "memory": {
    "compression_goal": "replace full-history agent handoffs with a compact source-grounded decision packet while preserving older critical facts",
    "enabled": true,
    "mode": "compare",
    "retrieval_tags": [
      "critical",
      "demand_tailwind",
      "rent_growth",
      "risk_flag",
      "financing"
    ],
    "selection_limit": 36
  },
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "research_coscientist_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "agentic_research": {
    "enabled": true,
    "isolation": {
      "runner": "openshell",
      "single_job_instance": true,
      "reuse_shared_sandbox": true,
      "autonomous_node": "autonomous_research"
    },
    "agent_ids": [
      "research:benchmark_runner",
      "research:code_implementer",
      "research:evidence_ranker",
      "research:experiment_designer",
      "research:idea_generator",
      "research:literature_reviewer",
      "research:meta_reviewer",
      "research:paper_writer",
      "research:proximity_reviewer",
      "research:result_analyst",
      "research:skeptic",
      "research:topic_finder"
    ],
    "max_iterations_per_agent": 3,
    "max_tool_calls_per_agent": 4,
    "max_total_tool_calls": 12,
    "allow_goal_refinement": true,
    "allow_prompt_creation": true,
    "allow_generated_code": true,
    "generated_code": {
      "language": "python",
      "timeout_seconds": 15,
      "max_output_chars": 20000,
      "max_memory_mb": 256,
      "workspace": "generated_research"
    },
    "allowed_tools": [
      "document_extract",
      "browser_search",
      "browser_page",
      "knowledge_retrieve",
      "hypothesis_rank",
      "generated_python",
      "finish"
    ],
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run",
    "default_mode": "isolated_autonomous_research",
    "note": "One job-scoped OpenShell worker owns every autonomous subphase. It may refine goals, create prompts, request allowlisted mn-skills tools, and execute bounded generated Python; deterministic stages prepare evidence and verify all outputs."
  },
  "knowledge_rag": {
    "enabled": true,
    "backend": "milvus_lite",
    "required": false,
    "knowledge_dir": "knowledge",
    "purpose": "Retrieve research-method guidance, evidence-quality checks, and approved local documents for topic framing, hypothesis critique, experiment design, and drafting.",
    "retrieval_targets": [
      "research question and scope framing",
      "literature and source-quality evaluation",
      "hypothesis and counter-hypothesis criteria",
      "experiment, benchmark, and analysis planning",
      "evidence gaps, ethics, safety, and human-review checks"
    ],
    "grounding_policy": "Use retrieved material to locate and evaluate evidence; label hypotheses, inferences, and unknowns rather than treating them as facts.",
    "namespace": "",
    "embedding_provider": "docker_model_runner",
    "embedding_model": "rag-embedding",
    "embedding_api_base": "auto",
    "embedding_query_prefix": "Query: ",
    "embedding_document_prefix": "Document: ",
    "embedding_start_command": "",
    "embedding_healthcheck_enabled": true,
    "vector_dim": 1024,
    "index_on_startup": true,
    "top_k": 4,
    "max_context_chars": 4000,
    "chunk_size": 700,
    "chunk_overlap": 70,
    "privacy": "Index checked-in guidance and approved local input files in an isolated per-run namespace; never send private records, credentials, or participant data to public research."
  },
