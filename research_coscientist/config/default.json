{
  "agent_handoffs": {},
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 30,
      "max_concurrent_calls": 1,
      "min_interval_seconds": 2.0,
      "rationale": "Protect local Docker Model Runner from concurrent blueprint actor calls."
    },
    "max_concurrency": 4,
    "max_events_per_second": 10,
    "queue_size": 1000
  },
  "benchmark": {
    "baseline": "all_context",
    "enabled": true,
    "quality_metrics": [
      "evidence_traceability",
      "hypothesis_falsifiability",
      "counterargument_coverage",
      "experiment_design_quality",
      "uncertainty_calibration",
      "token_reduction_ratio"
    ],
    "schema_version": "mn.science.research_coscientist.v2"
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 20,
    "max_disk_mb": 250,
    "max_llm_calls": 20,
    "max_llm_tokens": 20000,
    "max_runtime_seconds": 600,
    "max_stream_duration_seconds": 3600
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "network.egress",
      "stream.subscribe",
      "knowledge.rag",
      "llm.tool_plan"
    ],
    "required": [
      "filesystem.write"
    ]
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "evaluate_workflow_state",
    "route_by_context",
    "request_human_input",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact",
    "fan_out_output_skills",
    "emit_status_events",
    "handle_human_control",
    "write_artifact_records"
  ],
  "human_control": {
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "execute_unapproved_experiment",
      "claim_validated_result",
      "publish_or_submit_manuscript",
      "contact_external_research_participant",
      "make_clinical_or_safety_decision"
    ],
    "decision_event": "human_decision_applied",
    "default_action": "reject",
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "approval_required",
    "reason": "Human approval is required before experiments, public claims, manuscripts, participant contact, or consequential scientific and safety decisions.",
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "timeout_seconds": 3600
  },
  "identity": {
    "blueprint_id": "research_coscientist",
    "name": "Research Co-Scientist"
  },
  "input_skills": {
    "llm_ocr": {
      "skill": "llm_ocr_skill",
      "package": "mirrorneuron-llm-ocr-skill",
      "enabled": true,
      "required": false,
      "min_text_chars": 40
    },
    "w3m_browser": {
      "skill": "w3m_browser_skill",
      "package": "mirrorneuron-w3m-browser-skill",
      "enabled": true,
      "required": false,
      "purpose": "Primary public text-browser research for source-grounded literature discovery."
    },
    "web_browser": {
      "skill": "web_browser_skill",
      "package": "mirrorneuron-web-browser-skill",
      "enabled": true,
      "required": false,
      "purpose": "Optional rendered-browser fallback for public pages that require JavaScript."
    }
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic large-context inputs bundled with the blueprint.",
    "payload": {
      "research_goal": "Identify testable, non-clinical strategies for reducing energy use in a small data-center cooling loop.",
      "research_domain": "engineering",
      "research_question": "Which controllable cooling-loop interventions are most plausible to test first, and what evidence would distinguish them?",
      "scope": "Desk research and experiment planning only; no live system changes.",
      "success_criteria": [
        "testable hypotheses",
        "traceable evidence",
        "falsifiable experiment plan",
        "explicit uncertainty"
      ],
      "constraints": {
        "no_live_system_changes": true,
        "require_human_review": true,
        "max_hypotheses": 3
      },
      "seed_hypotheses": [],
      "input_folder": "research_coscientist/examples/sample_inputs",
      "output_folder": "~/Download/research_coscientist"
    }
  },
