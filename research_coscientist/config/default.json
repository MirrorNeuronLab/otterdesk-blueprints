    "problem_solved": "Research teams need to explore many possible explanations while preserving evidence, exposing counterarguments, and keeping experiments and claims under human control.",
    "simulation_type": "Multi-agent research workflow with literature review, hypothesis generation, adversarial critique, experiment design, and drafting.",
    "standard_version": "1.0",
    "target_user": "Researchers, scientists, engineers, analysts, and research leads.",
