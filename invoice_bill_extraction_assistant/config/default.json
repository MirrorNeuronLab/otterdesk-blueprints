{
  "standard_version": "mn.blueprint.config.v1",
  "identity": {
    "blueprint_id": "invoice_bill_extraction_assistant",
    "name": "Invoice Bill Extraction Assistant"
  },
  "mode": "document_automation_review",
  "metadata": {
    "category": "Finance",
    "description": "An invoice and bill extraction co-worker for accounts-payable review. Put invoice, bill, or utility PDF/JSON files in the input folder; it OCRs and extracts supplier, customer, invoice ID, tax, due date, total, line item, billing period, and consumption fields, then writes a review-only extraction packet and source-grounded report to the output folder."
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default demo inputs use the public dataset reference; for real use select a local downloaded dataset folder.",
    "payload": {
      "document_folder": "invoice_bill_extraction_assistant/examples/sample_inputs",
      "output_folder": "~/Download/invoice_bill_extraction_assistant",
      "field_profile": [
        "supplier_name",
        "customer_name",
        "invoice_id",
        "tax_id",
        "due_date",
        "total_amount",
        "line_items",
        "consumption_fields",
        "billing_period"
      ],
      "public_dataset": {
        "name": "IDSEM Dataset",
        "provider": "University of Las Palmas de Gran Canaria on Zenodo",
        "url": "https://zenodo.org/records/6373179",
        "license": "Dataset record on Zenodo; review source terms before production use.",
        "availability_note": "Public Zenodo dataset with electricity bill PDFs and JSON labels; includes reduced preview subsets as described by the dataset record.",
        "expected_files": [
          "*.pdf",
          "*.json"
        ],
        "download_hint": "Use the reduced preview first; the full idsem.zip is large."
      },
      "input_folder": "invoice_bill_extraction_assistant/examples/sample_inputs"
    }
  },
  "document_sources": {
    "folder_path": "invoice_bill_extraction_assistant/examples/sample_inputs",
    "expected_files": [
      "*.pdf",
      "*.json"
    ],
    "public_dataset_url": "https://zenodo.org/records/6373179"
  },
  "dataset_input": {
    "name": "IDSEM Dataset",
    "provider": "University of Las Palmas de Gran Canaria on Zenodo",
    "url": "https://zenodo.org/records/6373179",
    "license": "Dataset record on Zenodo; review source terms before production use.",
    "availability_note": "Public Zenodo dataset with electricity bill PDFs and JSON labels; includes reduced preview subsets as described by the dataset record.",
    "expected_files": [
      "*.pdf",
      "*.json"
    ],
    "download_hint": "Use the reduced preview first; the full idsem.zip is large."
  },
  "document_automation": {
    "fields": [
      "supplier_name",
      "customer_name",
      "invoice_id",
      "tax_id",
      "due_date",
      "total_amount",
      "line_items",
      "consumption_fields",
      "billing_period"
    ],
    "output_type": "invoice_bill_extraction_packet",
    "review_required": true,
    "recommended_action": "review_extracted_invoice_fields_before_erp_or_payment_use"
  },
  "llm": {
    "model": "default",
    "enabled": true,
    "mode": "live",
    "mock_mode": "fake",
    "default_config": "primary",
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "responsibilities": [
      "Keep OCR and field extraction deterministic and evidence-bound.",
      "Use actors to review payable fields, utility bill details, and approval risks.",
      "Require human review before ERP, payment, or accounting use."
    ],
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "model": "default",
        "api_base": "http://localhost:12434/engines/v1",
        "timeout_seconds": 60,
        "max_tokens": 900,
        "num_retries": 1,
        "mock_mode": "fake",
        "mode": "live"
      }
    },
    "agents": {
      "invoice_dataset_intake": {
        "llm_config": "primary",
        "model": "default",
        "role": "Invoice intake coordinator",
        "responsibilities": [
          "Stage invoice and utility-bill inputs.",
          "Check dataset provenance and expected files.",
          "Flag missing or unreadable documents."
        ]
      },
      "invoice_ocr_extractor": {
        "llm_config": "primary",
        "model": "default",
        "role": "Invoice OCR reader",
        "responsibilities": [
          "Review OCR text quality and extraction warnings.",
          "Keep source-page evidence attached to extracted fields.",
          "Flag documents needing manual review."
        ]
      },
      "invoice_text_redactor": {
        "llm_config": "primary",
        "model": "default",
        "role": "Payables privacy redactor",
        "responsibilities": [
          "Redact identifiers before actor summaries.",
          "Preserve non-sensitive payable evidence.",
          "Flag unredacted sensitive fields."
        ]
      },
      "ap_field_extractor": {
        "llm_config": "primary",
        "model": "default",
        "role": "Accounts-payable field extractor",
        "responsibilities": [
          "Review supplier, customer, invoice, due-date, and total fields.",
          "Tie field confidence to source evidence.",
          "Flag ambiguous payable values."
        ]
      },
      "utility_bill_specialist": {
        "llm_config": "primary",
        "model": "default",
        "role": "Utility bill specialist",
        "responsibilities": [
          "Review billing period and consumption fields.",
          "Explain utility-specific extraction caveats.",
          "Flag missing meter or tax details."
        ]
      },
      "invoice_label_validator": {
        "llm_config": "primary",
        "model": "default",
        "role": "Invoice label validator",
        "responsibilities": [
          "Compare extracted labels against expected field profile.",
          "Flag inconsistent totals or dates.",
          "Keep validation review-only."
        ]
      },
      "ap_report_writer": {
        "llm_config": "primary",
        "model": "default",
        "role": "Accounts-payable report writer",
        "responsibilities": [
          "Prepare the review packet narrative.",
          "Summarize evidence, warnings, and next steps.",
          "Require approval before ERP or payment use."
        ]
      }
    }
  },
  "outputs": {
    "folder_path": "~/Download/invoice_bill_extraction_assistant",
    "write_run_store": true,
    "write_markdown_report": true
  },
  "logging": {
    "level": "info",
    "events_jsonl": true,
    "logs_jsonl": true,
    "resources_jsonl": true,
    "stderr_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key",
      "ssn",
      "taxpayer_id",
      "account_number",
      "medical_record_number"
    ],
    "events": [
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed",
      "invoice_inputs_staged",
      "invoice_text_extracted",
      "payable_fields_extracted",
      "invoice_packet_validated",
      "invoice_packet_written"
    ]
  },
  "resources": {
    "cpu": {
      "min_cores": 1
    },
    "memory": {
      "min_gb": 2
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    }
  },
  "human_control": {
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "approve_invoice_for_payment",
      "post_to_erp",
      "send_payment_instruction",
      "email_vendor_without_review"
    ],
    "decision_event": "human_decision_applied",
    "default_action": "reject",
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "approval_required",
    "reason": "Human approval is required before any downstream release, filing, payment, legal, clinical, credit, or system-sync action.",
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "timeout_seconds": 3600
  },
  "input_skills": {
    "llm_ocr": {
      "skill": "llm_ocr_skill",
      "package": "mirrorneuron-llm-ocr-skill",
      "connector": "docker_model_runner",
      "purpose": "shared local LightOnOCR-2-1B OCR for scanned PDFs, images, forms, statements, and bills",
      "enabled": true,
      "required": false,
      "backend": "auto",
      "endpoint": "http://localhost:12434",
      "model": null,
      "quantization": null,
      "min_text_chars": 40,
      "max_pages": null,
      "preload": false,
      "install_policy": "on_first_required_document",
      "remove_policy": "manual",
      "require_hardware_acceleration": true,
      "timeout_seconds": 180
    }
  },
  "output_skills": {},
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "missing_folder": {
        "mode": "use_public_dataset_note"
      },
      "ocr_required": {
        "mode": "continue_with_review_warning"
      },
      "llm_call": {
        "mode": "retry",
        "max_attempts": 3,
        "backoff_seconds": 2
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "privacy": {
    "default_classification": "confidential",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "schemas": {
    "artifact_record": "mn.artifact.record.v1",
    "config": "mn.blueprint.config.v1",
    "events": "mn.blueprint.events.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "human_control": "mn.blueprint.human_control.v1",
    "input_skills": "mn.blueprint.input_skills.v1",
    "inputs": "mn.blueprint.inputs.v1",
    "logs": "mn.blueprint.logs.v1",
    "output_skills": "mn.blueprint.output_skills.v1",
    "resources": "mn.blueprint.resources.v1",
    "status_contract": "mn.blueprint.status_contract.v1",
    "web_ui": "mn.blueprint.web_ui.v1"
  },
  "budgets": {
    "max_runtime_seconds": 900,
    "max_llm_calls": 30,
    "max_llm_tokens": 60000,
    "max_disk_mb": 500,
    "max_connector_reads": 200,
    "max_connector_writes": 0
  },
  "capabilities": {
    "required": [
      "filesystem.read",
      "filesystem.write",
      "pdf.extract"
    ],
    "optional": [
      "document.ocr",
      "llm.ocr",
      "llm.call",
      "pdf.render"
    ]
  },
  "determinism": {
    "enabled": true,
    "seed_field": "seed",
    "replay": {
      "from_inputs": "inputs.json",
      "from_events": "events.jsonl",
      "llm_mode": "fake"
    },
    "frozen_clock": null
  },
  "backpressure": {
    "max_concurrency": 4,
    "queue_size": 1000,
    "max_events_per_second": 10,
    "llm": {
      "max_concurrent_calls": 2,
      "max_calls_per_minute": 30
    },
    "drop_policy": "skip_with_error"
  },
  "web_ui": {
    "enabled": true,
    "input": {
      "adapter": "none",
      "fields": [],
      "host": "127.0.0.1",
      "port": null,
      "share": false,
      "title": null,
      "instructions": null,
      "custom_url": null
    },
    "output": {
      "adapter": "gradio",
      "auto_generate": true,
      "refresh_seconds": 2,
      "title": "Invoice Bill Extraction Assistant",
      "custom_url": null
    },
    "dashboard": {
      "data_source": "local_run_store",
      "reads": [
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json",
        "web_ui.json"
      ],
      "panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ],
      "standard_panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ]
    }
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "description": "Stable run-store files and domain-specific document automation outputs.",
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl",
          "human.jsonl",
          "resources.jsonl",
          "*-review.md"
        ]
      },
      "events": {
        "artifact": "events.jsonl",
        "description": "Append-only workflow events."
      },
      "human": {
        "artifact": "human.jsonl",
        "description": "Human notices, approval requests, responses, timeouts, and applied decisions."
      },
      "input_skills": {
        "description": "Local filesystem intake plus shared llm_ocr_skill OCR through Docker Model Runner."
      },
      "inputs": {
        "artifact": "inputs.json",
        "description": "Resolved document folder, public dataset reference, and field extraction profile."
      },
      "logs": {
        "artifact": "logs.jsonl",
        "description": "Runtime stdout/stderr and redacted document automation logs.",
        "stream": "stdout/stderr"
      },
      "outputs": {
        "artifacts": [
          "result.json",
          "final_artifact.json",
          "*-review.md"
        ],
        "description": "Primary review packet and structured extraction results."
      },
      "resources": {
        "artifact": "resources.jsonl",
        "description": "Resource samples such as token, runtime, connector, and disk usage."
      },
      "web_ui": {
        "artifacts": [
          "web_ui.json",
          "ui.json",
          "web/index.html"
        ],
        "description": "Optional review dashboard for artifact inspection."
      }
    },
    "config": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "resources",
      "human_control",
      "real_adapters",
      "streams",
      "input_skills",
      "output_skills",
      "error_handling",
      "state",
      "capabilities",
      "privacy",
      "triggers",
      "backpressure",
      "determinism",
      "schemas",
      "budgets",
      "agent_handoffs",
      "web_ui",
      "interfaces",
      "execution_model",
      "memory_layer",
      "dataset_input",
      "document_automation"
    ],
    "config_sections": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "resources",
      "human_control",
      "real_adapters",
