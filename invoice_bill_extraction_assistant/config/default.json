    ],
    "identity": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "outputs": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ],
    "optional_outputs": [
      "job.json",
      "web_ui.json",
      "ui.json",
      "web/index.html",
      "logs.jsonl",
      "human.jsonl",
      "resources.jsonl",
      "*-review.md"
    ],
    "optional_run_artifacts": [
      "job.json",
      "web_ui.json",
      "ui.json",
      "web/index.html",
      "logs.jsonl",
      "human.jsonl",
      "resources.jsonl",
      "*-review.md"
    ],
    "response_schema": "mn.blueprint.response.v1",
    "web_ui_adapters": [
      "none",
      "static_html",
      "gradio",
      "custom"
    ]
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "extract_embedded_text_or_ocr",
    "redact_sensitive_values",
    "extract_structured_fields",
    "validate_against_public_labels_when_available",
    "request_human_review",
    "write_final_artifact",
    "write_artifact_records"
  ],
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "invoice_bill_extraction_assistant_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "state": {
    "document_folder": "invoice_bill_extraction_assistant/examples/sample_inputs",
    "output_folder": "~/Download/invoice_bill_extraction_assistant",
    "review": {},
    "final_report": {},
    "input_folder": "invoice_bill_extraction_assistant/examples/sample_inputs"
  },
  "triggers": {
    "manual": true,
    "schedule": false
  },
  "real_adapters": {
    "filesystem": {
      "enabled": true,
      "read": true,
      "write": true
    }
  },
  "streams": {
    "enabled": false
  },
  "simulation": {
    "enabled": false
  }
}
