{
  "standard_version": "mn.blueprint.config.v1",
  "identity": {
    "blueprint_id": "bank_statement_extraction_assistant",
    "name": "Bank Statement Extraction Assistant"
  },
  "mode": "document_automation_review",
  "metadata": {
    "category": "Finance",
    "description": "Extracts bank statement account metadata, balances, transaction rows, debits, credits, fees, and validation checks from local statement PDFs."
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default demo inputs use the public dataset reference; for real use select a local downloaded dataset folder.",
    "payload": {
      "document_folder": "",
      "output_folder": "/Users/homer/Download/bank_statement_extraction_assistant",
      "field_profile": [
        "account_holder",
        "account_number",
        "ifsc_or_routing",
        "statement_period",
        "opening_balance",
        "closing_balance",
        "transactions",
        "debits",
        "credits",
        "fees"
      ],
      "public_dataset": {
        "name": "AgamiAI Indian Bank Statement Synthetic Dataset",
        "provider": "AgamiAI on Hugging Face",
        "url": "https://huggingface.co/datasets/AgamiAI/Indian-Bank-Statements",
        "license": "Apache 2.0",
        "availability_note": "Public synthetic bank statement dataset with scanned PDFs and structured JSON metadata.",
        "expected_files": [
          "*.pdf",
          "*.json"
        ],
        "download_hint": "Use huggingface_hub or git-lfs to fetch a small sample before the full dataset."
      }
    }
  },
  "document_sources": {
    "folder_path": "",
    "expected_files": [
      "*.pdf",
      "*.json"
    ],
    "public_dataset_url": "https://huggingface.co/datasets/AgamiAI/Indian-Bank-Statements"
  },
  "dataset_input": {
    "name": "AgamiAI Indian Bank Statement Synthetic Dataset",
    "provider": "AgamiAI on Hugging Face",
    "url": "https://huggingface.co/datasets/AgamiAI/Indian-Bank-Statements",
    "license": "Apache 2.0",
    "availability_note": "Public synthetic bank statement dataset with scanned PDFs and structured JSON metadata.",
    "expected_files": [
      "*.pdf",
      "*.json"
    ],
    "download_hint": "Use huggingface_hub or git-lfs to fetch a small sample before the full dataset."
  },
  "document_automation": {
    "fields": [
      "account_holder",
      "account_number",
      "ifsc_or_routing",
      "statement_period",
      "opening_balance",
      "closing_balance",
      "transactions",
      "debits",
      "credits",
      "fees"
    ],
    "output_type": "bank_statement_extraction_packet",
    "review_required": true,
    "recommended_action": "review_transactions_and_balance_reconciliation_before_downstream_use"
  },
  "llm": {
    "model": "default"
  },
  "outputs": {
    "folder_path": "/Users/homer/Download/bank_statement_extraction_assistant",
    "write_run_store": true,
    "write_markdown_report": true
  },
  "logging": {
    "level": "info",
    "events_jsonl": true,
    "logs_jsonl": true,
    "resources_jsonl": true,
    "stderr_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key",
      "ssn",
      "taxpayer_id",
      "account_number",
      "medical_record_number"
    ],
    "events": [
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed",
      "bank_inputs_staged",
      "bank_text_extracted",
      "transaction_ledger_extracted",
      "statement_consistency_validated",
      "bank_statement_packet_written"
    ]
  },
  "resources": {
    "cpu": {
      "min_cores": 1
    },
    "memory": {
      "min_gb": 2
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    }
  },
  "human_control": {
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "approve_credit_decision",
      "sync_to_loan_system",
      "sync_to_accounting_system",
      "send_customer_report_without_review"
    ],
    "decision_event": "human_decision_applied",
    "default_action": "reject",
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "approval_required",
    "reason": "Human approval is required before any downstream release, filing, payment, legal, clinical, credit, or system-sync action.",
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "timeout_seconds": 3600
  },
  "input_skills": {
    "llm_ocr": {
      "skill": "llm_ocr_skill",
      "package": "mirrorneuron-llm-ocr-skill",
      "connector": "docker_model_runner",
      "purpose": "shared local LightOnOCR-2-1B OCR for scanned PDFs, images, forms, statements, and bills",
      "enabled": true,
      "required": false,
      "backend": "auto",
      "endpoint": "http://localhost:12434",
      "model": null,
      "quantization": null,
      "min_text_chars": 40,
      "max_pages": null,
      "preload": false,
      "install_policy": "on_first_required_document",
      "remove_policy": "manual",
      "require_hardware_acceleration": true,
      "timeout_seconds": 180
    }
  },
  "output_skills": {},
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "missing_folder": {
        "mode": "use_public_dataset_note"
      },
      "ocr_required": {
        "mode": "continue_with_review_warning"
      },
      "llm_call": {
        "mode": "retry",
        "max_attempts": 3,
        "backoff_seconds": 2
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "privacy": {
    "default_classification": "regulated",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "schemas": {
    "artifact_record": "mn.artifact.record.v1",
    "config": "mn.blueprint.config.v1",
    "events": "mn.blueprint.events.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "human_control": "mn.blueprint.human_control.v1",
    "input_skills": "mn.blueprint.input_skills.v1",
    "inputs": "mn.blueprint.inputs.v1",
    "logs": "mn.blueprint.logs.v1",
    "output_skills": "mn.blueprint.output_skills.v1",
    "resources": "mn.blueprint.resources.v1",
    "status_contract": "mn.blueprint.status_contract.v1",
    "web_ui": "mn.blueprint.web_ui.v1"
  },
  "budgets": {
    "max_runtime_seconds": 900,
    "max_llm_calls": 30,
    "max_llm_tokens": 60000,
    "max_disk_mb": 500,
    "max_connector_reads": 200,
    "max_connector_writes": 0
  },
  "capabilities": {
    "required": [
      "filesystem.read",
      "filesystem.write",
      "pdf.extract"
    ],
    "optional": [
      "document.ocr",
      "llm.ocr",
      "llm.call",
      "pdf.render"
    ]
  },
  "determinism": {
    "enabled": true,
    "seed_field": "seed",
    "replay": {
      "from_inputs": "inputs.json",
      "from_events": "events.jsonl",
      "llm_mode": "fake"
    },
    "frozen_clock": null
  },
  "backpressure": {
    "max_concurrency": 4,
    "queue_size": 1000,
    "max_events_per_second": 10,
    "llm": {
      "max_concurrent_calls": 2,
      "max_calls_per_minute": 30
    },
    "drop_policy": "skip_with_error"
  },
  "web_ui": {
    "enabled": true,
    "input": {
      "adapter": "none",
      "fields": [],
      "host": "127.0.0.1",
      "port": null,
      "share": false,
      "title": null,
      "instructions": null,
      "custom_url": null
    },
    "output": {
      "adapter": "gradio",
      "auto_generate": true,
      "refresh_seconds": 2,
      "title": "Bank Statement Extraction Assistant",
      "custom_url": null
    },
    "dashboard": {
      "data_source": "local_run_store",
      "reads": [
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json",
        "web_ui.json"
      ],
      "panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ],
      "standard_panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ]
    }
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "description": "Stable run-store files and domain-specific document automation outputs.",
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl",
          "human.jsonl",
          "resources.jsonl",
          "*-review.md"
        ]
      },
      "events": {
        "artifact": "events.jsonl",
        "description": "Append-only workflow events."
      },
      "human": {
        "artifact": "human.jsonl",
        "description": "Human notices, approval requests, responses, timeouts, and applied decisions."
      },
      "input_skills": {
        "description": "Local filesystem intake plus shared llm_ocr_skill OCR through Docker Model Runner."
      },
      "inputs": {
        "artifact": "inputs.json",
        "description": "Resolved document folder, public dataset reference, and field extraction profile."
      },
      "logs": {
        "artifact": "logs.jsonl",
        "description": "Runtime stdout/stderr and redacted document automation logs.",
        "stream": "stdout/stderr"
      },
      "outputs": {
        "artifacts": [
          "result.json",
          "final_artifact.json",
          "*-review.md"
        ],
        "description": "Primary review packet and structured extraction results."
      },
      "resources": {
        "artifact": "resources.jsonl",
        "description": "Resource samples such as token, runtime, connector, and disk usage."
      },
      "web_ui": {
        "artifacts": [
          "web_ui.json",
          "ui.json",
          "web/index.html"
        ],
        "description": "Optional review dashboard for artifact inspection."
      }
    },
    "config": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "resources",
      "human_control",
      "real_adapters",
      "streams",
