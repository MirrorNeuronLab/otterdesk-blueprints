{
  "agent_handoffs": {},
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 30,
      "max_concurrent_calls": 1,
      "min_interval_seconds": 2.0,
      "rationale": "Protect local Docker Model Runner from concurrent blueprint actor calls."
    },
    "max_concurrency": 4,
    "max_events_per_second": 25,
    "queue_size": 1000
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 20,
    "max_disk_mb": 250,
    "max_llm_calls": 20,
    "max_llm_tokens": 20000,
    "max_runtime_seconds": 600,
    "max_stream_duration_seconds": 3600
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "network.egress",
      "stream.publish",
      "stream.subscribe",
      "knowledge.rag",
      "llm.tool_plan"
    ],
    "required": [
      "filesystem.write",
      "stream.subscribe"
    ]
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "evaluate_workflow_state",
    "route_by_context",
    "request_human_input",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact",
    "fan_out_output_skills",
    "emit_status_events",
    "handle_human_control",
    "write_artifact_records"
  ],
  "human_control": {
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "notice_only",
    "notice_event": "human_notice",
    "reason": "The workflow surfaces notable visual changes to reviewers but does not execute physical security actions by itself.",
    "requires_ack": false
  },
  "identity": {
    "blueprint_id": "cctv_operator",
    "name": "CCTV Operator"
  },
  "input_skills": {},
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "alert_policy": {
        "cooldown_seconds": 120,
        "min_confidence": 0.55,
        "notify_on": [
          "person",
          "unattended package",
          "restricted-area entry"
        ]
      },
      "input_folder": "cctv_operator/examples/sample_inputs",
      "output_folder": "~/Download/cctv_operator",
      "source_mode": "folder",
      "video_source": "",
      "visual_targets": [
        "person",
        "unattended package",
        "restricted-area entry"
      ]
    }
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json",
          "cctv_report.json",
          "cctv_report.md"
        ],
        "description": "Stable run-store files and domain-specific outputs.",
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl",
          "cctv_report.json",
          "cctv_report.md"
        ]
      },
      "events": {
        "artifact": "events.jsonl",
        "description": "Append-only workflow events."
      },
      "human": {
        "artifact": "human.jsonl",
        "description": "Human notices, approval requests, responses, timeouts, and applied decisions.",
        "mirrored_to": "events.jsonl"
      },
      "input_skills": {
        "description": "Connector-backed or reusable skill-backed input sources."
      },
      "inputs": {
        "artifact": "inputs.json",
        "description": "Resolved runtime inputs and adapter provenance."
      },
      "logs": {
        "artifact": "logs.jsonl",
        "description": "Runtime stdout/stderr and explicit log artifacts.",
        "index": "logs.index.json",
        "stream": "stdout/stderr"
      },
      "output_skills": {
        "description": "Optional fan-out destinations after local run-store writes."
      },
      "outputs": {
        "artifacts": [
          "result.json",
          "final_artifact.json",
          "cctv_report.json",
          "cctv_report.md"
        ],
        "description": "Primary result and final user-facing artifact."
      },
      "resources": {
        "artifact": "resources.jsonl",
        "description": "Resource samples such as token, runtime, connector, and disk usage."
      },
      "streams": {
        "default": [
          "events"
        ],
        "description": "Named data or event streams exposed by the blueprint.",
        "kinds": [
          "audio",
          "video",
          "data",
          "multimodal"
        ],
        "transports": [
