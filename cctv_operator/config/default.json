{
  "agent_handoffs": {},
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 6,
      "max_concurrent_calls": 1,
      "min_interval_seconds": 10.0,
      "rationale": "Protect local Docker Model Runner from concurrent blueprint actor calls."
    },
    "max_concurrency": 1,
    "max_events_per_second": 25,
    "queue_size": 1
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 20,
    "max_disk_mb": 2048,
    "max_llm_calls": 360,
    "max_llm_tokens": 324000,
    "max_runtime_seconds": 3600,
    "max_stream_duration_seconds": 3600
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "network.egress",
      "stream.publish",
      "stream.subscribe",
      "knowledge.rag",
      "llm.tool_plan"
    ],
    "required": [
      "filesystem.write",
      "stream.subscribe"
    ]
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "evaluate_workflow_state",
    "route_by_context",
    "request_human_input",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact",
    "fan_out_output_skills",
    "emit_status_events",
    "handle_human_control",
    "write_artifact_records"
  ],
  "human_control": {
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "notice_only",
    "notice_event": "human_notice",
    "reason": "The workflow surfaces notable visual changes to reviewers but does not execute physical security actions by itself.",
    "requires_ack": false
  },
  "identity": {
    "blueprint_id": "cctv_operator",
    "name": "CCTV Operator"
  },
  "input_skills": {},
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "alert_policy": {
        "cooldown_seconds": 120,
        "min_confidence": 0.55,
        "notify_on": [
          "person",
          "unattended package",
          "restricted-area entry"
        ]
      },
      "output_folder": "~/Download/cctv_operator",
      "source_mode": "stream",
      "video_source": "",
      "visual_targets": [
        "person",
        "unattended package",
        "restricted-area entry"
      ]
    }
  },
