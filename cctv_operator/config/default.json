  "llm": {
    "model": "gemma4:e2b",
    "provider": "docker_model_runner",
    "runtime_model": "gemma4:e2b",
    "backend": "llama.cpp",
    "install_mode": "workflow_node",
    "enabled": true,
    "agent_role": "AI assistant for reviewing video stream activity and preparing visual detection alerts.",
    "agents": {
      "visual_target_detector": {
        "llm_config": "primary",
        "model": "gemma4:e2b",
        "role": "Visual target detector actor",
        "responsibilities": [
          "Detect configured visual targets from sampled frames.",
          "Tie alerts to frame evidence and model state.",
          "Flag uncertain detections for review."
        ]
      },
      "quality_controller": {
        "llm_config": "primary",
        "model": "gemma4:e2b",
        "role": "Video quality controller",
        "responsibilities": [
          "Check detection confidence and stream quality.",
          "Flag blurry, missing, or stale frames.",
          "Keep alert quality visible to reviewers."
        ]
      },
      "frame_sampler": {
        "llm_config": "primary",
        "model": "gemma4:e2b",
        "role": "Frame sampler actor",
        "responsibilities": [
          "Sample frames from configured video sources.",
          "Track sample cadence and source provenance.",
          "Flag source gaps or decode failures."
        ]
      },
      "video_source_validator": {
        "llm_config": "primary",
        "model": "gemma4:e2b",
        "role": "Video source validator",
        "responsibilities": [
          "Validate video source configuration and reachability.",
          "Flag unsupported or unavailable sources.",
          "Keep service readiness separate from hardware gating."
        ]
      },
      "video_monitor": {
        "llm_config": "primary",
        "model": "gemma4:e2b",
        "role": "Video monitor actor",
        "responsibilities": [
          "Maintain watch state and runtime lifecycle.",
          "Summarize active monitoring status.",
          "Escalate service or stream blockers."
        ]
      },
      "report_writer": {
        "llm_config": "primary",
        "model": "gemma4:e2b",
        "role": "CCTV report writer",
        "responsibilities": [
          "Write concise watch summaries from detection events.",
          "Preserve frame and source references.",
          "Avoid claiming certainty beyond sampled evidence."
        ]
      }
    },
    "mock_mode": "fake",
    "mode": "live",
    "default_config": "primary",
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "responsibilities": [
      "Keep visual detection evidence tied to sampled frames and runtime service state.",
      "Use actors to explain alerts, quality checks, and watch summaries.",
      "Avoid claiming surveillance certainty beyond the sampled evidence."
    ],
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "model": "gemma4:e2b",
        "install_mode": "workflow_node",
        "api_base": "http://localhost:12434/engines/v1",
        "timeout_seconds": 60,
        "max_tokens": 900,
        "num_retries": 1,
        "mock_mode": "fake",
        "mode": "live"
      }
    }
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed",
      "video_frame_tick_generated",
      "cctv_operator_frame_observed",
      "cctv_operator_folder_completed",
      "cctv_operator_attention_updated",
      "cctv_operator_detection",
      "human_notice",
      "cctv_operator_slack_alert_sent",
      "cctv_operator_slack_alert_skipped",
      "cctv_operator_slack_alert_error",
      "cctv_operator_frame_analysis_failed",
      "cctv_operator_report_ready",
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "resources_jsonl": true,
    "rotation": {
      "check_interval_records": 100,
      "compress": "background",
      "enabled": true,
      "max_bytes_mb": 100,
      "max_segments": 7,
      "span_seconds": 86400
    },
    "stderr_jsonl": true,
    "writer": {
      "batch_size": 100,
      "flush_interval_seconds": 0.5,
      "mode": "async",
      "overflow_policy": "drop_low_priority",
      "queue_size": 10000,
      "shutdown_flush_timeout_seconds": 2
    }
  },
  "manifest_config_bindings": [
    {
      "config_path": "identity.run_id",
      "manifest_path": "runtime.bindings.run_workflow.workers.visual_detector.with.environment.MN_RUN_ID",
      "stringify": true
    },
    {
      "config_path": "outputs.run_root",
      "manifest_path": "runtime.bindings.run_workflow.workers.visual_detector.with.environment.MN_RUNS_ROOT",
      "stringify": true
    },
    {
      "config_path": "video_source.frame_sample_seconds",
      "manifest_path": "agents.nodes.video_frame_tick_source.config.interval_seconds"
    }
  ],
  "local_inputs": {
    "folders": [
      {
        "config_path": "video_source.folder_path",
        "payload_path": "cctv_operator/mn_local_inputs/videos",
        "runtime_path": "mn_local_inputs/videos",
        "default_config_value": "cctv_operator/examples/sample_inputs",
        "source_path": "examples/sample_inputs",
        "allowed_extensions": [
          ".mp4",
          ".mov",
          ".mkv",
          ".avi",
          ".webm",
          ".m4v",
          ".ts",
          ".mts"
        ],
        "linked_config_paths": [
          "inputs.payload.input_folder"
        ]
      }
    ]
  },
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "cctv_operator_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "agentic_research": {
    "enabled": true,
    "agent_ids": [
      "video_source_validator",
      "frame_sampler",
      "visual_target_detector",
      "quality_controller",
      "report_writer"
    ],
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "allowed_tools": [
      "video_source_validate",
      "frame_sample",
      "visual_model_infer",
      "alert_policy_check",
      "knowledge_retrieve",
      "finish"
    ],
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run",
    "default_mode": "bounded_llm_guided_cctv_operator_review",
    "note": "CCTV actors ground detections in staged files or the configured stream, frame evidence, and alert policy."
  },
  "knowledge_rag": {
    "enabled": true,
    "backend": "milvus_lite",
    "required": false,
    "knowledge_dir": "knowledge",
    "purpose": "Retrieve approved CCTV policy for target detections, source provenance, cooldown behavior, and review-only alert boundaries.",
    "retrieval_targets": [
      "visual target evidence",
      "folder or stream source provenance",
      "alert cooldowns",
      "human review boundaries"
    ],
    "grounding_policy": "Use retrieved local blueprint knowledge to improve actor review prompts; do not invent facts when retrieval is unavailable.",
    "namespace": "",
    "embedding_provider": "docker_model_runner",
    "embedding_model": "rag-embedding",
    "embedding_api_base": "http://localhost:12434/engines/v1",
    "embedding_query_prefix": "Query: ",
    "embedding_document_prefix": "Document: ",
    "embedding_start_command": "",
    "embedding_healthcheck_enabled": true,
    "vector_dim": 1024,
    "index_on_startup": true,
    "top_k": 4,
    "max_context_chars": 4000,
    "chunk_size": 700,
    "chunk_overlap": 70,
    "privacy": "index local blueprint knowledge only; do not index private run documents unless a future runtime explicitly opts in"
  },
  "metadata": {
    "agent_role": "AI assistant for reviewing recorded or live video activity and preparing visual detection reports and alerts.",
    "blueprint_id": "cctv_operator",
    "blueprint_revision": "v1",
    "category": "business",
    "customizable_for": "Video monitoring, configurable visual detection, facility operations, and site safety workflows.",
    "description": "An NVIDIA-only CCTV co-worker. Give it a local input folder of recordings or one approved RTSP/RTMP stream, visual targets, alert policy, and output folder; it prepares sampled frames with CUDA-enabled FFmpeg and writes source-grounded JSON and Markdown review reports.",
    "llm_agent_role": "AI assistant for reviewing recorded or live video activity and preparing visual detection reports and alerts.",
    "name": "CCTV Operator",
    "problem_solved": "One NVIDIA-only workflow handles both staged recording folders and approved RTSP/RTMP streams while preserving source provenance in cumulative review reports.",
    "simulation_type": "Recording-folder or live-stream sampling with visual detection review state.",
    "standard_version": "1.0",
    "target_user": "Video operators, security reviewers, safety operations teams, and site-access coordinators.",
    "target_users": "Video operators, security reviewers, safety operations teams, and site-access coordinators."
  },
  "mode": "mock",
  "openshell_network": {
    "endpoints": [],
    "include_dns": false
  },
  "output_skills": {
    "websocket_events": {
      "connector": "websocket",
      "content": "events",
      "destination": "MN_BLUEPRINT_EVENTS_WS_URL",
      "direction": "output",
      "enabled": false,
      "failure_policy": "skip",
      "integration_status": "optional_mock_disabled_by_default",
      "activation": "Set MN_BLUEPRINT_EVENTS_WS_URL and enable this output skill via config override to stream events.",
      "mock": true,
      "required": false,
      "skill": "websocket_stream",
      "transport": "websocket",
      "url_env": "MN_BLUEPRINT_EVENTS_WS_URL"
    }
  },
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Visual detection observations with count, label, category, color, position, activity, confidence, and alert status.",
    "run_root": "~/.mn/runs",
    "skills": {
      "websocket_events": {
        "connector": "websocket",
        "content": "events",
        "direction": "output",
        "enabled": false,
        "integration_status": "optional_mock_disabled_by_default",
        "activation": "Set MN_BLUEPRINT_EVENTS_WS_URL and enable this output skill via config override to stream events.",
        "mock": true,
        "required": false,
        "skill": "websocket_stream",
        "transport": "websocket",
        "url_env": "MN_BLUEPRINT_EVENTS_WS_URL"
      }
    },
    "tcp": {
      "enabled": false,
      "ports": []
    },
    "write_run_store": true,
    "folder_path": "~/Download/cctv_operator"
  },
  "privacy": {
    "default_classification": "internal",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "resources": {
    "enabled": true,
    "gpu_enabled": true,
    "gpu_sample_interval_seconds": 60,
    "history_window_hours": 24,
    "raw_retention_hours": 48,
    "rollup_bucket_seconds": 3600,
    "sample_interval_seconds": 10,
    "gpu_count": 1,
    "gpu": {
      "min_count": 1,
      "vendor": "nvidia",
      "driver": "cuda",
      "min_memory_mb": 49152,
      "memory_operator": ">=",
      "enforcement": "hard"
    },
    "required_capabilities": [
      "nvidia",
      "cuda"
    ]
  },
  "schemas": {
    "artifact_record": "mn.artifact.record.v1",
    "config": "mn.blueprint.config.v1",
    "events": "mn.blueprint.events.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "human_control": "mn.blueprint.human_control.v1",
    "input_skills": "mn.blueprint.input_skills.v1",
    "inputs": "mn.blueprint.inputs.v1",
    "logs": "mn.blueprint.logs.v1",
    "output_skills": "mn.blueprint.output_skills.v1",
    "resources": "mn.blueprint.resources.v1",
    "status_contract": "mn.blueprint.status_contract.v1",
    "web_ui": "mn.blueprint.web_ui.v1"
  },
  "simulation": {
    "deterministic": true,
    "enabled": true,
    "seed_field": "seed",
    "type": "Video stream sampling with visual detection review state."
  },
  "standard_version": "1.0",
  "state": {
    "checkpoint_interval": {
