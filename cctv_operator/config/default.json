      "event_id"
    ],
    "resume_mode": "checkpoint",
    "input_folder": "cctv_operator/examples/sample_inputs",
    "output_folder": "~/Download/cctv_operator"
  },
  "streams": {
    "cctv_operator_stream": {
      "codec": "h264",
      "enabled": false,
      "kind": "video",
      "transport": "rtsp_or_rtmp",
      "uri": ""
    }
  },
  "triggers": {
    "schedule": null,
    "sources": [
      "cctv_operator_stream"
    ],
