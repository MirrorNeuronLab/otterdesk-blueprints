  "knowledge": {
    "irs_sources": [
      {
        "name": "IRS Form 1040",
        "url": "https://www.irs.gov/Form1040",
        "use": "current Form 1040, schedules, and filing instructions"
      },
      {
        "name": "IRS Publication 17",
        "url": "https://www.irs.gov/publications/p17",
        "use": "general individual federal income tax preparation knowledge"
      },
      {
        "name": "IRS Form 1099-INT",
        "url": "https://www.irs.gov/forms-pubs/about-form-1099-int",
        "use": "interest income source form knowledge"
      },
      {
        "name": "IRS Form 1099-R",
        "url": "https://www.irs.gov/forms-pubs/about-form-1099-r",
        "use": "retirement, IRA, annuity, and 401(k) distribution source form knowledge"
      }
    ],
    "local_files": [
      "knowledge/irs-source-map.md",
      "knowledge/tax-document-routing.md",
      "knowledge/advisor-conversation-style.md"
    ]
  },
  "llm": {
    "enabled": true,
    "agent_role": "Personal tax preparation team that prepares a source-grounded draft Form 1040 review packet while asking careful review questions.",
    "agents": {
      "intake_documents": {
        "llm_config": "primary",
        "model": "default",
        "role": "Intake Documents",
        "responsibilities": [
          "Review the deterministic workflow state for domain-specific risks.",
          "Summarize evidence, caveats, and next review steps without inventing facts.",
          "Keep the output review-only and preserve the source workflow results."
        ]
      },
      "prepare_income_workpapers": {
        "llm_config": "primary",
        "model": "default",
        "role": "Prepare Income Workpapers",
        "responsibilities": [
          "Review the deterministic workflow state for domain-specific risks.",
          "Summarize evidence, caveats, and next review steps without inventing facts.",
          "Keep the output review-only and preserve the source workflow results."
        ]
      },
      "prepare_property_workpapers": {
        "llm_config": "primary",
        "model": "default",
        "role": "Prepare Property Workpapers",
        "responsibilities": [
          "Review the deterministic workflow state for domain-specific risks.",
          "Summarize evidence, caveats, and next review steps without inventing facts.",
          "Keep the output review-only and preserve the source workflow results."
        ]
      },
      "prepare_investment_workpapers": {
        "llm_config": "primary",
        "model": "default",
        "role": "Prepare Investment Workpapers",
        "responsibilities": [
          "Review the deterministic workflow state for domain-specific risks.",
          "Summarize evidence, caveats, and next review steps without inventing facts.",
          "Keep the output review-only and preserve the source workflow results."
        ]
      },
      "merge_tax_workpapers": {
        "llm_config": "primary",
        "model": "default",
        "role": "Merge Tax Workpapers",
        "responsibilities": [
          "Review the deterministic workflow state for domain-specific risks.",
          "Summarize evidence, caveats, and next review steps without inventing facts.",
          "Keep the output review-only and preserve the source workflow results."
        ]
      },
      "audit_and_manager_review": {
        "llm_config": "primary",
        "model": "default",
        "role": "Audit And Manager Review",
        "responsibilities": [
          "Review the deterministic workflow state for domain-specific risks.",
          "Summarize evidence, caveats, and next review steps without inventing facts.",
          "Keep the output review-only and preserve the source workflow results."
        ]
      },
      "write_review_packet": {
        "llm_config": "primary",
        "model": "default",
        "role": "Write Review Packet",
        "responsibilities": [
          "Review the deterministic workflow state for domain-specific risks.",
          "Summarize evidence, caveats, and next review steps without inventing facts.",
          "Keep the output review-only and preserve the source workflow results."
        ]
      },
      "report_sink": {
        "llm_config": "primary",
        "model": "default",
        "role": "Report Sink",
        "responsibilities": [
          "Review the deterministic workflow state for domain-specific risks.",
          "Summarize evidence, caveats, and next review steps without inventing facts.",
          "Keep the output review-only and preserve the source workflow results."
        ]
      },
      "tax_auditor": {
        "llm_config": "primary",
        "responsibilities": [
          "Audit source support.",
          "Flag missing evidence and filing risks.",
          "Block unsupported return-ready claims."
        ],
        "role": "Tax auditor",
        "model": "default"
      },
      "manager_reviewer": {
        "llm_config": "primary",
        "responsibilities": [
          "Perform manager-level review.",
          "Write blockers and signoff status.",
          "Hold the packet as draft only."
        ],
        "role": "Tax manager reviewer",
        "model": "default"
      },
      "client_intake_coordinator": {
        "llm_config": "primary",
        "responsibilities": [
          "Confirm engagement scope.",
          "Identify missing taxpayer profile facts.",
          "Build a preparer-style intake checklist."
        ],
        "role": "Client intake coordinator",
        "model": "default"
      },
      "document_understanding_agent": {
        "llm_config": "primary",
        "responsibilities": [
          "Classify tax documents.",
          "Summarize each form tax meaning.",
          "Separate simple source forms from schedule-triggering forms."
        ],
        "role": "Document understanding agent",
        "model": "default"
      },
      "source_field_extractor": {
        "llm_config": "primary",
        "responsibilities": [
          "Extract box-level source facts.",
          "Tie every amount to evidence.",
          "Flag OCR and unsupported fields."
        ],
        "role": "Source field extractor",
        "model": "default"
      },
      "form_1040_assembler": {
        "llm_config": "primary",
        "responsibilities": [
          "Assemble supported draft Form 1040 lines.",
          "Preserve assumptions and source evidence.",
          "Avoid unsupported filing-ready calculations."
        ],
        "role": "Form 1040 assembler",
        "model": "default"
      },
      "income_preparer": {
        "llm_config": "primary",
        "responsibilities": [
          "Prepare income workpapers.",
          "Map source facts to Form 1040 income lines.",
          "Flag Schedule C, D, and dividend review items."
        ],
        "role": "Income preparer",
        "model": "default"
      },
      "income_validator": {
        "llm_config": "primary",
        "model": "default",
        "role": "Income validator",
        "responsibilities": [
          "Validate income workpapers against source forms.",
          "Flag missing income support.",
          "Keep validation draft-only."
        ]
      },
      "investment_preparer": {
        "llm_config": "primary",
        "model": "default",
        "role": "Investment preparer",
        "responsibilities": [
          "Prepare investment-income workpapers.",
          "Separate interest, dividends, and capital activity.",
          "Flag missing brokerage details."
        ]
      },
      "investment_validator": {
        "llm_config": "primary",
        "model": "default",
        "role": "Investment validator",
        "responsibilities": [
          "Validate investment workpapers and assumptions.",
          "Flag unsupported capital-gain treatment.",
          "Keep validation source-grounded."
        ]
      },
      "property_preparer": {
        "llm_config": "primary",
        "model": "default",
        "role": "Rental property preparer",
        "responsibilities": [
          "Prepare property and rental workpapers.",
          "Map property facts to draft schedules.",
          "Flag missing expense and basis support."
        ]
      },
      "property_tax_validator": {
        "llm_config": "primary",
        "model": "default",
        "role": "Property tax validator",
        "responsibilities": [
          "Validate property workpapers against evidence.",
          "Flag rental or deduction risks.",
          "Keep outputs draft-only."
        ]
      },
      "advisor_report_writer": {
        "llm_config": "primary",
        "responsibilities": [
          "Explain the draft in plain English.",
          "Summarize open review items.",
          "Prepare the user-facing report voice."
        ],
        "role": "Advisor and report writer",
        "model": "default"
      },
      "form_1040_packet_writer": {
        "llm_config": "primary",
        "responsibilities": [
          "Assemble the final review packet.",
          "Preserve filesystem artifact references.",
          "Keep large workpapers out of inter-agent messages."
        ],
        "role": "Form 1040 packet writer",
        "model": "default"
      },
      "deductions_credits_preparer": {
        "llm_config": "primary",
        "responsibilities": [
          "Prepare standard deduction treatment.",
          "Flag itemized deduction evidence.",
          "Identify credits requiring follow-up."
        ],
        "role": "Deductions and credits preparer",
        "model": "default"
      }
    },
    "responsibilities": [
      "Keep tax preparation outputs draft-only and tied to source evidence.",
      "Use specialist actors to prepare, audit, review, and explain the packet.",
      "Block filing-ready claims until human tax review is complete."
    ],
    "mock_mode": "fake",
    "provider": "docker_model_runner",
    "model": "gemma4:e2b",
    "runtime_model": "gemma4:e2b",
    "backend": "llama.cpp",
    "quick_test_uses_fake": false,
    "prefer_shared_skill": false,
    "strict_json": true,
    "mode": "live",
    "default_config": "primary",
    "live_model_profile": {
      "provider": "docker_model_runner",
      "runtime_model": "gemma4:e2b",
      "api_base": "http://localhost:12434/engines/v1",
      "backend": "llama.cpp",
      "mock_fallback": "disabled_for_tax_quick_tests"
    },
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "model": "gemma4:e2b",
        "runtime_model": "gemma4:e2b",
        "backend": "llama.cpp",
        "api_base": "http://localhost:12434/engines/v1",
        "timeout_seconds": 60,
        "max_tokens": 900,
        "num_retries": 1,
        "mock_mode": "fake",
        "mode": "live"
      }
    }
  },
  "local_inputs": {
    "folders": [
      {
        "allowed_extensions": [
          ".pdf",
          ".txt",
          ".json"
        ],
        "config_path": "tax_documents.folder_path",
        "linked_config_paths": [
          "inputs.payload.document_folder"
        ],
        "payload_path": "tax_workflow/mn_local_inputs/tax_documents",
        "runtime_path": "mn_local_inputs/tax_documents"
      }
    ]
