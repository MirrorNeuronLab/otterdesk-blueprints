{
  "agent_handoffs": {
    "artifact_manifest": "tax_team/artifact_manifest.json",
    "review_required": true,
    "transport": "filesystem_artifact_refs_only",
    "workflow": [
      "client_intake_coordinator",
      "document_understanding_agent",
      "source_field_extractor",
      "income_preparer",
      "deductions_credits_preparer",
      "form_1040_assembler",
      "tax_auditor",
      "manager_reviewer",
      "advisor_report_writer",
      "form_1040_packet_writer"
    ]
  },
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 30,
      "max_concurrent_calls": 1,
      "min_interval_seconds": 2.0,
      "rationale": "Protect local Docker Model Runner from concurrent blueprint actor calls."
    },
    "max_concurrency": 4,
    "max_events_per_second": 10,
    "queue_size": 1000
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 0,
    "max_disk_mb": 500,
    "max_llm_calls": 45,
    "max_llm_tokens": 60000,
    "max_runtime_seconds": 900,
    "max_stream_duration_seconds": 0
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "llm.ocr",
      "document.ocr",
      "pdf.render",
      "knowledge.rag",
      "llm.tool_plan"
    ],
    "required": [
      "filesystem.read",
      "filesystem.write",
      "pdf.extract"
    ]
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "missing_folder": {
        "mode": "use_sample_documents"
      },
      "ocr_required": {
        "mode": "continue_with_review_warning"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "evaluate_workflow_state",
    "route_by_context",
    "request_human_input",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact",
    "fan_out_output_skills",
    "create_tax_team_workspace",
    "scan_local_tax_folder",
    "write_artifact_manifest",
    "extract_pdf_text_or_mark_ocr",
    "command_only_agent_handoffs",
    "client_intake_coordinator",
    "llm_document_understanding",
    "llm_source_field_extraction",
    "income_preparer_workpaper",
    "deductions_credits_preparer_workpaper",
    "form_1040_assembler_maps_supported_lines",
    "tax_auditor_checks_assumptions",
    "manager_reviewer_blocks_filing_ready_claims",
    "advisor_report_writer",
    "write_markdown_report",
    "write_pdf_review_packet",
    "request_human_review",
    "emit_status_events",
    "handle_human_control",
    "write_artifact_records"
  ],
  "human_control": {
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "file_tax_return",
      "submit_to_irs",
      "send_to_tax_preparer",
      "write_tax_packet_to_connector_without_review"
    ],
    "decision_event": "human_decision_applied",
    "default_action": "reject",
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "approval_required",
    "reason": "Human approval is required before high-impact downstream actions such as file_tax_return, submit_to_irs, send_to_tax_preparer.",
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "timeout_seconds": 3600
  },
  "identity": {
    "blueprint_id": "personal_income_tax_expert",
    "name": "Personal Income Tax Expert"
  },
  "input_skills": {
    "llm_ocr": {
      "backend": "auto",
      "connector": "docker_model_runner",
      "enabled": true,
      "endpoint": "http://localhost:12434",
      "install_policy": "on_first_required_document",
      "max_pages": null,
      "min_text_chars": 40,
      "model": null,
      "package": "mirrorneuron-llm-ocr-skill",
      "preload": false,
      "purpose": "shared local LightOnOCR-2-1B OCR for scanned PDFs, images, and forms",
      "quantization": null,
      "remove_policy": "manual",
      "require_hardware_acceleration": true,
      "required": false,
      "skill": "llm_ocr_skill",
      "timeout_seconds": 180
    }
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default demo inputs use bundled sample text records. For real use, select a local folder containing tax PDFs.",
    "payload": {
      "document_folder": "personal_income_tax_expert/examples/sample_inputs",
      "filing_status": "single",
      "tax_year": 2025,
      "input_folder": "personal_income_tax_expert/examples/sample_inputs",
      "output_folder": "~/Download/personal_income_tax_expert"
    }
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
        "description": "Stable run-store files and domain-specific outputs.",
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl",
          "logs.index.json",
          "human.jsonl",
          "resources.jsonl"
