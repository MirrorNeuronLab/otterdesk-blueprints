{
  "standard_version": "1.0",
  "identity": {
    "blueprint_id": "personal_income_tax_expert",
    "name": "Personal Income Tax Expert"
  },
  "mode": {
    "default": "document_automation",
    "supports_mock": true,
    "supports_real_inputs": true
  },
  "metadata": {
    "blueprint_revision": "2026-05-23",
    "category": "finance",
    "description": "Runs an LLM-assisted tax preparation team over a local folder of tax documents, builds source-grounded draft Form 1040 workpapers, audits the packet, and writes JSON, Markdown, and PDF review outputs.",
    "runtime_features": [
      "local tax PDF intake",
      "LLM document understanding",
      "specialist tax preparer team",
      "source field extraction workpapers",
      "tax auditor and manager review gates",
      "draft Form 1040 review packet",
      "Markdown and PDF final packet",
      "Membrane context memory optimization"
    ]
  },
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "personal_income_tax_expert_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "tax_profile": {
    "tax_year": 2025,
    "filing_status": "single",
    "state_return": "not_prepared",
    "advisor_voice": "warm, direct, evidence-grounded, and careful like a personal tax advisor"
  },
  "tax_documents": {
    "folder_path": "",
    "recommended_forms": [
      "W-2",
      "1099-INT",
      "1099-R"
    ],
    "accepted_forms": [
      "W-2",
      "1099-INT",
      "1099-R",
      "1099-DIV",
      "1099-B",
      "1099-NEC",
      "1098",
      "1095-A",
      "5498",
      "brokerage_statement"
    ],
    "sample_documents": [
      {
        "path": "examples/sample_tax_documents/sample-w2.txt",
        "filename": "sample-w2.txt",
        "document_type": "W-2",
        "text": "Form W-2 Wage and Tax Statement. Box 1 wages 86000.00. Box 2 federal income tax withheld 11200.00.",
        "ocr_required": false,
        "extraction_method": "sample_text"
      },
      {
        "path": "examples/sample_tax_documents/sample-1099-int.txt",
        "filename": "sample-1099-int.txt",
        "document_type": "1099-INT",
        "text": "Form 1099-INT Interest Income. Box 1 interest income 128.44. Box 4 federal income tax withheld 0.00.",
        "ocr_required": false,
        "extraction_method": "sample_text"
      },
      {
        "path": "examples/sample_tax_documents/sample-1099-r-401k.txt",
        "filename": "sample-1099-r-401k.txt",
        "document_type": "1099-R",
        "text": "Form 1099-R Distributions From Pensions, Annuities, Retirement or Profit-Sharing Plans, IRAs, Insurance Contracts. 401(k) gross distribution 2400.00. Taxable amount 2400.00. Box 4 federal income tax withheld 240.00.",
        "ocr_required": false,
        "extraction_method": "sample_text"
      }
    ]
  },
  "local_inputs": {
    "folders": [
      {
        "config_path": "tax_documents.folder_path",
        "payload_path": "tax_workflow/mn_local_inputs/tax_documents",
        "runtime_path": "mn_local_inputs/tax_documents",
        "allowed_extensions": [
          ".pdf",
          ".txt",
          ".json"
        ],
        "linked_config_paths": [
          "inputs.payload.document_folder"
        ]
      }
    ]
  },
  "tax_knowledge": {
    "standard_deduction_2025": {
      "single": 15750,
      "married_filing_separately": 15750,
      "married_filing_jointly": 31500,
      "qualifying_surviving_spouse": 31500,
      "head_of_household": 23625
    },
    "form_1040_line_mapping": {
      "W-2": [
        "Line 1z wages",
        "Line 25a federal income tax withheld"
      ],
      "1099-INT": [
        "Line 2b taxable interest",
        "Schedule B review when thresholds or special cases apply"
      ],
      "1099-R": [
        "Line 4a distributions",
        "Line 4b taxable amount",
        "Schedule 2 review when early-distribution additional tax may apply"
      ]
    }
  },
  "knowledge": {
    "irs_sources": [
      {
        "name": "IRS Form 1040",
        "url": "https://www.irs.gov/Form1040",
        "use": "current Form 1040, schedules, and filing instructions"
      },
      {
        "name": "IRS Publication 17",
        "url": "https://www.irs.gov/publications/p17",
        "use": "general individual federal income tax preparation knowledge"
      },
      {
        "name": "IRS Form 1099-INT",
        "url": "https://www.irs.gov/forms-pubs/about-form-1099-int",
        "use": "interest income source form knowledge"
      },
      {
        "name": "IRS Form 1099-R",
        "url": "https://www.irs.gov/forms-pubs/about-form-1099-r",
        "use": "retirement, IRA, annuity, and 401(k) distribution source form knowledge"
      }
    ],
    "local_files": [
      "knowledge/irs-source-map.md",
      "knowledge/tax-document-routing.md",
      "knowledge/advisor-conversation-style.md"
    ]
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default demo inputs use bundled sample text records. For real use, select a local folder containing tax PDFs.",
    "payload": {
      "tax_year": 2025,
      "filing_status": "single",
      "document_folder": ""
    }
  },
  "llm": {
    "enabled": true,
    "mode": "ollama",
    "mock_mode": "fake",
    "api_base": "http://192.168.4.173:11434",
    "model": "ollama/nemotron3:33b",
    "default_config": "primary",
    "agent_role": "Personal tax preparation team that prepares a source-grounded draft Form 1040 review packet while asking careful review questions.",
    "responsibilities": [
      "understand tax documents with LLM specialist agents",
      "extract source fields and build preparer workpapers",
      "assemble supported Form 1040 draft lines",
      "audit assumptions, missing forms, and schedule risks",
      "write JSON, Markdown, and PDF review outputs"
    ],
    "configs": {
      "primary": {
        "provider": "ollama",
        "mode": "ollama",
        "api_base": "http://192.168.4.173:11434",
        "model": "ollama/nemotron3:33b",
        "max_tokens": 1200,
        "num_retries": 1,
        "timeout_seconds": 90,
        "mock_mode": "fake"
      }
    },
    "agents": {
      "client_intake_coordinator": {
        "role": "Client intake coordinator",
        "llm_config": "primary",
        "responsibilities": [
          "confirm engagement scope",
          "identify missing taxpayer profile facts",
          "build a preparer-style intake checklist"
        ]
      },
      "document_understanding_agent": {
        "role": "Document understanding agent",
        "llm_config": "primary",
        "responsibilities": [
          "classify tax documents",
          "summarize each form's tax meaning",
          "separate simple source forms from schedule-triggering forms"
        ]
      },
      "source_field_extractor": {
        "role": "Source field extractor",
        "llm_config": "primary",
        "responsibilities": [
          "extract box-level source facts",
          "tie every amount to evidence",
          "flag OCR and unsupported fields"
        ]
      },
      "income_preparer": {
        "role": "Income preparer",
        "llm_config": "primary",
        "responsibilities": [
          "prepare income workpapers",
          "map source facts to Form 1040 income lines",
          "flag Schedule C, D, and dividend review items"
        ]
      },
      "deductions_credits_preparer": {
        "role": "Deductions and credits preparer",
        "llm_config": "primary",
        "responsibilities": [
          "prepare standard deduction treatment",
          "flag itemized deduction evidence",
          "identify credits requiring follow-up"
        ]
      },
      "form_1040_assembler": {
        "role": "Form 1040 assembler",
        "llm_config": "primary",
        "responsibilities": [
          "assemble supported draft Form 1040 lines",
          "preserve assumptions and source evidence",
          "avoid unsupported filing-ready calculations"
        ]
      },
      "tax_auditor": {
        "role": "Tax auditor",
        "llm_config": "primary",
        "responsibilities": [
          "audit source support",
          "flag missing evidence and filing risks",
          "block unsupported return-ready claims"
        ]
      },
      "manager_reviewer": {
        "role": "Tax manager reviewer",
        "llm_config": "primary",
        "responsibilities": [
          "perform manager-level review",
          "write blockers and signoff status",
          "hold the packet as draft only"
        ]
      },
      "advisor_report_writer": {
        "role": "Advisor and report writer",
        "llm_config": "primary",
        "responsibilities": [
          "explain the draft in plain English",
          "summarize open review items",
          "prepare the user-facing report voice"
        ]
      }
    }
  },
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Prepared draft Form 1040 review packet with source evidence, specialist workpapers, audit and manager review, advisor-style next steps, Markdown, and PDF outputs.",
    "folder_path": "~/Downloads",
    "run_root": "~/.mn/runs",
    "write_run_store": true,
    "skills": {},
    "tcp": {
      "enabled": false,
      "ports": []
    }
  },
  "real_adapters": {
    "file": {
      "description": "JSON input file can provide document_folder, tax_year, filing_status, and taxpayer profile fields."
    },
    "env_json": {
      "env": "MN_BLUEPRINT_INPUT_JSON"
    }
  },
  "streams": {},
  "input_skills": {
    "tax_pdf_ocr": {
      "skill": "tax_pdf_ocr_skill",
      "package": "mirrorneuron-tax-pdf-ocr-skill",
      "purpose": "extract embedded text, classify tax PDFs, and mark LLM OCR needs"
    },
    "pdf_extract": {
      "skill": "pdf_extract_skill",
      "package": "mirrorneuron-pdf-extract-skill",
      "purpose": "fallback PDF text extraction"
    }
  },
  "output_skills": {},
  "privacy": {
    "default_classification": "regulated",
    "rules": {
      "regulated": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      }
    }
  },
  "capabilities": {
    "required": [
      "filesystem.read",
      "filesystem.write",
      "pdf.extract"
    ],
    "optional": [
      "llm.call",
      "llm.ocr",
      "document.ocr",
      "pdf.render"
    ]
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 0,
    "max_disk_mb": 500,
    "max_llm_calls": 45,
    "max_llm_tokens": 60000,
    "max_runtime_seconds": 900,
    "max_stream_duration_seconds": 0
  },
  "agent_handoffs": {
    "workflow": [
      "client_intake_coordinator",
      "document_understanding_agent",
      "source_field_extractor",
      "income_preparer",
      "deductions_credits_preparer",
      "form_1040_assembler",
      "tax_auditor",
      "manager_reviewer",
      "advisor_report_writer",
      "form_1040_packet_writer"
    ],
    "review_required": true
  },
  "interfaces": {
    "config_sections": [
      "tax_profile",
      "tax_documents",
      "tax_knowledge",
      "knowledge",
      "llm",
      "privacy",
      "budgets",
      "agent_handoffs"
    ]
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "scan_local_tax_folder",
    "extract_pdf_text_or_mark_ocr",
    "client_intake_coordinator",
    "llm_document_understanding",
    "llm_source_field_extraction",
    "income_preparer_workpaper",
    "deductions_credits_preparer_workpaper",
    "form_1040_assembler_maps_supported_lines",
    "tax_auditor_checks_assumptions",
    "manager_reviewer_blocks_filing_ready_claims",
    "advisor_report_writer",
    "write_final_artifact",
    "write_markdown_report",
    "write_pdf_review_packet",
    "request_human_review"
  ],
  "logging": {
    "level": "info",
    "redact_tax_identifiers": true
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "ocr_required": {
        "mode": "continue_with_review_warning"
      },
      "missing_folder": {
        "mode": "use_sample_documents"
      }
    }
  },
  "web_ui": {
    "enabled": true,
    "input": {
      "adapter": "none",
      "fields": [],
      "title": null,
      "instructions": null,
      "host": "127.0.0.1",
      "port": null,
      "share": false,
      "custom_url": null
    },
    "output": {
      "adapter": "gradio",
      "auto_generate": true,
      "refresh_seconds": 2,
      "title": "Personal Income Tax Expert"
    }
  }
}
