          "adapter": "json",
          "description": "Inline JSON object supplied through config or runtime overrides."
        },
        "local_folder": {
          "adapter": "file",
          "description": "Local folder mounted through OtterDesk local input handling.",
          "path": "tax_documents.folder_path"
        },
        "mock": {
          "adapter": "mock",
          "description": "Bundled sample W-2, 1099-INT, and 1099-R text records.",
          "payload": {
            "document_folder": "",
            "filing_status": "single",
            "tax_year": 2025
          }
        },
        "sample_file": {
          "adapter": "file",
          "description": "JSON payload pointing to a staged local tax document folder.",
          "path": "inputs/personal_tax_sample.json"
        }
      },
      "required_inputs": [
        {
          "description": "Local folder of tax documents to review.",
          "example": "/Users/me/Documents/2025-tax-docs",
          "name": "tax_document_folder",
          "type": "domain_value"
        },
        {
          "description": "Federal tax year for the draft packet.",
          "example": 2025,
          "name": "tax_year",
          "type": "domain_value"
        },
        {
          "description": "Filing status used for assumptions and readiness checks.",
          "example": "single",
          "name": "filing_status",
          "type": "domain_value"
        },
        {
          "description": "Local folder where JSON, Markdown, and PDF review files should be written.",
          "example": "~/Downloads",
          "name": "output_folder",
          "type": "domain_value"
        }
      ],
      "resolved_artifact": "inputs.json",
      "schema_version": "mn.blueprint.input_contract.v1",
      "supported_adapters": [
        "mock",
        "json",
        "file",
        "env_json"
      ],
      "validation_rules": [
        {
          "command": [
            "python3",
            "payloads/validation/validate_tax_folder.py"
