  "entrypoints": [
    "tax_workflow_runner"
  ],
  "graph_id": "personal_income_tax_expert_v1",
  "initial_inputs": {
    "tax_workflow_runner": [
      {
        "description": "Prepare a draft Form 1040 review packet from a local folder of tax PDFs, using bundled sample documents until the user selects a real folder.",
        "document_folder": "",
        "filing_status": "single",
        "ollama_base_url": "http://192.168.4.173:11434",
        "ollama_model": "nemotron3:33b",
        "scenario": "personal_income_tax_packet",
        "tax_year": 2025
      }
    ]
  },
  "input_validation": {
    "rules": [
      {
        "command": [
          "python3",
          "payloads/validation/validate_tax_folder.py"
        ],
        "name": "tax_document_folder",
        "timeout_seconds": 10,
        "type": "command"
      }
    ]
  },
  "job_name": "personal-income-tax-expert",
  "license": "LICENSE.md",
  "manifest_version": "1.0",
  "metadata": {
    "agent_role": "Personal tax preparation team that prepares a source-grounded draft Form 1040 review packet while asking careful review questions.",
