      "library": "../mn-agents/index.json",
      "nodes": [
        {
          "node_id": "tax_workflow_runner",
          "uses": "mn-agents.data_python_executor@1.0.0"
        },
        {
          "node_id": "report_sink",
          "uses": "mn-agents.control_join@1.0.0"
        }
      ],
      "render_tool": "../mn-agents/tools/render_agent_templates.py",
      "rendered_output": "manifest.rendered.json or runtime metadata",
      "renderer": "mn_blueprint_support.render_manifest_agent_templates"
    },
    "blueprint_id": "personal_income_tax_expert",
    "category": "finance",
    "configuration_contract": {
      "optional_files": [
        "config/overwrite.json",
        "knowledge/",
        "examples/sample_tax_documents/"
      ],
      "required_files": [
        "manifest.json",
        "README.md",
        "SPEC.md",
        "config/default.json",
        "payloads/",
        "LICENSE.md",
        "TERM.md"
      ]
    },
    "customizable_for": "Personal federal tax preparation, 401(k) and retirement distribution review, interest income intake, brokerage statements, mortgage interest review, and tax document checklists.",
    "description": "Runs an LLM-assisted tax preparation team over local tax documents, builds draft Form 1040 workpapers, audits the packet, and writes JSON, Markdown, and PDF review outputs.",
    "human_control": {
      "allowed_decisions": [
        "approve",
        "revise",
        "reject"
      ],
      "blocked_actions": [
        "file_tax_return",
        "submit_to_irs",
        "send_to_tax_preparer",
        "write_tax_packet_to_connector_without_review"
      ],
      "decision_event": "human_decision_applied",
      "default_action": "reject",
      "enabled": true,
      "events": [
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied"
      ],
      "mode": "approval_required",
      "reason": "Human approval is required before high-impact downstream actions such as file_tax_return, submit_to_irs, send_to_tax_preparer.",
      "request_event": "human_input_requested",
      "response_event": "human_input_received",
      "timeout_event": "human_input_timeout",
      "timeout_seconds": 3600
    },
    "init_config_review": {
      "fields": [
        {
          "default": "",
          "description": "Choose a local folder containing W-2, 1099, 1098, brokerage, or related tax documents.",
          "label": "Tax document folder",
          "path": "tax_documents.folder_path"
        },
        {
          "default": "single",
          "description": "Confirm filing status before treating draft calculations as meaningful.",
          "label": "Filing status",
          "path": "tax_profile.filing_status"
        },
        {
          "default": 2025,
          "description": "Federal tax year for the review packet.",
          "label": "Tax year",
          "path": "tax_profile.tax_year"
        },
        {
          "default": "~/Downloads",
          "description": "Choose where JSON, Markdown, and PDF review files should be written.",
          "label": "Output folder",
          "path": "outputs.folder_path"
        },
        {
          "default": "ollama",
          "description": "Use ollama for the real local model, fake only for deterministic tests.",
          "label": "LLM mode",
          "path": "llm.mode"
        },
        {
          "default": "http://192.168.4.173:11434",
          "description": "Base URL for the local Ollama-compatible model server.",
          "label": "Ollama URL",
          "path": "llm.api_base"
        },
        {
          "default": "ollama/nemotron3:33b",
          "description": "Model used by the specialist tax team.",
          "label": "LLM model",
          "path": "llm.model"
        }
      ],
      "instruction": "Ask the user to select the local tax document folder, confirm filing status, and choose the output folder before launch. If they skip the document folder, run the demo sample packet and explain that it is not filing-ready.",
      "required": true
    },
    "input_contract": {
      "description": "Tax source documents arrive as scattered PDFs; users need a private workflow that turns W-2, 1099-INT, 1099-R, and related forms into a reviewable Form 1040 draft packet with preparer workpapers and manager review.",
      "optional_inputs": [
        {
          "description": "Expected source forms for completeness checks.",
          "example": [
            "W-2",
            "1099-INT",
            "1099-R"
          ],
          "name": "recommended_forms",
          "type": "domain_value"
        },
        {
          "description": "Tone and boundary guidance for the final advisor message.",
          "example": "warm, direct, evidence-grounded",
          "name": "advisor_voice",
          "type": "domain_value"
        }
      ],
      "privacy_classification": "regulated",
      "profiles": {
        "env_json": {
          "adapter": "env_json",
          "description": "JSON object loaded from MN_BLUEPRINT_INPUT_JSON."
        },
        "file": {
          "adapter": "file",
          "description": "JSON object loaded from a local file path."
        },
