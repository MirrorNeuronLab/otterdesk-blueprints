{
  "agent_handoffs": {},
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 30,
      "max_concurrent_calls": 1,
      "min_interval_seconds": 2.0,
      "rationale": "Protect local Docker Model Runner from concurrent blueprint actor calls."
    },
    "max_concurrency": 4,
    "max_events_per_second": 10,
    "queue_size": 1000
  },
  "benchmark": {
    "baseline": "all_context",
    "enabled": true,
    "quality_metrics": [
      "action_accuracy",
      "purchase_type_fit",
      "critical_fact_recall",
      "risk_awareness",
      "quality_score_delta",
      "estimated_token_reduction_ratio",
      "budget_violation_rate"
    ],
    "schema_version": "mn.finance.purchase_research.v1"
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 20,
    "max_disk_mb": 250,
    "max_llm_calls": 20,
    "max_llm_tokens": 20000,
    "max_runtime_seconds": 600,
    "max_stream_duration_seconds": 3600
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "network.egress",
      "stream.subscribe",
      "knowledge.rag",
      "llm.tool_plan"
    ],
    "required": [
      "filesystem.write"
    ]
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "evaluate_workflow_state",
    "route_by_context",
    "request_human_input",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact",
    "fan_out_output_skills",
    "emit_status_events",
    "handle_human_control",
    "write_artifact_records"
  ],
  "human_control": {
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "buy_or_book",
      "pay_or_transfer_funds",
      "submit_application_or_offer",
      "contact_seller_provider_or_broker"
    ],
    "decision_event": "human_decision_applied",
    "default_action": "reject",
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "approval_required",
    "reason": "Human approval is required before any purchase, booking, payment, application, offer, or seller/provider contact action.",
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "timeout_seconds": 3600
  },
  "identity": {
    "blueprint_id": "purchase_research_assistant",
    "name": "Purchase Research Assistant"
  },
  "input_skills": {
    "llm_ocr": {
      "skill": "llm_ocr_skill",
      "package": "mirrorneuron-llm-ocr-skill",
      "enabled": true,
      "required": false,
      "min_text_chars": 40
    },
    "w3m_browser": {
      "skill": "w3m_browser_skill",
      "package": "mirrorneuron-w3m-browser-skill",
      "enabled": true,
      "required": false,
      "purpose": "Primary public text-browser research."
    },
    "web_browser": {
      "skill": "web_browser_skill",
      "package": "mirrorneuron-web-browser-skill",
      "enabled": true,
      "required": false,
      "purpose": "Optional rendered-browser fallback."
    }
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic large-context inputs bundled with the blueprint.",
    "payload": {
      "purchase_type": "property",
      "item_description": "Find one single-family house with at least 3 bedrooms in ZIP code 03755.",
      "budget": null,
      "location": "03755",
      "route": "",
      "travel_dates": "",
      "priorities": [
        "single-family house",
        "at least 3 bedrooms",
        "03755",
        "total cost",
        "condition",
        "inspection risk"
      ],
      "constraints": {
        "property_type": "single-family house",
        "min_bedrooms": 3,
        "zip_code": "03755"
      },
      "input_folder": "@/examples/sample_inputs",
      "output_folder": "~/Downloads/purchase_research_assistant"
    }
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
        "description": "Stable run-store files and domain-specific outputs.",
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl"
        ]
      },
