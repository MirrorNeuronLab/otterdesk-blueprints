{
  "agentic_research": {
    "agent_ids": [
      "purchase:intake",
      "purchase:price_research",
      "purchase:total_cost",
      "purchase:policy_risk",
      "purchase:alternatives",
      "purchase:recommender",
      "purchase:auditor",
      "purchase:report_writer"
    ],
    "allowed_tools": [
      "document_extract",
      "browser_search",
      "browser_page",
      "knowledge_retrieve",
      "finish"
    ],
    "default_mode": "bounded_llm_guided_purchase_research",
    "enabled": true,
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "note": "Purchase actors combine user documents, local RAG, public sources, and deterministic checks while preserving source refs and uncertainty.",
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run"
  },
  "agents": {
    "registry": {
      "purchase_intake_analyst": {
        "handler": "agents.purchase_intake_analyst",
        "role": "Purchase Intake Analyst"
      },
      "purchase_knowledge_retriever": {
        "handler": "agents.purchase_knowledge_retriever",
        "role": "Purchase Knowledge Retriever"
      },
      "purchase_market_researcher": {
        "handler": "agents.purchase_market_researcher",
        "role": "Purchase Market Researcher"
      },
      "purchase_total_cost_analyst": {
        "handler": "agents.purchase_total_cost_analyst",
        "role": "Purchase Total Cost Analyst"
      },
      "purchase_risk_reviewer": {
        "handler": "agents.purchase_risk_reviewer",
        "role": "Purchase Risk Reviewer"
      },
      "purchase_recommendation_auditor": {
        "handler": "agents.purchase_recommendation_auditor",
        "role": "Purchase Recommendation Auditor"
      },
      "purchase_report_writer": {
        "handler": "agents.purchase_report_writer",
        "role": "Purchase Report Writer"
      }
    }
  },
  "apiVersion": "mn.workflow.source/v2",
  "config": {
    "default": "config/default.json",
    "embed": true,
    "manifest_defaults": [
      "llm",
      "knowledge_rag",
      "agentic_research",
      {
        "from": "requirements",
        "to": "resources"
      },
      {
        "from": "workflow.policy.human",
        "to": "human_control"
      },
      {
        "from": "contracts.input_adapters.supported",
        "to": "interfaces.input_adapters"
      },
      {
        "from": "identity.id",
        "to": "identity.blueprint_id"
      },
      {
        "from": "identity.name",
        "to": "identity.name"
      }
    ]
  },
  "contracts": {
    "events": {
      "human_stream": "human.jsonl",
      "stream": "events.jsonl",
      "types": [
        "run_started",
        "inputs_loaded",
        "large_context_seeded",
        "simulation_step_started",
        "memory_context_compiled",
        "llm_decision",
        "benchmark_step_scored",
        "simulation_state_updated",
        "run_completed",
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "artifact_written",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
        "output_skill_started",
        "output_skill_completed",
        "output_skill_failed"
      ]
    },
    "input_adapters": {
      "default": "mock",
      "resolved_artifact": "inputs.json",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ]
    },
    "inputs": {
      "budget": {
        "description": "Optional budget or price ceiling for comparison.",
        "example": 30000,
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "constraints": {
        "description": "Optional purchase constraints and must-have requirements.",
        "example": {
          "must_have": [
            "refundable"
          ]
        },
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "input_folder": {
        "description": "Default local input folder for sample files or user-provided files.",
        "example": "purchase_research_assistant/examples/sample_inputs",
        "path_kind": "directory",
        "privacy": "confidential",
        "required": false,
        "type": "local_path"
      },
      "item_description": {
        "description": "The item, listing, vehicle, route, or trip to study.",
        "example": "2022 hybrid SUV with 40,000 miles",
        "privacy": "confidential",
        "required": true,
        "type": "domain_value"
      },
      "location": {
        "description": "Optional market, pickup, destination, or service location.",
        "example": "Boston, MA",
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "output_folder": {
        "description": "Default local output folder for generated artifacts and reports.",
        "example": "~/Downloads/purchase_research_assistant",
        "path_kind": "directory",
        "privacy": "confidential",
        "required": false,
        "type": "local_path"
      },
      "priorities": {
        "description": "Optional ranking priorities such as total cost, quality, speed, or flexibility.",
        "example": [
          "total cost",
          "reliability"
        ],
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "purchase_type": {
        "description": "Broad purchase category; use property, rental_property, car, airline_ticket, or custom for any other good, service, subscription, or commitment.",
        "example": "car",
        "privacy": "confidential",
        "required": true,
        "type": "domain_value"
      },
      "route": {
        "description": "Optional origin and destination for airline or travel research.",
        "example": "Boston to Lisbon",
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "travel_dates": {
        "description": "Optional travel dates or purchase timing.",
        "example": "2026-09-10 to 2026-09-18",
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      }
    },
    "outputs": {
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "logs",
          "mime_type": "application/x-jsonlines",
          "path": "logs.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.logs.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "logs"
        },
        {
          "artifact_id": "resources",
          "mime_type": "application/x-jsonlines",
          "path": "resources.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.resources.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "resource_samples"
        },
        {
          "artifact_id": "web_ui",
          "mime_type": "application/json",
          "path": "web_ui.json",
          "producer": "web_ui",
          "schema_version": "mn.blueprint.web_ui.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "web_ui"
        },
        {
          "artifact_id": "human_events",
          "mime_type": "application/x-jsonlines",
          "path": "human.jsonl",
          "producer": "human_control",
          "schema_version": "mn.blueprint.human_events.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "human_events"
        },
        {
          "artifact_id": "purchase_research_report",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.generated_report.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "generated_report"
        },
        {
          "artifact_id": "purchase_research_bundle",
          "mime_type": "application/json",
          "path": "purchase_research.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.purchase_research.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "purchase_research"
        },
        {
          "artifact_id": "research_sources",
          "mime_type": "application/json",
          "path": "research_sources.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.research_sources.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "research_sources"
        },
        {
          "artifact_id": "knowledge_rag",
          "mime_type": "application/json",
          "path": "knowledge_rag.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.knowledge_rag.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "knowledge_rag"
        },
        {
          "artifact_id": "evidence",
          "mime_type": "application/json",
          "path": "evidence.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.evidence.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "evidence"
        },
        {
          "artifact_id": "artifact_quality",
          "mime_type": "application/json",
          "path": "artifact_quality.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.artifact_quality.v1",
          "source_refs": [
            "purchase_research.json"
          ],
          "type": "artifact_quality"
        },
        {
          "artifact_id": "run_health",
          "mime_type": "application/json",
          "path": "run_health.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.run_health.v1",
          "source_refs": [
            "purchase_research.json"
          ],
          "type": "run_health"
        },
        {
          "artifact_id": "memory_benchmark",
          "mime_type": "application/json",
          "path": "result.json#/benchmark",
          "producer": "workflow",
          "schema_version": "mn.blueprint.benchmark_report.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "benchmark_report"
        }
      ],
      "primary": {
        "id": "final_artifact",
        "path": "final_artifact.json",
        "required_fields": [
          "type",
          "executive_summary",
          "recommended_action",
          "confidence",
          "evidence",
          "next_steps",
          "source_refs"
        ],
        "schema_version": "mn.blueprint.final_artifact_contract.v1",
        "type": "final_artifact"
      },
      "profile": "standard_run_store"
    },
    "privacy": {
      "default_classification": "confidential",
      "rules": {
        "confidential": {
          "log": "redacted",
          "send_to_llm": "allowed_configs_only",
          "send_to_output_skills": "approved_destinations_only"
        },
        "internal": {
          "log": "metadata_only",
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "public": {
          "log": true,
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "regulated": {
          "log": "redacted",
          "send_to_llm": false,
          "send_to_output_skills": "approved_destinations_only"
        }
      }
    },
    "status": {
      "event": "blueprint_status",
      "heartbeat": true,
      "phases": [
        "loading_inputs",
        "running_worker",
        "waiting_for_human",
        "writing_artifacts",
        "completed"
      ]
    },
    "summary": "Purchase review depends on older broker, lender, rent, insurance, and diligence details that are easy to lose in noisy pipelines.",
    "users": [
      "Consumers, travelers, vehicle buyers, property buyers, renters, and purchase analysts."
    ]
  },
  "defaults": {
    "worker": {
      "with": {
        "stereotype": "internal_write_worker",
        "image": "mirror-neuron/purchase-research-assistant:local"
      }
    }
  },
  "identity": {
    "category": "finance",
    "id": "purchase_research_assistant",
    "job_name": "purchase-research-assistant",
    "manifest_version": "1.0",
    "name": "Purchase Research Assistant",
    "version": 1
  },
  "intent": {
    "description": "A general purchase research co-worker for studying property, rental property, cars, airline tickets, services, subscriptions, equipment, software, and other custom purchases. It uses a portable local DMR profile, local knowledge, user evidence, and bounded public research to explain total-cost tradeoffs and write a review-ready recommendation.",
    "problem": "Purchase review depends on older broker, lender, rent, insurance, and diligence details that are easy to lose in noisy pipelines.",
    "safety": {
      "allowed_decisions": [
        "approve",
        "revise",
        "reject"
      ],
      "blocked_actions": [
        "buy_or_book",
        "pay_or_transfer_funds",
        "submit_application_or_offer",
        "contact_seller_provider_or_broker"
      ],
      "decision_event": "human_decision_applied",
      "default_action": "reject",
      "enabled": true,
      "events": [
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied"
      ],
      "mode": "approval_required",
      "reason": "Human approval is required before any purchase, booking, payment, application, offer, or seller/provider contact action.",
      "request_event": "human_input_requested",
      "response_event": "human_input_received",
      "timeout_event": "human_input_timeout",
      "timeout_seconds": 3600
    },
    "target_users": "Consumers, travelers, vehicle buyers, property buyers, renters, and purchase analysts."
  },
  "kind": "WorkflowSource",
  "knowledge_rag": {
    "backend": "milvus_lite",
    "chunk_overlap": 70,
    "chunk_size": 700,
    "embedding_api_base": "auto",
    "embedding_document_prefix": "Document: ",
    "embedding_healthcheck_enabled": true,
    "embedding_model": "rag-embedding",
    "embedding_provider": "docker_model_runner",
    "embedding_query_prefix": "Query: ",
    "embedding_start_command": "",
    "enabled": true,
    "grounding_policy": "Use retrieved guidance as a checklist; facts must come from user documents or cited public sources.",
    "index_on_startup": true,
    "knowledge_dir": "knowledge",
    "max_context_chars": 4000,
    "namespace": "",
    "privacy": "index checked-in guidance and approved local input files in an isolated per-run namespace; do not send private files to public research.",
    "purpose": "Retrieve purchase guidance and approved local evidence for price, total cost, policy, risk, and comparison checks.",
    "required": false,
    "retrieval_targets": [
      "purchase-type evidence checklists",
      "price and availability facts",
      "total cost and recurring fees",
      "policy, warranty, cancellation, and risk gaps",
      "alternative comparison criteria"
    ],
    "top_k": 4,
    "vector_dim": 1024
  },
  "manifest": {
    "input_validation": {
      "rules": []
    },
    "license": "LICENSE.md",
    "policies": {
      "recovery_mode": "local_restart"
    },
    "requiredContextEngine": false,
    "term": "TERM.md"
  },
  "metadata": {
    "blueprint_id": "purchase_research_assistant",
    "job_data": {
      "resources": [
        {
          "name": "knowledge",
          "path": "knowledge",
          "access": "read_write",
          "seed": "@/payloads/knowledge"
        },
        {
          "name": "rag",
          "path": "databases/rag",
          "access": "read_write"
        },
        {
          "name": "state",
          "path": "state",
          "access": "read_write"
        }
      ]
    }
  },
  "requirements": {
    "cpu": {
      "min_cores": 1
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    },
    "memory": {
      "min_gb": 2
    }
  },
  "skill_dependencies": [
    {
      "name": "mirrorneuron-blueprint-support-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-llm-ocr-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-rag-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-w3m-browser-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-web-browser-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    }
  ],
  "agent_dependencies": [
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-stateful-step-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-bounded-tool-loop-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-actor-review-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-artifact-finalizer-agent",
      "version": "1.2.29"
    }
  ],
  "standard": {
    "migration_policy": "sdk_managed",
    "profile": "blueprint",
    "source_schema": "mn.workflow.source/v2",
    "target_schema": "mn.workflow/v1"
  },
  "workflow": {
    "workflow_id": "purchase_research_assistant_v1",
    "execution": {
      "strategy": "parallel"
    },
    "policy": {
      "failure": {
        "default": "fail_closed"
      },
      "human": {
        "allowed_decisions": [
          "approve",
          "revise",
          "reject"
        ],
        "blocked_actions": [
          "buy_or_book",
          "pay_or_transfer_funds",
          "submit_application_or_offer",
          "contact_seller_provider_or_broker"
        ],
        "decision_event": "human_decision_applied",
        "default_action": "reject",
        "enabled": true,
        "events": [
          "human_notice",
          "human_input_requested",
          "human_input_received",
          "human_input_timeout",
          "human_decision_applied"
        ],
        "mode": "approval_required",
        "reason": "Human approval is required before any purchase, booking, payment, application, offer, or seller/provider contact action.",
        "request_event": "human_input_requested",
        "response_event": "human_input_received",
        "timeout_event": "human_input_timeout",
        "timeout_seconds": 3600
      }
    },
    "state": {
      "input_folder": {
        "from": "$inputs.input_folder"
      },
      "output_folder": {
        "from": "$inputs.output_folder"
      },
      "workflow": {},
      "final_report": {}
    },
    "steps": [
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 900,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Normalize the decision, constraints, must-haves, budget, horizon, and evidence gaps.",
        "id": "frame_purchase_request",
        "kind": "source",
        "label": "Frame Purchase Request",
        "needs": [],
        "run": {
          "definition": "steps.frame_purchase_request"
        }
      },
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 900,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Extract approved local evidence and retrieve category-specific diligence guidance.",
        "id": "build_purchase_evidence",
        "kind": "stage",
        "label": "Build Purchase Evidence",
        "needs": [
          "frame_purchase_request"
        ],
        "run": {
          "definition": "steps.build_purchase_evidence"
        }
      },
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 1800,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Research candidate availability, model total cost, test constraints, and audit recommendation support.",
        "id": "compare_purchase_options",
        "kind": "stage",
        "label": "Compare Purchase Options",
        "needs": [
          "build_purchase_evidence"
        ],
        "run": {
          "definition": "steps.compare_purchase_options"
        }
      },
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 900,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Write a review-ready comparison with candidate ranking, cost ranges, risks, sources, and verification tasks.",
        "id": "publish_purchase_decision_packet",
        "kind": "sink",
        "label": "Publish Purchase Decision Packet",
        "needs": [
          "compare_purchase_options"
        ],
        "run": {
          "definition": "steps.publish_purchase_decision_packet"
        }
      }
    ]
  },
  "workers": {
