{
  "agentic_research": {
    "agent_ids": [
      "invoice_bill_extractor",
      "payable_field_validator",
      "contract_clause_extractor",
      "contract_playbook_comparator",
      "legal_evidence_reconciler",
      "legal_review_auditor",
      "legal_reporter"
    ],
    "allowed_tools": [
      "llm_ocr_extract",
      "field_extract",
      "schema_validate",
      "clause_extract",
      "taxonomy_map",
      "knowledge_retrieve",
      "finish"
    ],
    "default_mode": "bounded_llm_guided_legal_document_review",
    "enabled": true,
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "note": "Document actors may use OCR and local playbook guidance; uncertain legal or payable values remain review-required.",
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run"
  },
  "agents": {
    "registry": {
      "legal_folder_watcher": {
        "handler": "agents.legal_folder_watcher",
        "role": "Legal Folder Watcher"
      },
      "legal_document_reader": {
        "handler": "agents.legal_document_reader",
        "role": "Legal Document Reader"
      },
      "invoice_bill_extractor": {
        "handler": "agents.invoice_bill_extractor",
        "role": "Invoice Bill Extractor"
      },
      "payable_field_validator": {
        "handler": "agents.payable_field_validator",
        "role": "Payable Field Validator"
      },
      "contract_clause_extractor": {
        "handler": "agents.contract_clause_extractor",
        "role": "Contract Clause Extractor"
      },
      "contract_playbook_comparator": {
        "handler": "agents.contract_playbook_comparator",
        "role": "Contract Playbook Comparator"
      },
      "legal_evidence_reconciler": {
        "handler": "agents.legal_evidence_reconciler",
        "role": "Legal Evidence Reconciler"
      },
      "legal_review_auditor": {
        "handler": "agents.legal_review_auditor",
        "role": "Legal Review Auditor"
      },
      "legal_reporter": {
        "handler": "agents.legal_reporter",
        "role": "Legal Reporter"
      }
    }
  },
  "apiVersion": "mn.workflow.source/v2",
  "config": {
    "default": "config/default.json",
    "embed": true,
    "manifest_defaults": [
      "llm",
      "knowledge_rag",
      "agentic_research",
      {
        "from": "requirements",
        "to": "resources"
      },
      {
        "from": "workflow.policy.human",
        "to": "human_control"
      },
      {
        "from": "contracts.input_adapters.supported",
        "to": "interfaces.input_adapters"
      },
      {
        "from": "identity.id",
        "to": "identity.blueprint_id"
      },
      {
        "from": "identity.name",
        "to": "identity.name"
      }
    ]
  },
  "contracts": {
    "events": {
      "human_stream": "human.jsonl",
      "stream": "events.jsonl",
      "types": [
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "artifact_written",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
        "legal_folder_watcher_completed",
        "legal_document_reader_completed",
        "invoice_bill_extractor_completed",
        "payable_field_validator_completed",
        "contract_clause_extractor_completed",
        "contract_playbook_comparator_completed",
        "legal_evidence_reconciler_completed",
        "legal_review_auditor_completed",
        "legal_reporter_completed"
      ]
    },
    "input_adapters": {
      "default": "mock",
      "resolved_artifact": "inputs.json",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ]
    },
    "inputs": {
      "document_folder": {
        "description": "Local folder containing invoices, bills, contracts, clause notes, labels, and support files.",
        "example": "legal_assistant/examples/sample_inputs",
        "path_kind": "directory",
        "privacy": "confidential",
        "required": true,
        "type": "local_path"
      },
      "field_profile": {
        "description": "Invoice payable fields and contract clause taxonomy fields used by the workflow.",
        "example": {
          "clause_fields": [
            "governing_law",
            "assignment",
            "termination",
            "liability"
          ],
          "invoice_fields": [
            "supplier_name",
            "invoice_id",
            "due_date",
            "total_amount"
          ]
        },
        "privacy": "internal",
        "required": false,
        "type": "domain_value"
      },
      "input_folder": {
        "description": "Alias for document_folder.",
        "example": "legal_assistant/examples/sample_inputs",
        "path_kind": "directory",
        "privacy": "confidential",
        "required": false,
        "type": "local_path"
      },
      "matter_profile": {
        "description": "Optional matter, jurisdiction, or review context.",
        "example": {
          "jurisdiction": "not_specified",
          "review_context": "small_business_vendor_contract"
        },
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "output_folder": {
        "description": "Local folder where integrated legal review packets should be written.",
        "example": "~/Downloads/legal_assistant",
        "path_kind": "directory",
        "privacy": "confidential",
        "required": true,
        "type": "local_path"
      },
      "review_policy": {
        "description": "Optional review objective, audience, focus areas, and jurisdiction note for bounded contract triage.",
        "example": {
          "audience": "small_business_operator_and_attorney",
          "focus_areas": [
            "termination_and_continuity_risk",
            "indemnity_and_liability_exposure",
            "assignment_and_change_of_control_effects"
          ],
          "jurisdiction_note": "Do not generalize the supplied document's governing framework.",
          "objective": "contract_intake_risk_triage"
        },
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      }
    },
    "outputs": {
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "invoice_bill_extraction",
          "mime_type": "application/json",
          "path": "invoice_bill_extraction.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.legal_assistant.invoice_bill_extraction.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "structured_extraction"
        },
        {
          "artifact_id": "contract_clause_review",
          "mime_type": "application/json",
          "path": "contract_clause_review.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.legal_assistant.contract_clause_review.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "clause_review"
        },
        {
          "artifact_id": "legal_issue_register",
          "mime_type": "application/json",
          "path": "legal_issue_register.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.legal_assistant.issue_register.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "issue_register"
        },
        {
          "artifact_id": "legal_deep_review",
          "mime_type": "application/json",
          "path": "legal_deep_review.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.legal_assistant.deep_review.v1",
          "source_refs": [
            "final_artifact.json",
            "knowledge/"
          ],
          "type": "llm_review"
        },
        {
          "artifact_id": "review_packet_markdown",
          "mime_type": "text/markdown",
          "path": "<outputs.folder_path>/legal_assistant_report.md",
          "producer": "workflow",
          "schema_version": "mn.blueprint.generated_report.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "generated_report"
        }
      ],
      "primary": {
        "id": "final_artifact",
        "path": "final_artifact.json",
        "required_fields": [
          "type",
          "executive_summary",
          "recommended_action",
          "confidence",
          "evidence",
          "next_steps",
          "source_refs"
        ],
        "schema_version": "mn.blueprint.final_artifact_contract.v1",
        "type": "final_artifact"
      },
      "profile": "standard_run_store"
    },
    "privacy": {
      "default_classification": "confidential"
    },
    "status": {
      "heartbeat": true
    }
  },
  "defaults": {
    "worker": {
      "with": {
        "image": "mirror-neuron/legal-assistant:local"
      }
    }
  },
  "identity": {
    "category": "legal",
    "id": "legal_assistant",
    "job_name": "legal-assistant",
    "manifest_version": "1.0",
    "name": "Legal Assistant",
    "version": 1
  },
  "intent": {
    "customizable_for": "Individual legal intake, small-business invoice review, vendor contract review, CLM intake, payable approval support, and attorney review preparation.",
    "description": "A legal document co-worker for invoice, bill, and contract review. Put invoices, bills, contracts, clause notes, labels, or supporting files in the input folder; it extracts payable fields, maps contract clauses, compares playbook expectations, flags review issues, and writes a source-grounded review packet to the output folder.",
    "problem": "Personal and small-business legal work often mixes payable documents with contracts and obligations; users need one local review assistant that keeps invoice facts, contract clauses, evidence, and approval boundaries together.",
    "safety": {
      "allowed_decisions": [
        "approve",
        "revise",
        "reject"
      ],
      "blocked_actions": [
        "send_legal_advice",
        "approve_or_sign_contract",
        "redline_contract_as_final",
        "post_invoice_to_erp",
        "submit_payment_instruction",
        "email_vendor_or_counterparty_without_review",
        "share_privileged_or_private_documents_externally"
      ],
      "decision_event": "human_decision_applied",
      "default_action": "reject",
      "enabled": true,
      "events": [
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied"
      ],
      "mode": "approval_required",
      "reason": "Human and attorney review is required before relying on legal conclusions, approving payments, signing contracts, contacting counterparties, or sharing private/privileged documents.",
      "request_event": "human_input_requested",
      "response_event": "human_input_received",
      "timeout_event": "human_input_timeout",
      "timeout_seconds": 3600
    },
    "target_users": "Individuals, founders, small-business operators, legal operations teams, in-house reviewers, and attorneys preparing first-pass document packets."
  },
  "kind": "WorkflowSource",
  "knowledge_rag": {
    "backend": "milvus_lite",
    "chunk_overlap": 150,
    "chunk_size": 2500,
    "embedding_api_base": "auto",
    "embedding_document_prefix": "Document: ",
    "embedding_healthcheck_enabled": false,
    "embedding_model": "rag-embedding",
    "embedding_provider": "docker_model_runner",
    "embedding_query_prefix": "Query: ",
    "embedding_start_command": "",
    "enabled": true,
    "grounding_policy": "Use retrieved or bundled local blueprint knowledge to improve actor prompts; preserve deterministic outputs, cite supplied evidence, and label unknowns when retrieval is unavailable.",
    "index_on_startup": true,
    "knowledge_dir": "knowledge",
    "max_context_chars": 4500,
    "namespace": "",
    "privacy": "index local blueprint knowledge only; do not index private run documents unless a future runtime explicitly opts in",
    "purpose": "Retrieve local legal assistant guidance for invoice extraction, contract clause mapping, playbook comparison, privilege/privacy handling, and review-only boundaries.",
    "redis_url": "",
    "required": false,
    "retrieval_targets": [
      "invoice and bill extraction",
      "contract clause taxonomy",
      "playbook comparison",
      "privilege and privacy review",
      "payment and legal action blockers",
      "evidence hierarchy and source traceability",
      "calculation invariance and assumption clarity",
      "cross-domain reconciliation and report quality"
    ],
    "top_k": 5,
    "vector_dim": 1024
  },
  "metadata": {
    "blueprint_id": "legal_assistant",
    "job_data": {
      "resources": [
        {
          "name": "knowledge",
          "path": "knowledge",
          "access": "read_write",
          "seed": "@/payloads/knowledge"
        },
        {
          "name": "rag",
          "path": "databases/rag",
          "access": "read_write"
        },
        {
          "name": "state",
          "path": "state",
          "access": "read_write"
        }
      ]
    }
  },
  "requirements": {
    "cpu": {
      "min_cores": 1
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    },
    "memory": {
      "min_gb": 2
    }
  },
  "skill_dependencies": [
    {
      "name": "mirrorneuron-blueprint-support-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-llm-ocr-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-litellm-communicate-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-rag-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    }
  ],
  "agent_dependencies": [
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-stateful-step-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-bounded-tool-loop-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-actor-review-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-artifact-finalizer-agent",
      "version": "1.2.29"
    }
  ],
  "standard": {
    "migration_policy": "sdk_managed",
    "profile": "blueprint",
    "profile_version": 1,
    "source_schema": "mn.workflow.source/v2",
    "target_schema": "mn.workflow/v1"
  },
  "workers": {
    "groups": [
      {
        "steps": [
          "publish_legal_review_packet"
        ],
        "with": {
          "stereotype": "internal_write_worker"
        }
      }
    ]
  },
  "workflow": {
    "workflow_id": "legal_assistant_v1",
    "execution": {
      "strategy": "parallel"
    },
    "policy": {
      "failure": {
        "default": "fail_closed"
      },
      "human": {
        "enabled": true,
        "mode": "approval_required",
        "default_action": "reject",
        "allowed_decisions": [
          "approve",
          "revise",
          "reject"
        ],
        "blocked_actions": [
          "send_legal_advice",
          "approve_or_sign_contract",
          "redline_contract_as_final",
          "post_invoice_to_erp",
          "submit_payment_instruction",
          "email_vendor_or_counterparty_without_review",
          "share_privileged_or_private_documents_externally"
        ],
        "reason": "Human and attorney review is required before relying on legal conclusions, approving payments, signing contracts, contacting counterparties, or sharing private/privileged documents.",
        "events": [
          "human_notice",
          "human_input_requested",
          "human_input_received",
          "human_input_timeout",
          "human_decision_applied"
        ],
        "request_event": "human_input_requested",
        "response_event": "human_input_received",
        "timeout_event": "human_input_timeout",
        "decision_event": "human_decision_applied",
        "timeout_seconds": 3600
      }
    },
    "state": {
      "input_folder": {
        "from": "$inputs.input_folder"
      },
      "output_folder": {
        "from": "$inputs.output_folder"
      },
      "workflow": {},
      "final_report": {}
    },
    "steps": [
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 1200,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Inventory the matter, extract document text, classify sources, and record OCR limitations.",
        "id": "prepare_legal_matter",
        "kind": "source",
        "label": "Prepare Legal Matter",
        "needs": [],
        "run": {
          "definition": "steps.prepare_legal_matter"
        }
      },
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 1800,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Run separate payable-validation and contract-playbook review lanes, then join their durable findings.",
        "id": "analyze_legal_documents",
        "kind": "stage",
        "label": "Analyze Legal Documents",
        "needs": [
          "prepare_legal_matter"
        ],
        "run": {
          "definition": "steps.analyze_legal_documents"
        }
      },
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 1200,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Reconcile cross-document obligations, conflicts, missing evidence, deadlines, and human-review questions.",
        "id": "reconcile_legal_review",
        "kind": "stage",
        "label": "Reconcile Legal Review",
        "needs": [
          "analyze_legal_documents"
        ],
        "run": {
          "definition": "steps.reconcile_legal_review"
        }
      },
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 1200,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Write the source-grounded matter overview, issue register, obligation calendar, and review queue.",
        "id": "publish_legal_review_packet",
        "kind": "sink",
        "label": "Publish Legal Review Packet",
        "needs": [
          "reconcile_legal_review"
        ],
        "run": {
          "definition": "steps.publish_legal_review_packet"
        }
      }
    ]
  },
  "llm": {
    "enabled": true,
    "mode": "live",
    "mock_mode": "fake",
    "model": "default",
    "backend": "llama.cpp",
    "provider": "docker_model_runner",
    "default_config": "primary",
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "require_live": true,
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "backend": "llama.cpp",
        "api_base": "auto",
        "timeout_seconds": 75,
        "max_tokens": 1600,
        "num_retries": 1,
        "retry_backoff_seconds": 1.0,
        "mock_mode": "fake",
        "mode": "live",
        "strict_json": false,
        "required": true
      }
    },
    "agents": {
      "legal_folder_watcher": {
        "llm_config": "primary",
        "role": "Legal Folder Watcher",
        "responsibilities": [
          "Resolve the local legal document folder.",
          "Fingerprint invoice, bill, contract, and support files.",
          "Preserve source paths without exposing private content externally."
        ]
      },
      "legal_document_reader": {
        "llm_config": "primary",
        "role": "Legal Document Reader",
        "responsibilities": [
          "Read local text and structured files.",
          "Classify invoice, bill, contract, clause, and supporting documents.",
          "Flag OCR-required documents for review."
        ]
      },
      "invoice_bill_extractor": {
        "llm_config": "primary",
        "role": "Invoice And Bill Extractor",
        "responsibilities": [
          "Extract payable fields from invoices and bills.",
          "Tie supplier, date, total, and line-item values to source evidence.",
          "Flag missing or ambiguous payable fields."
        ]
      },
      "payable_field_validator": {
        "llm_config": "primary",
        "role": "Payable Field Validator",
        "responsibilities": [
          "Check extracted invoice fields for completeness.",
          "Separate review-only values from downstream payment actions.",
          "Flag ERP and payment blockers."
        ]
      },
      "contract_clause_extractor": {
        "llm_config": "primary",
        "role": "Contract Clause Extractor",
        "responsibilities": [
          "Extract candidate clauses from contract text.",
          "Map clauses to the configured taxonomy.",
          "Preserve snippets and source references."
        ]
      },
      "contract_playbook_comparator": {
        "llm_config": "primary",
        "role": "Contract Playbook Comparator",
        "responsibilities": [
          "Compare extracted clauses to playbook expectations.",
          "Flag missing high-value clauses and deviations.",
          "Avoid giving legal advice."
        ]
      },
      "legal_evidence_reconciler": {
        "llm_config": "primary",
        "role": "Legal Evidence Reconciler",
        "responsibilities": [
          "Merge invoice and contract evidence.",
          "Create a unified issue register.",
          "Preserve confidence, warnings, and review owners."
        ]
      },
      "legal_review_auditor": {
        "llm_config": "primary",
        "role": "Legal Review Auditor",
        "responsibilities": [
          "Audit review-only boundaries.",
          "Check blocked actions remain blocked.",
          "Prepare attorney and human-review caveats."
