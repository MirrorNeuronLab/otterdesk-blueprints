{
  "standard_version": "mn.blueprint.config.v1",
  "mode": "review_only",
  "identity": {
    "blueprint_id": "legal_assistant",
    "name": "Legal Assistant"
  },
  "metadata": {
    "blueprint_id": "legal_assistant",
    "blueprint_revision": "v1",
    "category": "Legal",
    "name": "Legal Assistant",
    "description": "A legal document co-worker for invoice, bill, and contract review. Put invoices, bills, contracts, clause notes, labels, or supporting files in the input folder; it extracts payable fields, maps contract clauses, compares playbook expectations, flags review issues, and writes a source-grounded review packet to the output folder.",
    "problem": "Personal and small-business legal work often mixes payable documents with contracts and obligations; users need one local review assistant that keeps invoice facts, contract clauses, evidence, and approval boundaries together.",
    "target_users": "Individuals, founders, small-business operators, legal operations teams, in-house reviewers, and attorneys preparing first-pass document packets.",
    "customizable_for": "Individual legal intake, small-business invoice review, vendor contract review, CLM intake, payable approval support, and attorney review preparation.",
    "agent_role": "Local legal document assistant that extracts invoice and contract evidence while keeping conclusions review-only."
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default sample inputs include one invoice/bill JSON fixture and one contract text fixture.",
    "payload": {
      "document_folder": "legal_assistant/examples/sample_inputs",
      "input_folder": "legal_assistant/examples/sample_inputs",
      "output_folder": "~/Downloads/legal_assistant",
      "field_profile": {
        "invoice_fields": [
          "supplier_name",
          "customer_name",
          "invoice_id",
          "tax_id",
          "due_date",
          "total_amount",
          "line_items",
          "consumption_fields",
          "billing_period"
        ],
        "clause_fields": [
          "governing_law",
          "change_of_control",
          "assignment",
          "indemnity",
          "termination",
          "audit_rights",
          "renewal",
          "exclusivity",
          "liability"
        ]
      },
      "matter_profile": {
        "review_context": "personal_or_small_business_document_review",
        "jurisdiction": "not_specified",
        "review_only": true
      },
      "review_policy": {
        "objective": "contract_intake_risk_triage",
        "audience": "small_business_operator_and_attorney",
        "focus_areas": [
          "clause_presence_and_source_traceability",
          "invoice_and_payment_controls",
          "termination_and_continuity_risk",
          "indemnity_and_liability_exposure",
          "assignment_and_change_of_control_effects",
          "privacy_privilege_and_missing_evidence"
        ],
        "jurisdiction_note": "Use the supplied document's governing framework only; do not generalize federal-contract terms to another matter."
      },
      "public_dataset": {
        "name": "FAR 52.212-4 Contract Terms and Conditions—Commercial Products and Commercial Services",
        "provider": "U.S. General Services Administration, Acquisition.gov",
        "url": "https://www.acquisition.gov/far/52.212-4",
        "download_url": "https://www.acquisition.gov/node/31867/printable/pdf",
        "license_note": "U.S. government regulatory text; verify current version and source terms before production use.",
        "availability_note": "Bundled public-domain sample PDF is for local blueprint validation and is not legal advice.",
        "expected_files": [
          "*.pdf",
          "*.txt",
          "*.json",
          "*.md"
        ]
      }
    }
  },
  "document_sources": {
    "folder_path": "legal_assistant/examples/sample_inputs",
    "expected_files": [
      "*.pdf",
      "*.txt",
      "*.json",
      "*.md"
    ],
    "grouping": "single_legal_review_packet"
  },
  "outputs": {
    "adapter": "local_run_store",
    "folder_path": "~/Downloads/legal_assistant",
    "run_root": "~/.mn/runs",
    "write_run_store": true,
    "write_markdown_report": true,
  "domain_artifacts": [
    "invoice_bill_extraction.json",
    "contract_clause_review.json",
    "legal_issue_register.json",
    "legal_deep_review.json",
    "legal_assistant_report.md",
    "action_ledger.json",
    "artifact_quality.json",
    "run_health.json"
  ],
  "artifact_contract": "Review-only invoice extraction, OCR-aware contract clause review, RAG-grounded deep LLM review, issue register, action ledger, quality summary, and integrated Markdown report."
  },
  "resources": {
    "enabled": true,
    "gpu_enabled": "auto",
    "sample_interval_seconds": 10,
    "gpu_sample_interval_seconds": 60,
    "history_window_hours": 24,
    "raw_retention_hours": 48,
    "rollup_bucket_seconds": 3600
  },
  "human_control": {
    "enabled": true,
    "mode": "approval_required",
    "default_action": "reject",
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "send_legal_advice",
      "approve_or_sign_contract",
      "redline_contract_as_final",
      "post_invoice_to_erp",
      "submit_payment_instruction",
      "email_vendor_or_counterparty_without_review",
      "share_privileged_or_private_documents_externally"
    ],
    "reason": "Human and attorney review is required before relying on legal conclusions, approving payments, signing contracts, contacting counterparties, or sharing private/privileged documents.",
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "decision_event": "human_decision_applied",
    "timeout_seconds": 3600
  },
  "privacy": {
    "default_classification": "confidential",
    "rules": {
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "privileged": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "llm": {
    "enabled": true,
    "mode": "live",
    "mock_mode": "fake",
    "model": "small",
    "runtime_model": "small",
    "fallback_model": "small",
    "backend": "llama.cpp",
    "provider": "docker_model_runner",
    "default_config": "primary",
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "require_live": true,
    "preferred_model": "medium",
    "review_agents": [
      "invoice_bill_extractor",
      "payable_field_validator",
      "contract_clause_extractor",
      "contract_playbook_comparator",
      "legal_evidence_reconciler",
      "legal_review_auditor",
      "legal_reporter"
    ],
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "model": "small",
        "runtime_model": "small",
        "fallback_model": "small",
        "backend": "llama.cpp",
        "api_base": "auto",
        "timeout_seconds": 75,
        "max_tokens": 1600,
        "num_retries": 1,
        "retry_backoff_seconds": 1.0,
        "mock_mode": "fake",
        "mode": "live",
        "required": true
      },
      "large": {
        "provider": "docker_model_runner",
        "model": "medium",
        "runtime_model": "medium",
        "fallback_model": "small",
        "backend": "llama.cpp",
        "timeout_seconds": 120,
        "max_tokens": 2800,
        "num_retries": 1,
        "retry_backoff_seconds": 1.0,
        "strict_json": true,
        "require_live": true,
        "context_size": 8192,
        "quantization": "MOSTLY_Q4_K_M",
        "parameter_count_b": 31.58,
        "required": false,
        "hardware": {
          "gpu": {
            "min_count": 1,
            "min_memory_mb": 49152,
            "memory_operator": ">="
          }
        }
      }
    },
    "small_model_profile": {
      "provider": "docker_model_runner",
      "model": "small",
      "runtime_model": "small",
      "fallback_model": "small",
      "backend": "llama.cpp",
      "api_base": "auto",
      "timeout_seconds": 75,
      "max_tokens": 1600,
      "num_retries": 1,
      "retry_backoff_seconds": 1.0,
      "strict_json": false,
      "require_live": false
    },
    "live_model_profile": {
      "provider": "docker_model_runner",
      "model": "small",
      "runtime_model": "small",
      "fallback_model": "small",
      "backend": "llama.cpp",
      "api_base": "auto",
      "timeout_seconds": 75,
      "max_tokens": 1600,
      "num_retries": 1,
      "retry_backoff_seconds": 1.0,
      "strict_json": false,
      "require_live": false
    },
    "large_model_profile": {
      "provider": "docker_model_runner",
      "model": "medium",
      "runtime_model": "medium",
      "fallback_model": "small",
      "backend": "llama.cpp",
      "timeout_seconds": 120,
      "max_tokens": 2800,
      "num_retries": 1,
      "retry_backoff_seconds": 1.0,
      "strict_json": true,
      "require_live": true,
      "context_size": 8192,
      "quantization": "MOSTLY_Q4_K_M",
      "parameter_count_b": 31.58,
      "hardware": {
        "gpu": {
          "min_count": 1,
          "min_memory_mb": 49152,
          "memory_operator": ">="
        }
      }
    },
    "agents": {
      "legal_folder_watcher": {
        "llm_config": "primary",
        "role": "Legal Folder Watcher",
        "responsibilities": [
          "Resolve the local legal document folder.",
          "Fingerprint invoice, bill, contract, and support files.",
          "Preserve source paths without exposing private content externally."
        ]
      },
      "legal_document_reader": {
        "llm_config": "primary",
        "role": "Legal Document Reader",
        "responsibilities": [
          "Read local text and structured files.",
          "Classify invoice, bill, contract, clause, and supporting documents.",
          "Flag OCR-required documents for review."
        ]
      },
      "invoice_bill_extractor": {
        "llm_config": "primary",
        "role": "Invoice And Bill Extractor",
        "responsibilities": [
          "Extract payable fields from invoices and bills.",
          "Tie supplier, date, total, and line-item values to source evidence.",
          "Flag missing or ambiguous payable fields."
        ]
      },
      "payable_field_validator": {
        "llm_config": "primary",
        "role": "Payable Field Validator",
        "responsibilities": [
          "Check extracted invoice fields for completeness.",
          "Separate review-only values from downstream payment actions.",
          "Flag ERP and payment blockers."
        ]
      },
      "contract_clause_extractor": {
        "llm_config": "primary",
        "role": "Contract Clause Extractor",
        "responsibilities": [
          "Extract candidate clauses from contract text.",
          "Map clauses to the configured taxonomy.",
          "Preserve snippets and source references."
        ]
      },
      "contract_playbook_comparator": {
        "llm_config": "large",
        "role": "Contract Playbook Comparator",
        "responsibilities": [
          "Compare extracted clauses to playbook expectations.",
          "Flag missing high-value clauses and deviations.",
          "Avoid giving legal advice."
        ]
      },
      "legal_evidence_reconciler": {
        "llm_config": "primary",
        "role": "Legal Evidence Reconciler",
        "responsibilities": [
          "Merge invoice and contract evidence.",
          "Create a unified issue register.",
          "Preserve confidence, warnings, and review owners."
        ]
      },
      "legal_review_auditor": {
        "llm_config": "large",
        "role": "Legal Review Auditor",
        "responsibilities": [
          "Audit review-only boundaries.",
          "Check blocked actions remain blocked.",
          "Prepare attorney and human-review caveats."
        ]
      },
      "legal_reporter": {
        "llm_config": "large",
        "role": "Legal Reporter",
        "responsibilities": [
          "Write the integrated legal review packet.",
          "Summarize invoice, bill, contract, and issue-register sections.",
          "Keep all next steps source-grounded and review-only."
        ]
      }
    },
    "responsibilities": [
      "Keep legal and payable outputs review-only and source-grounded.",
      "Use specialist agents for document intake, extraction, playbook comparison, audit, and report writing.",
      "Require human and attorney approval before legal advice, payment, signature, or external sharing."
    ]
  },
  "knowledge_rag": {
    "enabled": true,
    "backend": "milvus_lite",
    "required": false,
    "knowledge_dir": "knowledge",
    "purpose": "Retrieve local legal assistant guidance for invoice extraction, contract clause mapping, playbook comparison, privilege/privacy handling, and review-only boundaries.",
    "retrieval_targets": [
      "invoice and bill extraction",
      "contract clause taxonomy",
      "playbook comparison",
      "privilege and privacy review",
      "payment and legal action blockers",
      "evidence hierarchy and source traceability",
      "calculation invariance and assumption clarity",
      "cross-domain reconciliation and report quality"
    ],
    "grounding_policy": "Use retrieved or bundled local blueprint knowledge to improve actor prompts; preserve deterministic outputs, cite supplied evidence, and label unknowns when retrieval is unavailable.",
    "namespace": "",
    "embedding_provider": "docker_model_runner",
    "embedding_model": "rag-embedding",
    "embedding_api_base": "http://host.docker.internal:12434/engines/v1",
    "embedding_query_prefix": "Query: ",
    "embedding_document_prefix": "Document: ",
    "embedding_start_command": "",
    "embedding_healthcheck_enabled": false,
    "vector_dim": 1024,
    "index_on_startup": true,
    "top_k": 5,
    "max_context_chars": 4500,
    "chunk_size": 2500,
    "chunk_overlap": 150,
    "privacy": "index local blueprint knowledge only; do not index private run documents unless a future runtime explicitly opts in"
  },
  "agentic_research": {
    "enabled": true,
    "agent_ids": [
      "invoice_bill_extractor",
      "payable_field_validator",
      "contract_clause_extractor",
      "contract_playbook_comparator",
      "legal_evidence_reconciler",
      "legal_review_auditor",
      "legal_reporter"
    ],
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "allowed_tools": [
      "llm_ocr_extract",
      "field_extract",
      "schema_validate",
      "clause_extract",
      "taxonomy_map",
      "knowledge_retrieve",
      "finish"
    ],
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run",
    "default_mode": "bounded_llm_guided_legal_document_review",
    "note": "Document actors may use OCR and local playbook guidance; uncertain legal or payable values remain review-required."
  },
  "input_skills": {
    "llm_ocr": {
      "skill": "llm_ocr_skill",
      "package": "mirrorneuron-llm-ocr-skill",
      "connector": "docker_model_runner",
      "purpose": "Shared local LightOnOCR-2-1B OCR for scanned invoices, bills, contracts, and legal-support documents.",
      "enabled": true,
      "required": false,
      "backend": "llama.cpp",
      "endpoint": "http://host.docker.internal:12434",
      "model": "hf.co/noctrex/LightOnOCR-2-1B-GGUF:Q4_K_M",
      "quantization": "Q4_K_M",
      "min_text_chars": 40,
      "max_pages": null,
      "preload": true,
      "install_policy": "runtime",
      "remove_policy": "manual",
      "require_hardware_acceleration": true,
      "timeout_seconds": 180
    }
  },
  "output_skills": {},
  "skill_runtime": {
    "enabled": true,
    "auto_patch": false,
    "driver": "docker_worker",
    "install_scope": "shared_job_container",
    "docker_worker_image": "document_workflow/docker_worker",
    "image": "mirror-neuron/legal-assistant:local",
    "network": "mirror-neuron-runtime",
    "node_scope": "legal_assistant_python_executor_nodes"
  },
  "document_automation": {
    "fields": {
      "invoice_fields": [
        "supplier_name",
        "customer_name",
        "invoice_id",
        "tax_id",
        "due_date",
        "total_amount",
        "line_items",
        "consumption_fields",
        "billing_period"
      ],
      "clause_fields": [
        "governing_law",
        "change_of_control",
        "assignment",
        "indemnity",
        "termination",
        "audit_rights",
        "renewal",
        "exclusivity",
        "liability"
      ]
    },
    "output_type": "legal_assistant_report",
    "review_required": true,
    "recommended_action": "attorney_and_human_review_required_before_legal_payment_or_contract_action"
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
        "description": "Stable run-store files and domain-specific outputs.",
        "optional_artifacts": [
          "action_ledger.json",
          "artifact_quality.json",
          "run_health.json",
          "legal_deep_review.json",
          "legal_assistant_report.md"
        ]
      },
      "knowledge_rag": {
        "description": "Optional local blueprint knowledge retrieval used to ground actor prompts and tool planning.",
        "config": "knowledge_rag",
        "artifact": "knowledge/",
        "privacy": "blueprint knowledge only by default"
      },
      "agentic_research": {
        "description": "Bounded LLM-selected or actor-guided tool contract for local legal document work.",
        "config": "agentic_research"
      }
    },
