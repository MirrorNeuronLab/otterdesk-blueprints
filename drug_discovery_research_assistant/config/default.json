  "llm": {
    "enabled": true,
    "agent_role": "AI service coordinator for distributed candidate generation, DrugCLIP virtual screening, folding, simulation, and evidence review.",
    "agents": {
      "binding_evaluation": {
        "llm_config": "primary",
        "role": "Binding evaluation analyst",
        "responsibilities": [
          "Review docking or binding-score outputs.",
          "Explain affinity ranking caveats.",
          "Flag candidates needing wet-lab validation."
        ]
      },
      "candidate_generation": {
        "llm_config": "primary",
        "role": "Candidate generation strategist",
        "responsibilities": [
          "Compare generated compounds against project constraints.",
          "Summarize candidate families and tradeoffs.",
          "Flag manufacturability or novelty review needs."
        ]
      },
      "ranking_reporting": {
        "llm_config": "primary",
        "role": "Discovery report lead",
        "responsibilities": [
          "Assemble candidate ranking evidence.",
          "Summarize go/no-go review points.",
          "Keep conclusions preclinical and hypothesis-only."
        ]
      },
      "structure_generation": {
        "llm_config": "primary",
        "role": "Molecular design chemist",
        "responsibilities": [
          "Generate candidate structure rationale from deterministic outputs.",
          "Explain scaffold diversity and chemistry caveats.",
          "Keep generated structures review-only."
        ]
      },
      "target_discovery": {
        "llm_config": "primary",
        "role": "Target discovery scientist",
        "responsibilities": [
          "Identify disease-target hypotheses from configured inputs.",
          "Summarize target evidence and uncertainty.",
          "Flag missing assay or literature support."
        ]
      }
    },
    "provider": "docker_model_runner",
    "model": "default",
    "backend": "llama.cpp",
    "mode": "live",
    "mock_mode": "fake",
    "default_config": "primary",
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "responsibilities": [
      "Keep cheminformatics scoring and simulation outputs as the source of truth.",
      "Use LLM actors to explain hypotheses, evidence gaps, and review packets.",
      "Avoid claiming experimental validation or clinical readiness."
    ],
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "backend": "llama.cpp",
        "api_base": "auto",
        "timeout_seconds": 60,
        "max_tokens": 900,
        "num_retries": 1,
        "mock_mode": "fake",
        "mode": "live",
        "retry_backoff_seconds": 1.0,
        "required": true
      }
    },
    "require_live": false
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed",
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "resources_jsonl": true,
    "rotation": {
      "check_interval_records": 100,
      "compress": "background",
      "enabled": true,
      "max_bytes_mb": 100,
      "max_segments": 7,
      "span_seconds": 86400
    },
    "stderr_jsonl": true,
    "writer": {
      "batch_size": 100,
      "flush_interval_seconds": 0.5,
      "mode": "async",
      "overflow_policy": "drop_low_priority",
      "queue_size": 10000,
      "shutdown_flush_timeout_seconds": 2
    }
  },
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "drug_discovery_research_assistant_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "agentic_research": {
    "enabled": true,
    "agent_ids": [
      "target_discovery",
      "structure_generation",
      "candidate_generation",
      "binding_evaluation",
      "ranking_reporting"
    ],
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "allowed_tools": [
      "target_database_lookup",
      "structure_generation",
      "candidate_generation",
      "docking_score",
      "toxicity_filter",
      "finish"
    ],
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run",
    "default_mode": "bounded_llm_guided_scientific_tool_review",
    "note": "Scientific workers may use bounded tool outputs and local RAG guidance; failed or thin evidence remains explicit in the review packet."
  },
  "knowledge_rag": {
    "enabled": true,
    "backend": "milvus_lite",
    "required": false,
    "knowledge_dir": "knowledge",
    "purpose": "Retrieve local discovery-triage guidance for target evidence, generated candidate review, docking caveats, and report-only scientific risk checks.",
    "retrieval_targets": [
      "target evidence",
      "candidate scoring caveats",
      "docking and toxicity limitations",
      "scientific review blockers"
    ],
    "grounding_policy": "Use retrieved local blueprint knowledge to improve actor review prompts; do not invent facts when retrieval is unavailable.",
    "namespace": "",
    "embedding_provider": "docker_model_runner",
    "embedding_model": "rag-embedding",
    "embedding_api_base": "auto",
    "embedding_query_prefix": "Query: ",
    "embedding_document_prefix": "Document: ",
    "embedding_start_command": "",
    "embedding_healthcheck_enabled": true,
    "vector_dim": 1024,
    "index_on_startup": true,
    "top_k": 4,
    "max_context_chars": 4000,
    "chunk_size": 700,
    "chunk_overlap": 70,
    "privacy": "index local blueprint knowledge only; do not index private run documents unless a future runtime explicitly opts in"
  },
  "metadata": {
    "agent_role": "AI assistant for organizing drug discovery candidate generation, filtering, and evidence review.",
    "blueprint_id": "drug_discovery_research_assistant",
    "blueprint_revision": "v1",
    "category": "science",
    "customizable_for": "Drug discovery, target-focused virtual screening, molecular-generation pipelines, folding, simulation, and scientific research operations.",
    "description": "A continuous drug-discovery research service. Give it a disease or target profile, screening criteria, optional candidate seeds, literature notes, and an input folder; it continuously generates candidate hypotheses, screens them with DrugCLIP, folds targets, runs configured simulations across cluster workers, and writes review-only cycle reports until manually stopped.",
    "llm_agent_role": "AI service coordinator for distributed candidate generation, DrugCLIP virtual screening, folding, simulation, and evidence review.",
    "name": "Drug Discovery Research Assistant",
    "problem_solved": "Discovery work needs continuous, traceable candidate generation and scientific screening without collapsing cluster-scale folding and simulation into a single serial worker.",
    "simulation_type": "Continuous distributed computational discovery service with DrugCLIP virtual screening.",
    "standard_version": "1.0",
    "target_user": "Computational biology researchers, scientific AI platform teams, and research operations groups.",
    "target_users": "Computational biology researchers, scientific AI platform teams, and research operations groups."
  },
  "mode": "live",
  "service": {
    "enabled": true,
    "run_until": "manual_stop",
    "stop_file": "${MN_RUN_DIR}/STOP",
    "cycle_interval_seconds": 15,
    "max_cycles": null,
    "candidate_count": 160,
    "candidate_pool_size": 800,
    "drugclip_scoring_batch_size": 64,
    "simulation_top_k": 16,
    "parallelism": {
      "folding_workers": 2,
      "drugclip_workers": 4,
      "simulation_workers": 4
    },
    "shutdown_grace_seconds": 30,
    "status_artifact": "service_state.json"
  },
  "execution": {
    "fake_science_adapters": false,
    "native_worker_required": true,
    "mode": "cluster_dispatch"
  },
  "cluster_distribution": {
    "enabled": true,
    "dispatch_command": [],
    "dispatch_timeout_seconds": 1800,
    "fallback": "fail_closed",
    "contract": "The configured native dispatcher receives a JSON job specification on stdin and returns JSON with either result or a written output_path.",
    "worker_pools": {
      "control": "default",
      "generation": "science-generation",
      "folding": "science-folding",
      "drugclip": "science-drugclip",
      "simulation": "science-simulation",
      "aggregation": "default"
    },
    "collaboration": {
      "mode": "cross_box_fanout_fanin",
      "shared_artifact_contract": "cycle request/result JSON files in the run store",
      "idempotency_key": "run_id:cycle_id:adapter:target_or_candidate"
    }
  },
  "candidate_generator": {
    "required": true,
    "command": [
      "python3",
      "scripts/biotarget_adapter.py",
      "--adapter",
      "candidate_generator",
      "--input",
      "{input_path}",
      "--output",
      "{output_path}"
    ],
    "timeout_seconds": 1800,
    "contract": "Run BioTarget Stage C using the DrugClip graph-text model. Read JSON request from {input_path}; write JSON containing candidates to {output_path}."
  },
  "folding": {
    "required": true,
    "command": [
      "python3",
      "scripts/biotarget_adapter.py",
      "--adapter",
      "folding",
      "--input",
      "{input_path}",
      "--output",
      "{output_path}"
    ],
    "timeout_seconds": 3600,
    "contract": "Run BioTarget Stage B. Read a target request from {input_path}; write a structure result with a local path to {output_path}."
  },
  "drugclip": {
    "required": true,
    "mode": "text_molecular_graph_alignment",
    "model_ref": "hf.co/homerquan/DrugClip",
    "generic_model": {
      "enabled": true,
      "ownership": "blueprint_problem_specific",
      "shared_model_catalog": false,
      "model_ref": "https://huggingface.co/homerquan/DrugClip",
      "runtime": "native_checkpoint",
      "execution": "native_checkpoint",
      "validator": "mirrorneuron-use-generic-model-skill",
      "failure_policy": "fail_closed",
      "installation_policy": "Validate the explicit Hugging Face reference with mirrorneuron-use-generic-model-skill, then load best.ckpt through the native DrugCLIP checkpoint adapter. Docker Model Runner is intentionally unsupported for this checkpoint-only repository."
    },
    "checkpoint_repo": "homerquan/DrugClip",
    "checkpoint_filename": "best.ckpt",
    "source_repository": "@/payloads",
    "command": [
      "python3",
      "scripts/biotarget_adapter.py",
      "--adapter",
      "drugclip",
      "--input",
      "{input_path}",
      "--output",
      "{output_path}"
    ],
    "timeout_seconds": 1800,
    "contract": "Use BioTarget's DrugClip graph-text alignment path. Read a molecular candidate and therapeutic intent from {input_path}; write drugclip_score to {output_path}."
  },
  "biotarget": {
    "enabled": true,
    "source_dir": "@/payloads",
    "native_python_required": true,
    "stages": {
      "target_discovery": "biotarget.stages.stage_a_discovery",
      "folding": "biotarget.stages.stage_b_structure",
      "candidate_generation": "biotarget.stages.stage_c_generative",
      "evaluation": "biotarget.stages.stage_d_evaluation"
    },
    "simulation_engine": "gnina"
  },
  "output_skills": {},
  "python_dependencies": {
    "installer": "pip",
    "requirements": "requirements.txt",
    "index_url": "https://us-central1-python.pkg.dev/mirrorneuron-public-packages/agent-skills/simple/",
    "extra_index_url": "https://pypi.org/simple",
    "packages": []
  },
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Continuous-cycle candidate, folding, DrugCLIP, simulation, state, and review-only scientific evidence artifacts.",
    "run_root": "~/.mn/runs",
    "skills": {},
    "tcp": {
      "enabled": false,
      "ports": []
    },
    "write_run_store": true,
    "folder_path": "~/Downloads/drug_discovery_research_assistant"
  },
  "privacy": {
    "default_classification": "confidential",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "resources": {
    "enabled": true,
    "gpu_enabled": true,
    "gpu_sample_interval_seconds": 60,
    "history_window_hours": 24,
    "raw_retention_hours": 48,
    "rollup_bucket_seconds": 3600,
    "sample_interval_seconds": 10,
    "gpu_count": 1,
    "gpu": {
      "min_count": 1,
      "vendor": "nvidia",
      "driver": "cuda",
      "enforcement": "hard"
    },
    "required_capabilities": [
      "nvidia",
      "cuda"
    ]
  },
  "schemas": {
    "artifact_record": "mn.artifact.record.v1",
    "config": "mn.blueprint.config.v1",
    "events": "mn.blueprint.events.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "human_control": "mn.blueprint.human_control.v1",
    "input_skills": "mn.blueprint.input_skills.v1",
