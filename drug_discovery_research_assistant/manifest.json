          "type": "domain_value"
        }
      ],
      "resolved_artifact": "inputs.json",
      "schema_version": "mn.blueprint.input_contract.v1",
      "supported_adapters": [
        "mock",
        "json",
        "file",
        "env_json"
      ],
      "validation_rules": []
    },
    "interfaces": {
      "channels": {
        "agentic_research": {
          "config": "agentic_research",
          "description": "Bounded LLM-selected or actor-guided tool contract for domain work."
        },
        "artifacts": {
          "artifacts": [
            "run.json",
            "config.json",
            "inputs.json",
            "events.jsonl",
            "result.json",
            "final_artifact.json"
          ],
          "description": "Stable run-store files and domain-specific outputs.",
          "optional_artifacts": [
            "job.json",
            "web_ui.json",
            "ui.json",
            "web/index.html",
            "logs.jsonl"
          ]
        },
        "events": {
          "artifact": "events.jsonl",
          "description": "Append-only workflow events."
        },
        "human": {
          "artifact": "human.jsonl",
          "description": "Human notices, approval requests, responses, timeouts, and applied decisions."
        },
        "input_skills": {
          "description": "Connector-backed or reusable skill-backed input sources."
        },
        "inputs": {
          "artifact": "inputs.json",
          "description": "Resolved runtime inputs and adapter provenance."
        },
        "knowledge_rag": {
          "artifact": "knowledge/",
          "config": "knowledge_rag",
          "description": "Optional local blueprint knowledge retrieval used to ground actor prompts and tool planning.",
          "privacy": "blueprint knowledge only by default"
        },
        "logs": {
          "description": "Runtime stdout/stderr and explicit log artifacts.",
          "stream": "stdout/stderr"
        },
        "output_skills": {
          "description": "Optional fan-out destinations after local run-store writes."
        },
        "outputs": {
          "artifacts": [
            "result.json",
            "final_artifact.json"
          ],
          "description": "Primary result and final user-facing artifact."
        },
        "resources": {
          "artifact": "resources.jsonl",
          "description": "Resource samples such as token, runtime, connector, and disk usage."
        },
        "streams": {
          "default": [
