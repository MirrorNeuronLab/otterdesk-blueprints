  "requirements": {
    "cpu": {
      "min_cores": 1
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "driver": "cuda",
      "enforcement": "hard",
      "min_count": 1,
      "vendor": "nvidia"
    },
    "memory": {
      "min_gb": 2
    }
  },
  "runtime": {
    "models": {
      "primary": {
        "backend": "llama.cpp",
        "model": "default",
        "provider": "docker_model_runner",
        "required": true
      }
    }
  },
  "service": {
    "cycle_artifact_root": "cycles/",
    "enabled": true,
    "manual_close": "send SIGTERM or create the configured STOP file",
    "run_until": "manual_stop",
    "state_artifact": "service_state.json",
    "stop_file": "${MN_RUN_DIR}/STOP"
  },
  "skill_dependencies": [
    {
      "type": "pip",
      "source": "gar",
      "name": "mirrorneuron-use-generic-model-skill",
      "version": "1.2.29"
    }
  ],
  "agent_dependencies": [
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-stateful-step-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-supervised-service-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-artifact-finalizer-agent",
      "version": "1.2.29"
    }
  ],
  "standard": {
    "migration_policy": "sdk_managed",
    "profile": "blueprint",
    "profile_version": 1,
    "source_schema": "mn.workflow.source/v2",
    "target_schema": "mn.workflow/v1"
  },
  "type": "service",
  "workers": {
    "groups": [
      {
        "steps": [
          "target_discovery",
          "structure_generation",
          "candidate_generation",
          "binding_evaluation",
          "ranking_reporting"
        ],
        "uses": "mn-agents.worker.python_docker@1",
        "with": {
          "stereotype": [
            "blueprint_docker_worker",
            "internal_write_worker"
          ],
          "docker_worker_image": "docker_worker",
          "image": "mirror-neuron/drug-discovery-research-assistant:drugclip-gnina",
          "gpus": "all",
          "shared_container": true,
          "reuse_shared_container": true,
          "timeout_seconds": 0
        }
      }
    ]
  },
  "workflow": {
    "dynamic": {
      "apply_at": "between_steps",
      "enabled": false,
      "patch_events": []
    },
    "execution": {
      "strategy": "parallel"
    },
    "policy": {
      "failure": {
        "default": "fail_closed"
      },
      "human": {
        "allowed_decisions": [
          "approve",
          "revise",
          "reject"
        ],
        "blocked_actions": [
          "advance_to_lab_experiment",
          "make_clinical_claim",
          "submit_regulatory_material",
          "send_candidate_to_external_system_without_review"
        ],
        "decision_event": "human_decision_applied",
        "default_action": "reject",
        "enabled": true,
        "events": [
          "human_notice",
          "human_input_requested",
          "human_input_received",
          "human_input_timeout",
          "human_decision_applied"
        ],
        "mode": "approval_required",
        "reason": "Human approval is required before high-impact downstream actions such as advance_to_lab_experiment, make_clinical_claim, submit_regulatory_material.",
        "request_event": "human_input_requested",
        "response_event": "human_input_received",
        "timeout_event": "human_input_timeout",
        "timeout_seconds": 3600
      }
    },
    "state": {
      "candidate_seed_set": {
        "from": "$inputs.candidate_seed_set"
      },
      "candidates": {},
      "disease_or_target_profile": {
        "from": "$inputs.disease_or_target_profile"
      },
      "evaluations": {},
      "final_report": {},
      "screening_criteria": {
        "from": "$inputs.screening_criteria"
      },
      "structures": {},
      "targets": {}
    },
    "steps": [
      {
        "goal": "Identify and summarize disease targets and biological constraints.",
        "id": "target_discovery",
        "kind": "source",
        "label": "Target Discovery",
        "needs": [],
        "run": {
          "definition": "steps.target_discovery"
        }
      },
      {
        "goal": "Generate or retrieve useful target structures for screening.",
        "id": "structure_generation",
        "kind": "stage",
        "label": "Structure Generation",
        "needs": [
          "target_discovery"
        ],
        "run": {
          "definition": "steps.structure_generation"
        }
      },
      {
        "goal": "Continuously generate candidates, dispatch parallel folding, DrugCLIP screening, and simulation jobs until manually stopped.",
        "id": "candidate_generation",
        "kind": "stage",
        "label": "Continuous Discovery Service",
        "needs": [
          "structure_generation"
        ],
        "run": {
          "definition": "steps.candidate_generation"
        }
      },
      {
        "goal": "Read the final continuous-service cycle summaries and preserve review-only scientific evidence.",
        "id": "binding_evaluation",
        "kind": "stage",
        "label": "Cycle Results Review",
        "needs": [
          "candidate_generation"
        ],
        "run": {
          "definition": "steps.binding_evaluation"
        }
      },
      {
        "goal": "Rank candidates, summarize evidence, and prepare a human-reviewable research artifact.",
        "id": "ranking_reporting",
        "kind": "sink",
        "label": "Ranking And Reporting",
        "needs": [
          "binding_evaluation"
        ],
        "run": {
          "definition": "steps.ranking_reporting"
        }
      }
    ],
    "workflow_id": "drug_discovery_research_assistant_v1"
  }
}
