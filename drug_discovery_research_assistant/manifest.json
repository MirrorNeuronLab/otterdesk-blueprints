      "required": true
    },
    "input_contract": {
      "description": "Discovery work is iterative and evidence-heavy; researchers need an assistant that keeps candidate generation, scoring, extraction, and review moving in order.",
      "optional_inputs": [
        {
          "description": "Research papers, notes, or database exports used as evidence.",
          "example": "pubmed-export.json",
