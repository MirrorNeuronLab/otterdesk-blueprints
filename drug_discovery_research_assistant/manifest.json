{
  "agentic_research": {
    "agent_ids": [
      "target_discovery",
      "structure_generation",
      "candidate_generation",
      "binding_evaluation",
      "ranking_reporting"
    ],
    "allowed_tools": [
      "target_database_lookup",
      "structure_generation",
      "candidate_generation",
      "docking_score",
      "toxicity_filter",
      "finish"
    ],
    "default_mode": "bounded_llm_guided_scientific_tool_review",
    "enabled": true,
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "note": "Scientific workers may use bounded tool outputs and local RAG guidance; failed or thin evidence remains explicit in the review packet.",
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run"
  },
  "agents": {
    "registry": {
      "target_discovery": {
        "handler": "agents.target_discovery",
        "role": "Target Discovery"
      },
      "structure_generation": {
        "handler": "agents.structure_generation",
        "role": "Structure Generation"
      },
      "candidate_generation": {
        "handler": "agents.candidate_generation",
        "role": "Continuous Discovery Service"
      },
      "binding_evaluation": {
        "handler": "agents.binding_evaluation",
        "role": "Cycle Results Review"
      },
      "ranking_reporting": {
        "handler": "agents.ranking_reporting",
        "role": "Ranking And Reporting"
      }
    }
  },
  "apiVersion": "mn.workflow.source/v2",
  "cluster_distribution": {
    "collaboration": {
      "aggregation": "fan in cycle artifacts into review-only reports",
      "drugclip": "fan out by target-candidate pair",
      "folding": "fan out by target",
      "mode": "cross_box_fanout_fanin",
      "simulation": "fan out over DrugCLIP-selected candidates"
    },
    "dispatch_contract": "A configured dispatcher receives JSON jobs on stdin and returns JSON results or writes the declared output_path.",
    "enabled": true,
    "execution_backend": "native_dispatch_contract",
    "fallback": "fail_closed",
    "native_worker": "MirrorNeuron.Runner.HostLocal",
    "worker_pools": {
      "aggregation": "default",
      "control": "default",
      "drugclip": "science-drugclip",
      "folding": "science-folding",
      "generation": "science-generation",
      "simulation": "science-simulation"
    }
  },
  "config": {
    "default": "config/default.json",
    "embed": true,
    "manifest_defaults": [
      "agentic_research",
      {
        "from": "requirements",
        "to": "resources"
      },
      {
        "from": "workflow.policy.human",
        "to": "human_control"
      },
      {
        "from": "contracts.input_adapters.supported",
        "to": "interfaces.input_adapters"
      },
      {
        "from": "contracts.inputs",
        "to": "interfaces.input_contract"
      },
      {
        "from": "identity.id",
        "to": "identity.blueprint_id"
      },
      {
        "from": "identity.name",
        "to": "identity.name"
      }
    ]
  },
  "contracts": {
    "events": {
      "human_stream": "human.jsonl",
      "stream": "events.jsonl",
      "types": [
        "run_started",
        "inputs_loaded",
        "simulation_step_started",
        "llm_decision",
        "simulation_state_updated",
        "run_completed",
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "artifact_written",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
        "output_skill_started",
        "output_skill_completed",
        "output_skill_failed"
      ]
    },
    "input_adapters": {
      "default": "mock",
      "resolved_artifact": "inputs.json",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ]
    },
    "inputs": {
      "assay_constraints": {
        "description": "Wet-lab, ADMET, or computational constraints that shape recommendations.",
        "example": {
          "assay": "in vitro",
          "species": "human"
        },
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "candidate_seed_set": {
        "description": "Optional seed molecules, protein targets, or prior candidates to compare.",
        "example": [
          "known_reference_compound_a"
        ],
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "disease_or_target_profile": {
        "description": "Disease, target, pathway, or phenotype that frames the discovery run.",
        "example": "Alzheimer disease BACE1 modulation",
        "privacy": "confidential",
        "required": true,
        "type": "domain_value"
      },
      "input_folder": {
        "description": "Default local input folder for sample files or user-provided files.",
        "example": "@/examples/sample_inputs",
        "path_kind": "directory",
        "privacy": "confidential",
        "required": false,
        "type": "local_path"
      },
      "literature_corpus": {
        "description": "Research papers, notes, or database exports used as evidence.",
        "example": "pubmed-export.json",
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      },
      "output_folder": {
        "description": "Default local output folder for generated artifacts and reports.",
        "example": "~/Downloads/drug_discovery_research_assistant",
        "path_kind": "directory",
        "privacy": "confidential",
        "required": false,
        "type": "local_path"
      },
      "screening_criteria": {
        "description": "Desired candidate, assay, safety, novelty, or evidence criteria.",
        "example": {
          "potency": "sub-micromolar",
          "toxicity": "low"
        },
        "privacy": "confidential",
        "required": false,
        "type": "domain_value"
      }
    },
    "outputs": {
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "logs",
          "mime_type": "application/x-jsonlines",
          "path": "logs.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.logs.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "logs"
        },
        {
          "artifact_id": "resources",
          "mime_type": "application/x-jsonlines",
          "path": "resources.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.resources.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "resource_samples"
        },
        {
          "artifact_id": "web_ui",
          "mime_type": "application/json",
          "path": "web_ui.json",
          "producer": "web_ui",
          "schema_version": "mn.blueprint.web_ui.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "web_ui"
        },
        {
          "artifact_id": "human_events",
          "mime_type": "application/x-jsonlines",
          "path": "human.jsonl",
          "producer": "human_control",
          "schema_version": "mn.blueprint.human_events.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "human_events"
        },
        {
          "artifact_id": "candidate_report",
          "mime_type": "application/json",
          "path": "final_artifact.candidate_artifacts",
          "producer": "workflow",
          "schema_version": "mn.blueprint.generated_report.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "generated_report"
        },
        {
          "artifact_id": "stage_logs",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.event_log.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "event_log"
        }
      ],
      "primary": {
        "id": "final_artifact",
        "path": "final_artifact.json",
        "required_fields": [
          "type",
          "executive_summary",
          "recommended_action",
          "confidence",
          "evidence",
          "next_steps",
          "source_refs"
        ],
        "schema_version": "mn.blueprint.final_artifact_contract.v1",
        "type": "final_artifact"
      },
      "profile": "standard_run_store"
    },
    "privacy": {
      "default_classification": "confidential",
      "rules": {
        "confidential": {
          "log": "redacted",
          "send_to_llm": "allowed_configs_only",
          "send_to_output_skills": "approved_destinations_only"
        },
        "internal": {
          "log": "metadata_only",
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "public": {
          "log": true,
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "regulated": {
          "log": "redacted",
          "send_to_llm": false,
          "send_to_output_skills": "approved_destinations_only"
        }
      }
    },
    "status": {
      "event": "blueprint_status",
      "heartbeat": true,
      "phases": [
        "loading_inputs",
        "running_worker",
        "waiting_for_human",
        "writing_artifacts",
        "completed"
      ]
    },
    "summary": "A manually stopped native discovery service that continuously fans candidate, folding, DrugCLIP, and simulation work across configured cluster pools.",
    "users": [
      "Computational biology researchers, scientific AI platform teams, and research operations groups."
    ]
  },
  "defaults": {
    "worker": {
      "uses": "mn-agents.worker.python_host@1",
      "with": {
        "stereotype": [
          "blueprint_host_worker",
          "internal_write_worker"
        ],
        "upload_paths": [
          {
            "source": "domain",
            "target": "domain"
          },
          {
            "source": "service",
            "target": "service"
          },
          {
            "source": "biotarget",
            "target": "biotarget"
          }
        ]
      }
    }
  },
  "description": "A continuous drug-discovery research service. Give it a disease or target profile, screening criteria, optional candidate seeds, literature notes, and an input folder; it continuously generates candidate hypotheses, screens them with DrugCLIP, folds targets, runs configured simulations across cluster workers, and writes review-only cycle reports until manually stopped.",
  "identity": {
    "category": "science",
    "id": "drug_discovery_research_assistant",
    "job_name": "drug-discovery-research-assistant",
    "manifest_version": "1.0",
    "name": "Drug Discovery Research Assistant",
    "version": 1
  },
  "intent": {
    "customizable_for": "Drug discovery, material search, assay planning, scientific literature review, and research pipeline support.",
    "description": "A continuous drug-discovery research service. Give it a disease or target profile, screening criteria, optional candidate seeds, literature notes, and an input folder; it continuously generates candidate hypotheses, screens them with DrugCLIP, folds targets, runs configured simulations across cluster workers, and writes review-only cycle reports until manually stopped.",
    "problem": "Discovery work needs continuous, traceable candidate generation and scientific screening without collapsing cluster-scale folding and simulation into a single serial worker.",
    "safety": {
      "allowed_decisions": [
        "approve",
        "revise",
        "reject"
      ],
      "blocked_actions": [
        "advance_to_lab_experiment",
        "make_clinical_claim",
        "submit_regulatory_material",
        "send_candidate_to_external_system_without_review"
      ],
      "decision_event": "human_decision_applied",
      "default_action": "reject",
      "enabled": true,
      "events": [
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied"
      ],
      "mode": "approval_required",
      "reason": "Human approval is required before high-impact downstream actions such as advance_to_lab_experiment, make_clinical_claim, submit_regulatory_material.",
      "request_event": "human_input_requested",
      "response_event": "human_input_received",
      "timeout_event": "human_input_timeout",
      "timeout_seconds": 3600
    },
    "target_users": "Computational biology researchers, scientific AI platform teams, and research operations groups."
  },
  "job_name": "drug-discovery-research-assistant",
  "kind": "WorkflowSource",
  "knowledge_rag": {
    "backend": "redis_vector_rag",
    "chunk_overlap": 70,
    "chunk_size": 700,
    "embedding_api_base": "auto",
    "embedding_document_prefix": "Document: ",
    "embedding_healthcheck_enabled": true,
    "embedding_model": "rag-embedding",
    "embedding_provider": "docker_model_runner",
    "embedding_query_prefix": "Query: ",
    "embedding_start_command": "",
    "enabled": true,
    "grounding_policy": "Use retrieved local blueprint knowledge to improve actor review prompts; do not invent facts when retrieval is unavailable.",
    "index_on_startup": false,
    "knowledge_dir": "knowledge",
    "max_context_chars": 4000,
    "namespace": "",
    "privacy": "index local blueprint knowledge only; do not index private run documents unless a future runtime explicitly opts in",
    "purpose": "Retrieve local discovery-triage guidance for target evidence, generated candidate review, docking caveats, and report-only scientific risk checks.",
    "redis_url": "",
    "required": false,
    "retrieval_targets": [
      "target evidence",
      "candidate scoring caveats",
      "docking and toxicity limitations",
      "scientific review blockers"
    ],
    "top_k": 4,
    "vector_dim": 1024
  },
  "manifest": {
    "type": "service"
  },
  "metadata": {
    "agent_role": "AI service coordinator for distributed candidate generation, DrugCLIP virtual screening, folding, simulation, and evidence review.",
    "agentic_research": {
      "agent_ids": [
        "target_discovery",
        "structure_generation",
        "candidate_generation",
        "binding_evaluation",
        "ranking_reporting"
      ],
      "allowed_tools": [
        "target_database_lookup",
        "structure_generation",
        "candidate_generation",
        "docking_score",
        "toxicity_filter",
        "finish"
      ],
      "default_mode": "bounded_llm_guided_scientific_tool_review",
      "enabled": true,
      "max_iterations_per_agent": 1,
      "max_tool_calls_per_agent": 2,
      "note": "Scientific workers may use bounded tool outputs and local RAG guidance; failed or thin evidence remains explicit in the review packet.",
      "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run"
    },
    "blueprint_id": "drug_discovery_research_assistant",
    "category": "science",
    "configuration_contract": {
      "optional_files": [
        "scenario.json",
        "config/overwrite.json",
        "knowledge/"
      ],
