  "name": "Drug Discovery Research Assistant",
  "nodes": [
    {
      "node_id": "target_discovery",
      "uses": "mn-agents.data_python_executor@1.0.0",
      "with": {
        "command": [
          "python3",
          "scripts/stage_a.py"
        ],
