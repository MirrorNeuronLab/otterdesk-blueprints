        }
      ],
      "privacy_classification": "confidential",
      "profiles": {
        "connector": {
          "adapter": "json",
          "description": "Connector-provided target profile and evidence summaries from approved research systems."
        },
        "env_json": {
          "adapter": "env_json",
          "description": "JSON object loaded from MN_BLUEPRINT_INPUT_JSON."
        },
        "file": {
          "adapter": "file",
          "description": "JSON object loaded from a local file path."
        },
        "json": {
          "adapter": "json",
