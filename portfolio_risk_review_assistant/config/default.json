{
  "agent_handoffs": {},
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 30,
      "max_concurrent_calls": 2
    },
    "max_concurrency": 4,
    "max_events_per_second": 10,
    "queue_size": 1000
  },
  "benchmark": {
    "baseline": "no_action",
    "benchmark_portfolio": {
      "AGG": 0.3,
      "GLD": 0.1,
      "SPY": 0.6
    },
    "enabled": true,
    "quality_metrics": [
      "expected_return",
      "var_reduction",
      "cvar_reduction",
      "drawdown_reduction",
      "policy_fit",
      "turnover"
    ],
    "schema_version": "mn.finance.portfolio_risk.benchmark.v1"
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 20,
    "max_disk_mb": 250,
    "max_llm_calls": 5,
    "max_llm_tokens": 20000,
    "max_runtime_seconds": 600,
    "max_stream_duration_seconds": 3600
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "network.egress",
      "stream.subscribe"
    ],
    "required": [
      "filesystem.write"
    ]
  },
  "decision_policy": {
    "allowed_actions": [
      "no_action",
      "raise_cash",
      "reduce_concentration",
      "reduce_equity_beta",
      "duration_hedge",
      "credit_risk_reduction"
    ],
    "blocked_actions": [
      "place_trade",
      "rebalance_portfolio",
      "send_order",
      "notify_client_with_recommendation_without_review"
    ],
    "max_turnover_pct": 15,
    "minimum_cash_pct": 5,
    "restricted_symbols": [],
    "review_only": true
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "evaluate_workflow_state",
    "route_by_context",
    "request_human_input",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact",
    "fan_out_output_skills",
    "emit_status_events",
    "handle_human_control",
    "write_artifact_records"
  ],
  "human_control": {
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "place_trade",
      "rebalance_portfolio",
      "send_order",
      "notify_client_with_recommendation_without_review"
    ],
    "decision_event": "human_decision_applied",
    "default_action": "reject",
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "approval_required",
    "reason": "Human approval is required before high-impact downstream actions such as place_trade, rebalance_portfolio, send_order.",
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "timeout_seconds": 3600
  },
  "identity": {
    "blueprint_id": "portfolio_risk_review_assistant",
    "name": "Portfolio Risk Review Assistant"
  },
  "input_skills": {},
  "inputs": {
    "adapter": "json",
    "description": "Real-data default portfolio using public market quotes for supplied symbols.",
    "payload": {
      "benchmark_portfolio": {
        "AGG": 0.3,
        "GLD": 0.1,
        "SPY": 0.6
      },
      "decision_constraints": {
        "allowed_actions": [
          "no_action",
          "raise_cash",
          "reduce_concentration",
          "reduce_equity_beta",
          "duration_hedge",
          "credit_risk_reduction"
        ],
        "restricted_symbols": [],
        "review_only": true
      },
      "market_signals": [],
      "monte_carlo_paths": 1000,
      "portfolio": {
        "base_currency": "USD",
        "cash": 50000,
        "holdings": [
          {
            "asset_class": "equity",
            "liquidity": "daily",
            "quantity": 180,
            "symbol": "SPY"
          },
          {
            "asset_class": "rates",
            "liquidity": "daily",
            "quantity": 300,
            "symbol": "AGG"
          },
          {
            "asset_class": "commodity",
            "liquidity": "daily",
            "quantity": 80,
            "symbol": "GLD"
          }
        ]
      },
      "risk_policy": {
        "max_cvar_pct": 11,
        "max_drawdown_pct": 15,
        "max_single_name_weight_pct": 45,
        "max_turnover_pct": 15,
        "max_var_pct": 8,
        "min_cash_pct": 5
      },
      "seed": 42,
      "simulation_horizon_days": 20
    }
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
        "description": "Stable run-store files and domain-specific outputs.",
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl"
        ]
      },
      "events": {
        "artifact": "events.jsonl",
        "description": "Append-only workflow events."
      },
      "human": {
        "artifact": "human.jsonl",
        "description": "Human notices, approval requests, responses, timeouts, and applied decisions.",
        "mirrored_to": "events.jsonl"
      },
      "input_skills": {
        "description": "Connector-backed or reusable skill-backed input sources."
      },
      "inputs": {
        "artifact": "inputs.json",
        "description": "Resolved runtime inputs and adapter provenance."
      },
      "logs": {
        "artifact": "logs.jsonl",
        "description": "Runtime stdout/stderr and explicit log artifacts.",
        "index": "logs.index.json",
        "stream": "stdout/stderr"
      },
      "output_skills": {
        "description": "Optional fan-out destinations after local run-store writes."
      },
      "outputs": {
        "artifacts": [
          "result.json",
          "final_artifact.json"
        ],
        "description": "Primary result and final user-facing artifact."
      },
      "resources": {
        "artifact": "resources.jsonl",
        "description": "Resource samples such as token, runtime, connector, and disk usage."
      },
      "streams": {
        "default": [
          "events"
        ],
        "description": "Named data or event streams exposed by the blueprint.",
        "kinds": [
          "audio",
          "video",
          "data",
          "multimodal"
        ],
