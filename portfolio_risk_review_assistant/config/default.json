  "metadata": {
    "agent_role": "LLM report writer that summarizes supplied market signals and structured simulation evidence; deterministic finance workers propose, simulate, evaluate, and benchmark decisions.",
    "blueprint_id": "portfolio_risk_review_assistant",
    "blueprint_revision": "v1",
    "category": "finance",
    "customizable_for": "Wealth management, treasury review, family offices, robo-advisory risk workflows, portfolio monitoring, and review-only advisor workbenches.",
    "description": "Real-time, review-only portfolio risk advisor that uses public market data, financial engineering simulation, decision benchmarking, and LLM-written review reports.",
    "llm_agent_role": "LLM report writer that summarizes supplied market signals and structured simulation evidence; deterministic finance workers propose, simulate, evaluate, and benchmark decisions.",
    "name": "Portfolio Risk Review Assistant",
    "problem_solved": "Portfolio teams need reviewable real-time risk advice that separates deterministic financial engineering from LLM narrative generation.",
    "simulation_type": "Real-time public-market portfolio risk review with Monte Carlo decision benchmarking.",
    "standard_version": "1.0",
    "target_user": "Investors, advisors, portfolio managers, treasury teams, and fintech operators.",
    "target_users": "Investors, advisors, portfolio managers, treasury teams, and fintech operators."
  },
  "mode": "real_time_review",
  "monte_carlo": {
    "horizon_days": 20,
    "paths": 1000,
    "rebalance_assumption": "review_only_partial_trim_to_cash",
    "seed": 42,
    "shock_overlays": [
      "historical_return_distribution"
    ]
  },
  "output_skills": {},
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Plain-language portfolio risk notes, stress results, and draft rebalancing options.",
    "run_root": "~/.mn/runs",
    "skills": {},
    "tcp": {
      "enabled": false,
      "ports": []
    },
    "write_run_store": true
  },
  "privacy": {
    "default_classification": "confidential",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "real_adapters": {
