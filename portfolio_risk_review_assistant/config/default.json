  "llm": {
    "enabled": true,
    "agent_role": "LLM report writer that summarizes supplied market signals and structured simulation evidence; deterministic finance workers propose, simulate, evaluate, and benchmark decisions.",
    "agents": {
      "default": {
        "llm_config": "primary",
        "responsibilities": [
          "interpret supplied market signals",
          "write final report from structured metrics",
          "avoid inventing prices or executable trades"
        ],
        "role": "LLM report writer that summarizes supplied market signals and structured simulation evidence; deterministic finance workers propose, simulate, evaluate, and benchmark decisions."
      }
    },
    "responsibilities": [
      "interpret supplied market signals",
      "write final report from structured metrics",
      "avoid inventing prices or executable trades"
    ],
    "mock_mode": "fake",
    "model": "default"
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed",
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "market_data_loaded",
      "risk_state_computed",
      "decision_candidates_proposed",
      "decision_simulated",
      "decision_evaluated",
      "benchmark_step_scored",
      "llm_report_written",
      "output_skill_failed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "resources_jsonl": true,
    "rotation": {
      "check_interval_records": 100,
      "compress": "background",
      "enabled": true,
      "max_bytes_mb": 100,
      "max_segments": 7,
      "span_seconds": 86400
    },
    "stderr_jsonl": true,
    "writer": {
      "batch_size": 100,
      "flush_interval_seconds": 0.5,
      "mode": "async",
      "overflow_policy": "drop_low_priority",
      "queue_size": 10000,
      "shutdown_flush_timeout_seconds": 2
    }
  },
  "market_data": {
    "benchmark_symbols": [
      "SPY",
      "AGG",
      "GLD"
    ],
    "fail_closed": true,
    "history_range": "1y",
    "interval": "1d",
    "provider": "public_yahoo_chart",
    "refresh_seconds": 60,
    "retry": {
      "backoff_seconds": 1,
      "max_attempts": 2
    },
    "stale_after_seconds": 259200,
    "timeout_seconds": 8
  },
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
