          "node_id": "report_sink",
          "uses": "mn-agents.control_join@1.0.0"
        }
      ],
      "render_tool": "../mn-agents/tools/render_agent_templates.py",
      "rendered_output": "manifest.rendered.json or runtime metadata",
      "renderer": "mn_blueprint_support.render_manifest_agent_templates"
    },
    "blueprint_id": "portfolio_risk_review_assistant",
    "category": "finance",
    "configuration_contract": {
      "optional_files": [
        "scenario.json",
        "config/overwrite.json",
        "knowledge/"
      ],
      "required_files": [
        "manifest.json",
        "README.md",
        "SPEC.md",
        "config/default.json",
        "payloads/",
        "LICENSE.md",
        "TERM.md"
      ]
    },
    "customizable_for": "Wealth management, treasury review, family offices, robo-advisory risk workflows, and portfolio check-ins.",
    "description": "Stress-tests a portfolio against market crashes, rate shocks, and liquidity pressure, then explains risks and possible rebalancing options in plain language.",
    "human_control": {
      "allowed_decisions": [
        "approve",
        "revise",
        "reject"
      ],
      "blocked_actions": [
        "place_trade",
        "rebalance_portfolio",
        "send_order",
        "notify_client_with_recommendation_without_review"
      ],
      "decision_event": "human_decision_applied",
      "default_action": "reject",
      "enabled": true,
      "events": [
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied"
      ],
      "mode": "approval_required",
      "reason": "Human approval is required before high-impact downstream actions such as place_trade, rebalance_portfolio, send_order.",
      "request_event": "human_input_requested",
      "response_event": "human_input_received",
      "timeout_event": "human_input_timeout",
      "timeout_seconds": 3600
    },
    "init_config_review": {
      "checks": [
        "identity",
        "mode",
        "inputs",
        "streams",
        "input_skills",
        "outputs",
        "privacy",
        "budgets"
      ],
      "fields": [
        {
          "default": "stagflation shock",
          "description": "Confirm the macro or market shock to evaluate.",
          "label": "Stress scenario",
          "path": "inputs.payload.scenario"
        },
        {
          "default": 5,
          "description": "Number of decision-loop steps to run.",
          "label": "Simulation steps",
          "path": "inputs.payload.steps"
        },
        {
          "default": "http://192.168.4.173:11434",
          "description": "Base URL for the local risk-review model server.",
          "label": "LLM URL",
          "path": "llm.api_base"
        },
        {
          "default": "ollama/nemotron3:33b",
          "description": "Model used to draft risk notes and ranked options.",
          "label": "LLM model",
          "path": "llm.model"
        }
      ],
      "instruction": "When running in OtterDesk, show these overwriteable fields during init config and ask the user to change them or keep the defaults before launch.",
      "required": true
    },
    "input_contract": {
      "description": "Portfolio risk can change quickly during shocks; users need an assistant that makes downside exposure and possible next steps easier to review.",
      "optional_inputs": [
        {
          "description": "Allowed actions, no-trade assets, cash needs, and client restrictions.",
          "example": [
            "raise_cash",
            "hedge_rates"
          ],
          "name": "rebalancing_constraints",
          "type": "domain_value"
        },
        {
          "description": "Human notes that should shape the risk explanation.",
          "example": "client needs two years of cash buffer",
          "name": "advisor_notes",
          "type": "domain_value"
        }
      ],
      "privacy_classification": "confidential",
      "profiles": {
        "connector": {
          "adapter": "json",
          "description": "Portfolio snapshot supplied by an approved PMS, custodian, or risk connector."
        },
        "env_json": {
          "adapter": "env_json",
          "description": "JSON object loaded from MN_BLUEPRINT_INPUT_JSON."
        },
        "file": {
          "adapter": "file",
          "description": "JSON object loaded from a local file path."
        },
        "json": {
          "adapter": "json",
          "description": "Inline JSON object supplied through config or runtime overrides."
        },
        "mock": {
          "adapter": "mock",
          "description": "Bundled stagflation stress scenario.",
          "payload": {
            "scenario": "stagflation shock",
            "seed": 42,
            "steps": 5
          }
        },
        "sample_file": {
          "adapter": "file",
          "description": "JSON holdings and scenario file loaded from disk.",
          "path": "scenario.json"
        }
      },
      "required_inputs": [
        {
          "description": "Holdings, exposure, liquidity, and constraints used for the stress review.",
          "example": {
            "liquidity_pct": 18,
            "portfolio_value": 1000000
          },
          "name": "portfolio_snapshot",
          "type": "domain_value"
        },
        {
          "description": "Market scenario or macro shock to test.",
          "example": "stagflation shock",
          "name": "shock_scenario",
          "type": "domain_value"
        },
        {
          "description": "Risk, liquidity, drawdown, tax, and mandate limits used to evaluate actions.",
          "example": {
            "max_drawdown_pct": 12
          },
          "name": "risk_policy",
          "type": "domain_value"
        }
      ],
      "resolved_artifact": "inputs.json",
      "schema_version": "mn.blueprint.input_contract.v1",
      "supported_adapters": [
