  "job_name": "portfolio-risk-review-assistant",
  "license": "LICENSE.md",
  "manifest_version": "1.0",
  "metadata": {
    "agent_role": "AI assistant for reviewing portfolio stress scenarios and drafting risk notes.",
    "agent_templates": {
      "library": "../mn-agents/index.json",
      "nodes": [
        {
          "node_id": "simulation_loop",
          "uses": "mn-agents.data_python_executor@1.0.0"
