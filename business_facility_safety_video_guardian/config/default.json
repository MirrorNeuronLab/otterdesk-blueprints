  "llm": {
    "agent_role": "Safety observation and face-description escalation agent.",
    "agents": {
      "default": {
        "llm_config": "primary",
        "responsibilities": [],
        "role": "Safety observation and face-description escalation agent."
      }
    },
    "api_base": "http://192.168.4.173:11434",
    "configs": {
      "primary": {
        "api_base": "http://192.168.4.173:11434",
        "max_tokens": 700,
        "mock_mode": "fake",
        "mode": "ollama",
        "model": "ollama/nemotron3:33b",
        "num_retries": 1,
        "provider": "ollama",
        "timeout_seconds": 60
      }
    },
    "default_config": "primary",
    "enabled": true,
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b"
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed",
      "door_camera_human_detected",
      "door_camera_slack_alert_sent",
      "door_camera_slack_alert_skipped",
      "door_camera_slack_alert_error",
      "door_camera_frame_analysis_failed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "stderr_jsonl": true
  },
  "manifest_config_bindings": [
    {
      "config_path": "identity.run_id",
      "manifest_path": "nodes.person_detector.config.environment.MN_RUN_ID",
      "stringify": true
    },
    {
      "config_path": "outputs.run_root",
      "manifest_path": "nodes.person_detector.config.environment.MN_RUNS_ROOT",
      "stringify": true
    }
  ],
  "metadata": {
    "blueprint_revision": "v1",
    "category": "business",
    "customizable_for": "Door monitoring, restricted-area alerts, retail safety, warehouse operations.",
    "problem_solved": "Video monitoring is continuous, noisy, and operationally sensitive; teams need stateful alerts, cooldowns, and explainable observations rather than raw frames.",
    "standard_version": "1.0",
    "target_users": "Facilities, security, safety operations, and property management teams."
  },
  "mode": "mock",
  "output_skills": {
    "websocket_events": {
      "connector": "websocket",
      "content": "events",
      "direction": "output",
      "enabled": false,
      "mock": true,
      "required": false,
      "skill": "websocket_stream",
      "transport": "websocket",
      "url_env": "MN_BLUEPRINT_EVENTS_WS_URL"
    }
  },
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Human detection events, observable appearance and activity descriptions, alert decisions, and notification payloads.",
    "run_root": "~/.mn/runs",
    "skills": {
      "websocket_events": {
        "connector": "websocket",
        "content": "events",
        "direction": "output",
        "enabled": false,
        "mock": true,
        "required": false,
        "skill": "websocket_stream",
        "transport": "websocket",
        "url_env": "MN_BLUEPRINT_EVENTS_WS_URL"
      }
    },
    "tcp": {
      "enabled": false,
      "ports": []
    },
    "write_run_store": true
  },
  "privacy": {
    "default_classification": "internal",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "schemas": {
    "config": "mn.blueprint.config.v1",
    "events": "mn.blueprint.events.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "input_skills": "mn.blueprint.input_skills.v1",
    "inputs": "mn.blueprint.inputs.v1",
    "output_skills": "mn.blueprint.output_skills.v1"
  },
  "simulation": {
    "deterministic": true,
    "enabled": true,
    "seed_field": "seed",
    "type": "Video stream sampling with alert state."
  },
  "standard_version": "1.0",
  "state": {
    "checkpoint_interval": {
      "events": 100,
      "seconds": 60
    },
    "enabled": true,
    "idempotency_key_fields": [
      "source_ref",
      "event_id"
    ],
    "resume_mode": "checkpoint"
  },
  "streams": {
    "door_camera_video": {
      "codec": "h264",
      "enabled": true,
      "kind": "video",
      "transport": "rtsp",
      "uri": "rtsp://host.docker.internal:8554/local-camera"
    }
  },
  "triggers": {
    "daemon": true,
    "schedule": null,
    "sources": [
      "door_camera_video"
    ],
    "type": "stream"
  },
  "video_source": {
    "camera_id": "front-door",
    "codec": "h264",
    "description": "Configurable facility video stream. The default expects a local RTSP camera publishing H.264 video.",
    "frame_jpeg_max_width": 896,
    "frame_sample_seconds": 10.0,
    "transport": "rtsp",
    "uri": "rtsp://host.docker.internal:8554/local-camera"
  },
  "vl_model": {
    "base_url": "http://192.168.4.173:11434",
    "description": "Configurable vision-language model used to understand sampled facility video frames.",
    "endpoint": "/api/generate",
    "model": "nemotron3:33b",
    "provider": "ollama",
    "temperature": 0.0,
    "timeout_seconds": 90
  },
  "web_ui": {
