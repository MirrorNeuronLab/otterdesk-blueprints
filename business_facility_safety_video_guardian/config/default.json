      "browser_publish_source": "http://127.0.0.1:8889/local-camera/publish?video-codec=h264%2F90000&audio-device=none&video-width=1280&video-height=720&video-framerate=30",
      "browser_video_source": "http://127.0.0.1:8889/local-camera/",
      "default_video_source": "rtsp://host.docker.internal:8554/local-camera",
      "event_feed": {
        "default_path": "~/.mn/runs/<run_id>/events.jsonl",
        "format": "jsonl"
      },
      "event_types": [
        "door_camera_human_detected",
        "door_camera_slack_alert_sent",
        "door_camera_slack_alert_skipped",
        "door_camera_slack_alert_error",
        "door_camera_frame_analysis_failed"
      ]
