{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "business_facility_safety_video_guardian",
    "name": "Facility Safety Video Guardian"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {}
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "video_source",
      "vl_model",
      "llm",
      "outputs",
      "logging",
      "real_adapters",
      "web_ui"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json",
      "ui.json",
      "web_ui.json"
    ]
  },
  "llm": {
    "agent_role": "Safety observation and face-description escalation agent.",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b"
  },
  "video_source": {
    "uri": "rtsp://127.0.0.1:8554/local-camera",
    "transport": "rtsp",
    "codec": "h264",
    "camera_id": "front-door",
    "frame_sample_seconds": 5.0,
    "frame_jpeg_max_width": 896,
    "description": "Configurable facility video stream. The default expects a local RTSP camera publishing H.264 video."
  },
  "vl_model": {
    "provider": "ollama",
    "base_url": "http://192.168.4.173:11434",
    "model": "nemotron3:33b",
    "endpoint": "/api/generate",
    "timeout_seconds": 90,
    "temperature": 0.0,
    "description": "Configurable vision-language model used to understand sampled facility video frames."
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed",
      "door_camera_frame_analyzed",
      "door_camera_face_detected",
      "door_camera_slack_alert_sent",
      "door_camera_slack_alert_skipped",
      "door_camera_slack_alert_error",
      "door_camera_frame_analysis_failed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "business",
    "customizable_for": "Door monitoring, restricted-area alerts, retail safety, warehouse operations.",
    "problem_solved": "Video monitoring is continuous, noisy, and operationally sensitive; teams need stateful alerts, cooldowns, and explainable observations rather than raw frames.",
    "target_users": "Facilities, security, safety operations, and property management teams."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Face detection events, observable facial appearance descriptions, alert decisions, and notification payloads.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "deterministic": true,
    "enabled": true,
    "seed_field": "seed",
    "type": "Video stream sampling with alert state."
  },
  "standard_version": "1.0",
  "web_ui": {
    "enabled": true,
    "input": {
      "adapter": "none"
    },
    "output": {
      "adapter": "gradio",
      "title": "Facility Safety Video Guardian",
      "server": "blueprint_support",
      "host": "127.0.0.1",
      "refresh_seconds": 2.0
    },
    "dashboard": {
      "default_video_source": "person_detector/samples/door-demo.mp4",
      "event_types": [
        "door_camera_frame_analyzed",
        "door_camera_face_detected",
        "door_camera_slack_alert_sent",
        "door_camera_slack_alert_skipped",
        "door_camera_slack_alert_error",
        "door_camera_frame_analysis_failed"
      ],
      "event_feed": {
        "format": "jsonl",
        "default_path": "~/.mn/runs/<run_id>/events.jsonl"
      }
    }
  },
  "manifest_config_bindings": [
    {
      "config_path": "identity.run_id",
      "manifest_path": "nodes.person_detector.config.environment.MN_RUN_ID",
      "stringify": true
    },
    {
      "config_path": "outputs.run_root",
      "manifest_path": "nodes.person_detector.config.environment.MN_RUNS_ROOT",
      "stringify": true
    }
  ]
}
