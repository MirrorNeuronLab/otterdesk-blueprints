      "stdout": "single JSON object, event envelope, or bundle path"
    },
    "problem_solved": "Video monitoring is continuous, noisy, and operationally sensitive; teams need stateful alerts, cooldowns, and explainable observations rather than raw frames.",
    "quick_test": {
      "description": "Quick test mode shortens the sample interval, disables Slack, and uses mock human detection unless OLLAMA_LIVE_IN_QUICK_TEST=1.",
      "enabled": false,
      "env": "MN_BLUEPRINT_QUICK_TEST=1"
    },
    "runtime_features": [
      "video sampling",
      "configurable VL model decision path",
      "cooldown state",
      "Slack alerting"
    ],
    "simulation_type": "Video stream sampling with alert state.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load_metadata -> resolve_config -> load_inputs -> start_run_store -> observe_simulation_state -> call_llm_agent -> evaluate_workflow_state -> route_by_context -> request_human_input -> apply_decision_to_simulation -> emit_events -> write_final_artifact -> fan_out_output_skills",
      "execution_steps": [
