    "name": "Facility Safety Video Guardian",
    "output": "Human detection events, observable appearance and activity descriptions, alert decisions, and notification payloads.",
    "output_contract": {
      "events": "typed event objects with payload",
      "events_jsonl": "events.jsonl",
