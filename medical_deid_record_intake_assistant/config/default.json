      "suggested_schedule",
      "knowledge_rag",
      "agentic_research"
    ],
    "identity": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "outputs": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ],
    "optional_outputs": [
      "job.json",
      "web_ui.json",
      "ui.json",
      "web/index.html",
      "logs.jsonl",
      "human.jsonl",
      "resources.jsonl",
      "*-review.md"
    ],
    "optional_run_artifacts": [
      "job.json",
      "web_ui.json",
      "ui.json",
      "web/index.html",
      "logs.jsonl",
      "human.jsonl",
      "resources.jsonl",
      "*-review.md"
    ],
    "response_schema": "mn.blueprint.response.v1",
    "web_ui_adapters": [
      "none",
      "static_html",
      "gradio",
      "custom"
    ]
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "extract_embedded_text_or_ocr",
    "redact_sensitive_values",
    "extract_structured_fields",
    "validate_against_public_labels_when_available",
    "request_human_review",
    "write_final_artifact",
    "write_artifact_records"
  ],
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "medical_deid_record_intake_assistant_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "agentic_research": {
    "enabled": true,
    "agent_ids": [
      "medical_ocr_extractor",
      "phi_detector",
      "clinical_field_extractor",
      "medical_redaction_validator",
      "privacy_report_writer"
    ],
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "allowed_tools": [
      "llm_ocr_extract",
      "phi_detect",
      "redaction_validate",
      "knowledge_retrieve",
      "finish"
    ],
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run",
    "default_mode": "bounded_llm_guided_deidentification_review",
    "note": "Medical actors use OCR and privacy guidance while keeping ambiguous PHI review-required."
  },
  "knowledge_rag": {
    "enabled": true,
    "backend": "milvus_lite",
    "required": false,
    "knowledge_dir": "knowledge",
    "purpose": "Retrieve de-identification guidance for PHI/PII detection, OCR uncertainty, bounding-box review, and privacy signoff boundaries.",
    "retrieval_targets": [
      "PHI categories",
      "redaction risks",
      "OCR uncertainty",
      "privacy review blockers"
    ],
    "grounding_policy": "Use retrieved local blueprint knowledge to improve actor review prompts; do not invent facts when retrieval is unavailable.",
    "namespace": "",
    "embedding_provider": "docker_model_runner",
    "embedding_model": "huggingface.co/jinaai/jina-embeddings-v5-text-small-retrieval:Q4_K_M",
    "embedding_api_base": "http://localhost:12434/engines/v1",
    "embedding_query_prefix": "Query: ",
    "embedding_document_prefix": "Document: ",
    "embedding_start_command": "",
    "embedding_healthcheck_enabled": true,
    "vector_dim": 1024,
    "index_on_startup": true,
    "top_k": 4,
    "max_context_chars": 4000,
    "chunk_size": 700,
    "chunk_overlap": 70,
    "privacy": "index local blueprint knowledge only; do not index private run documents unless a future runtime explicitly opts in"
  },
  "state": {
    "document_folder": "medical_deid_record_intake_assistant/examples/sample_inputs",
    "output_folder": "~/Download/medical_deid_record_intake_assistant",
    "review": {},
    "final_report": {},
    "input_folder": "medical_deid_record_intake_assistant/examples/sample_inputs"
  },
  "triggers": {
    "manual": true,
    "schedule": false
  },
  "real_adapters": {
    "filesystem": {
      "enabled": true,
      "read": true,
      "write": true
    }
  },
  "streams": {
    "enabled": false
  },
  "simulation": {
    "enabled": false
  },
  "suggested_schedule": {
    "cron": "0 * * * *",
    "cadence": "hourly",
    "advisory_only": true,
    "note": "Suggested cadence only; runtime decides the actual schedule."
  }
}
