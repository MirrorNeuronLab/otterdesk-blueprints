{
  "description": "Watches a mapped local video stream, detects configured visual targets, and reports count, label, category, color, position, activity, and alert status for review.",
  "edges": [
    {
      "edge_id": "ingress_to_tick_source",
      "from_node": "ingress",
      "message_type": "video_monitor_start",
      "to_node": "video_frame_tick_source"
    },
    {
      "edge_id": "tick_source_to_visual_detector",
      "from_node": "video_frame_tick_source",
      "message_type": "video_frame_tick",
      "to_node": "visual_detector"
    }
  ],
  "entrypoints": [
    "ingress"
  ],
  "graph_id": "video_watch_assistant_v1",
  "initial_inputs": {
    "ingress": [
      {
        "description": "Continuously sample the mapped local RTSP stream, ask the configured VL model whether configured visual targets are present or active, report count, label, category, color, position, and activity, and send alerts when a target is detected.",
        "ollama_base_url": "http://192.168.4.173:11434",
        "ollama_model": "nemotron3:33b",
        "scenario": "video_visual_monitor",
        "slack_optional": true,
        "video_source_codec": "h264",
        "video_source_transport": "rtsp",
        "video_source_uri": "rtsp://127.0.0.1:8554/video-watch",
        "vl_model_base_url": "http://192.168.4.173:11434",
        "vl_model_name": "nemotron3:33b"
      }
    ]
  },
  "job_name": "video-watch-assistant",
  "license": "LICENSE.md",
  "term": "TERM.md",
  "manifest_version": "1.0",
  "type": "service",
  "requirements": {
    "cpu": {
      "min_cores": 1
    },
    "gpu": {
      "min_count": 0
    },
    "memory": {
      "min_gb": 2
    },
    "disk": {
      "min_gb": 1
    }
  },
  "input_validation": {
    "rules": [
      {
        "name": "video_source_uri_rtsp",
        "type": "pattern",
        "path": "video_source.uri",
        "pattern": "^rtsps?://",
        "message": "video_source.uri must be an rtsp:// or rtsps:// URL."
      },
      {
        "name": "video_source_rtsp_probe",
        "type": "command",
        "command": [
          "python3",
          "payloads/validation/validate_rtsp_source.py"
        ],
        "timeout_seconds": 12
      }
    ]
  },
  "metadata": {
    "agent_templates": {
      "library": "../mn-agents/index.json",
      "nodes": [
        {
          "node_id": "ingress",
          "uses": "mn-agents.control_router@1.0.0"
        },
        {
          "node_id": "video_frame_tick_source",
          "uses": "mn-agents.data_module@1.0.0"
        },
        {
          "node_id": "visual_detector",
          "uses": "mn-agents.data_python_executor@1.0.0"
        }
      ],
      "render_tool": "../mn-agents/tools/render_agent_templates.py",
      "rendered_output": "manifest.rendered.json or runtime metadata",
      "renderer": "mn_blueprint_support.render_manifest_agent_templates"
    },
    "blueprint_id": "video_watch_assistant",
    "category": "business",
    "configuration_contract": {
      "optional_files": [
        "scenario.json",
        "config/overwrite.json",
        "knowledge/"
      ],
      "required_files": [
        "manifest.json",
        "README.md",
        "SPEC.md",
        "config/default.json",
        "payloads/",
        "LICENSE.md",
        "TERM.md"
      ]
    },
    "customizable_for": "Video monitoring, configurable visual detection, facility operations, and site safety workflows.",
    "description": "Watches a mapped local video stream, detects configured visual targets, and reports count, label, category, color, position, activity, and alert status for review.",
    "init_config_review": {
      "fields": [
        {
          "default": "rtsp://127.0.0.1:8554/video-watch",
          "description": "Leave the default mapped endpoint. The pre-launch hook loops the bundled demo video into the selected local RTSP port before the worker starts.",
          "label": "Video input",
          "path": "video_source.uri"
        },
        {
          "default": "http://192.168.4.173:11434",
          "description": "Base URL for the Ollama-compatible vision-language model server.",
          "label": "VL model URL",
          "path": "vl_model.base_url"
        },
        {
          "default": "nemotron3:33b",
          "description": "Vision-language model name used to understand sampled video frames.",
          "label": "VL model name",
          "path": "vl_model.model"
        }
      ],
      "instruction": "When running in OtterDesk, show these overwriteable fields during init config and ask the user to change them or keep the defaults before launch.",
      "required": true
    },
