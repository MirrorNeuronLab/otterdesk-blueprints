    "llm": {
      "agent_role": "AI assistant for reviewing video stream activity and preparing visual detection alerts."
    },
    "llm_agent_role": "AI assistant for reviewing video stream activity and preparing visual detection alerts.",
    "memory_layer": {
      "collection": "mn_memory",
      "containers": "optional_sidecar",
      "context_addr_env": "MN_CONTEXT_ADDR",
      "conversation": {
        "agent_role": "otterdesk_chat",
        "include_human_events": true,
        "include_runtime_events": true,
        "include_runtime_logs": true,
        "target_tokens": 2400,
        "token_budget": 6000,
        "use_model_compression": false
      },
      "conversation_enabled": true,
      "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
      "default_context_addr": "localhost:50052",
      "enabled": true,
      "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
      "namespace": "video_watch_assistant_context",
      "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
      "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
      "sdk_distribution": "mirrorneuron-membrane-python-sdk",
      "sdk_import_package": "mn_context_engine_sdk"
    },
    "name": "Video Watch Assistant",
    "output": "Visual detection observations with count, label, category, color, position, activity, confidence, and alert status.",
    "output_contract": {
      "events": "typed event objects with payload",
      "events_jsonl": "events.jsonl",
      "final_artifact_json": "final_artifact.json",
      "local_run_store": "~/.mn/runs/<run_id>/",
      "logs_jsonl": "logs.jsonl",
      "response_schema": "mn.blueprint.response.v1",
      "result_json": "result.json",
      "status": "JSON lines on stderr",
      "stdout": "single JSON object, event envelope, or bundle path"
    },
    "problem_solved": "User RTSP sources can be unstable or unavailable inside OpenShell, so this blueprint maps any validated upstream video or demo file into one stable local stream endpoint.",
    "quick_test": {
      "description": "Quick test mode shortens the sample interval, disables Slack, and uses mock visual detection unless OLLAMA_LIVE_IN_QUICK_TEST=1.",
      "enabled": false,
      "env": "MN_BLUEPRINT_QUICK_TEST=1"
    },
    "runtime_features": [
      "video sampling",
      "visual detection review",
      "cooldown state",
      "Slack alerting",
      "Membrane context memory optimization"
    ],
    "simulation_type": "Video stream sampling with visual detection review state.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load_metadata -> resolve_config -> load_inputs -> start_run_store -> observe_simulation_state -> call_llm_agent -> evaluate_workflow_state -> route_by_context -> request_human_input -> apply_decision_to_simulation -> emit_events -> write_final_artifact -> fan_out_output_skills",
      "execution_steps": [
        "load_metadata",
        "resolve_config",
        "load_inputs",
        "start_run_store",
        "observe_simulation_state",
        "call_llm_agent",
        "evaluate_workflow_state",
        "route_by_context",
        "request_human_input",
        "apply_decision_to_simulation",
        "emit_events",
        "write_final_artifact",
        "fan_out_output_skills"
      ],
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "file",
        "json",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0"
    },
    "status_logging": {
      "env": "MN_BLUEPRINT_LOG_LEVEL",
      "format": "jsonl",
      "stream": "stderr"
    },
    "streaming": {
      "backpressure": {
        "drop_policy": "skip_with_error",
        "llm": {
          "max_calls_per_minute": 30,
          "max_concurrent_calls": 2
        },
        "max_concurrency": 4,
        "max_events_per_second": 25,
        "queue_size": 1000
      },
      "kind": "video",
      "primary_stream": "video_watch_stream",
      "transport": "rtsp",
      "websocket_skill": false
    },
    "target_user": "Video operators, security reviewers, safety operations teams, and site-access coordinators.",
    "video_source": {
      "codec": "h264",
      "config_env": [
        "VIDEO_SOURCE_URI",
        "VIDEO_SOURCE_TRANSPORT",
        "VIDEO_SOURCE_CODEC"
      ],
      "transport": "rtsp",
      "uri": "rtsp://127.0.0.1:8554/video-watch",
      "description": "Default mapped RTSP endpoint consumed by the OpenShell worker. The host-side pre-launch hook loops the bundled demo video into the selected local RTSP port before launch."
    },
    "vl_model": {
      "base_url": "http://192.168.4.173:11434",
      "config_env": [
        "VL_MODEL_BASE_URL",
        "VL_MODEL_NAME"
      ],
      "legacy_env_aliases": [
        "OLLAMA_BASE_URL",
        "OLLAMA_MODEL"
      ],
      "model": "nemotron3:33b",
      "provider": "ollama"
    },
    "web_ui": {
      "adapter": "gradio",
      "dashboard_model": "grafana_json",
      "arguments": {
        "browser_video_source": "Resolved by scripts/pre-launch.sh. The hook starts MediaMTX, selects an available browser preview port, and writes the preview URL into launch config.",
        "browser_publish_source": "Set to disabled because this blueprint's host-side mapper owns publishing into the local RTSP endpoint.",
        "run_id": "MirrorNeuron run id used to resolve ~/.mn/runs/<run_id>.",
        "runs_root": "MirrorNeuron runs root, defaulting to ~/.mn/runs.",
        "url": "Shared support Gradio app URL written to web_ui.json."
      },
      "description": "Shared blueprint support Gradio dashboard rendered from the blueprint's Grafana JSON model and live run-store events.",
      "enabled": true,
      "event_types": [
        "video_frame_tick_generated",
        "video_watch_frame_observed",
        "video_watch_attention_updated",
        "video_watch_detection",
        "human_notice",
        "video_watch_slack_alert_sent",
        "video_watch_slack_alert_skipped",
        "video_watch_slack_alert_error",
        "video_watch_frame_analysis_failed"
      ],
      "kind": "output",
      "registration": {
        "api": [
          "main"
        ],
        "module": "mn_blueprint_support.gradio_dashboard",
        "package": "mirrorneuron-blueprint-support-skill[webui]",
        "writes": "ui.json and web_ui.json"
      },
      "server": "blueprint_support",
      "video_preview_bridge": {
        "auto_start": false,
        "enabled": false,
        "cleanup_script": "scripts/post-launch.sh",
        "script": "scripts/pre-launch.sh",
        "stream_path": "video-watch"
      },
      "browser_video_source": "disabled",
      "browser_publish_source": "disabled"
    },
    "agent_role": "AI assistant for reviewing video stream activity and preparing visual detection alerts.",
    "target_users": "Video operators, security reviewers, safety operations teams, and site-access coordinators.",
    "openshell_network": {
      "policy_path": "visual_detector/policies/video-egress.yaml",
      "include_dns": false,
      "endpoints": [
        {
          "name": "mapped-local-rtsp-stream-loopback",
          "uri": "rtsp://127.0.0.1:8554/video-watch",
          "binaries": [
            "/usr/bin/ffmpeg",
            "/usr/bin/python3"
          ],
          "allowed_ips": [
            "127.0.0.1/32"
          ]
        },
        {
          "name": "mapped-local-rtsp-stream-localhost",
          "uri": "rtsp://localhost:8554/video-watch",
          "binaries": [
            "/usr/bin/ffmpeg",
            "/usr/bin/python3"
          ],
          "allowed_ips": [
            "127.0.0.1/32"
          ]
        },
        {
          "name": "mapped-local-rtsp-stream-openshell-host",
          "uri": "rtsp://host.openshell.internal:8554/video-watch",
          "binaries": [
            "/usr/bin/ffmpeg",
            "/usr/bin/python3"
          ],
          "allowed_ips": [
            "127.0.0.1/32",
            "192.168.65.254/32"
          ]
        },
        {
          "name": "mapped-local-rtsp-stream-docker-host",
          "uri": "rtsp://host.docker.internal:8554/video-watch",
          "binaries": [
            "/usr/bin/ffmpeg",
            "/usr/bin/python3"
          ],
          "allowed_ips": [
            "192.168.65.254/32",
            "127.0.0.1/32"
          ]
        },
        {
          "name": "mapped-local-rtsp-stream-gateway",
          "uri": "rtsp://192.168.65.254:8554/video-watch",
          "binaries": [
            "/usr/bin/ffmpeg",
            "/usr/bin/python3"
          ],
          "allowed_ips": [
            "192.168.65.254/32"
          ]
        },
        {
          "name": "local-vl-model",
          "uri": "http://192.168.4.173:11434",
          "binaries": [
            "/bin/bash",
            "/usr/bin/bash",
            "/usr/bin/python3",
            "/usr/bin/python3.12"
          ],
          "allowed_ips": [
            "192.168.4.173/32"
          ]
        }
      ]
    },
    "search_terms": [
      "video monitoring",
      "visual detection",
      "facility operations",
      "site safety",
      "rtsp stream"
    ]
  },
  "name": "Video Watch Assistant",
  "nodes": [
    {
      "node_id": "ingress",
      "uses": "mn-agents.control_router@1.0.0",
      "with": {
        "emit_type": "video_monitor_start",
        "node_type": "map",
        "role": "root_coordinator"
      }
    },
    {
      "node_id": "video_frame_tick_source",
      "uses": "mn-agents.data_module@1.0.0",
      "with": {
        "camera_id": "video-watch",
        "interval_ms": 10000,
        "module": "MirrorNeuron.Examples.VideoWatchAssistant.VideoFrameTickSource",
        "module_source": "beam_modules/video_frame_tick_source.ex",
        "node_type": "stream",
        "role": "video_frame_sampler",
        "target_node": "visual_detector"
      }
    },
    {
      "node_id": "visual_detector",
      "uses": "mn-agents.data_python_executor@1.0.0",
      "with": {
        "cleanup_remote_dir": true,
        "command": [
          "bash",
          "scripts/run_detector_in_openshell.sh"
        ],
        "custom_openshell_image": "visual_detector/openshell_sandbox",
        "environment": {
          "FFMPEG_FRAME_TIMEOUT_SECONDS": "8",
          "FFMPEG_RTSP_TRANSPORT": "tcp",
          "FRAME_JPEG_MAX_WIDTH": "896",
          "FRAME_SAMPLE_SECONDS": "10.0",
          "MN_BLUEPRINT_LOG_LEVEL": "info",
          "OLLAMA_BASE_URL": "http://192.168.4.173:11434",
          "OLLAMA_MODEL": "nemotron3:33b",
          "OLLAMA_THINK": "false",
          "SLACK_ALERT_ENABLED": "true",
          "SLACK_DEFAULT_CHANNEL": "#safety",
          "SLACK_MESSAGE_PREFIX": "Video detection alert",
          "VIDEO_SOURCE_CODEC": "h264",
          "VIDEO_SOURCE_TRANSPORT": "rtsp",
          "VIDEO_SOURCE_URI": "rtsp://127.0.0.1:8554/video-watch",
          "VL_MODEL_BASE_URL": "http://192.168.4.173:11434",
          "VL_MODEL_NAME": "nemotron3:33b",
          "MN_HOST_STREAM_FALLBACK_HOSTS": "host.openshell.internal,host.docker.internal,192.168.65.254",
          "DETECTION_ALERT_COOLDOWN_SECONDS": "60",
          "DETECTION_CONFIDENCE_THRESHOLD": "0.65",
          "VISUAL_DETECTION_TARGETS": "people, equipment, objects, hazards, access activity, workflow activity, and other configured visual targets"
        },
        "gpu": false,
        "name_prefix": "video_watch_assistant",
        "node_type": "stream",
        "output_message_type": null,
        "persistent_workspace": false,
        "policy": "visual_detector/policies/video-egress.yaml",
        "reuse_shared_sandbox": true,
        "role": "vl_model_video_visual_detector",
        "runner_module": "MirrorNeuron.Sandbox.OpenShell",
        "script": "scripts/run_blueprint.py",
        "upload_path": "visual_detector",
        "upload_paths": [
          {
            "source": "visual_detector",
            "target": "visual_detector"
          }
        ],
        "upload_as": "visual_detector",
        "workdir": "/sandbox/job/visual_detector"
      }
    }
  ],
  "policies": {
    "recovery_mode": "cluster_recover",
    "stream_mode": "live"
  },
  "requiredContextEngine": false
}
