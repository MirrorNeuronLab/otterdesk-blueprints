{
  "agentic_research": {
    "agent_ids": [
      "cash_flow_llm_analyst",
      "public_finance_researcher",
      "tax_form_ocr_capturer",
      "tax_llm_reviewer",
      "portfolio_llm_reviewer",
      "advisor_evidence_reconciler",
      "advisor_review_auditor",
      "financial_advice_reporter"
    ],
    "allowed_tools": [
      "knowledge_retrieve",
      "browser_search",
      "browser_page",
      "market_data_history",
      "risk_metric_compute",
      "llm_ocr_extract",
      "form_classify",
      "field_locate",
      "schema_validate",
      "finish"
    ],
    "default_mode": "bounded_llm_guided_financial_advisor_review",
    "enabled": true,
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "note": "Public research actors derive queries from generic risk and document categories only.",
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run"
  },
  "agents": {
    "registry": {
      "financial_folder_watcher": {
        "handler": "agents.financial_folder_watcher",
        "role": "Financial Folder Watcher"
      },
      "financial_document_reader": {
        "handler": "agents.financial_document_reader",
        "role": "Financial Document Reader"
      },
      "bank_statement_extractor": {
        "handler": "agents.bank_statement_extractor",
        "role": "Bank Statement Extractor"
      },
      "cash_flow_normalizer": {
        "handler": "agents.cash_flow_normalizer",
        "role": "Cash Flow Normalizer"
      },
      "cash_flow_llm_analyst": {
        "handler": "agents.cash_flow_llm_analyst",
        "role": "Cash Flow LLM Analyst"
      },
      "tax_document_router": {
        "handler": "agents.tax_document_router",
        "role": "Tax Document Router"
      },
      "tax_form_ocr_capturer": {
        "handler": "agents.tax_form_ocr_capturer",
        "role": "Tax Form OCR Capturer"
      },
      "tax_workpaper_preparer": {
        "handler": "agents.tax_workpaper_preparer",
        "role": "Tax Workpaper Preparer"
      },
      "tax_llm_reviewer": {
        "handler": "agents.tax_llm_reviewer",
        "role": "Tax LLM Reviewer"
      },
      "portfolio_context_loader": {
        "handler": "agents.portfolio_context_loader",
        "role": "Portfolio Context Loader"
      },
      "portfolio_market_data_loader": {
        "handler": "agents.portfolio_market_data_loader",
        "role": "Portfolio Market Data Loader"
      },
      "portfolio_risk_engine": {
        "handler": "agents.portfolio_risk_engine",
        "role": "Portfolio Risk Engine"
      },
      "portfolio_llm_reviewer": {
        "handler": "agents.portfolio_llm_reviewer",
        "role": "Portfolio LLM Reviewer"
      },
      "public_finance_researcher": {
        "handler": "agents.public_finance_researcher",
        "role": "Public Finance Researcher"
      },
      "advisor_evidence_reconciler": {
        "handler": "agents.advisor_evidence_reconciler",
        "role": "Advisor Evidence Reconciler"
      },
      "advisor_review_auditor": {
        "handler": "agents.advisor_review_auditor",
        "role": "Advisor Review Auditor"
      },
      "financial_advice_reporter": {
        "handler": "agents.financial_advice_reporter",
        "role": "Financial Advice Reporter"
      }
    }
  },
  "apiVersion": "mn.workflow.source/v2",
  "config": {
    "default": "config/default.json",
    "embed": true,
    "manifest_defaults": [
      "llm",
      "knowledge_rag",
      "agentic_research",
      {
        "from": "requirements",
        "to": "resources"
      },
      {
        "from": "workflow.policy.human",
        "to": "human_control"
      },
      {
        "from": "contracts.input_adapters.supported",
        "to": "interfaces.input_adapters"
      },
      {
        "from": "identity.id",
        "to": "identity.blueprint_id"
      },
      {
        "from": "identity.name",
        "to": "identity.name"
      }
    ]
  },
  "contracts": {
    "events": {
      "human_stream": "human.jsonl",
      "stream": "events.jsonl",
      "types": [
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "artifact_written",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
        "output_skill_started",
        "output_skill_completed",
        "output_skill_failed",
        "tool_call_started",
        "tool_call_completed",
        "tool_call_failed",
        "financial_folder_watcher_completed",
        "financial_document_reader_completed",
        "bank_statement_extractor_completed",
        "cash_flow_normalizer_completed",
        "cash_flow_llm_analyst_completed",
        "tax_document_router_completed",
        "tax_form_ocr_capturer_completed",
        "tax_workpaper_preparer_completed",
        "tax_llm_reviewer_completed",
        "portfolio_context_loader_completed",
        "portfolio_market_data_loader_completed",
        "portfolio_risk_engine_completed",
        "portfolio_llm_reviewer_completed",
        "public_finance_researcher_completed",
        "advisor_evidence_reconciler_completed",
        "advisor_review_auditor_completed",
        "financial_advice_reporter_completed",
        "watch_cycle_started",
        "watch_cycle_completed"
      ]
    },
    "input_adapters": {
      "default": "mock",
      "resolved_artifact": "inputs.json",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ]
    },
    "inputs": {
      "document_folder": {
        "description": "Local folder monitored for personal finance, bank statement, tax, and portfolio documents.",
        "example": "financial_advisor/examples/sample_inputs",
        "path_kind": "directory",
        "privacy": "regulated",
        "required": true,
        "type": "local_path"
      },
      "field_profile": {
        "description": "Financial fields and review areas captured by the advisor.",
        "example": [
          "document_kind",
          "income_amounts",
          "tax_forms",
          "form_type",
          "field_locations",
          "portfolio_holdings",
          "risk_flags"
        ],
        "privacy": "internal",
        "required": false,
        "type": "domain_value"
      },
      "filing_status": {
        "description": "Draft filing-status label for review-only tax packet.",
        "example": "single",
        "privacy": "regulated",
        "required": false,
        "type": "domain_value"
      },
      "input_folder": {
        "description": "Default local input folder for sample files or user-provided files.",
        "example": "financial_advisor/examples/sample_inputs",
        "path_kind": "directory",
        "privacy": "regulated",
        "required": false,
        "type": "local_path"
      },
      "monitoring": {
        "description": "Folder monitoring configuration for one-shot or continuous polling runs.",
        "example": {
          "enabled": true,
          "max_cycles": 1,
          "poll_interval_seconds": 60
        },
        "privacy": "internal",
        "required": false,
        "type": "domain_value"
      },
      "output_folder": {
        "description": "Local folder where JSON and Markdown advisor reports should be written.",
        "example": "~/Downloads/financial_advisor",
        "path_kind": "directory",
        "privacy": "regulated",
        "required": true,
        "type": "local_path"
      },
      "portfolio": {
        "description": "Optional portfolio holdings for review-only risk analysis.",
        "example": {
          "base_currency": "USD",
          "cash": 50000,
          "holdings": [
            {
              "asset_class": "equity",
              "quantity": 180,
              "symbol": "SPY"
            }
          ]
        },
        "privacy": "regulated",
        "required": false,
        "type": "domain_value"
      },
      "tax_year": {
        "description": "Tax year used for draft workpaper labels.",
        "example": 2025,
        "privacy": "internal",
        "required": false,
        "type": "domain_value"
      }
    },
    "outputs": {
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "action_ledger",
          "mime_type": "application/json",
          "path": "action_ledger.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.action_ledger.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "action_ledger"
        },
        {
          "artifact_id": "artifact_quality",
          "mime_type": "application/json",
          "path": "artifact_quality.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.artifact_quality.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "artifact_quality"
        },
        {
          "artifact_id": "run_health",
          "mime_type": "application/json",
          "path": "run_health.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.run_health.v1",
          "source_refs": [
            "final_artifact.json",
            "action_ledger.json",
            "artifact_quality.json"
          ],
          "type": "run_health"
        },
        {
          "artifact_id": "review_packet_markdown",
          "mime_type": "text/markdown",
          "path": "<outputs.folder_path>/financial_advisor_report.md",
          "producer": "workflow",
          "schema_version": "mn.blueprint.generated_report.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "generated_report"
        },
        {
          "artifact_id": "customer_report",
          "mime_type": "application/json",
          "path": "<outputs.folder_path>/customer_report.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.financial_advisor.customer_report.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "customer_report"
        },
        {
          "artifact_id": "cash_flow_llm_review",
          "mime_type": "application/json",
          "path": "<outputs.folder_path>/cash_flow_llm_review.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.financial_advisor.llm_review.v1",
          "source_refs": [
            "household_finance_summary.json",
            "final_artifact.json"
          ],
          "type": "llm_review"
        },
        {
          "artifact_id": "tax_form_ocr_capture",
          "mime_type": "application/json",
          "path": "<outputs.folder_path>/tax_form_ocr_capture.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.tax_form_capture.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "tax_form_capture"
        },
        {
          "artifact_id": "tax_llm_review",
          "mime_type": "application/json",
          "path": "<outputs.folder_path>/tax_llm_review.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.financial_advisor.llm_review.v1",
          "source_refs": [
            "tax_review_packet.json",
            "tax_form_ocr_capture.json",
            "final_artifact.json"
          ],
          "type": "llm_review"
        },
        {
          "artifact_id": "portfolio_llm_review",
          "mime_type": "application/json",
          "path": "<outputs.folder_path>/portfolio_llm_review.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.financial_advisor.llm_review.v1",
          "source_refs": [
            "portfolio_risk_review.json",
            "final_artifact.json"
          ],
          "type": "llm_review"
        }
      ],
      "primary": {
        "id": "final_artifact",
        "path": "final_artifact.json",
        "required_fields": [
          "type",
          "executive_summary",
          "recommended_action",
          "confidence",
          "evidence",
          "next_steps",
          "source_refs",
          "research_summary",
          "research_sources",
          "research_warnings",
          "llm_analysis"
        ],
        "schema_version": "mn.blueprint.final_artifact_contract.v1",
        "type": "final_artifact"
      },
      "profile": "standard_run_store"
    },
    "status": {
      "heartbeat": true
    }
  },
  "defaults": {
    "worker": {
      "with": {
        "image": "mirror-neuron/financial-advisor:local"
      }
    }
  },
  "identity": {
    "category": "finance",
    "id": "financial_advisor",
    "job_name": "financial-advisor",
    "manifest_version": "1.0",
    "name": "Financial Advisor",
    "version": 1
  },
  "intent": {
    "description": "A unified personal financial advisor co-worker. Put bank statements, receipts, bills, income records, W-2s, 1099s, tax-form images with answer files, brokerage statements, portfolio files, and related finance documents in the input folder; it extracts document evidence, captures tax-form OCR fields for review, prepares review-only tax and household finance summaries, runs portfolio risk analysis, and writes integrated advisor reports to the output folder.",
    "problem": "Personal finance work is split across statement review, tax preparation, household planning, and portfolio risk checks; users need one review-only local assistant that keeps evidence, calculations, and next steps together.",
    "safety": {
      "allowed_decisions": [
        "approve",
        "revise",
        "reject"
      ],
      "blocked_actions": [
        "file_tax_return",
        "submit_tax_form",
        "treat_ocr_capture_as_filing_ready",
        "make_trade",
        "move_money",
        "pay_bill",
        "open_or_close_account",
        "submit_financial_recommendation_as_final",
        "share_regulated_financial_data",
        "contact_financial_institution_without_review"
      ],
      "decision_event": "human_decision_applied",
      "default_action": "reject",
      "enabled": true,
      "events": [
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied"
      ],
      "mode": "approval_required",
      "reason": "Human approval is required before filing, trading, moving money, bill payment, external sharing, or downstream financial decisions.",
      "request_event": "human_input_requested",
      "response_event": "human_input_received",
      "timeout_event": "human_input_timeout",
      "timeout_seconds": 3600
    },
    "target_users": "Individuals, households, freelancers, financial coaches, tax preparers, and advisors reviewing personal finance folders."
  },
  "kind": "WorkflowSource",
  "knowledge_rag": {
    "backend": "redis_vector_rag",
    "chunk_overlap": 80,
    "chunk_size": 800,
    "embedding_api_base": "auto",
    "embedding_document_prefix": "Document: ",
    "embedding_healthcheck_enabled": true,
    "embedding_model": "rag-embedding",
    "embedding_provider": "docker_model_runner",
    "embedding_query_prefix": "Query: ",
    "embedding_start_command": "",
    "enabled": true,
    "grounding_policy": "Use retrieved or bundled local blueprint knowledge to improve actor prompts; preserve deterministic outputs, cite supplied evidence, and label unknowns when retrieval is unavailable.",
    "index_on_startup": false,
    "knowledge_dir": "knowledge",
    "max_context_chars": 6000,
    "namespace": "",
    "privacy": "index local blueprint knowledge only; do not index private run documents unless a future runtime explicitly opts in",
    "purpose": "Retrieve local financial-advisor guidance for bank statement extraction, household cash-flow review, tax-form OCR capture, tax workpaper routing, portfolio risk interpretation, and review-only safety boundaries.",
    "redis_url": "",
    "required": false,
    "retrieval_targets": [
      "bank statement extraction",
      "cash-flow review",
      "tax form OCR capture",
      "field location validation",
      "tax workpaper routing",
      "portfolio risk interpretation",
      "human approval boundaries",
      "evidence hierarchy and source traceability",
      "calculation invariance and assumption clarity",
      "cross-domain reconciliation and report quality"
    ],
    "top_k": 5,
    "vector_dim": 1024
  },
  "metadata": {
    "blueprint_id": "financial_advisor",
    "job_data": {
      "resources": [
        {
          "name": "knowledge",
          "path": "knowledge",
          "access": "read_write",
          "seed": "@/payloads/knowledge"
        },
        {
          "name": "rag",
          "path": "databases/rag",
          "access": "read_write"
        },
        {
          "name": "state",
          "path": "state",
          "access": "read_write"
        }
      ]
    }
  },
  "requirements": {
    "cpu": {
      "min_cores": 1
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    },
    "memory": {
      "min_gb": 2
    }
  },
  "skill_dependencies": [
    {
      "name": "mirrorneuron-blueprint-support-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-litellm-communicate-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-llm-ocr-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-w3m-browser-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    },
    {
      "name": "mirrorneuron-web-browser-skill",
      "source": "gar",
      "type": "pip",
      "version": "1.2.29"
    }
  ],
  "agent_dependencies": [
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-stateful-step-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-bounded-tool-loop-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-actor-review-agent",
      "version": "1.2.29"
    },
    {
      "type": "pip",
      "source": "gar",
      "name": "mn-prototype-artifact-finalizer-agent",
      "version": "1.2.29"
    }
  ],
  "standard": {
    "migration_policy": "sdk_managed",
    "profile": "blueprint",
    "profile_version": 1,
    "source_schema": "mn.workflow.source/v2",
    "target_schema": "mn.workflow/v1"
  },
  "workers": {
    "groups": [
      {
        "steps": [
          "collect_public_finance_guidance"
        ],
        "with": {
          "stereotype": "public_browser_worker"
        }
      },
      {
        "steps": [
          "publish_financial_review_packet"
        ],
        "with": {
          "stereotype": "internal_write_worker"
        }
      }
    ]
  },
  "workflow": {
    "workflow_id": "financial_advisor_v1",
    "execution": {
      "strategy": "parallel"
    },
    "policy": {
      "failure": {
        "default": "fail_closed"
      },
      "human": {
        "enabled": true,
        "mode": "approval_required",
        "default_action": "reject",
        "allowed_decisions": [
          "approve",
          "revise",
          "reject"
        ],
        "blocked_actions": [
          "file_tax_return",
          "submit_tax_form",
          "treat_ocr_capture_as_filing_ready",
          "make_trade",
          "move_money",
          "pay_bill",
          "open_or_close_account",
          "submit_financial_recommendation_as_final",
          "share_regulated_financial_data",
          "contact_financial_institution_without_review"
        ],
        "reason": "Human approval is required before filing, trading, moving money, bill payment, external sharing, or downstream financial decisions.",
        "events": [
          "human_notice",
          "human_input_requested",
          "human_input_received",
          "human_input_timeout",
          "human_decision_applied"
        ],
        "request_event": "human_input_requested",
        "response_event": "human_input_received",
        "timeout_event": "human_input_timeout",
        "decision_event": "human_decision_applied",
        "timeout_seconds": 3600
      }
    },
    "state": {
      "input_folder": {
        "from": "$inputs.input_folder"
      },
      "output_folder": {
        "from": "$inputs.output_folder"
      },
      "workflow": {},
      "final_report": {}
    },
    "steps": [
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 1800,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Inventory and extract household, tax, and portfolio documents with OCR provenance.",
        "id": "prepare_financial_packet",
        "kind": "source",
        "label": "Prepare Financial Packet",
        "needs": [],
        "run": {
          "definition": "steps.prepare_financial_packet"
        }
      },
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 1800,
          "uncertainty": {
            "min_confidence": 0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "goal": "Extract statement transactions, normalize recurring cash flow, and review liquidity and spending evidence.",
        "id": "analyze_household_finances",
        "kind": "stage",
        "label": "Analyze Household Finances",
        "needs": [
          "prepare_financial_packet"
        ],
        "run": {
          "definition": "steps.analyze_household_finances"
        }
      },
      {
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
