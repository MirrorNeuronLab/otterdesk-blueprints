{
  "agentic_research": {
    "agent_ids": [
      "cash_flow_llm_analyst",
      "public_finance_researcher",
      "tax_form_ocr_capturer",
      "tax_llm_reviewer",
      "portfolio_llm_reviewer",
      "advisor_evidence_reconciler",
      "advisor_review_auditor",
      "financial_advice_reporter"
    ],
    "allowed_tools": [
      "knowledge_retrieve",
      "browser_search",
      "browser_page",
      "market_data_history",
      "risk_metric_compute",
      "llm_ocr_extract",
      "form_classify",
      "field_locate",
      "schema_validate",
      "finish"
    ],
    "default_mode": "bounded_llm_guided_financial_advisor_review",
    "enabled": true,
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "note": "Public research actors derive queries from generic risk and document categories only.",
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run"
  },
  "agents": {
    "extra_edges": [
      {
        "edge_id": "financial_advice_reporter_to_report_sink",
        "from_node": "financial_advice_reporter",
        "message_type": "financial_advice_reporter_completed",
        "to_node": "report_sink"
      }
    ],
    "extra_templates": [
      {
        "node_id": "report_sink",
        "uses": "mn-agents.control.terminal_sink@1",
        "with": {
          "stereotype": "terminal_report_sink"
        }
      }
    ]
  },
  "apiVersion": "mn.workflow.source/v2",
  "config": {
    "default": "config/default.json",
    "embed": true
  },
  "contracts": {
    "events": {
      "human_stream": "human.jsonl",
      "stream": "events.jsonl",
      "types": [
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "artifact_written",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
        "output_skill_started",
        "output_skill_completed",
        "output_skill_failed",
        "tool_call_started",
        "tool_call_completed",
        "tool_call_failed",
        "financial_folder_watcher_completed",
        "financial_document_reader_completed",
        "bank_statement_extractor_completed",
        "cash_flow_normalizer_completed",
        "cash_flow_llm_analyst_completed",
        "tax_document_router_completed",
        "tax_form_ocr_capturer_completed",
        "tax_workpaper_preparer_completed",
        "tax_llm_reviewer_completed",
        "portfolio_context_loader_completed",
        "portfolio_market_data_loader_completed",
        "portfolio_risk_engine_completed",
        "portfolio_llm_reviewer_completed",
        "public_finance_researcher_completed",
        "advisor_evidence_reconciler_completed",
        "advisor_review_auditor_completed",
        "financial_advice_reporter_completed",
        "watch_cycle_started",
        "watch_cycle_completed"
      ]
    },
    "input_adapters": {
      "default": "mock",
      "resolved_artifact": "inputs.json",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ]
    },
    "inputs": {
      "document_folder": {
        "description": "Local folder monitored for personal finance, bank statement, tax, and portfolio documents.",
        "example": "financial_advisor/examples/sample_inputs",
        "path_kind": "directory",
        "privacy": "regulated",
        "required": true,
        "type": "local_path"
      },
      "field_profile": {
        "description": "Financial fields and review areas captured by the advisor.",
        "example": [
          "document_kind",
          "income_amounts",
          "tax_forms",
          "form_type",
          "field_locations",
          "portfolio_holdings",
          "risk_flags"
        ],
        "privacy": "internal",
        "required": false,
        "type": "domain_value"
      },
      "filing_status": {
        "description": "Draft filing-status label for review-only tax packet.",
        "example": "single",
        "privacy": "regulated",
        "required": false,
        "type": "domain_value"
      },
      "input_folder": {
        "description": "Default local input folder for sample files or user-provided files.",
        "example": "financial_advisor/examples/sample_inputs",
        "path_kind": "directory",
        "privacy": "regulated",
        "required": false,
        "type": "local_path"
      },
      "monitoring": {
        "description": "Folder monitoring configuration for one-shot or continuous polling runs.",
        "example": {
          "enabled": true,
          "max_cycles": 1,
          "poll_interval_seconds": 60
        },
        "privacy": "internal",
        "required": false,
        "type": "domain_value"
      },
      "output_folder": {
        "description": "Local folder where JSON and Markdown advisor reports should be written.",
        "example": "~/Downloads/financial_advisor",
        "path_kind": "directory",
        "privacy": "regulated",
        "required": true,
        "type": "local_path"
      },
      "portfolio": {
        "description": "Optional portfolio holdings for review-only risk analysis.",
        "example": {
          "base_currency": "USD",
          "cash": 50000,
          "holdings": [
            {
              "asset_class": "equity",
              "quantity": 180,
              "symbol": "SPY"
            }
          ]
        },
        "privacy": "regulated",
        "required": false,
        "type": "domain_value"
      },
      "tax_year": {
        "description": "Tax year used for draft workpaper labels.",
        "example": 2025,
        "privacy": "internal",
        "required": false,
        "type": "domain_value"
      }
    },
    "outputs": {
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "action_ledger",
          "mime_type": "application/json",
          "path": "action_ledger.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.action_ledger.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "action_ledger"
        },
        {
          "artifact_id": "artifact_quality",
          "mime_type": "application/json",
          "path": "artifact_quality.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.artifact_quality.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "artifact_quality"
        },
        {
          "artifact_id": "run_health",
          "mime_type": "application/json",
          "path": "run_health.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.run_health.v1",
          "source_refs": [
            "final_artifact.json",
            "action_ledger.json",
            "artifact_quality.json"
          ],
          "type": "run_health"
        },
        {
          "artifact_id": "review_packet_markdown",
          "mime_type": "text/markdown",
          "path": "<outputs.folder_path>/financial_advisor_report.md",
          "producer": "workflow",
          "schema_version": "mn.blueprint.generated_report.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "generated_report"
        },
        {
          "artifact_id": "customer_report",
          "mime_type": "application/json",
          "path": "<outputs.folder_path>/customer_report.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.financial_advisor.customer_report.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "customer_report"
        },
        {
          "artifact_id": "cash_flow_llm_review",
          "mime_type": "application/json",
          "path": "<outputs.folder_path>/cash_flow_llm_review.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.financial_advisor.llm_review.v1",
          "source_refs": [
            "household_finance_summary.json",
            "final_artifact.json"
          ],
          "type": "llm_review"
        },
        {
          "artifact_id": "tax_form_ocr_capture",
          "mime_type": "application/json",
          "path": "<outputs.folder_path>/tax_form_ocr_capture.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.tax_form_capture.v1",
          "source_refs": [
            "final_artifact.json"
          ],
          "type": "tax_form_capture"
        },
        {
          "artifact_id": "tax_llm_review",
          "mime_type": "application/json",
          "path": "<outputs.folder_path>/tax_llm_review.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.financial_advisor.llm_review.v1",
          "source_refs": [
            "tax_review_packet.json",
            "tax_form_ocr_capture.json",
            "final_artifact.json"
          ],
          "type": "llm_review"
        },
        {
          "artifact_id": "portfolio_llm_review",
          "mime_type": "application/json",
          "path": "<outputs.folder_path>/portfolio_llm_review.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.financial_advisor.llm_review.v1",
          "source_refs": [
            "portfolio_risk_review.json",
            "final_artifact.json"
          ],
          "type": "llm_review"
        }
      ],
      "primary": {
        "id": "final_artifact",
        "path": "final_artifact.json",
        "required_fields": [
          "type",
          "executive_summary",
          "recommended_action",
          "confidence",
          "evidence",
          "next_steps",
          "source_refs",
          "research_summary",
          "research_sources",
          "research_warnings",
          "llm_analysis"
        ],
        "schema_version": "mn.blueprint.final_artifact_contract.v1",
        "type": "final_artifact"
      },
      "profile": "standard_run_store"
    },
    "status": {
      "heartbeat": true
    }
  },
  "defaults": {
    "worker": {
      "with": {
        "image": "mirror-neuron/financial-advisor:local"
      }
    }
  },
  "description": "A unified personal financial advisor co-worker. Put bank statements, receipts, bills, income records, W-2s, 1099s, tax-form images with answer files, brokerage statements, portfolio files, and related finance documents in the input folder; it extracts document evidence, captures tax-form OCR fields for review, prepares review-only tax and household finance summaries, runs portfolio risk analysis, and writes integrated advisor reports to the output folder.",
  "identity": {
    "category": "finance",
    "id": "financial_advisor",
    "job_name": "financial-advisor",
    "manifest_version": "1.0",
    "name": "Financial Advisor",
    "version": 1
  },
  "intent": {
    "description": "A unified personal financial advisor co-worker. Put bank statements, receipts, bills, income records, W-2s, 1099s, tax-form images with answer files, brokerage statements, portfolio files, and related finance documents in the input folder; it extracts document evidence, captures tax-form OCR fields for review, prepares review-only tax and household finance summaries, runs portfolio risk analysis, and writes integrated advisor reports to the output folder.",
    "problem": "Personal finance work is split across statement review, tax preparation, household planning, and portfolio risk checks; users need one review-only local assistant that keeps evidence, calculations, and next steps together.",
    "safety": {
      "allowed_decisions": [
        "approve",
        "revise",
        "reject"
      ],
      "blocked_actions": [
        "file_tax_return",
        "submit_tax_form",
        "treat_ocr_capture_as_filing_ready",
        "make_trade",
        "move_money",
        "pay_bill",
        "open_or_close_account",
        "submit_financial_recommendation_as_final",
        "share_regulated_financial_data",
        "contact_financial_institution_without_review"
      ],
      "decision_event": "human_decision_applied",
      "default_action": "reject",
      "enabled": true,
      "events": [
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied"
      ],
      "mode": "approval_required",
      "reason": "Human approval is required before filing, trading, moving money, bill payment, external sharing, or downstream financial decisions.",
      "request_event": "human_input_requested",
      "response_event": "human_input_received",
      "timeout_event": "human_input_timeout",
      "timeout_seconds": 3600
    },
    "target_users": "Individuals, households, freelancers, financial coaches, tax preparers, and advisors reviewing personal finance folders."
  },
