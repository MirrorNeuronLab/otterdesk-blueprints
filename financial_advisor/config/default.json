{
  "standard_version": "mn.blueprint.config.v1",
  "mode": "review_only",
  "metadata": {
    "category": "Finance",
    "description": "A unified personal financial advisor co-worker. Put bank statements, receipts, bills, income records, W-2s, 1099s, tax-form images with answer files, brokerage statements, portfolio files, and related finance documents in the input folder; it extracts document evidence, captures tax-form OCR fields for review, prepares review-only tax and household finance summaries, runs portfolio risk analysis, and writes integrated advisor reports to the output folder."
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default demo inputs use bundled synthetic finance documents, tax records, tax-form OCR fixtures, and a sample portfolio.",
    "payload": {
      "document_folder": "@/examples/sample_inputs",
      "input_folder": "@/examples/sample_inputs",
      "output_folder": "~/Downloads/financial_advisor",
      "tax_year": 2025,
      "filing_status": "single",
      "taxpayer_profile": {
        "residency": "US",
        "review_only": true
      },
      "customer_profile": {
        "account_purpose": "Long-term retirement and medium-term home reserve",
        "investment_objective": "Balanced growth with capital preservation for near-term reserves",
        "time_horizon": "15 years for retirement assets; 3 years for home reserve",
        "expected_withdrawal_date": "2029-06-30 for the home reserve",
        "risk_tolerance": "moderate",
        "liquidity_needs": "Maintain twelve months of core expenses outside volatile assets",
        "tax_objective": "Avoid unnecessary short-term gains and reconcile retirement distributions",
        "amount_that_must_remain_liquid": 30000,
        "other_investment_accounts": "Employer 401(k) exists but is not included in this packet",
        "tax_consequences_of_selling": "Unknown cost basis; obtain brokerage tax lots before considering sales"
      },
      "portfolio": {
        "base_currency": "USD",
        "cash": 50000,
        "holdings": [
          {
            "symbol": "SPY",
            "quantity": 180,
            "asset_class": "equity",
            "liquidity": "daily"
          },
          {
            "symbol": "AGG",
            "quantity": 300,
            "asset_class": "rates",
            "liquidity": "daily"
          },
          {
            "symbol": "GLD",
            "quantity": 80,
            "asset_class": "commodity",
            "liquidity": "daily"
          }
        ]
      },
      "benchmark_portfolio": {
        "SPY": 0.6,
        "AGG": 0.3,
        "GLD": 0.1
      },
      "risk_policy": {
        "max_single_name_weight_pct": 45,
        "max_var_pct": 8,
        "max_cvar_pct": 11,
        "max_drawdown_pct": 15,
        "min_cash_pct": 5,
        "max_turnover_pct": 15
      },
      "risk_policy_metadata": {
        "source": "Default portfolio screening policy",
        "version": "default-2026.2",
        "effective_date": "2026-01-01",
        "customer_specific": false
      },
      "decision_constraints": {
        "allowed_actions": [
          "no_action",
          "raise_cash",
          "reduce_concentration",
          "reduce_equity_beta",
          "duration_hedge",
          "credit_risk_reduction"
        ],
        "restricted_symbols": [],
        "review_only": true
      },
      "market_signals": [],
      "monitoring": {
        "enabled": true,
        "poll_interval_seconds": 60,
        "max_cycles": 1
      },
      "field_profile": [
        "document_kind",
        "institution_or_merchant",
        "account_or_source",
        "document_date",
        "income_amounts",
        "expense_amounts",
        "recurring_items",
        "balances",
        "debt_or_credit_obligations",
        "fees",
        "tax_forms",
        "form_type",
        "taxpayer_name",
        "taxpayer_id",
        "field_locations",
        "portfolio_holdings",
        "customer_profile",
        "investment_objective",
        "time_horizon",
        "risk_tolerance",
        "liquidity_needs",
        "tax_objective",
        "risk_flags",
        "recommended_actions"
      ],
      "public_dataset": {
        "name": "Synthetic financial advisor sample packet",
        "provider": "OtterDesk blueprint fixtures",
        "license": "Synthetic demo data",
        "availability_note": "Bundled sample documents are synthetic and intended only for local blueprint validation.",
        "expected_files": [
          "*.pdf",
          "*.png",
          "*.jpg",
          "*.jpeg",
          "*.tif",
          "*.tiff",
          "*.bmp",
          "*.webp",
          "*.txt",
          "*.json",
          "*.csv",
          "*.md"
        ],
        "tax_form_ocr_source": {
          "name": "US Tax Forms Donut Dataset derived from NIST-SD2",
          "provider": "hyturing on Hugging Face",
          "license": "MIT according to the Hugging Face dataset card; review source terms before production use.",
          "availability_note": "Bundled sample image/label pairs are copied into the financial advisor fixtures for local validation."
        }
      }
    }
  },
  "document_sources": {
    "folder_path": "@/examples/sample_inputs",
    "expected_files": [
      "*.pdf",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.tif",
      "*.tiff",
      "*.bmp",
      "*.webp",
      "*.txt",
      "*.json",
      "*.csv",
      "*.md"
    ],
    "grouping": "single_household_packet"
  },
  "outputs": {
    "folder_path": "~/Downloads/financial_advisor",
    "write_run_store": true,
    "write_markdown_report": true,
    "domain_artifacts": [
      "bank_statement_extraction.json",
      "household_finance_summary.json",
      "cash_flow_llm_review.json",
      "tax_review_packet.json",
      "tax_form_ocr_capture.json",
      "tax_llm_review.json",
      "portfolio_risk_review.json",
      "portfolio_llm_review.json",
      "customer_report.json",
      "financial_advisor_report.md",
      "action_ledger.json",
      "artifact_quality.json",
      "run_health.json"
    ]
  },
  "resources": {
    "cpu": {
      "min_cores": 1
    },
    "memory": {
      "min_gb": 2
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    }
  },
  "privacy": {
    "default_classification": "regulated",
    "rules": {
      "regulated": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      }
    }
  },
  "llm": {
    "mode": "live",
    "strict_json": false,
    "require_live": true,
    "configs": {
      "primary": {
        "timeout_seconds": 60,
        "max_tokens": 1800,
        "num_retries": 2,
        "retry_backoff_seconds": 1.0
      }
    }
  },
  "knowledge_rag": {
    "backend": "milvus_lite"
  },
  "input_skills": {
    "llm_ocr": {
      "skill": "llm_ocr_skill",
      "package": "mirrorneuron-llm-ocr-skill",
      "connector": "docker_model_runner",
      "purpose": "shared local LightOnOCR-2-1B OCR for scanned finance PDFs, forms, statements, and images",
      "enabled": true,
      "required": false,
      "backend": "llama.cpp",
      "endpoint": "auto",
      "model": "hf.co/noctrex/LightOnOCR-2-1B-GGUF:Q4_K_M",
      "api_model": "lightonocr-2-1b",
      "quantization": "Q4_K_M",
      "min_text_chars": 40,
      "max_pages": null,
      "preload": true,
      "install_policy": "runtime",
      "remove_policy": "manual",
      "require_hardware_acceleration": true,
      "timeout_seconds": 180
    },
    "w3m_browser": {
      "skill": "w3m_browser_skill",
      "package": "mirrorneuron-w3m-browser-skill",
      "import": "mn_w3m_browser_skill",
      "runner": "w3m",
      "purpose": "privacy-safe public web research for source-grounded finance, tax, and investor education guidance",
      "enabled": true,
      "required": false,
      "install_policy": "docker_worker_image",
      "timeout_seconds": 20,
      "max_chars": 12000,
      "max_queries": 6,
      "max_sources_per_query": 3,
      "use_model_compression": true,
      "docker_worker_requirements": "requirements.txt",
      "runtime": {
        "driver": "docker_worker",
        "install_scope": "shared_job_container",
        "docker_worker_image": "docker_worker",
        "image": "mirror-neuron/financial-advisor:local",
        "network": "mirror-neuron-runtime",
        "node_scope": "financial_advisor_python_executor_nodes"
      }
    },
    "web_browser": {
      "skill": "web_browser_skill",
      "package": "mirrorneuron-web-browser-skill",
      "import": "mn_web_browser_skill",
      "runner": "playwright",
      "purpose": "optional rendered-page fallback for JavaScript-heavy public guidance pages; records blocked states instead of bypassing them",
      "enabled": true,
      "required": false,
      "install_policy": "python_environment_pip",
      "respect_robots": true,
      "stop_on_blocked": true,
      "no_proxy_rotation": true,
      "no_captcha_solving": true,
      "timeout_seconds": 30,
      "max_chars": 12000,
      "max_pages_per_run": 2,
      "python_environment": "requirements.txt"
    }
  },
  "skill_runtime": {
    "enabled": true,
    "auto_patch": false,
    "driver": "docker_worker",
    "install_scope": "shared_job_container",
    "docker_worker_image": "docker_worker",
    "image": "mirror-neuron/financial-advisor:local",
    "network": "mirror-neuron-runtime",
    "node_scope": "financial_advisor_python_executor_nodes"
  },
  "local_inputs": {
    "folders": [
      {
        "config_path": "document_sources.folder_path",
        "payload_path": "runtime/mn_local_inputs/financial_documents",
        "runtime_path": "mn_local_inputs/financial_documents",
        "allowed_extensions": [
          ".pdf",
          ".png",
          ".jpg",
          ".jpeg",
          ".tif",
          ".tiff",
          ".bmp",
          ".webp",
          ".txt",
          ".json",
          ".csv",
          ".md"
        ],
        "linked_config_paths": [
          "inputs.payload.document_folder",
          "inputs.payload.input_folder",
          "state.document_folder",
          "state.input_folder"
        ]
      }
    ]
  },
  "document_automation": {
    "fields": [
      "document_kind",
      "institution_or_merchant",
      "account_or_source",
      "document_date",
      "income_amounts",
      "expense_amounts",
      "balances",
      "tax_forms",
      "form_type",
      "taxpayer_name",
      "taxpayer_id",
      "field_locations",
      "portfolio_holdings",
      "risk_flags",
      "recommended_actions"
    ],
    "output_type": "financial_advisor_report",
    "review_required": true,
    "recommended_action": "review_integrated_financial_advisor_packet_before_any_financial_action"
  },
  "financial_tools": {
    "enabled": true,
    "adapters": [
      "local_statement_math",
      "draft_tax_workpaper_math",
      "deterministic_portfolio_risk_math"
    ],
    "paid_provider_connectors": false,
    "missing_provider_data_policy": "record_missing_evidence"
  },
  "market_data": {
    "provider": "deterministic_public_market_fixture",
    "history_range": "1y",
    "interval": "1d",
    "timeout_seconds": 8,
    "refresh_seconds": 60,
    "stale_after_seconds": 259200,
    "fail_closed": false,
    "benchmark_symbols": [
      "SPY",
      "AGG",
      "GLD"
    ]
  },
  "risk_engine": {
    "annualization_factor": 252,
    "beta_proxy_symbol": "SPY",
    "concentration_limit_field": "max_single_name_weight_pct",
    "covariance_method": "sample",
    "return_horizon": "daily",
    "var_confidence": 0.95,
    "cvar_confidence": 0.95
  },
  "tax_documents": {
    "accepted_forms": [
      "W-2",
      "1099-INT",
      "1099-R",
      "1099-DIV",
      "1099-B",
      "1099-NEC",
      "1098",
      "1095-A",
      "5498",
      "brokerage_statement"
    ],
    "folder_path": "@/examples/sample_inputs",
    "recommended_forms": [
      "W-2",
      "1099-INT",
      "1099-R"
    ]
  },
  "backpressure": {
    "llm": {
      "max_concurrent_calls": 1,
      "min_interval_seconds": 1.0,
      "rationale": "Protect local Docker Model Runner from concurrent financial advisor calls."
    }
  },
  "execution": {
    "deterministic_output_order": "source_path",
    "quick_test": false
  },
  "interfaces": {
    "channels": {
      "inputs": {
        "artifact": "inputs.json",
        "description": "Resolved document folder, portfolio inputs, tax profile, and field profile."
      },
      "outputs": {
        "description": "Integrated review-only finance, tax, bank-statement, and portfolio outputs.",
        "artifacts": [
          "result.json",
          "final_artifact.json",
          "action_ledger.json",
          "artifact_quality.json",
          "run_health.json",
          "bank_statement_extraction.json",
          "household_finance_summary.json",
          "cash_flow_llm_review.json",
          "tax_review_packet.json",
          "tax_form_ocr_capture.json",
          "tax_llm_review.json",
          "portfolio_risk_review.json",
          "portfolio_llm_review.json",
          "customer_report.json",
          "financial_advisor_report.md"
        ]
      },
      "events": {
        "artifact": "events.jsonl",
        "description": "Append-only workflow events."
      },
      "human": {
        "artifact": "human.jsonl",
        "description": "Human review and approval events."
      },
      "knowledge_rag": {
        "description": "Optional local blueprint knowledge retrieval used to ground actor prompts.",
        "config": "knowledge_rag",
        "artifact": "@/payloads/knowledge/",
        "privacy": "blueprint knowledge only by default"
      },
      "agentic_research": {
        "description": "Bounded tool contract for privacy-safe public guidance and deterministic finance tools.",
        "config": "agentic_research"
      }
    },
    "config": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "outputs",
      "logging",
      "resources",
      "human_control",
      "input_skills",
      "output_skills",
      "error_handling",
      "state",
      "capabilities",
      "privacy",
      "triggers",
      "backpressure",
      "determinism",
      "schemas",
      "budgets",
      "agent_handoffs",
      "web_ui",
      "interfaces",
      "execution_model",
      "memory_layer",
      "dataset_input",
      "document_automation",
      "knowledge_rag",
      "agentic_research"
    ],
    "config_sections": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "outputs",
      "logging",
      "resources",
      "human_control",
      "input_skills",
      "output_skills",
      "error_handling",
      "state",
      "capabilities",
      "privacy",
      "triggers",
      "backpressure",
      "determinism",
      "schemas",
      "budgets",
      "agent_handoffs",
      "web_ui",
      "interfaces",
      "execution_model",
      "memory_layer",
      "dataset_input",
      "document_automation",
      "knowledge_rag",
      "agentic_research"
    ],
    "identity": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "outputs": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json",
      "action_ledger.json",
      "artifact_quality.json",
      "run_health.json"
    ],
    "optional_outputs": [
      "job.json",
      "web_ui.json",
      "ui.json",
      "web/index.html",
      "logs.jsonl",
      "human.jsonl",
      "resources.jsonl",
      "bank_statement_extraction.json",
      "household_finance_summary.json",
      "cash_flow_llm_review.json",
      "tax_review_packet.json",
      "tax_form_ocr_capture.json",
      "tax_llm_review.json",
      "portfolio_risk_review.json",
      "portfolio_llm_review.json",
      "customer_report.json",
      "financial_advisor_report.md"
    ],
    "response_schema": "mn.blueprint.response.v1"
  },
  "execution_model": {
    "type": "manifest_dag",
    "runtime_note": "Topology, dependencies, handlers, and terminal routing are declared only in manifest.json."
  },
  "capabilities": [
    "folder_monitoring",
    "document_evidence_extraction",
    "bank_statement_extraction",
    "cash_flow_normalization",
    "cash_flow_llm_review",
    "tax_form_ocr_capture",
    "tax_form_answer_file_validation",
    "draft_tax_workpapers",
    "tax_llm_review",
    "portfolio_risk_review",
    "portfolio_llm_review",
    "privacy_safe_public_research",
    "integrated_financial_report_generation",
    "deterministic_financial_tools",
    "source_grounded_review_outputs"
  ],
  "logging": {
    "events": [
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed",
      "tool_call_started",
      "tool_call_completed",
      "tool_call_failed"
    ]
  },
  "web_ui": {
    "dashboard": {
      "standard_panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ]
    }
  },
  "schemas": {
    "response": "mn.blueprint.response.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "events": "mn.blueprint.events.v1"
  },
  "budgets": {
    "default_action_budget": 80,
    "max_public_queries": 200,
    "max_runtime_seconds": 900
  },
  "state": {
    "workflow": {},
    "final_report": {}
  },
  "error_handling": {
    "default": "fail_closed",
    "external_research_failure": "continue_with_warning",
    "missing_evidence": "mark_insufficient_evidence"
  },
  "suggested_schedule": {
    "cron": "0 8 * * *",
    "cadence": "daily",
    "advisory_only": true,
    "note": "Suggested cadence only; runtime decides the actual schedule."
  }
}
