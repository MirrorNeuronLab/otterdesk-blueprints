      "execution_model",
      "memory_layer",
      "dataset_input",
      "document_automation",
      "suggested_schedule",
      "knowledge_rag",
      "agentic_research"
    ],
    "config_sections": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
