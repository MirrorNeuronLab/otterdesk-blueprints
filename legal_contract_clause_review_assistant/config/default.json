{
  "standard_version": "mn.blueprint.config.v1",
  "identity": {
    "blueprint_id": "legal_contract_clause_review_assistant",
    "name": "Legal Contract Clause Review Assistant"
  },
  "mode": "document_automation_review",
  "metadata": {
    "category": "Legal",
    "description": "A contract review co-worker for clause intake and attorney review. Put contracts, text exports, playbook notes, or clause annotations in the input folder; it extracts key clauses, maps them to the configured taxonomy, compares them with the playbook, flags issues and evidence gaps, and writes a source-grounded review packet to the output folder."
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default demo inputs use the public dataset reference; for real use select a local downloaded dataset folder.",
    "payload": {
      "document_folder": "legal_contract_clause_review_assistant/examples/sample_inputs",
      "output_folder": "~/Download/legal_contract_clause_review_assistant",
      "field_profile": [
        "governing_law",
        "change_of_control",
        "assignment",
        "indemnity",
        "termination",
        "audit_rights",
        "renewal",
        "exclusivity",
        "liability"
      ],
      "public_dataset": {
        "name": "Contract Understanding Atticus Dataset (CUAD) v1",
        "provider": "The Atticus Project on Zenodo and Hugging Face",
        "url": "https://zenodo.org/records/4595826",
        "alternate_url": "https://huggingface.co/datasets/theatticusproject/cuad",
        "license": "CC BY 4.0",
        "availability_note": "Public dataset with 510 commercial contracts and 13,000+ labels across 41 clause types.",
        "expected_files": [
          "full_contracts_pdf/*.pdf",
          "full_contracts_txt/*.txt",
          "*.csv",
          "*.json"
        ],
        "download_hint": "Download CUAD_v1.zip from Zenodo or use the Hugging Face dataset for text-oriented experiments."
      },
      "input_folder": "legal_contract_clause_review_assistant/examples/sample_inputs"
    }
  },
  "document_sources": {
    "folder_path": "legal_contract_clause_review_assistant/examples/sample_inputs",
    "expected_files": [
      "full_contracts_pdf/*.pdf",
      "full_contracts_txt/*.txt",
      "*.csv",
      "*.json"
    ],
    "public_dataset_url": "https://zenodo.org/records/4595826"
  },
  "dataset_input": {
    "name": "Contract Understanding Atticus Dataset (CUAD) v1",
    "provider": "The Atticus Project on Zenodo and Hugging Face",
    "url": "https://zenodo.org/records/4595826",
    "alternate_url": "https://huggingface.co/datasets/theatticusproject/cuad",
    "license": "CC BY 4.0",
    "availability_note": "Public dataset with 510 commercial contracts and 13,000+ labels across 41 clause types.",
    "expected_files": [
      "full_contracts_pdf/*.pdf",
      "full_contracts_txt/*.txt",
      "*.csv",
      "*.json"
    ],
    "download_hint": "Download CUAD_v1.zip from Zenodo or use the Hugging Face dataset for text-oriented experiments."
  },
  "document_automation": {
    "fields": [
      "governing_law",
      "change_of_control",
      "assignment",
      "indemnity",
      "termination",
      "audit_rights",
      "renewal",
      "exclusivity",
      "liability"
    ],
    "output_type": "contract_clause_review_packet",
    "review_required": true,
    "recommended_action": "attorney_review_required_before_relying_on_clause_findings"
  },
  "llm": {
    "enabled": true,
    "provider": "docker_model_runner",
    "model": "gemma4:e2b",
    "runtime_model": "gemma4:e2b",
    "backend": "llama.cpp",
    "mode": "live",
    "mock_mode": "fake",
    "default_config": "primary",
    "live_model_profile": {
      "provider": "docker_model_runner",
      "runtime_model": "gemma4:e2b",
      "api_base": "http://localhost:12434/engines/v1",
      "backend": "llama.cpp",
      "mock_fallback": "fake_for_quick_test_only"
    },
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "responsibilities": [
      "Keep clause extraction tied to source contract text and playbook terms.",
      "Use actors to summarize legal review risks without giving legal advice.",
      "Require attorney review before relying on any clause finding."
    ],
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "model": "gemma4:e2b",
        "runtime_model": "gemma4:e2b",
        "backend": "llama.cpp",
        "api_base": "http://localhost:12434/engines/v1",
        "timeout_seconds": 60,
        "max_tokens": 900,
        "num_retries": 1,
        "mock_mode": "fake",
        "mode": "live"
      }
    },
    "agents": {
      "contract_dataset_intake": {
        "llm_config": "primary",
        "model": "default",
        "role": "Contract intake coordinator",
        "responsibilities": [
          "Stage contract inputs and dataset notes.",
          "Check file readability and provenance.",
          "Flag missing agreement context."
        ]
      },
      "contract_ocr_extractor": {
        "llm_config": "primary",
        "model": "default",
        "role": "Contract text reader",
        "responsibilities": [
          "Review OCR or text extraction quality.",
          "Preserve clause source snippets.",
          "Flag incomplete or noisy contract pages."
        ]
      },
      "privilege_redactor": {
        "llm_config": "primary",
        "model": "default",
        "role": "Legal privacy redactor",
        "responsibilities": [
          "Redact sensitive party and privilege indicators as configured.",
          "Preserve clause meaning for review.",
          "Flag privacy or confidentiality risks."
        ]
      },
      "clause_extractor": {
        "llm_config": "primary",
        "model": "default",
        "role": "Clause extraction attorney assistant",
        "responsibilities": [
          "Identify candidate clauses from source text.",
          "Tie each clause to evidence snippets.",
          "Flag ambiguous or missing clause language."
        ]
      },
      "contract_taxonomy_mapper": {
        "llm_config": "primary",
        "model": "default",
        "role": "Contract taxonomy mapper",
        "responsibilities": [
          "Map clauses to the configured taxonomy.",
          "Explain taxonomy uncertainty.",
          "Flag unsupported clause categories."
        ]
      },
      "playbook_comparator": {
        "llm_config": "primary",
        "model": "default",
        "role": "Contract playbook comparator",
        "responsibilities": [
          "Compare extracted clauses to review playbook expectations.",
          "Flag deviations and negotiation risks.",
          "Avoid giving legal advice."
        ]
      },
      "legal_review_writer": {
        "llm_config": "primary",
        "model": "default",
        "role": "Legal review packet writer",
        "responsibilities": [
          "Prepare attorney-review packet summaries.",
          "Preserve source references and caveats.",
          "Require attorney review before reliance."
        ]
      }
    }
  },
  "outputs": {
    "folder_path": "~/Download/legal_contract_clause_review_assistant",
    "write_run_store": true,
    "write_markdown_report": true
  },
  "logging": {
    "level": "info",
    "events_jsonl": true,
    "logs_jsonl": true,
    "resources_jsonl": true,
    "stderr_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key",
      "ssn",
      "taxpayer_id",
      "account_number",
      "medical_record_number"
    ],
    "events": [
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed",
      "contract_inputs_staged",
      "contract_text_extracted",
      "clause_matrix_extracted",
      "contract_playbook_compared",
      "clause_review_packet_written"
    ]
  },
  "resources": {
    "cpu": {
      "min_cores": 1
    },
    "memory": {
      "min_gb": 2
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    }
  },
  "human_control": {
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "send_legal_advice",
      "approve_contract",
      "route_for_signature",
      "send_to_counterparty_without_review"
    ],
    "decision_event": "human_decision_applied",
    "default_action": "reject",
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "approval_required",
    "reason": "Human approval is required before any downstream release, filing, payment, legal, clinical, credit, or system-sync action.",
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "timeout_seconds": 3600
  },
  "input_skills": {
    "llm_ocr": {
      "skill": "llm_ocr_skill",
      "package": "mirrorneuron-llm-ocr-skill",
      "connector": "docker_model_runner",
      "purpose": "shared local LightOnOCR-2-1B OCR for scanned PDFs, images, forms, statements, and bills",
      "enabled": true,
      "required": false,
      "backend": "auto",
      "endpoint": "http://localhost:12434",
      "model": null,
      "quantization": null,
      "min_text_chars": 40,
      "max_pages": null,
      "preload": false,
      "install_policy": "on_first_required_document",
      "remove_policy": "manual",
      "require_hardware_acceleration": true,
      "timeout_seconds": 180
    }
  },
  "output_skills": {},
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "missing_folder": {
        "mode": "use_public_dataset_note"
      },
      "ocr_required": {
        "mode": "continue_with_review_warning"
      },
      "llm_call": {
        "mode": "retry",
        "max_attempts": 3,
        "backoff_seconds": 2
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "privacy": {
    "default_classification": "confidential",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "schemas": {
    "artifact_record": "mn.artifact.record.v1",
    "config": "mn.blueprint.config.v1",
    "events": "mn.blueprint.events.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "human_control": "mn.blueprint.human_control.v1",
    "input_skills": "mn.blueprint.input_skills.v1",
    "inputs": "mn.blueprint.inputs.v1",
    "logs": "mn.blueprint.logs.v1",
    "output_skills": "mn.blueprint.output_skills.v1",
    "resources": "mn.blueprint.resources.v1",
    "status_contract": "mn.blueprint.status_contract.v1",
    "web_ui": "mn.blueprint.web_ui.v1"
  },
  "budgets": {
    "max_runtime_seconds": 900,
    "max_llm_calls": 30,
    "max_llm_tokens": 60000,
    "max_disk_mb": 500,
    "max_connector_reads": 200,
    "max_connector_writes": 0
  },
  "capabilities": {
    "required": [
      "filesystem.read",
      "filesystem.write",
      "pdf.extract"
    ],
    "optional": [
      "document.ocr",
      "llm.ocr",
      "llm.call",
      "pdf.render",
      "knowledge.rag",
      "llm.tool_plan"
    ]
  },
  "determinism": {
    "enabled": true,
    "seed_field": "seed",
    "replay": {
      "from_inputs": "inputs.json",
      "from_events": "events.jsonl",
      "llm_mode": "fake"
    },
    "frozen_clock": null
  },
  "backpressure": {
    "max_concurrency": 4,
    "queue_size": 1000,
    "max_events_per_second": 10,
    "llm": {
      "max_concurrent_calls": 1,
      "max_calls_per_minute": 30,
      "min_interval_seconds": 2.0,
      "rationale": "Protect local Docker Model Runner from concurrent blueprint actor calls."
    },
    "drop_policy": "skip_with_error"
  },
  "web_ui": {
    "enabled": true,
    "input": {
      "adapter": "none",
      "fields": [],
      "host": "127.0.0.1",
      "port": null,
      "share": false,
      "title": null,
      "instructions": null,
      "custom_url": null
    },
    "output": {
      "adapter": "gradio",
      "auto_generate": true,
      "refresh_seconds": 2,
      "title": "Legal Contract Clause Review Assistant",
      "custom_url": null
    },
    "dashboard": {
      "data_source": "local_run_store",
      "reads": [
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json",
        "web_ui.json"
      ],
      "panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ],
      "standard_panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ]
    }
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "description": "Stable run-store files and domain-specific document automation outputs.",
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl",
          "human.jsonl",
          "resources.jsonl",
          "*-review.md"
        ]
      },
      "events": {
        "artifact": "events.jsonl",
        "description": "Append-only workflow events."
      },
      "human": {
        "artifact": "human.jsonl",
        "description": "Human notices, approval requests, responses, timeouts, and applied decisions."
      },
      "input_skills": {
        "description": "Local filesystem intake plus shared llm_ocr_skill OCR through Docker Model Runner."
      },
      "inputs": {
        "artifact": "inputs.json",
        "description": "Resolved document folder, public dataset reference, and field extraction profile."
      },
      "logs": {
        "artifact": "logs.jsonl",
        "description": "Runtime stdout/stderr and redacted document automation logs.",
        "stream": "stdout/stderr"
      },
      "outputs": {
        "artifacts": [
          "result.json",
          "final_artifact.json",
          "*-review.md"
        ],
        "description": "Primary review packet and structured extraction results."
      },
      "resources": {
        "artifact": "resources.jsonl",
        "description": "Resource samples such as token, runtime, connector, and disk usage."
      },
      "web_ui": {
        "artifacts": [
          "web_ui.json",
          "ui.json",
          "web/index.html"
        ],
        "description": "Optional review dashboard for artifact inspection."
      },
      "knowledge_rag": {
        "description": "Optional local blueprint knowledge retrieval used to ground actor prompts and tool planning.",
        "config": "knowledge_rag",
        "artifact": "knowledge/",
        "privacy": "blueprint knowledge only by default"
      },
      "agentic_research": {
        "description": "Bounded LLM-selected or actor-guided tool contract for domain work.",
        "config": "agentic_research"
      }
    },
    "config": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "resources",
      "human_control",
      "real_adapters",
      "streams",
      "input_skills",
      "output_skills",
      "error_handling",
      "state",
      "capabilities",
      "privacy",
      "triggers",
      "backpressure",
      "determinism",
      "schemas",
      "budgets",
      "agent_handoffs",
      "web_ui",
