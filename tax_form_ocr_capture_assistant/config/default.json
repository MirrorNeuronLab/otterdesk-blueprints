{
  "standard_version": "mn.blueprint.config.v1",
  "identity": {
    "blueprint_id": "tax_form_ocr_capture_assistant",
    "name": "Tax Form OCR Capture Assistant"
  },
  "mode": "document_automation_review",
  "metadata": {
    "category": "Finance",
    "description": "A tax-form OCR co-worker for structured intake review. Put tax form images, PDFs, answer files, or field-context tables in the input folder; it classifies forms, locates fields, captures taxpayer and line-item values, validates totals, and writes a review-only tax capture packet to the output folder."
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default demo inputs use the public dataset reference; for real use select a local downloaded dataset folder.",
    "payload": {
      "document_folder": "tax_form_ocr_capture_assistant/examples/sample_inputs",
      "output_folder": "~/Download/tax_form_ocr_capture_assistant",
      "field_profile": [
        "form_type",
        "taxpayer_name",
        "taxpayer_id",
        "wages",
        "deductions",
        "credits",
        "line_items",
        "computed_totals",
        "field_locations"
      ],
      "public_dataset": {
        "name": "NIST Special Database 2 and NIST Special Database 6",
        "provider": "National Institute of Standards and Technology",
        "url": "https://www.nist.gov/srd/nist-special-database-2",
        "alternate_url": "https://www.nist.gov/srd/nist-special-database-6",
        "license": "NIST free reference data; review source terms before production use.",
        "availability_note": "Public NIST structured-form reference sets with simulated tax submissions, form images, and answer files.",
        "expected_files": [
          "*.png",
          "*.fmt",
          "field context tables"
        ],
        "download_hint": "Download the Special Database 2 or 6 ZIP from NIST, then point document_sources.folder_path at an extracted submission folder."
      },
      "input_folder": "tax_form_ocr_capture_assistant/examples/sample_inputs"
    }
  },
  "document_sources": {
    "folder_path": "tax_form_ocr_capture_assistant/examples/sample_inputs",
    "expected_files": [
      "*.png",
      "*.fmt",
      "field context tables"
    ],
    "public_dataset_url": "https://www.nist.gov/srd/nist-special-database-2"
  },
  "dataset_input": {
    "name": "NIST Special Database 2 and NIST Special Database 6",
    "provider": "National Institute of Standards and Technology",
    "url": "https://www.nist.gov/srd/nist-special-database-2",
    "alternate_url": "https://www.nist.gov/srd/nist-special-database-6",
    "license": "NIST free reference data; review source terms before production use.",
    "availability_note": "Public NIST structured-form reference sets with simulated tax submissions, form images, and answer files.",
    "expected_files": [
      "*.png",
      "*.fmt",
      "field context tables"
    ],
    "download_hint": "Download the Special Database 2 or 6 ZIP from NIST, then point document_sources.folder_path at an extracted submission folder."
  },
  "document_automation": {
    "fields": [
      "form_type",
      "taxpayer_name",
      "taxpayer_id",
      "wages",
      "deductions",
      "credits",
      "line_items",
      "computed_totals",
      "field_locations"
    ],
    "output_type": "tax_form_ocr_capture_packet",
    "review_required": true,
    "recommended_action": "review_captured_fields_against_source_forms_before_tax_use"
  },
  "llm": {
    "model": "default",
    "enabled": true,
    "mode": "live",
    "mock_mode": "fake",
    "default_config": "primary",
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "responsibilities": [
      "Keep OCR, field capture, and validation tied to source form evidence.",
      "Use actors to review tax form identity, field locations, and capture risks.",
      "Require human review before tax preparation or filing use."
    ],
    "configs": {
      "primary": {
        "provider": "docker_model_runner",
        "model": "default",
        "api_base": "http://localhost:12434/engines/v1",
        "timeout_seconds": 60,
        "max_tokens": 900,
        "num_retries": 1,
        "mock_mode": "fake",
        "mode": "live"
      }
    },
    "agents": {
      "tax_dataset_intake": {
        "llm_config": "primary",
        "model": "default",
        "role": "Tax form intake coordinator",
        "responsibilities": [
          "Stage tax form images and answer files.",
          "Check dataset provenance and expected files.",
          "Flag missing or unreadable forms."
        ]
      },
      "tax_ocr_extractor": {
        "llm_config": "primary",
        "model": "default",
        "role": "Tax form OCR reader",
        "responsibilities": [
          "Review OCR text and image extraction quality.",
          "Preserve source-form evidence.",
          "Flag fields needing manual readback."
        ]
      },
      "tax_identifier_redactor": {
        "llm_config": "primary",
        "model": "default",
        "role": "Tax identifier redactor",
        "responsibilities": [
          "Redact taxpayer identifiers before summaries.",
          "Preserve non-sensitive field evidence.",
          "Flag unredacted identifier risk."
        ]
      },
      "tax_form_classifier": {
        "llm_config": "primary",
        "model": "default",
        "role": "Tax form classifier",
        "responsibilities": [
          "Classify form type and schedule context.",
          "Tie classification to visible evidence.",
          "Flag ambiguous or unsupported forms."
        ]
      },
      "field_locator": {
        "llm_config": "primary",
        "model": "default",
        "role": "Tax field locator",
        "responsibilities": [
          "Locate wages, deductions, credits, totals, and line items.",
          "Preserve field-location evidence.",
          "Flag low-confidence boxes or lines."
        ]
      },
      "tax_answer_validator": {
        "llm_config": "primary",
        "model": "default",
        "role": "Tax capture validator",
        "responsibilities": [
          "Compare captured fields against expected answer profile.",
          "Flag inconsistent totals or unsupported values.",
          "Keep validation review-only."
        ]
      },
      "tax_capture_report_writer": {
        "llm_config": "primary",
        "model": "default",
        "role": "Tax capture report writer",
        "responsibilities": [
          "Prepare the tax capture review packet.",
          "Summarize evidence, warnings, and next steps.",
          "Require review before tax preparation use."
        ]
      }
    }
  },
  "outputs": {
    "folder_path": "~/Download/tax_form_ocr_capture_assistant",
    "write_run_store": true,
    "write_markdown_report": true
  },
  "logging": {
    "level": "info",
    "events_jsonl": true,
    "logs_jsonl": true,
    "resources_jsonl": true,
    "stderr_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key",
      "ssn",
      "taxpayer_id",
      "account_number",
      "medical_record_number"
    ],
    "events": [
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed",
      "tax_form_inputs_staged",
      "tax_form_text_extracted",
      "tax_fields_located",
      "tax_capture_validated",
      "tax_capture_packet_written"
    ]
  },
  "resources": {
    "cpu": {
      "min_cores": 1
    },
    "memory": {
      "min_gb": 2
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    }
  },
  "human_control": {
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "file_tax_return",
      "submit_to_tax_agency",
      "send_to_preparer_without_review",
      "mark_values_final_without_review"
    ],
    "decision_event": "human_decision_applied",
    "default_action": "reject",
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "approval_required",
    "reason": "Human approval is required before any downstream release, filing, payment, legal, clinical, credit, or system-sync action.",
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "timeout_seconds": 3600
  },
  "input_skills": {
    "llm_ocr": {
      "skill": "llm_ocr_skill",
      "package": "mirrorneuron-llm-ocr-skill",
      "connector": "docker_model_runner",
      "purpose": "shared local LightOnOCR-2-1B OCR for scanned PDFs, images, forms, statements, and bills",
      "enabled": true,
      "required": false,
      "backend": "auto",
      "endpoint": "http://localhost:12434",
      "model": null,
      "quantization": null,
      "min_text_chars": 40,
      "max_pages": null,
      "preload": false,
      "install_policy": "on_first_required_document",
      "remove_policy": "manual",
      "require_hardware_acceleration": true,
      "timeout_seconds": 180
    }
  },
  "output_skills": {},
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "missing_folder": {
        "mode": "use_public_dataset_note"
      },
      "ocr_required": {
        "mode": "continue_with_review_warning"
      },
      "llm_call": {
        "mode": "retry",
        "max_attempts": 3,
        "backoff_seconds": 2
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "privacy": {
    "default_classification": "regulated",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "schemas": {
    "artifact_record": "mn.artifact.record.v1",
    "config": "mn.blueprint.config.v1",
    "events": "mn.blueprint.events.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "human_control": "mn.blueprint.human_control.v1",
    "input_skills": "mn.blueprint.input_skills.v1",
    "inputs": "mn.blueprint.inputs.v1",
    "logs": "mn.blueprint.logs.v1",
    "output_skills": "mn.blueprint.output_skills.v1",
    "resources": "mn.blueprint.resources.v1",
    "status_contract": "mn.blueprint.status_contract.v1",
    "web_ui": "mn.blueprint.web_ui.v1"
  },
  "budgets": {
    "max_runtime_seconds": 900,
    "max_llm_calls": 30,
    "max_llm_tokens": 60000,
    "max_disk_mb": 500,
    "max_connector_reads": 200,
    "max_connector_writes": 0
  },
  "capabilities": {
    "required": [
      "filesystem.read",
      "filesystem.write",
      "pdf.extract"
    ],
    "optional": [
      "document.ocr",
      "llm.ocr",
      "llm.call",
      "pdf.render",
      "knowledge.rag",
      "llm.tool_plan"
    ]
  },
  "determinism": {
    "enabled": true,
    "seed_field": "seed",
    "replay": {
      "from_inputs": "inputs.json",
      "from_events": "events.jsonl",
      "llm_mode": "fake"
    },
    "frozen_clock": null
  },
  "backpressure": {
    "max_concurrency": 4,
    "queue_size": 1000,
    "max_events_per_second": 10,
    "llm": {
      "max_concurrent_calls": 1,
      "max_calls_per_minute": 30,
      "min_interval_seconds": 2.0,
      "rationale": "Protect local Docker Model Runner from concurrent blueprint actor calls."
    },
    "drop_policy": "skip_with_error"
  },
  "web_ui": {
    "enabled": true,
    "input": {
      "adapter": "none",
      "fields": [],
      "host": "127.0.0.1",
      "port": null,
      "share": false,
      "title": null,
      "instructions": null,
      "custom_url": null
    },
    "output": {
      "adapter": "gradio",
      "auto_generate": true,
      "refresh_seconds": 2,
      "title": "Tax Form OCR Capture Assistant",
      "custom_url": null
    },
    "dashboard": {
      "data_source": "local_run_store",
      "reads": [
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json",
        "web_ui.json"
      ],
      "panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ],
      "standard_panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ]
    }
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "description": "Stable run-store files and domain-specific document automation outputs.",
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl",
          "human.jsonl",
          "resources.jsonl",
          "*-review.md"
        ]
      },
      "events": {
        "artifact": "events.jsonl",
        "description": "Append-only workflow events."
      },
      "human": {
        "artifact": "human.jsonl",
        "description": "Human notices, approval requests, responses, timeouts, and applied decisions."
      },
      "input_skills": {
        "description": "Local filesystem intake plus shared llm_ocr_skill OCR through Docker Model Runner."
      },
      "inputs": {
        "artifact": "inputs.json",
        "description": "Resolved document folder, public dataset reference, and field extraction profile."
      },
      "logs": {
        "artifact": "logs.jsonl",
        "description": "Runtime stdout/stderr and redacted document automation logs.",
        "stream": "stdout/stderr"
      },
      "outputs": {
        "artifacts": [
          "result.json",
          "final_artifact.json",
          "*-review.md"
        ],
        "description": "Primary review packet and structured extraction results."
      },
      "resources": {
        "artifact": "resources.jsonl",
        "description": "Resource samples such as token, runtime, connector, and disk usage."
      },
      "web_ui": {
        "artifacts": [
          "web_ui.json",
          "ui.json",
          "web/index.html"
        ],
        "description": "Optional review dashboard for artifact inspection."
      },
      "knowledge_rag": {
        "description": "Optional local blueprint knowledge retrieval used to ground actor prompts and tool planning.",
        "config": "knowledge_rag",
        "artifact": "knowledge/",
        "privacy": "blueprint knowledge only by default"
      },
      "agentic_research": {
        "description": "Bounded LLM-selected or actor-guided tool contract for domain work.",
        "config": "agentic_research"
      }
    },
    "config": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "resources",
      "human_control",
      "real_adapters",
      "streams",
      "input_skills",
      "output_skills",
      "error_handling",
      "state",
      "capabilities",
      "privacy",
      "triggers",
      "backpressure",
      "determinism",
      "schemas",
      "budgets",
      "agent_handoffs",
      "web_ui",
      "interfaces",
      "execution_model",
      "memory_layer",
      "dataset_input",
      "document_automation",
      "suggested_schedule",
      "knowledge_rag",
      "agentic_research"
    ],
    "config_sections": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "resources",
      "human_control",
      "real_adapters",
      "streams",
      "input_skills",
      "output_skills",
      "error_handling",
      "state",
      "capabilities",
      "privacy",
      "triggers",
      "backpressure",
      "determinism",
      "schemas",
      "budgets",
      "agent_handoffs",
      "web_ui",
      "interfaces",
      "execution_model",
      "memory_layer",
      "dataset_input",
      "document_automation",
      "suggested_schedule",
      "knowledge_rag",
      "agentic_research"
    ],
    "identity": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "outputs": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ],
    "optional_outputs": [
      "job.json",
      "web_ui.json",
      "ui.json",
      "web/index.html",
      "logs.jsonl",
      "human.jsonl",
      "resources.jsonl",
      "*-review.md"
    ],
    "optional_run_artifacts": [
      "job.json",
      "web_ui.json",
      "ui.json",
      "web/index.html",
      "logs.jsonl",
      "human.jsonl",
      "resources.jsonl",
      "*-review.md"
    ],
    "response_schema": "mn.blueprint.response.v1",
    "web_ui_adapters": [
      "none",
      "static_html",
      "gradio",
      "custom"
    ]
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "extract_embedded_text_or_ocr",
    "redact_sensitive_values",
    "extract_structured_fields",
    "validate_against_public_labels_when_available",
    "request_human_review",
    "write_final_artifact",
    "write_artifact_records"
  ],
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "tax_form_ocr_capture_assistant_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "agentic_research": {
    "enabled": true,
    "agent_ids": [
      "tax_ocr_extractor",
      "tax_form_classifier",
      "field_locator",
      "tax_answer_validator",
      "tax_capture_report_writer"
    ],
    "max_iterations_per_agent": 1,
    "max_tool_calls_per_agent": 2,
    "allowed_tools": [
      "llm_ocr_extract",
      "form_classify",
      "field_locate",
      "schema_validate",
      "knowledge_retrieve",
      "finish"
    ],
    "quick_test_behavior": "tools_may_be_stubbed_or_skipped_for_default_smoke_run",
    "default_mode": "bounded_llm_guided_tax_form_capture_review",
    "note": "Tax capture actors use OCR and local guidance while keeping uncertain fields review-required."
  },
  "knowledge_rag": {
    "enabled": true,
    "backend": "redis_vector_rag",
    "required": false,
    "knowledge_dir": "knowledge",
    "purpose": "Retrieve tax-form capture guidance for OCR field location, validation checks, source refs, and review-only tax intake boundaries.",
    "retrieval_targets": [
      "tax form classification",
      "field location",
      "validation checks",
      "tax review blockers"
    ],
    "grounding_policy": "Use retrieved local blueprint knowledge to improve actor review prompts; do not invent facts when retrieval is unavailable.",
    "redis_url": "",
    "namespace": "",
    "embedding_provider": "docker_model_runner",
    "embedding_model": "hf.co/jinaai/jina-embeddings-v5-text-small-retrieval:Q4_K_M",
    "embedding_api_base": "http://localhost:12434/engines/v1",
    "embedding_query_prefix": "Query: ",
    "embedding_document_prefix": "Document: ",
    "embedding_start_command": "",
    "embedding_healthcheck_enabled": true,
    "vector_dim": 1024,
    "index_on_startup": false,
    "top_k": 4,
    "max_context_chars": 4000,
    "chunk_size": 700,
    "chunk_overlap": 70,
    "privacy": "index local blueprint knowledge only; do not index private run documents unless a future runtime explicitly opts in"
  },
  "state": {
    "document_folder": "tax_form_ocr_capture_assistant/examples/sample_inputs",
    "output_folder": "~/Download/tax_form_ocr_capture_assistant",
    "review": {},
    "final_report": {},
    "input_folder": "tax_form_ocr_capture_assistant/examples/sample_inputs"
  },
  "triggers": {
    "manual": true,
    "schedule": false
  },
  "real_adapters": {
    "filesystem": {
      "enabled": true,
      "read": true,
      "write": true
    }
  },
  "streams": {
    "enabled": false
  },
  "simulation": {
    "enabled": false
  },
  "suggested_schedule": {
    "cron": "0 6 * * *",
    "cadence": "daily",
    "advisory_only": true,
    "note": "Suggested cadence only; runtime decides the actual schedule."
  }
}
