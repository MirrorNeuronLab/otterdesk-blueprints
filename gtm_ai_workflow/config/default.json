      "backpressure",
      "determinism",
      "schemas",
      "budgets",
      "agent_handoffs",
      "web_ui",
      "interfaces",
      "execution_model"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "optional_run_artifacts": [
      "job.json",
      "web_ui.json",
      "ui.json",
      "web/index.html",
      "logs.jsonl",
      "events.log",
      "errors.log",
      "events.index.json",
      "logs.index.json",
      "errors.index.json",
      "timeline.json",
      "human.jsonl",
      "resources.jsonl"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "response_schema": "mn.blueprint.response.v1",
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ],
    "stream_kinds": [
      "audio",
      "video",
      "data",
      "multimodal"
    ],
    "stream_transports": [
      "file",
      "http",
      "https",
      "rtsp",
      "rtmp",
      "webrtc",
      "websocket",
      "socketio",
      "tcp",
      "udp",
      "sse",
      "kafka",
      "mqtt",
      "custom"
    ],
    "web_ui_adapters": [
      "none",
      "static_html",
      "gradio",
      "custom"
    ]
  },
  "llm": {
    "agent_role": "Account researcher, pain hypothesis analyst, sales email drafter, response summarizer, CRM updater, and product-marketing feedback assistant.",
    "agents": {
      "input_adapter": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "role": "GTM intake adapter",
        "responsibilities": [
          "Normalize strategy, customer, template, and inbox inputs.",
          "Preserve provenance for downstream GTM actors.",
          "Flag missing required campaign context."
        ]
      },
      "monitor_scheduler_agent": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "role": "Buying-signal monitor",
        "responsibilities": [
          "Schedule account and inbox monitoring work.",
          "Prioritize signals that match the GTM strategy.",
          "Avoid inventing intent signals not present in inputs."
        ]
      },
      "account_research_agent": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "role": "Account research actor",
        "responsibilities": [
          "Summarize account context and likely pain hypotheses.",
          "Tie claims to supplied customer evidence.",
          "Flag assumptions for review."
        ]
      },
      "outreach_copywriter_agent": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "role": "Outbound copywriter actor",
        "responsibilities": [
          "Draft concise account-specific outreach.",
          "Use approved templates and product positioning.",
          "Keep copy reviewable before delivery."
        ]
      },
      "email_designer_agent": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "role": "Email design actor",
        "responsibilities": [
          "Convert copy into approved email layouts.",
          "Preserve brand and accessibility constraints.",
          "Flag missing assets or unsupported formatting."
        ]
      },
      "deliverability_ops_agent": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "role": "Deliverability operations actor",
        "responsibilities": [
          "Check send readiness, rate limits, and delivery policy.",
          "Summarize deliverability blockers.",
          "Avoid sending when controls are not satisfied."
        ]
      },
      "control_manager_agent": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "role": "GTM control manager",
        "responsibilities": [
          "Review workflow decisions before automation.",
          "Apply human-control and compliance boundaries.",
          "Record blockers and approvals."
        ]
      },
      "gtm_automation_agent": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "role": "GTM automation actor",
        "responsibilities": [
          "Execute approved workflow actions only.",
          "Record action provenance and outcomes.",
          "Stop on policy or delivery blockers."
        ]
      },
      "inbox_reply_agent": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "role": "Inbox reply actor",
        "responsibilities": [
          "Summarize inbound replies and intent.",
          "Draft response options from approved context.",
          "Avoid promising unavailable commitments."
        ]
      },
      "inbox_poller_agent": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "role": "Inbox polling actor",
        "responsibilities": [
          "Poll configured inbox sources.",
          "Classify new messages for workflow routing.",
          "Preserve message provenance and privacy boundaries."
        ]
      },
      "artifact_writer": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "role": "GTM artifact writer",
        "responsibilities": [
          "Assemble final workflow artifacts.",
          "Summarize completed and blocked actions.",
          "Preserve source references for review."
        ]
      }
    },
    "api_base": "http://192.168.4.173:11434",
    "configs": {
      "primary": {
        "provider": "ollama",
        "model": "ollama/nemotron3:33b",
        "api_base": "http://192.168.4.173:11434",
        "timeout_seconds": 60,
        "max_tokens": 700,
        "num_retries": 1,
        "mock_mode": "fake",
        "mode": "ollama"
      }
    },
    "default_config": "primary",
    "enabled": true,
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "quick_test_uses_fake": true,
    "strict_json": false,
    "prefer_shared_skill": true,
    "responsibilities": [
      "Coordinate GTM workflow actors around account context, outreach, design, delivery, and control checks.",
      "Keep outbound content reviewable and tied to strategy inputs.",
      "Avoid fabricating customer facts or sending without policy approval."
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed",
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "rotation": {
      "check_interval_records": 100,
      "compress": "background",
      "enabled": true,
      "max_bytes_mb": 100,
      "max_segments": 7,
      "span_seconds": 86400
    },
    "stderr_jsonl": true,
    "writer": {
      "batch_size": 100,
      "flush_interval_seconds": 0.5,
      "mode": "async",
      "overflow_policy": "drop_low_priority",
      "queue_size": 10000,
      "shutdown_flush_timeout_seconds": 2
    }
  },
  "metadata": {
    "blueprint_id": "gtm_ai_workflow",
    "blueprint_revision": "v1",
    "category": "business",
    "customizable_for": "Account-based outbound, founder-led sales, RevOps CRM hygiene, product marketing feedback loops, and sales-assist workflows.",
    "name": "GTM AI Workflow",
    "problem_solved": "GTM teams need a learning loop from target-account signal to outreach, response, CRM state, product insight, and sharper positioning.",
    "standard_version": "1.0",
    "target_users": "Growth, sales, RevOps, product marketing, and founder-led GTM teams."
  },
  "mode": "mock",
  "output_skills": {},
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Local CRM CSV, market insight CSV, prepared sales email, delivery events, response summaries, and recommended next actions.",
    "run_root": "~/.mn/runs",
    "skills": {},
    "tcp": {
      "enabled": false,
      "ports": []
    },
    "write_run_store": true
  },
  "privacy": {
    "default_classification": "internal",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "resources": {
    "enabled": true,
    "gpu_enabled": "auto",
    "gpu_sample_interval_seconds": 60,
    "history_window_hours": 24,
    "raw_retention_hours": 48,
    "rollup_bucket_seconds": 3600,
    "sample_interval_seconds": 10
  },
  "schemas": {
    "artifact_record": "mn.artifact.record.v1",
    "config": "mn.blueprint.config.v1",
    "events": "mn.blueprint.events.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "human_control": "mn.blueprint.human_control.v1",
    "input_skills": "mn.blueprint.input_skills.v1",
    "inputs": "mn.blueprint.inputs.v1",
    "logs": "mn.blueprint.logs.v1",
    "output_skills": "mn.blueprint.output_skills.v1",
    "resources": "mn.blueprint.resources.v1",
    "status_contract": "mn.blueprint.status_contract.v1",
    "web_ui": "mn.blueprint.web_ui.v1"
  },
  "simulation": {
    "deterministic": true,
    "enabled": true,
    "seed_field": "seed",
    "type": "Long-running GTM learning loop with account research, outreach, inbox monitoring, CRM CSV updates, and product-marketing feedback."
  },
  "standard_version": "1.0",
  "state": {
    "checkpoint_interval": {
